Процедура ПолучитьСчетчики(ИК)
	
	Если НазваниеРесурса = "Электроснабжение" Тогда
		ВидРесурса = Перечисления.АР_ВидРесурса.Электроэнергия;
		ВидРесурса2 = Перечисления.АР_ВидРесурса.Электроэнергия;
	ИначеЕсли НазваниеРесурса = "Водоснабжение" Тогда
		ВидРесурса = Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам;
		ВидРесурса2 = Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам;
	ИначеЕсли НазваниеРесурса = "Теплоснабжение" Тогда
		ВидРесурса = Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам;
		ВидРесурса2 = Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_Счетчики.НомерСчетчика,
	               |	АР_Счетчики.Наименование
	               |ИЗ
	               |	Справочник.АР_Счетчики КАК АР_Счетчики
	               |ГДЕ
	               |	АР_Счетчики.ИК = &ИК
	               |	И (АР_Счетчики.НазваниеРесурса.ВидРесурса = &ВидРесурса
	               |			ИЛИ АР_Счетчики.НазваниеРесурса.ВидРесурса = &ВидРесурса2)";
	Запрос.УстановитьПараметр("ВидРесурса",ВидРесурса);
	Запрос.УстановитьПараметр("ВидРесурса2",ВидРесурса2);
	Запрос.УстановитьПараметр("ИК",ИК);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	ТЗ.Загрузить(Выгрузка);

	//Возврат Выгрузка;
	
КонецПроцедуры	


