////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.Имя = Параметры.Имя;
	Режим = ?(ЭтотОбъект.Имя = "ВыставлениеСчетов","Счет","Акт");
	
	Попытка
		Элементы.Страницы.ТекущаяСтраница = Элементы[ЭтотОбъект.Имя];
	Исключение
	    Отказ = Истина;
	КонецПопытки; 
	
	//Для Каждого Страница из ЭтаФорма.Элементы.Страницы Цикл
	//	//Если Страница
	//	а=а;
	//КонецЦикла;		
	
	ЭтаФорма.Заголовок = "Выберите месяцы " + Элементы.Страницы.ТекущаяСтраница.Заголовок;
	
	СформироватьПредставлениеПорядкаВыставления(Режим);
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ОК(Команда)
	СохранитьИзменения();
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура КомандаОтмена(Команда)
	
	Модифицированность = Ложь;
	Закрыть();
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура СохранитьИзменения()
	
	ПараметрыОбъект = Объект.Ссылка.ПолучитьОбъект();

	Режим = ?(ЭтотОбъект.Имя = "ВыставлениеСчетов","Счет","Акт");
	СтрМесяц.Очистить();
	
	Для к = 1 По 12 Цикл
		Если ЭтотОбъект["Выставлять" + Режим + "М" + к] Тогда
			СтрМесяц1 = Формат(Дата(1982,к,1),"ДФ=MMMM");  
			СтрМесяц.Добавить(СтрМесяц1);
			ПараметрыОбъект["Выставлять" + Режим + "М" + к] = Истина;
		Иначе	
			ПараметрыОбъект["Выставлять" + Режим + "М" + к] = Ложь;
		КонецЕсли; 
	КонецЦикла;	
	
	Если СтрМесяц.Количество() = 0 Тогда
		СтрМесяц.Добавить("Не начислять");	
	КонецЕсли;
	
	ПараметрыОбъект.Записать();
	
КонецПроцедуры

Процедура СформироватьПредставлениеПорядкаВыставления(Режим)

	Ссылка = Параметры.Ключ;
	СтрМесяц.Очистить();
	
	Для к = 1 По 12 Цикл
		Если Ссылка["Выставлять" + Режим + "М" + к] Тогда
			СтрМесяц1 = Формат(Дата(1982,к,1),"ДФ=MMMM");  
			СтрМесяц.Добавить(СтрМесяц1);
			ЭтотОбъект["Выставлять" + Режим + "М" + к] = Истина;
		Иначе
			ЭтотОбъект["Выставлять" + Режим + "М" + к] = Ложь;
		КонецЕсли;
	КонецЦикла;	
	
	Если СтрМесяц.Количество() = 0 Тогда
		СтрМесяц.Добавить("Не начислять");	
	КонецЕсли;
	
КонецПроцедуры // СформироватьПредставлениеПорядкаВыставления()
