Процедура ОбновитьСобственникиРег()
	СобственникиРег.Очистить();
	Рег = РегистрыСведений.АР_СобственникиОбъектовАрендыСпр;
	Отбор = Новый Структура("ОбъектАренды");
	Отбор.ОбъектАренды = Объект.Ссылка;
	
	Выборка = Рег.Выбрать(,,Отбор);
	Пока Выборка.Следующий() Цикл
		Стр1 = СобственникиРег.Добавить();
		Стр1.Контрагент = Выборка.Контрагент;
		Стр1.ДоговорКонтрагента = Выборка.ДоговорКонтрагента;
		Стр1.Период = Выборка.Период;
		Стр1.ДоляСобственника = Выборка.ДоляСобственника;
	КонецЦикла;
КонецПроцедуры	
