					Если СокрЛП(НайденныйОбъект) = "" Тогда
						СохранитьОбъект(КомнатаНомерБТИ,"Помещение",РодительПомещения,Объект.РасположениеНаПлане,Планировка,Площадь,Назначение, Балансодержатель, Договор, Примечание,КомнатаНомерБТИ,ПомещениеНомерБТИ); //-са					Иначе	
						ПерезаписатьНайденныйОбъект(КомнатаНомерБТИ,"Помещение",РодительПомещения,Объект.РасположениеНаПлане,Планировка,Площадь,Назначение,Балансодержатель,Договор,Примечание,КомнатаНомерБТИ,ПомещениеНомерБТИ); //-са
					КонецЕсли;
				КонецЦикла; //-са	
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;
	Если НужнаЗаписьФайла Тогда // + NAI Becar Конюшок С.Н. от 06.03.2017 16:30 
		Попытка
			Книга.Save();
		Исключение
		КонецПопытки;
	КонецЕсли; 
	
	Книга.Close(Ложь);
	Книга = Неопределено;	
	СохранитьЭтажность( Этажей, ПлощадьЗдания, ОбщаяМОП, ОбщаяВП, ОбщаяТП, ОбщаяАП, ОбщаяУК);
	ЭтаФорма.Прочитать();
	Объект.ОбщаяПлощадь = тзПлощадь.Итог("Площадь");
	Объект.ЗначениеХарактеристики = тзПлощадь.Итог("Площадь");
	Объект.КоэффициентАП = ОбщаяАП*100/Объект.ОбщаяПлощадь;
	Объект.МОП = ОбщаяМОП;
	Объект.ВП = ОбщаяВП;
	Объект.ТП = ОбщаяТП;
	Объект.АП = ОбщаяАП;
	Объект.РасположениеНаПлане = РасположениеНаПланеЗдание;
	УдалениеСпрОтстутствующихВРеквЭкс();
	Записать();
	
КонецПроцедуры

Процедура ЗаписатьИКДляЗагруженныхОбъектов()

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	АР_ОбъектыАренды.Ссылка КАК Объект,
		|	&Характеристика КАК ТипЗначения,
		|	&ИК КАК Значение
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка В ИЕРАРХИИ(&Здание)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&ИК,
		|	&Характеристика,
		|	&ИК";
		
	Если Объект.Родитель.ТипОбъекта = Справочники.АР_ТипыОбъектовАренды.ИмущественныйКомплекс Тогда
		Запрос.УстановитьПараметр("ИК", Объект.Родитель);
	Иначе
		Сообщить("Внимание! Процедура загрузки завершена не корректно, не записан регистр соответствия объектов недвижимости и их ИК! Возможно экспликация загружена не в объект с типом здание, либо для здания не указан ИК!");
		Возврат;
	КонецЕсли; 	
	Запрос.УстановитьПараметр("Здание", Объект.Ссылка);
	Запрос.УстановитьПараметр("Характеристика", ПланыВидовХарактеристик.АР_СвойстваУниверсальногоРегистра.ИмущественныйКомплекс);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Пока РЗ.Следующий() Цикл
		
			Запись = РегистрыСведений.АР_УниверсальныйРегистр.СоздатьМенеджерЗаписи();
			
			ЗаполнитьЗначенияСвойств(Запись,РЗ);
			
			Запись.Записать();
		
	КонецЦикла;

КонецПроцедуры
 

