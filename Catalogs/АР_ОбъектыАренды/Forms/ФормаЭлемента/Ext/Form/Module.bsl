			Иначе	
				ПерезаписатьНайденныйОбъект(СтрОфис.Помещение,"Офис",Родитель,Объект.РасположениеНаПлане,,СтрОфис.Площадь,,,,,,);
			КонецЕсли;	
		КонецЦикла;	
		СписокОбъектов = Новый СписокЗначений;
		СписокТекстбоксов = Новый СписокЗначений;
		Для Ном = 1 по План.Shapes().Count() Цикл
			Если План.Shapes(Ном).Type() = 17 Тогда
				СписокТекстбоксов.Добавить(План.Shapes(Ном).Name);
			ИначеЕсли (План.Shapes(Ном).Type() = 5) ИЛИ (План.Shapes(Ном).Type() = 1 И (План.Shapes(Ном).AutoShapeType < 105 
					ИЛИ План.Shapes(Ном).AutoShapeType > 108)) Тогда
				СписокОбъектов.Добавить(План.Shapes(Ном).Name);
			КонецЕсли;
		КонецЦикла;
		Для Каждого Элемент Из СписокОбъектов Цикл
			КомОбъект = План.Shapes(Элемент.Значение);
			Площадь = 0;
			Фильтр = Новый Структура("КомнатаНомерБТИ", СокрЛП(КомОбъект.Name));
			МассивПомещение = тзЭтаж.НайтиСтроки(Фильтр);
			Если МассивПомещение.Количество() > 0 Тогда
				Для Каждого СтрПомещение из МассивПомещение Цикл //-са
					Если СтрПомещение <> Неопределено Тогда
						Площадь = Число(СтрПомещение.Площадь);
						Назначение = СтрПомещение.Назначение;
						Примечание = СтрПомещение.Примечание;
						Балансодержатель = СтрПомещение.Балансодержатель;
						Договор = СтрПомещение.Договор;
						КомнатаНомерБТИ = СтрПомещение.КомнатаНомерБТИ;
						ПомещениеНомерБТИ = СтрПомещение.ПомещениеНомерБТИ;
					КонецЕсли;
					Если Назначение = "МОП" Тогда
						ОбщаяМОП = ОбщаяМОП + Площадь;
					ИначеЕсли Назначение = "ВП" Тогда
						ОбщаяВП = ОбщаяВП + Площадь;
					ИначеЕсли Назначение = "ТЕХ" Тогда
						ОбщаяТП = ОбщаяТП + Площадь;
					ИначеЕсли Назначение = "АП" Тогда
						ОбщаяАП = ОбщаяАП + Площадь;
					ИначеЕсли Назначение = "УК" Тогда
						ОбщаяУК = ОбщаяУК + Площадь;
					КонецЕсли;
					РодительПомещения = НайтиОбъект(СтрПомещение.Помещение,"Офис",Родитель);
					НайденныйОбъект = НайтиОбъект(КомнатаНомерБТИ,"Помещение",РодительПомещения); //-са
					Планировка = НайтиПланировку(СокрЛП(Объект.Ссылка) + "/" + СокрЛП(План.Name) + "/" + СокрЛП(КомОбъект.Name));
					Если Планировка = Неопределено или Планировка = ПустаяСсылка() Тогда
						СохранитьПланировку(СокрЛП(Объект.Ссылка) + "/" + СокрЛП(План.Name) + "/" + СокрЛП(КомОбъект.Name), "Помещение", План.Name, КомОбъект.Name, Объект.РасположениеНаПлане);
						Планировка = НайтиПланировку(СокрЛП(Объект.Ссылка) + "/" + СокрЛП(План.Name) + "/" + СокрЛП(КомОбъект.Name));
