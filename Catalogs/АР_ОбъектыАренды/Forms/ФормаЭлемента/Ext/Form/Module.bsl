Функция ВернутьРодителя(Элемент,Название)
	Если Элемент.Родитель.Пустая() Тогда
		Название = Элемент.Наименование + "/" + СокрЛП(Название);
		Возврат Название;
	Иначе
		Если Название = "" Тогда
			Название = Элемент.Наименование;	
		Иначе
			Название = Элемент.Наименование + "/" + СокрЛП(Название);
		КонецЕсли;	
        Возврат ВернутьРодителя(Элемент.Родитель, Название);
    КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписьСобственника" Тогда
		УстановитьСобственника();
	ИначеЕсли ИмяСобытия = "Запись_Файл" Тогда
		
		Если ТипЗнч(Параметр) = Тип("Структура")
			И Параметр.Свойство("ВладелецФайла")
			И Параметр.ВладелецФайла = Объект.Ссылка
			И ЗначениеЗаполнено(ВыбираемаяКартинка) Тогда
			
			Модифицированность = Истина;
			
			ФайлКартинки = ?(ТипЗнч(Источник) = Тип("Массив"), Источник[0], Источник);
			УстановитьКартинкуВЭлементе(ФайлКартинки, ВыбираемаяКартинка);
			
			ВыбираемаяКартинка = Неопределено;
			
		КонецЕсли;
	КонецЕсли;
	// Подсистема "Свойства"
	//Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
	//	ОбновитьЭлементыДополнительныхРеквизитов();
	//КонецЕсли;
	
КонецПроцедуры

