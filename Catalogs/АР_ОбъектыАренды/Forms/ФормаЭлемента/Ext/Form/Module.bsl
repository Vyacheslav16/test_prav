			Сообщить("Файл """ + СокрЛП(ПолноеИмяФайла) + """ не существует!", СтатусСообщения.Важное);
			Отказ = Истина;
		Иначе
			Попытка
				Excell = Новый COMОбъект("Excel.Application");
			Исключение
			КонецПопытки;
			Книга = Excell.Workbooks.Open(ПолноеИмяФайла); //(ПолноеИмяФайла,, Истина);
		КонецЕсли;
	КонецЕсли;
	
	РасположениеНаПланеЗдание = Объект.РасположениеНаПлане;
	
	ПолучитьПуть(Объект.РасположениеНаПлане);
	НужнаЗаписьФайла = Ложь;
	тзПлощадь.Очистить();
	Для Лист = 1 по Книга.Sheets.Count Цикл
		План = Книга.Sheets(Лист);
		
		НаименованиеЭтажа = План.Name; // + NAI Becar Конюшок С.Н. от 06.03.2017 16:21 обрежем пробелы в конце наименования этажа
		Если НаименованиеЭтажа <> СокрЛП(НаименованиеЭтажа) Тогда
			План.Name = СокрЛП(НаименованиеЭтажа);
		    НужнаЗаписьФайла = Истина;
		КонецЕсли;
					
		Если СокрЛП(Нрег(План.Name)) = "реквизиты" Тогда
			ВсегоСтрок = План.Cells(1,1).SpecialCells(11).Row;
			Для Строка = 51 По ВсегоСтрок Цикл   
				стрПлощадь = тзПлощадь.Добавить();
				стрПлощадь.Этаж = СокрЛП(План.Cells(Строка,2).Value);// + NAI Becar Конюшок С.Н. от 06.03.2017 16:32 
				стрПлощадь.ПомещениеНомерБТИ = СокрЛП(План.Cells(Строка,3).Value);
				стрПлощадь.КомнатаНомерБТИ = СокрЛП(План.Cells(Строка,4).Value);
				стрПлощадь.Помещение = СокрЛП(План.Cells(Строка,9).Value);
				стрПлощадь.Площадь = ?(СокрЛП(План.Cells(Строка,5).Value) = "",0 ,Число(СокрЛП(План.Cells(Строка,5).Value)));
				стрПлощадь.Назначение = СокрЛП(План.Cells(Строка,8).Value);
				стрПлощадь.Балансодержатель = СокрЛП(План.Cells(Строка,10).Value);
				стрПлощадь.Договор = СокрЛП(План.Cells(Строка,11).Value);
				стрПлощадь.Примечание = СокрЛП(План.Cells(Строка,12).Value);
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла;	
	
	ОбщаяМОП = 0;
	ОбщаяВП = 0;
	ОбщаяТП = 0;
	ОбщаяАП = 0;
	ОбщаяУК = 0;
	ПлощадьЗдания = 0;
	Этажей = 0;
	Для Лист = 1 по Книга.Sheets.Count Цикл
		План = Книга.Sheets(Лист);
		Если СокрЛП(Нрег(План.Name)) = "реквизиты" Тогда Продолжить; КонецЕсли;
		Этажей = Этажей + 1;
		ВыгрузитьТЗ(План.Name);
		Планировка = НайтиПланировку(СокрЛП(Объект.Ссылка) + "/" + СокрЛП(План.Name));
		Если Планировка = Неопределено или Планировка = ПустаяСсылка() Тогда
