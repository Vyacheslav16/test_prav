&НаСервере
Процедура ПерезаписатьНайденныйОбъект(Наименование,ТипОбъекта,Родитель,РасположениеНаПлане,Планировка,Площадь,Назначение,Балансодержатель, Договор, Примечание, КомнатаНомерБТИ, ПомещениеНомерБТИ)
	
	НайденныйОбъект = Справочники.АР_ОбъектыАренды.ПустаяСсылка();
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	АР_ОбъектыАренды.Ссылка
	                |ИЗ
	                |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	                |ГДЕ
	                |	АР_ОбъектыАренды.Наименование = &Наименование
	                |	И АР_ОбъектыАренды.ТипОбъекта = &ТипОбъекта
	                |	И АР_ОбъектыАренды.Родитель = &Родитель";
					
	Запрос.УстановитьПараметр("Наименование",Наименование);
	Запрос.УстановитьПараметр("ТипОбъекта",Справочники.АР_ТипыОбъектовАренды.НайтиПоНаименованию(ТипОбъекта));
	Запрос.УстановитьПараметр("Родитель",Родитель);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НайденныйОбъект = Выборка.Ссылка;
		Спр = НайденныйОбъект.ПолучитьОбъект();
		Если ТипОбъекта <> "Офис" Тогда
			Спр.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию("м2");
			Спр.ЕдиницаИзмеренияОбщая = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию("м2");
		КонецЕсли;
		Спр.РасположениеНаПлане = РасположениеНаПлане;
		Спр.Планировка = Планировка;
		Спр.Статус = Родитель.Статус;
		Если Назначение = "МОП" Тогда
			Спр.МОП = Площадь;
		ИначеЕсли Назначение = "ВП" Тогда
			Спр.ВП = Площадь;
		ИначеЕсли Назначение = "ТЕХ" Тогда
			Спр.ТП = Площадь;
		ИначеЕсли Назначение = "АП" Тогда
			Спр.АП = Площадь;
		ИначеЕсли Назначение = "УК" Тогда
			Спр.ЗначениеХарактеристики = Площадь;
		КонецЕсли;
		Спр.ЗначениеХарактеристики = Площадь;
		Спр.ОбщаяПлощадь = Площадь;
		Спр.Назначение = Назначение;
		Спр.ОписаниеОбъектаАренды = Примечание;
		Спр.КомнатаНомерБТИ = КомнатаНомерБТИ;
		Спр.ПомещениеНомерБТИ = ПомещениеНомерБТИ;
		Спр.КоэффициентАП = ?(Спр.ЗначениеХарактеристики=0,0,Спр.АП*100/Спр.ЗначениеХарактеристики);
		Спр.Записать();
		НСтр = ТЗЗагрОбъектов.Добавить();
		НСтр.ЗагрСпр = Спр.Ссылка;
		НайденныйКонтрагент = Справочники.Контрагенты.НайтиПоНаименованию(Балансодержатель, Истина);
		Если НайденныйКонтрагент <> Справочники.Контрагенты.ПустаяСсылка() и НайденныйКонтрагент <> Неопределено
			и Балансодержатель <> Неопределено Тогда
			НоваяЗапись = РегистрыСведений.АР_СобственникиОбъектовАренды.СоздатьМенеджерЗаписи();
		    НоваяЗапись.Период = ТекущаяДата();
		    НоваяЗапись.ОбъектАренды = Спр.Ссылка;
			НоваяЗапись.Контрагент = НайденныйКонтрагент;
		    НоваяЗапись.Записать(); 
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

