		|			ИНАЧЕ АР_ОбъектыАренды.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель
		|		КОНЕЦ КАК ИК
		|	ИЗ
		|		Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|	ГДЕ
		|		АР_ОбъектыАренды.Ссылка = &Ссылка) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_УстановкаПараметровИК.Контрагенты КАК АР_УстановкаПараметровИККонтрагенты
		|		ПО ВложенныйЗапрос.ИК = АР_УстановкаПараметровИККонтрагенты.Ссылка.ИКСсылка";
		
		
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	МассивСоб = Выгрузка.ВыгрузитьКолонку("Договор");
	Возврат МассивСоб;
КонецФункции

