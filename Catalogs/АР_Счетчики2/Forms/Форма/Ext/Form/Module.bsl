&НаКлиенте
Процедура ЗаписатьФайл(Команда)
	
	Режим = РежимДиалогаВыбораФайла.Сохранение; 
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим); 
	ДиалогОткрытияФайла.ПолноеИмяФайла = ""; 
	Фильтр = "Файл Excel (*,xls)|*.xls"; 
	ДиалогОткрытияФайла.Фильтр = Фильтр; 
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь; 
	ДиалогОткрытияФайла.Заголовок = "Выберите файл для сохранения бланка"; 
	
	ПутьКФайлу = НазваниеРесурса + "_" + ИК + "_" + Формат(Дата,"ДЛФ=Д");
	ДиалогОткрытияФайла.ПолноеИмяФайла = ПутьКФайлу;
	Если ДиалогОткрытияФайла.Выбрать() Тогда 
		ПутьКФайлу = ДиалогОткрытияФайла.ПолноеИмяФайла; 
	//Иначе
	//	ПутьКФайлу="";
	КонецЕсли;

	АдресВХранилище = "";
	
	ЗаписатьФайлСервер(ПутьКФайлу,НазваниеРесурса,АдресВХранилище);

	
	
КонецПроцедуры

Процедура ЗаписатьФайлСервер(ПутьКФайлу,НазваниеРесурса,АдресВХранилище)
	
	Попытка 
		Макет = Справочники.АР_Счетчики2.ПолучитьМакет(НазваниеРесурса);
		MSExcel = Макет.Получить();
		Книга = MSExcel.Application.Workbooks(1); 
		Лист1 = Книга.WorkSheets(1); 
		//Лист1.Cells.Clear(); //ClearContents();
	Исключение 
		Сообщить(ОписаниеОшибки()); 
		MSExcel.Application.Quit(); 
		Сообщить ("Ошибка при инициализаци xls");
	КонецПопытки; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_Счетчики2.НомерСчетчика
	               |ИЗ
	               |	Справочник.АР_Счетчики2 КАК АР_Счетчики2
	               |ГДЕ
	               |	АР_Счетчики2.ИК = &ИК";
	Запрос.УстановитьПараметр("ИК",ИК);
	Если НазваниеРесурса = "Электричество" Тогда
		НомерСтроки = 9;
		Лист1.Cells(4, 2).Value = ЭтотОбъект.Период;
	ИначеЕсли НазваниеРесурса = "ХВ_ГВ" Тогда
		НомерСтроки = 11;
		Лист1.Cells(3, 2).Value = ЭтотОбъект.Период;
	ИначеЕсли НазваниеРесурса = "Тепло" Тогда
		НомерСтроки = 10;
		Лист1.Cells(3, 2).Value = ЭтотОбъект.Период;
	КонецЕсли;
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НомерСтроки = НомерСтроки+1;
		Лист1.Rows(НомерСтроки).Insert();
		Лист1.Cells(НомерСтроки, 2).NumberFormat = "@";
		Лист1.Cells(НомерСтроки, 2).Value = Выборка.НомерСчетчика;
	КонецЦикла;	
	
	//+документ
	Док = Документы.АР_ФормыВводаКоммунальныхУслуг.СоздатьДокумент();
	Док.Дата = ТекущаяДата();
	Док.Записать();
	//-документ
	
	Лист1.Cells(1, 3).Value = НазваниеРесурса + "_" + ИК + "_" + Формат(Дата,"ДЛФ=Д") + "_" + Док.Номер;
	
	Попытка 
		MSExcel.Application.ScreenUpdating 	= Истина;
		//MSExcel.Application.EnableEvents	= Истина;
		MSExcel.Application.Visible         = Истина;
		MSExcel.Windows(1).Visible  = Истина;
		MSExcel.Worksheets(1).Visible  = Истина;
		MSExcel.Activate(); 
		Книга.SaveAs(ПутьКФайлу);
	Исключение
		Сообщить(ОписаниеОшибки()+" Файл не сохранен!");
	КонецПопытки; 
	
	//+документ
	ИмяФайлаИсточника = ПутьКФайлу;
	Поз = Найти(ИмяФайлаИсточника, "\");
	Пока Поз <> 0 Цикл
		ИмяФайлаИсточника = Сред(ИмяФайлаИсточника, Поз+1);
		Поз = Найти(ИмяФайлаИсточника, "\");
	КонецЦикла;
	Файл = Новый Файл(ПутьКФайлу);
	Если Файл.Существует() Тогда
		ПутьДоПланировок = "\\SERVER-STR\obmen\1\Forms\"+ИмяФайлаИсточника;
		КопироватьФайл(ПутьКФайлу,ПутьДоПланировок);
	КонецЕсли;
	//
	//Если ПоместитьФайл(АдресВХранилище, , ПутьДоПланировок, , УникальныйИдентификатор) Тогда
	//	ФайлДок = Новый Файл(ПутьДоПланировок);
	//	Имя = Файл.Имя;
	//	СсылкаНаФайлВоВременномХранилище = АдресВХранилище;
	//	//Объект.Наименование = Файл.Имя;
	//	//Объект.ИмяФайла = Имя;
	//КонецЕсли;
	//
	
	//ХЗ=Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресВХранилище));
	Док.Файл = ПутьДоПланировок;
	Док.Записать();
	//-документ
	
КонецПроцедуры	

