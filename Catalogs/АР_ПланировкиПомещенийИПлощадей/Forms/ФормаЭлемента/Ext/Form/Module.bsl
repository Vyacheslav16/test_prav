&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Excel = Новый COMОбъект("Excel.Application");
	Книга = Неопределено;
	СписокЛистов = Неопределено;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()
		
	Если Книга <> Неопределено Тогда
		Попытка
			Книга.Close(Ложь);
		Исключение
		КонецПопытки;
		Книга = Неопределено;		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ФайлПланировкиОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФайлВыполнить();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФайлВыполнить()
	
	ПолноеИмяФайла = ИнтеграцияЕГАИСВызовСервера.ЗначениеРеквизитаОбъекта(Объект.ФайлПланировки, "ИмяФайла");
	ЗапуститьПриложение(ПолноеИмяФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлПланировкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ФормаВыбора = ПолучитьФорму("Справочник.АР_ФайлыПланировокПомещенийИПлощадей.Форма.ФормаВыбора",, Элемент);
	ФормаВыбора.Открыть();
	
КонецПроцедуры
