////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаКлиенте
Процедура ОткрытьКнигу(Отказ)
	
	ИмяФайла = ИнтеграцияЕГАИСВызовСервера.ЗначениеРеквизитаОбъекта(Объект.ФайлПланировки, "ИмяФайла");
	// Получить расширение файла.
	РасширениеФайла = Прав(ИмяФайла, 4);
	
	Если Лев(РасширениеФайла, 1) = "." Тогда
		// Получить имя временного файла. Установить расширение временного файла.
		РасширениеФайла = Прав(ИмяФайла, 3);
	КонецЕсли;
	
	Если ВРег(РасширениеФайла) <> "XLS" И  ВРег(РасширениеФайла) <> "XLSX" Тогда // Файл не является экселевским
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Файл шаблона не является файлом Excel");
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Файл = Новый Файл(ИмяФайла);
	Если Не Файл.Существует() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Файл """ + СокрЛП(ИмяФайла) + """ не существует!",,"Объект.ФайлШаблона");
		Отказ = Истина;
	Иначе
		Книга = Excel.Workbooks.Open(ИмяФайла,, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьСписокЛистов()
	
	СписокЛистов = Новый СписокЗначений;
	//Если Не ЗначениеЗаполнено(Объект.ФайлШаблона) Тогда
	Если Не ЗначениеЗаполнено(Объект.ФайлПланировки) Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;
	Если Книга = Неопределено Тогда
		ОткрытьКнигу(Отказ);
		Если Отказ Тогда
			СписокЛистов = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если не Отказ Тогда
		Для Ном = 1 по Книга.Sheets().Count() Цикл
			СписокЛистов.Добавить(Книга.Sheets(Ном).Name);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

