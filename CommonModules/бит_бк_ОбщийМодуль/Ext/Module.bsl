Процедура ПриСозданииФормыУслуги(Элементы, Объект) Экспорт
	
	НовыйЭлемент = Элементы.Добавить("бит_бк_ЯвляетсяГруппой", Тип("ПолеФормы"), Элементы.ГруппаШапка);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;
	НовыйЭлемент.ПутьКДанным = "Объект.бит_бк_ЯвляетсяГруппойУслуг";
	НовыйЭлемент.Заголовок = "Является группой услуг";
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "бит_бк_ЯвляетсяУслугойПриИзменении");
	
	НоваяСтраница = Элементы.Добавить("СтрСоставУслуг",Тип("ГруппаФормы"), Элементы.Панель);
	НоваяСтраница.Вид = ВидГруппыФормы.Страница;                                          
	НоваяСтраница.Заголовок = "Состав услуги";
	НоваяСтраница.Видимость = Объект.бит_бк_ЯвляетсяГруппойУслуг;
	
	НоваяТаблица = Элементы.Добавить("ТаблицаСоставУслуг",Тип("ТаблицаФормы"), Элементы.СтрСоставУслуг);
	НоваяТаблица.ПутьКДанным = "Объект.бит_бк_СоставУслуги";
	НоваяТаблица.РастягиватьПоГоризонтали = Ложь;
	НоваяТаблица.Ширина = 100;
	НоваяТаблица.КоманднаяПанель.РазрешитьИзменениеСостава = Истина;
	
	НовыйЭлемент = Элементы.Добавить("бит_бк_Услуга", Тип("ПолеФормы"), Элементы.ТаблицаСоставУслуг);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Заголовок = "Услуга";
	НовыйЭлемент.ПутьКДанным = "Объект.бит_бк_СоставУслуги.Услуга";
	
	НовыйЭлемент = Элементы.Добавить("бит_бк_НеПривязанаКРасчетуПоДням", Тип("ПолеФормы"), Элементы.ГруппаШапка);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;
	НовыйЭлемент.ПутьКДанным = "Объект.бит_бк_НеПривязанаКРасчетуПоДням";
	
КонецПроцедуры

Процедура НачислениеУслугОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	Если Источник.ОбменДанными.Загрузка ИЛИ Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Услуга", Источник.Услуга);
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Источник.Дата));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УПЖКХ_НачисленияОбороты.Услуга,
	|	УПЖКХ_НачисленияОбороты.СуммаНачисленияОборот
	|ИЗ
	|	Справочник.КВП_Услуги.бит_бк_СоставУслуги КАК КВП_Услугибит_бк_СоставУслуги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.УПЖКХ_Начисления.Обороты(, &КонецПериода, , ) КАК УПЖКХ_НачисленияОбороты
	|		ПО КВП_Услугибит_бк_СоставУслуги.Услуга = УПЖКХ_НачисленияОбороты.Услуга
	|ГДЕ
	|	КВП_Услугибит_бк_СоставУслуги.Ссылка = &Услуга
	|	И КВП_Услугибит_бк_СоставУслуги.Ссылка.бит_бк_ЯвляетсяГруппойУслуг = ИСТИНА";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("За период " + Формат(Источник.Дата, "ДФ='ММММ гггг'") + " было начисление по составу услуги: " + Выборка.Услуга);
		Отказ = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ТекстЗапросаДляОтраженияНачиленийВРегУчете() Экспорт
	
	//+БИ 24062019
	// в запросе убрал лишнее соединение
	//-БИ 24062019
	
	Текст =
	"ВЫБРАТЬ
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорКонтрагента.Владелец КАК Контрагент,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Номенклатура КАК Номенклатура,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоЛьгота КАК ЭтоЛьгота,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоПени КАК ЭтоПени,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Тариф КАК Тариф,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ВариантПоставкиУслуг КАК ВариантПоставкиУслуг,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорПоставщикаУслуг КАК ДоговорПоставщикаУслуг,
	|	СУММА(КВП_НачислениеДляОтраженияВРеглУчетеОстатки.СуммаОстаток) КАК СуммаОтражения,
	|	СУММА(КВП_НачислениеДляОтраженияВРеглУчетеОстатки.КоличествоОстаток) КАК Количество
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	РегистрНакопления.КВП_НачислениеДляОтраженияВРеглУчете.Остатки(
	|			&ДатаСреза,
	|			Организация = &Организация
	|				И &ТекстДопУсловия) КАК КВП_НачислениеДляОтраженияВРеглУчетеОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КВП_Услуги.бит_бк_СоставУслуги КАК КВП_Услугибит_бк_СоставУслуги
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК УслугиБух
	|			ПО КВП_Услугибит_бк_СоставУслуги.Ссылка.Услуга = УслугиБух.Ссылка
	|		ПО КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Номенклатура = КВП_Услугибит_бк_СоставУслуги.Услуга.Услуга
	// Клес +
	|	&СоединениеОтборПоОбъектуОстатки
	// Клес -
	|
	|СГРУППИРОВАТЬ ПО
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорКонтрагента,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ВариантПоставкиУслуг,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоПени,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорПоставщикаУслуг,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоЛьгота,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.НоменклатурнаяГруппа,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорКонтрагента.Владелец,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Номенклатура,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Тариф
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДвиженияДокумента.ДоговорКонтрагента.Владелец КАК Контрагент,
	|	ДвиженияДокумента.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВЫБОР
	|		КОГДА КВП_Услуги.бит_бк_ЯвляетсяГруппойУслуг
	|			ТОГДА ДвиженияДокумента.Номенклатура
	|		ИНАЧЕ ЕСТЬNULL(УслугиБух.Ссылка, ДвиженияДокумента.Номенклатура)
	|	КОНЕЦ КАК Номенклатура,
	|	ДвиженияДокумента.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	ДвиженияДокумента.ЭтоЛьгота КАК ЭтоЛьгота,
	|	ДвиженияДокумента.ЭтоПени КАК ЭтоПени,
	|	ДвиженияДокумента.ВариантПоставкиУслуг КАК ВариантПоставкиУслуг,
	|	ДвиженияДокумента.ДоговорПоставщикаУслуг КАК ДоговорПоставщикаУслуг,
	|	СУММА(ДвиженияДокумента.Сумма) КАК СуммаОтражения,
	|	СУММА(ДвиженияДокумента.Количество) КАК Количество,
	|	ДвиженияДокумента.Тариф КАК Тариф
	|ПОМЕСТИТЬ ДвиженияДокумента
	|ИЗ
	|	РегистрНакопления.КВП_НачислениеДляОтраженияВРеглУчете КАК ДвиженияДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КВП_Услуги КАК КВП_Услуги
	|		ПО ДвиженияДокумента.Номенклатура = КВП_Услуги.Услуга
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КВП_Услуги.бит_бк_СоставУслуги КАК КВП_Услугибит_бк_СоставУслуги
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК УслугиБух
	|			ПО КВП_Услугибит_бк_СоставУслуги.Ссылка.Услуга = УслугиБух.Ссылка
	|		ПО ДвиженияДокумента.Номенклатура = КВП_Услугибит_бк_СоставУслуги.Услуга.Услуга
	//Клес +
	|	&СоединениеОтборПоОбъектуДвижения
	// Клес -
	|ГДЕ
	|	ДвиженияДокумента.Регистратор = &ДокСсылка
	|	И &ТекстДопУсловия
	|
	|СГРУППИРОВАТЬ ПО
	|	ДвиженияДокумента.ДоговорКонтрагента.Владелец,
	|	ДвиженияДокумента.ДоговорКонтрагента,
	|	ДвиженияДокумента.НоменклатурнаяГруппа,
	|	ДвиженияДокумента.ЭтоЛьгота,
	|	ДвиженияДокумента.ЭтоПени,
	|	ДвиженияДокумента.ВариантПоставкиУслуг,
	|	ДвиженияДокумента.ДоговорПоставщикаУслуг,
	|	ДвиженияДокумента.Тариф,
	|	ВЫБОР
	|		КОГДА КВП_Услуги.бит_бк_ЯвляетсяГруппойУслуг
	|			ТОГДА ДвиженияДокумента.Номенклатура
	|		ИНАЧЕ ЕСТЬNULL(УслугиБух.Ссылка, ДвиженияДокумента.Номенклатура)
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Контрагент КАК Контрагент,
	|	Остатки.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	Остатки.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	Остатки.ЭтоЛьгота КАК ЭтоЛьгота,
	|	Остатки.ЭтоПени КАК ЭтоПени,
	|	Остатки.Тариф КАК Тариф,
	|	Остатки.ВариантПоставкиУслуг КАК ВариантПоставкиУслуг,
	|	Остатки.ДоговорПоставщикаУслуг КАК ДоговорПоставщикаУслуг,
	|	Остатки.СуммаОтражения КАК СуммаОтражения,
	|	Остатки.Количество КАК Количество,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетРасчетов КАК СчетУчетаРасчетов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетАвансов КАК СчетУчетаАвансов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетРасчетов КАК бит_бк_СчетРасчетов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетАвансов КАК бит_бк_СчетАвансов
	|ПОМЕСТИТЬ ТаблицаОстатков
	|ИЗ
	|	Остатки КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаУчетаНоменклатуры КАК СчетаУчетаНоменклатуры
	|		ПО Остатки.Номенклатура = СчетаУчетаНоменклатуры.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДвиженияДокумента.Контрагент КАК Контрагент,
	|	ДвиженияДокумента.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ДвиженияДокумента.Номенклатура КАК Номенклатура,
	|	ДвиженияДокумента.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	ДвиженияДокумента.ЭтоЛьгота КАК ЭтоЛьгота,
	|	ДвиженияДокумента.ЭтоПени КАК ЭтоПени,
	|	ДвиженияДокумента.ВариантПоставкиУслуг КАК ВариантПоставкиУслуг,
	|	ДвиженияДокумента.ДоговорПоставщикаУслуг КАК ДоговорПоставщикаУслуг,
	|	ДвиженияДокумента.СуммаОтражения КАК СуммаОтражения,
	|	ДвиженияДокумента.Количество КАК Количество,
	|	ДвиженияДокумента.Тариф КАК Тариф,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетРасчетов КАК СчетУчетаРасчетов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетАвансов КАК СчетУчетаАвансов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетРасчетов КАК бит_бк_СчетРасчетов,
	|	СчетаУчетаНоменклатуры.бит_бк_СчетАвансов КАК бит_бк_СчетАвансов
	|ПОМЕСТИТЬ ТаблицаДвиженийДокумента
	|ИЗ
	|	ДвиженияДокумента КАК ДвиженияДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СчетаУчетаНоменклатуры КАК СчетаУчетаНоменклатуры
	|		ПО ДвиженияДокумента.Номенклатура = СчетаУчетаНоменклатуры.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТаблицаОстатков.Контрагент, ТаблицаДвиженийДокумента.Контрагент) КАК Контрагент,
	|	ЕСТЬNULL(ТаблицаОстатков.ДоговорКонтрагента, ТаблицаДвиженийДокумента.ДоговорКонтрагента) КАК ДоговорКонтрагента,
	|	ЕСТЬNULL(ТаблицаОстатков.Номенклатура, ТаблицаДвиженийДокумента.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТаблицаОстатков.НоменклатурнаяГруппа, ТаблицаДвиженийДокумента.НоменклатурнаяГруппа) КАК НоменклатурнаяГруппа,
	|	ЕСТЬNULL(ТаблицаОстатков.ЭтоЛьгота, ТаблицаДвиженийДокумента.ЭтоЛьгота) КАК ЭтоЛьгота,
	|	ЕСТЬNULL(ТаблицаОстатков.ЭтоПени, ТаблицаДвиженийДокумента.ЭтоПени) КАК ЭтоПени,
	|	ЕСТЬNULL(ТаблицаОстатков.ВариантПоставкиУслуг, ТаблицаДвиженийДокумента.ВариантПоставкиУслуг) КАК ВариантПоставкиУслуг,
	|	ЕСТЬNULL(ТаблицаОстатков.ДоговорПоставщикаУслуг, ТаблицаДвиженийДокумента.ДоговорПоставщикаУслуг) КАК ДоговорПоставщикаУслуг,
	|	ВЫБОР
	|		КОГДА &ВедетсяРаздельныйУчетКапРемонта
	|				И ЕСТЬNULL(ТаблицаОстатков.Номенклатура, ТаблицаДвиженийДокумента.Номенклатура) В (&СписокНоменклатурыУслугКапРемонта)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоКапРемонт,
	|	ЕСТЬNULL(ТаблицаОстатков.СуммаОтражения, 0) + ЕСТЬNULL(ТаблицаДвиженийДокумента.СуммаОтражения, 0) КАК СуммаОтражения,
	|	ЕСТЬNULL(ТаблицаОстатков.СчетУчетаРасчетов, ТаблицаДвиженийДокумента.СчетУчетаРасчетов) КАК СчетУчетаРасчетов,
	|	ЕСТЬNULL(ТаблицаОстатков.СчетУчетаАвансов, ТаблицаДвиженийДокумента.СчетУчетаАвансов) КАК СчетУчетаАвансов,
	|	ЕСТЬNULL(ТаблицаОстатков.бит_бк_СчетРасчетов, ТаблицаДвиженийДокумента.бит_бк_СчетРасчетов) КАК бит_бк_СчетРасчетов,
	|	ЕСТЬNULL(ТаблицаОстатков.бит_бк_СчетАвансов, ТаблицаДвиженийДокумента.бит_бк_СчетАвансов) КАК бит_бк_СчетАвансов,
	|	ЕСТЬNULL(ТаблицаОстатков.Тариф, ТаблицаДвиженийДокумента.Тариф) КАК Тариф,
	|	ЕСТЬNULL(ТаблицаОстатков.Количество, 0) + ЕСТЬNULL(ТаблицаДвиженийДокумента.Количество, 0) КАК Количество,
	|	ВЫБОР
	|		КОГДА &ОтражатьОтрицательныеНачисленияИНачисленияБезОбъемовОтдельно
	|			И (ЕСТЬNULL(ТаблицаОстатков.СуммаОтражения, 0) + ЕСТЬNULL(ТаблицаДвиженийДокумента.СуммаОтражения, 0) < 0
	|				ИЛИ ЕСТЬNULL(ТаблицаОстатков.Количество, 0) + ЕСТЬNULL(ТаблицаДвиженийДокумента.Количество, 0) = 0)
	|		ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоРеализация
	|ИЗ
	|	ТаблицаОстатков КАК ТаблицаОстатков
	|		ПОЛНОЕ СОЕДИНЕНИЕ ТаблицаДвиженийДокумента КАК ТаблицаДвиженийДокумента
	|		ПО (ТаблицаДвиженийДокумента.Контрагент = ТаблицаОстатков.Контрагент)
	|			И (ТаблицаДвиженийДокумента.ДоговорКонтрагента = ТаблицаОстатков.ДоговорКонтрагента)
	|			И (ТаблицаДвиженийДокумента.Номенклатура = ТаблицаОстатков.Номенклатура)
	|			И (ТаблицаДвиженийДокумента.НоменклатурнаяГруппа = ТаблицаОстатков.НоменклатурнаяГруппа)
	|			И (ТаблицаДвиженийДокумента.ЭтоЛьгота = ТаблицаОстатков.ЭтоЛьгота)
	|			И (ТаблицаДвиженийДокумента.ЭтоПени = ТаблицаОстатков.ЭтоПени)
	|			И (ТаблицаДвиженийДокумента.ВариантПоставкиУслуг = ТаблицаОстатков.ВариантПоставкиУслуг)
	|			И (ТаблицаДвиженийДокумента.ДоговорПоставщикаУслуг = ТаблицаОстатков.ДоговорПоставщикаУслуг)
	|ГДЕ
	|	&УсловиеОтрицательныхСумм";
	
	Возврат Текст;
	
