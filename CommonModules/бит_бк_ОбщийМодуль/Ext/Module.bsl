Процедура РаспределитьНачисленияСУчетомДней(Источник) Экспорт
	
	ТЗ = Источник.УслугиПоПоказаниямПУ.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ", ТЗ);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Источник.Дата));
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Источник.Дата));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗ.ЛицевойСчет
	// клес +
	|	,ТЗ.Услуга
	// клес -
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&ТЗ КАК ТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	// клес +
	|	ВТ.Услуга,
	// клес -
	|	бит_бк_ДанныеПоДнямСрезПоследних.ЛицевойСчет,
	|	бит_бк_ДанныеПоДнямСрезПоследних.КоличествоДней
	|ИЗ
	|	ВТ КАК ВТ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_бк_ДанныеПоДням.СрезПоследних(
	|				&КонецПериода,
	|				ЛицевойСчет В
	|						(ВЫБРАТЬ
	|							ВТ.ЛицевойСчет
	|						ИЗ
	|							ВТ КАК ВТ)
	|					И (Период МЕЖДУ &НачалоПериода И &КонецПериода)) КАК бит_бк_ДанныеПоДнямСрезПоследних
	|		ПО ВТ.ЛицевойСчет = бит_бк_ДанныеПоДнямСрезПоследних.ЛицевойСчет";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		
		// Клес +
		Отбор = Новый Структура;
		Отбор.Вставить("ЛицевойСчет", Выборка.ЛицевойСчет);
		Отбор.Вставить("Услуга", Выборка.Услуга);
		Поиск = Источник.УслугиПоПоказаниямПУ.НайтиСтроки(Отбор);
		Если Поиск.Количество() = 1 Тогда НайденнаяСтрока = Поиск[0]; КонецЕсли;
		//НайденнаяСтрока = Источник.УслугиПоПоказаниямПУ.Найти(Выборка.ЛицевойСчет);
		// Клес -
		//исключим строки по которым выполнен индивидуальный расчет
		Если ЗначениеЗаполнено(НайденнаяСтрока) И Не ЗначениеЗаполнено(НайденнаяСтрока.Сумма) Тогда
			
			ТекущаяСумма = НайденнаяСтрока.СуммаРаспределения;
			НайденнаяСтрока.СуммаРаспределения = ТекущаяСумма/День(КонецМесяца(Источник.Дата)) * Выборка.КоличествоДней;
			Сообщить("По " + Выборка.ЛицевойСчет + " по услуге " + Выборка.Услуга + " за " + Выборка.КоличествоДней + " дней рассчитано: " + НайденнаяСтрока.СуммаРаспределения);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

