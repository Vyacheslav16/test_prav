Процедура ПередЗаписьюРТиУ(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.ОбменДанными.Загрузка ИЛИ Отказ Тогда
		Возврат;
	КонецЕСли;
	
	Если Не Источник.ЭтоНовый() Тогда
		Возврат;
	КонецЕсли;
	
	Если Источник.Комментарий = "Документ сгенерирован автоматически для отражения  начислений." Тогда
		
		Для Каждого Строка Из Источник.Услуги Цикл
			
			ДопСодержание = " согласно Договору " + Источник.ДоговорКонтрагента.Номер + " от " +
			Формат(Источник.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy") + " за " + Формат(Источник.Дата, "ДФ='ММММ гггг'");
			Строка.Содержание = Строка.Содержание + ДопСодержание;
			
		КонецЦикла;
		
	КонецЕсли;
	
