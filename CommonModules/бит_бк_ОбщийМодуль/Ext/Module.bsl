Функция ЯвляетсяГруппойУслуг(Услуга) Экспорт
	
	Если Не ЗначениеЗаполнено(Услуга) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Услуга", Услуга);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КВП_Услуги.Ссылка
	|ИЗ
	|	Справочник.КВП_Услуги КАК КВП_Услуги
	|ГДЕ
	|	КВП_Услуги.Услуга = &Услуга
	|	И КВП_Услуги.бит_бк_ЯвляетсяГруппойУслуг = ИСТИНА";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
