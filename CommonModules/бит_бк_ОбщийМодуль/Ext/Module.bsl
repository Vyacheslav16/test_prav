	|				&КонецПериода,
	|				ЛицевойСчет В
	|						(ВЫБРАТЬ
	|							ВТ.ЛицевойСчет
	|						ИЗ
	|							ВТ КАК ВТ)
	|					И (Период МЕЖДУ &НачалоПериода И &КонецПериода)) КАК бит_бк_ДанныеПоДнямСрезПоследних
	|		ПО ВТ.ЛицевойСчет = бит_бк_ДанныеПоДнямСрезПоследних.ЛицевойСчет";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		
		НайденнаяСтрока = Источник.Услуги.Найти(Выборка.ЛицевойСчет);
		
		Если ЗначениеЗаполнено(НайденнаяСтрока) Тогда
			
			ТекущаяСумма = НайденнаяСтрока.Начислено;
			НайденнаяСтрока.Начислено = ТекущаяСумма/День(КонецМесяца(Источник.Дата)) * Выборка.КоличествоДней;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция РаспределитьПропорционально(Знач ИсхСумма, МассивКоэф, Знач Точность = 2, Здание, Дата) Экспорт
	
	Если МассивКоэф.Количество() = 0 Или ИсхСумма = 0 Или ИсхСумма = Null Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не ТипЗнч(Здание) = Тип("СправочникСсылка.КВП_Здания") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В качестве объекта необходимо указать здание!");
		Возврат Неопределено;
	КонецЕсли;
	
	Если Здание.ПлощадьЗданияОбщая = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена общая площадь здания!");
		Возврат Неопределено;
	КонецЕсли;
	
	МассивСумм = Новый Массив(МассивКоэф.Количество());
	
	мСуммаКРаспределению = ИсхСумма;
	// Клес + изменение по задаче от Писарьковой Юны "Теперь по законодательству мы должны делить не на общую S, а на жилую (арендопригодную)."
	Если Дата >= Дата("20220401") Тогда
		мЗнаменательРаспределения = Здание.ПлощадьЗданияЖилыхНежилыхПомещений;
	Иначе
		мЗнаменательРаспределения = Здание.ПлощадьЗданияОбщая;
	КонецЕсли;
	
	Для К = 0 По МассивКоэф.Количество() - 1 Цикл
		МассивСумм[К] = Окр(мСуммаКРаспределению * МассивКоэф[К] / ?(мЗнаменательРаспределения = 0, 1, мЗнаменательРаспределения), Точность, 1);
	КонецЦикла;
	
	Возврат МассивСумм;
	
КонецФункции

