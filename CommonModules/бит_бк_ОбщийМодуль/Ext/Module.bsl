Процедура СформироватьДвиженияПоСоставуУслуги(Услуга, Договор, СтрокаРеквизитов, НаборДвижений) Экспорт
	
	Если Не ЗначениеЗаполнено(Услуга) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Услуга);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КВП_Услугибит_бк_СоставУслуги.Услуга.Услуга КАК УслугаБух
	|ПОМЕСТИТЬ ВТ_СоставУслуги
	|ИЗ
	|	Справочник.КВП_Услуги.бит_бк_СоставУслуги КАК КВП_Услугибит_бк_СоставУслуги
	|ГДЕ
	|	КВП_Услугибит_бк_СоставУслуги.Ссылка.Услуга = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Организация,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорКонтрагента,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Номенклатура,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.НоменклатурнаяГруппа,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоЛьгота,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ЭтоПени,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ВариантПоставкиУслуг,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.ДоговорПоставщикаУслуг,
	|	КВП_НачислениеДляОтраженияВРеглУчетеОстатки.СуммаОстаток
	|ИЗ
	|	ВТ_СоставУслуги КАК ВТ_СоставУслуги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.КВП_НачислениеДляОтраженияВРеглУчете.Остатки(, ДоговорКонтрагента = &ДоговорКонтрагента) КАК КВП_НачислениеДляОтраженияВРеглУчетеОстатки
	|		ПО ВТ_СоставУслуги.УслугаБух = КВП_НачислениеДляОтраженияВРеглУчетеОстатки.Номенклатура";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Движение = НаборДвижений.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период      = СтрокаРеквизитов.Период;
		Движение.Организация = СтрокаРеквизитов.Организация;
		
		Движение.Номенклатура           = Выборка.Номенклатура;
		Движение.НоменклатурнаяГруппа   = Выборка.НоменклатурнаяГруппа;
		Движение.ДоговорКонтрагента     = Выборка.ДоговорКонтрагента;
		Движение.ВариантПоставкиУслуг   = Выборка.ВариантПоставкиУслуг;
		Движение.ДоговорПоставщикаУслуг = Выборка.ДоговорПоставщикаУслуг;
		
		Движение.ЭтоЛьгота              = Выборка.ЭтоЛьгота;
		Движение.ЭтоПени                = Выборка.ЭтоПени;
		Движение.Сумма                  = Выборка.СуммаОстаток;
		
	КонецЦикла
	
