Функция ЗагрузитьБанковскуюВыпискуНаСервереОбщая(ВыбранныеФайлы, ДополнительныеПараметры, Сч = 0) 
	
	ПомещаемыеФайлы = Новый Массив;
	ПомещаемыеФайлы.Добавить(Новый ОписаниеПередаваемогоФайла(ДополнительныеПараметры.ИмяФайла));
	
	ОписаниеФайла = ПомещаемыеФайлы.Получить(0);
	Кодировка = Неопределено;
	АдресХранилища = "";
	//
	СтруктураПараметров = Новый Структура;
	
	//Если РасширениеРаботыСФайламиПодключено
	//	И ТипЗнч(ОписаниеФайла) = Тип("ОписаниеПереданногоФайла")
	//	И ЗначениеЗаполнено(ОписаниеФайла.ПолноеИмя) Тогда
	//	СтруктураПараметров.Вставить("ФайлЗагрузки", ОписаниеФайла.ПолноеИмя);
	//Иначе
		СтруктураПараметров.Вставить("ФайлЗагрузки", ОписаниеФайла.Имя);
	//КонецЕсли;
	
	СтруктураПараметров.Вставить("АдресХранилищаРаспознанныеДанныеИзБанка",
		ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор));
	СтруктураПараметров.Вставить("Кодировка", Кодировка);
	Если Не ПустаяСтрока(ОписаниеФайла.Хранение) Тогда
		СтруктураПараметров.Вставить("ДвоичныеДанные", ПолучитьИзВременногоХранилища(ОписаниеФайла.Хранение));
	КонецЕсли;
	
	//
	СведенияОВладельцеБанковскогоСчетаИзКонтекста = Новый Структура;
	СведенияОВладельцеБанковскогоСчетаИзКонтекста.Вставить("Организация",               Новый Массив);
