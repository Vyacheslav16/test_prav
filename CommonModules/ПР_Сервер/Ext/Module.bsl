
Процедура ПриУстановкеНовогоНомераПриУстановкеНовогоНомера(Источник, СтандартнаяОбработка, Префикс) Экспорт

	СтандартнаяОбработка = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаДок",			Источник.Дата);
	Запрос.УстановитьПараметр("СтрМесяц",			"%/" + Формат(Источник.ДатаНач,"ДФ=ММ") + "/" + Формат(Источник.ДатаНач,"ДФ=гг")+"%");
	МесяцГод = "/" + Формат(Источник.ДатаНач,"ДФ=ММ") + "/" + Формат(Источник.ДатаНач,"ДФ=гг");
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПР_Квитанция.Номер КАК Номер
	               |ИЗ
	               |	Документ.ПР_Квитанция КАК ПР_Квитанция
	               |ГДЕ
	               |	ПР_Квитанция.Номер ПОДОБНО &СтрМесяц
	               //|	И ПР_Квитанция.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаДок, МЕСЯЦ) И КОНЕЦПЕРИОДА(&ДатаДок, МЕСЯЦ)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Номер УБЫВ";
				   
	Рез = Запрос.Выполнить().Выбрать();
	
	Если Рез.Следующий() Тогда
		
		НрмерБезК = СокрЛП(Сред(Рез.Номер,3));
		ПоследнийНомерСтрокой = Сред(НрмерБезК,1,Найти(НрмерБезК,МесяцГод)-1);
		ПоследнийНомерЧислом = Число(ПоследнийНомерСтрокой) + 1;
		ПоследнийНомерСтрокой = СтрЗаменить(Строка(ПоследнийНомерЧислом)," ","");
		Пока СтрДлина(ПоследнийНомерСтрокой) < 4 Цикл
			ПоследнийНомерСтрокой = "0" + ПоследнийНомерСтрокой;
		КонецЦикла;
		
		а=а;
		
	Иначе
		
		ПоследнийНомерСтрокой = "0001";
		
	КонецЕсли;
	
	Источник.Номер = "К-" + ПоследнийНомерСтрокой + "/" + Формат(Источник.ДатаНач,"ДФ=ММ") + "/" + Формат(Источник.ДатаНач,"ДФ=гг"); 
	
КонецПроцедуры

