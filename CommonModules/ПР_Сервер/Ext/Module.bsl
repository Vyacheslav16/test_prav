	Результат.Вставить("ТипКвартиры","");
	Результат.Вставить("ТипКорпуса","");
	Результат.Вставить("Улица","");
	
	Если СтрокаАдреса <> ""	Тогда
		СтруктураАдреса = ЗарплатаКадры.СтруктураАдресаИзXML(СтрокаАдреса);
		Для Каждого Элемент Из СтруктураАдреса Цикл
            Если Результат.Свойство(Элемент.Ключ) Тогда
				Результат.Вставить(Элемент.Ключ, Элемент.Значение);
