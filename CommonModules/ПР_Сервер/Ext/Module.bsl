Функция ПР_ДоступныеЗначенияАдреса(ЗначенияПолейДляАнализа, ЗаполняемНомерДома) Экспорт 
	СЗ = Новый СписокЗначений;
	Если ЗначенияПолейДляАнализа.Количество()>0 Тогда
		СтруктураАдреса = ЗарплатаКадры.СтруктураАдресаИзXML(ЗначенияПолейДляАнализа[0].Значение);
		Если ЗаполняемНомерДома Тогда
			СЗ.Добавить(СтруктураАдреса.Дом);
		Иначе	
			СЗ.Добавить(СтруктураАдреса.Индекс + ", " + СтруктураАдреса.Регион + ", " + СтруктураАдреса.Улица + ", дом № " + СтруктураАдреса.Дом);
			СЗ.Добавить(СтруктураАдреса.Регион + ", " + СтруктураАдреса.Улица + ", дом № " + СтруктураАдреса.Дом);
			СЗ.Добавить(СтруктураАдреса.Улица + ", дом № " + СтруктураАдреса.Дом);
			СЗ.Добавить("дом № " + СтруктураАдреса.Дом);
		КонецЕсли;	
	КонецЕсли;	
	Возврат СЗ;
КонецФункции

