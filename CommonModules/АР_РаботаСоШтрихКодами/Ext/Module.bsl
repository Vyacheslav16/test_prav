// Формирование изображения штрихкода для указанного объекта
// 
// Параметры: 
//  Нет 
// 
// Возвращаемое значение: 
//  Картинка - Картинка со сформированным штрихкодом ИЛИ НЕОПРЕДЕЛЕНО
Функция ПолучитьКартинкуШтрихкода(ШтрихКод) Экспорт

	// В зависимости от типа платформы подключим соответствующую внешнюю компоненту
	ИнформацияОСистеме = Новый СистемнаяИнформация;
	Если ИнформацияОСистеме.ТипПлатформы = ТипПлатформы.Windows_x86 Тогда

		ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодовWindows32", "КартинкаШтрихкода", ТипВнешнейКомпоненты.Native);

	ИначеЕсли ИнформацияОСистеме.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда

		ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодовWindows64", "КартинкаШтрихкода", ТипВнешнейКомпоненты.Native);

	ИначеЕсли ИнформацияОСистеме.ТипПлатформы = ТипПлатформы.Linux_x86 Тогда

		ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодовLinux32", "КартинкаШтрихкода", ТипВнешнейКомпоненты.Native);		

	Иначе

		ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодовLinux64", "КартинкаШтрихкода", ТипВнешнейКомпоненты.Native);

	КонецЕсли;
	
		ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиШтрихкодов", "КартинкаШтрихкода", ТипВнешнейКомпоненты.Native);

	// Создадим объект внешней компоненты
	Компонент = Новый("AddIn.КартинкаШтрихкода.Barcode");

	// Если нет возможности рисовать
	Если НЕ Компонент.ГрафикаУстановлена Тогда

		// То картинку сформировать не сможем
		Возврат Неопределено;

	КонецЕсли;

	// Если в системе установлен шрифт Tahoma
	Если Компонент.НайтиШрифт("Tahoma") = Истина Тогда

		// Выбираем его как шрифт для формирования картинки
		Компонент.Шрифт = "Tahoma";

	Иначе

		// Шрифт Tahoma в системе отсутствует

		// Обойдем все доступные компоненте шрифты
		Для Сч = 0 По Компонент.КоличествоШрифтов -1 Цикл

			// Получим очередной шрифт, доступный компоненте
			ТекущийШрифт = Компонент.ШрифтПоИндексу(Сч);

			// Если шрифт доступен
			Если ТекущийШрифт <> Неопределено Тогда

				// Они и будет шрифтом для формирования штрихкода
				Компонент.Шрифт = ТекущийШрифт;
				Прервать;

			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

	// Установим размер шрифта
	Компонент.РазмерШрифта = 12;

	// Зададим размер картинки
	Компонент.Ширина = 100;
	Компонент.Высота = 90;

	// Разрешим компоненте самой определять тип кода
	Компонент.АвтоТип = Истина;
	 //ИЛИ установим код EAN-13
	 //Компонент.АвтоТип = Ложь;
	 //Компонент.ТипКода = 3;
	 Компонент.ТипКода = 1;
	//
	// Тип смотрим в документации на внешнюю компоненту

	// Если код содержит контрольный символ, обязательно указываем
	//Компонент.СодержитКС = СтрДлина(ЭтотОбъект.Штрихкод) = 13;
	Компонент.СодержитКС = СтрДлина(Штрихкод) = 13;

	// Если отображать контрольный символ не нужно
	// Компонент.ВидимостьКС = Ложь;

	// Формируем картинку штрихкода
	//Компонент.ЗначениеКода = ЭтотОбъект.Штрихкод;
	Компонент.ЗначениеКода = Штрихкод;

	// Если установленная нами ширина меньше минимально допустимой для этого штрихкода
	Если Компонент.Ширина < Компонент.МинимальнаяШиринаКода Тогда

		// Скорректируем ширину
		Компонент.Ширина = Компонент.МинимальнаяШиринаКода + 10;

	КонецЕсли;

	// Сформируем картинку
	ДвоичныеДанныеКартинки = Компонент.ПолучитьШтрихкод();

	// Если картинка сформировалась
	Если НЕ ДвоичныеДанныеКартинки = Неопределено Тогда

		// Формируем из двоичных данных
		Возврат Новый Картинка(ДвоичныеДанныеКартинки);

	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция ПолучитьРегистратор(Регистратор) Экспорт
	Если Регистратор = Null Тогда
		Возврат "";	
	КонецЕсли;	
	Если ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
		Возврат "№ " +Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда 
		возврат Строка(Регистратор.ВидОперации) + " " + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	// + NAI Becar Комментирование Смирнов А.А. от 04.04.2017 17:10
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда 
		возврат "Акт №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_СчетНаАренду") Тогда 
		возврат "Счет №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.СчетФактураВыданный") Тогда 
		возврат "С/ф №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	// - NAI Becar Комментирование Смирнов А.А.
	Иначе
		Возврат Строка(ТипЗнч(Регистратор)) + " " + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	КонецЕсли;
КонецФункции
	
Функция ПолучитьБТИ(ОбъектАренды) Экспорт
	НомерБТИ = "";
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ОбъектыАренды.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ ВТ_Группа
	               |ИЗ
	               |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	               |ГДЕ
	               |	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР_ОбъектыАренды.Ссылка КАК Ссылка,
	               |	АР_ОбъектыАренды.ПомещениеНомерБТИ
	               |ИЗ
	               |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	               |ГДЕ
	               |	АР_ОбъектыАренды.Ссылка В ИЕРАРХИИ
	               |			(ВЫБРАТЬ
	               |				ВТ_Группа.Ссылка
	               |			ИЗ
	               |				ВТ_Группа)
	               |	И АР_ОбъектыАренды.ПомещениеНомерБТИ <> """"";
				   
				   
	Запрос.УстановитьПараметр("ОбъектАренды", ОбъектАренды);
	ТЗ = Запрос.Выполнить().Выгрузить();
	Для каждого Стр из ТЗ Цикл
		НомерБТИ = НомерБТИ + Стр.ПомещениеНомерБТИ + ", ";
	КонецЦикла;
	Если СокрЛП(НомерБТИ) <> "" Тогда
		НомерБТИ = Лев(НомерБТИ, СтрДлина(НомерБТИ)-2);
	КонецЕсли;
	Возврат НомерБТИ;
	
КонецФункции

Функция АР17_ПолучитьРегистратор(Регистратор) Экспорт
	Если Регистратор = Null Тогда
		Возврат "";	
	КонецЕсли;	
	// + NAI Becar Комментирование Смирнов А.А. от 04.04.2017 17:10
	Если ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
		РН = НайтиПодчиненнуюРеализацию(Регистратор.Ссылка);
		Если РН <> "" Тогда
			РН.ПолучитьОбъект();
			возврат "Акт №" + Строка(РН.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
		КонецЕсли;	
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_СчетНаАренду") Тогда 
		возврат "Счет №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.СчетФактураВыданный") Тогда 
		возврат "С/ф №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
		Возврат "Договор " + "№ " +Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда 
		возврат Строка(Регистратор.ВидОперации) + " " + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ИнформационныйДокумент") Тогда 
		возврат Регистратор.Наименование + " №" + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_РасторжениеДоговораАренды") Тогда 
		возврат "Расторжение договора" + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	// - NAI Becar Комментирование Смирнов А.А.
	Иначе
		//Возврат Регистратор;
		Возврат Строка(ТипЗнч(Регистратор)) + " " + Строка(Регистратор.Номер) + " от " + Формат(Регистратор.Дата, "ДФ=дд.ММ.гггг");
	КонецЕсли;
КонецФункции

Функция НайтиПодчиненнуюРеализацию(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	РеализацияТоваровУслуг.Ссылка КАК Реализация
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.СчетНаОплатуПокупателю = &ДокументОснование";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Реализация = Выборка.Реализация;
	Иначе
		Реализация = "";
	КонецЕсли;
	
	Возврат Реализация;
	
КонецФункции	

Функция АР17_ПолучитьГруппыУслуг(Регистратор) Экспорт
	Если Регистратор = Null Тогда
		Возврат "";	
	КонецЕсли;	
	// + NAI Becar Комментирование Смирнов А.А. от 04.04.2017 17:10
	Если ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_НачислениеАренднойПлаты") 
		или ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_СчетНаАренду") Тогда
			Стр = "";
			Для Каждого СтрТЧ Из Регистратор.Состав Цикл
				Если Найти(Стр,СтрТЧ.ГруппаУслуг.Наименование) > 0 Тогда Продолжить; КонецЕсли;
				Стр = Стр + СтрТЧ.ГруппаУслуг.Наименование + ",";
			КонецЦикла;	
			возврат Лев(Стр,СтрДлина(Стр)-1);
		ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.СчетФактураВыданный") Тогда
			Стр = "";
			Состав = ПолучитьПостЗДА(Регистратор.ДоговорКонтрагента);
			Для Каждого СтрТЧ Из Состав Цикл
				Если Найти(Стр,СтрТЧ.ГруппаУслуг.Наименование) > 0 Тогда Продолжить; КонецЕсли;
				Стр = Стр + СтрТЧ.ГруппаУслуг.Наименование + ",";
			КонецЦикла;	
			возврат Лев(Стр,СтрДлина(Стр)-1);
	ИначеЕсли ТипЗНч(Регистратор) = ТИП("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
			Стр = "";
			Для Каждого СтрТЧ Из Регистратор.ПостояннаяЧастьАренднойПлаты Цикл
				Если Найти(Стр,СтрТЧ.ГруппаУслуг.Наименование) > 0 Тогда Продолжить; КонецЕсли;
				Стр = Стр + СтрТЧ.ГруппаУслуг.Наименование + ",";
			КонецЦикла;	
			возврат Лев(Стр,СтрДлина(Стр)-1);
	// - NAI Becar Комментирование Смирнов А.А.
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьПостЗДА(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ГруппаУслуг
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты
	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента";
				   
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка;
КонецФункции
