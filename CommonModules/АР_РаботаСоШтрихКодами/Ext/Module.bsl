//*******************************************************************************************
// Параметры:
// ----------
// 		
//
// Возвращаемое значение:
// ----------------------
//		строка с текстом ШтрихКода
//
// Описание:
// ---------
// 		Формирует уникальный код ШК (еще нет в БД)
//
//*******************************************************************************************
Функция СформироватьШК()

	ШК = Новый УникальныйИдентификатор;
	ШК = СтрЗаменить(ШК,"-","");
	ШК = СимволыВЦифры(ШК);
	ШК = Лев(ШК,13);
	
	// Проверим что такого ШК еще нет
	//--------------------------------
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихКоды.СсылкаНаОбъект
	|ИЗ
	|	РегистрСведений.АР_ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.ШтрихКод = &ШтрихКод";
	Запрос.УстановитьПараметр("ШтрихКод",ШК);
	
	тз = Новый ТаблицаЗначений;
	тз = Запрос.Выполнить().Выгрузить();
	Если тз.Количество() <> 0 Тогда
		СформироватьШК();
	Иначе
		Возврат ШК;
	КонецЕсли;
КонецФункции // СформироватьШК()

//*******************************************************************************************
// Параметры:
// ----------
// 		Ссылка - ссылка на документ
//
// Возвращаемое значение:
// ----------------------
//		строка (ШК)
//
// Описание:
// ---------
// 		Возвращает строку штрихкода зарегестрированную для этого документа в базе, если еще не
//		формировалось, то создает соответствующую запись
//
//*******************************************************************************************
Функция ПроверитьИУстановитьШКДокумента(Ссылка) Экспорт 
	
	//Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат "";
	//КонецЕсли;

	// Проверим есть ли ШК для документа
	//-----------------------------------
    Запрос = Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ШтрихКоды.ШтрихКод
	|ИЗ
	|	РегистрСведений.АР_ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.СсылкаНаОбъект = &СсылкаНаОбъект";
	Запрос.УстановитьПараметр("СсылкаНаОбъект",Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		// Штрих код есть
		//------------------
		Возврат СокрЛП(Выборка.ШтрихКод);
	Иначе
		// Нет ШК, создаем новый
		//-------------------------
		Запись = РегистрыСведений.АР_ШтрихКоды.СоздатьМенеджерЗаписи();
		Запись.ШтрихКод = СформироватьШК();
		Запись.СсылкаНаОбъект = Ссылка;
		Попытка
			Запись.Записать(Ложь);
		Исключение
			Сообщить("Ошибка формирования штрих-кода! Обратитесь к разработчику.", СтатусСообщения.Внимание);
			Возврат "";
		КонецПопытки;
		
		Возврат СокрЛП(Запись.ШтрихКод);		
		
	КонецЕсли;
	
КонецФункции // ПроверитьИУстановитьШКДокумента()


