// Ищет документ по вхождению строки в штрих код
//
// Параметры:
// 		СтрШК - строка содержащая часть ШК по которой ищем
// 		Отображать - если ИСТИНА то откроет форму по ссылке или список если несколько
//
// Возвращаемое значение:
//		Ссылка/ Список значений со ссылками
//
Функция ПолучитьДокументыПоЧастиШК(СтрШК = "", Отображать=Истина) Экспорт 

	Если НЕ ЗначениеЗаполнено(СтрШК) Тогда
		//Если Не ВвестиСтроку(СтрШК,"Введите штрих-код:") Тогда
		//	Возврат Неопределено;
		//КонецЕсли;
	КонецЕсли;

	МассивСсылок = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ШтрихКоды.СсылкаНаОбъект КАК Ссылка,
	|	ШтрихКоды.ШтрихКод КАК ШК
	|ИЗ
	|	РегистрСведений.ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.ШтрихКод ПОДОБНО &ШтрихКод";
	Запрос.УстановитьПараметр("ШтрихКод","%" + СтрШК + "%");
	МассивСсылок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Если МассивСсылок.Количество() = 1 Тогда
		Если Отображать Тогда
			ОткрытьФормуПоСсылке(МассивСсылок[0]); 			
		КонецЕсли;
		Возврат МассивСсылок[0];
	ИначеЕсли МассивСсылок.Количество()>1 Тогда
		МассивСсылок = Запрос.Выполнить().Выгрузить();
		Список = Новый СписокЗначений;
		
		// сформируем список документов с представлением
		Для каждого СтрокаМассива Из МассивСсылок Цикл
			Список.Добавить(СтрокаМассива.Ссылка,ПредставлениеДокументаПоСсылке(СтрокаМассива.Ссылка) + " (" + СокрЛП(СтрокаМассива.ШК) + ")");
		КонецЦикла; 
		
		Если Отображать Тогда
			ЭлСсылка = Список.ВыбратьЭлемент("Найденные документы"); 			
			Если ЭлСсылка <> Неопределено Тогда
				ОткрытьФормуПоСсылке(ЭлСсылка.Значение);
			КонецЕсли;
		КонецЕсли;
		Возврат Список;
	Иначе
		 Возврат Неопределено;
	КонецЕсли;
	
КонецФункции // ПолучитьДокументыПоЧастиШК()

// Выводит в окно сообщенией основные параметры драйвера сканера штрих-кодов 
//
// Параметры:
//		<Драйвер> - ссылка на созданный экземпляр драйвера
//
Процедура ВывестиПараметрыДрайвера(Драйвер) Экспорт
	
	Если Драйвер = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Сообщить("-----------------------------------------------");
	Сообщить("Номер устройства: " + Драйвер.НомерТекущегоУстройства);
	Сообщить("Наименование устройства: " + Драйвер.НаименованиеТекущегоУстройства);
	Сообщить("Номер порта: " + Драйвер.НомерПорта);
	Сообщить("Скорость обмена: " + Драйвер.СкоростьОбмена);
	Сообщить("Четность: " + Драйвер.Четность);
	Сообщить("Биты данных: " + Драйвер.БитыДанных);
	Сообщить("Стоп биты: " + Драйвер.СтопБиты);
	Сообщить("Чувствительность: " + Драйвер.Чувствительность);
	Сообщить("Модель: " + Драйвер.Модель);
	Сообщить("Старая версия: " + Драйвер.СтараяВерсия);
	Сообщить("Префикс: " + КодСимвола(Драйвер.Префикс));
	Сообщить("Суффикс: " + КодСимвола(Драйвер.Суффикс));
	Сообщить("Устройство включено: " + Драйвер.УстройствоВключено);
	Сообщить("Описание результата: " + Драйвер.ОписаниеРезультата);
	Сообщить("-----------------------------------------------");
КонецПроцедуры

 // Выполняет попытку подключения драйвера "АТОЛ:Сканер штрихкода"
 // 		
 // Парамеры:
 //		<Результат> - строка с описанием результата подключения
 //
 // Возвращаемое значение:
 //		Значение "Неопределено" в случае неудачного подключения (описание ошибки записывается 
 //		в параметр <Результат>) и ссылку на драйвер в случае успешного подключения.
 //
Функция ПодключениеСканераШтрихКодов(Результат = "") Экспорт
Перем Драйвер;

	Драйвер = Неопределено;
	 
	#Если Клиент Тогда
	Попытка
		//подключаем компоненту
		ПодключитьВнешнююКомпоненту("AddIn.Scaner45");
		Попытка
			Драйвер = Новый("AddIn.Scaner45");
		Исключение
			Результат = ОписаниеОшибки();
			Возврат Неопределено;
		КонецПопытки;
	Исключение
		Результат = ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
	
	// получим настройки оборудования для текущего компьютера
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НастройкиСканеровШтрихКода.Ссылка КАК Настройки
	               |ИЗ
	               |	Справочник.НастройкиСканеровШтрихКода КАК НастройкиСканеровШтрихКода
	               |ГДЕ
	               |	НастройкиСканеровШтрихКода.Компьютер = &Компьютер
	               |	И НастройкиСканеровШтрихКода.Активный = ИСТИНА";
	Запрос.УстановитьПараметр("Компьютер", ВРег(ИмяКомпьютера()));
		
	Выборка = Запрос.Выполнить().Выгрузить();
	// если настроек нет, возврат
	Если Выборка.Количество() = 0 Тогда
		Результат = "Для данного компьютера нет настроек сканера штрихкода!";
		Возврат Неопределено;
	КонецЕсли;	
	
	Настройки = Выборка[0].Настройки;
	
	мПрефикс = СтрЗаменить(Настройки.Префикс, "#", Символы.ПС);
	Для Сч = 2 по СтрЧислоСтрок(мПрефикс) Цикл
		Префикс = ""+Префикс + Символ(Число(СтрПолучитьСтроку(мПрефикс, Сч)));
	КонецЦикла;	
	мСуффикс = СтрЗаменить(Настройки.Суффикс, "#", Символы.ПС);
	Для Сч = 2 по СтрЧислоСтрок(мСуффикс) Цикл
		Суффикс = ""+Суффикс + Символ(Число(СтрПолучитьСтроку(мСуффикс, Сч)));
	КонецЦикла;	
	
	// создаем экземпляр оборудования и прописываем его параметры 
	Драйвер.ДобавитьУстройство();
	Если Драйвер.Результат = 0 Тогда
		Драйвер.НаименованиеТекущегоУстройства = Настройки.Наименование;
		Драйвер.НомерПорта = Настройки.Порт;   
		Драйвер.СкоростьОбмена = Настройки.Скорость;  
		Драйвер.Четность = Настройки.Четность;
		Драйвер.БитыДанных = Настройки.БитДанных;
		Драйвер.СтопБиты = Настройки.СтопБит;
		Драйвер.Чувствительность = Настройки.Чувствительность;
		Драйвер.Префикс = Префикс;
		Драйвер.Суффикс = Суффикс; 
	Иначе
		// если создать устройство не удалось...
		Результат = Драйвер.ОписаниеРезультата;
		Возврат Неопределено;
	КонецЕсли;
	

	// попытаемся включить устройство
	Драйвер.УстройствоВключено = 1;
	Результат = Драйвер.ОписаниеРезультата;
	
	Если Драйвер.Результат <> 0 Тогда
		
		// удаляем экземпляр устройства
		Драйвер.УстройствоВключено = 0;
		Драйвер.УдалитьУстройство();
		Возврат Неопределено;
	КонецЕсли;
	 
 	#КонецЕсли
 
 	Возврат Драйвер;
 КонецФункции
 
//*********************************************************************************
// ОткрыитьФормуПоСсылке(Значение)
//
// Параметры:
// ----------
// 		Значение - Значение форму которого необходимо открыть	
//      Владелец - тип: Форма. ФормаВладелец открываемой формы
//
// Возвращаемое значение:
// ----------------------
//      
//
// Описание:
// ---------
//   Если значение является ссылкой на элемент справочника или документ   
//	 будет открыта соответсвующая форма элемента или документа	
//*********************************************************************************
Функция ОткрытьФормуПоСсылке(Значение, Владелец=Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат Ложь;
	КонецЕсли;
		
	// Если Значение является сылкой на элемент
	// справочника или документа откроем форму
	// документа или элемента справочника
	//-----------------------------------------
    
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) Тогда 
		Если НЕ Значение.Пустая() Тогда
			Попытка
				Форма = Значение.ПолучитьФорму();
				Если НЕ Владелец=Неопределено Тогда
					Форма.ВладелецФормы = Владелец;
				КонецЕсли;
				Форма.Открыть();	
				Возврат Истина;
			Исключение
				Возврат Ложь;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции


