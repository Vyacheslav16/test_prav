Функция НайтиШаблон(Наим,ИК)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ШаблоныОповещений.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.АР_ШаблоныОповещений КАК АР_ШаблоныОповещений
	               |ГДЕ
	               |	АР_ШаблоныОповещений.ИК = &ИК
	               |	И АР_ШаблоныОповещений.Наименование = &Наименование";
	Запрос.УстановитьПараметр("ИК",ИК);
	Запрос.УстановитьПараметр("Наименование",Наим);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
	
КонецФункции	


