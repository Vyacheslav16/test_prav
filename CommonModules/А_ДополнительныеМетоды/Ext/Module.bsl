Функция ПолучитьСписокПараметров(СсылкаНаОбъект, СуммаОстаток, СрокОплаты, Долг, Шаблон, СрокОплатыЗДА, МесяцСрокаОплатыЗДА, Реализация)
	
	СписокПараметров = Новый СписокЗначений;
	
	Если СсылкаНаОбъект.Организация.Префикс = "БЭ" Тогда
		Орг = "ООО ""БЕКАР-ЭКСПЛУАТАЦИЯ""";
	Иначе
		Орг = СсылкаНаОбъект.Организация.НаименованиеСокращенное;
	КонецЕсли;	
	
	СписокПараметров.Вставить( 0, Орг																, "[Организация]");
	СписокПараметров.Вставить( 1, СсылкаНаОбъект.ДоговорКонтрагента.Номер							, "[НомерДоговора]");
	СписокПараметров.Вставить( 2, Формат(СсылкаНаОбъект.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy")	, "[ДатаДоговора]");
	СписокПараметров.Вставить( 3, СсылкаНаОбъект.Контрагент.Наименование							, "[Контрагент]");
	СписокПараметров.Вставить( 4, Формат(СсылкаНаОбъект.Дата, "ДФ=dd.MM.yyyy")						, "[ДатаНачалаДоговора]");
	СписокПараметров.Вставить( 5, Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy")							, "[ТекущаяДата]");
	СписокПараметров.Вставить( 6, Строка(СуммаОстаток)												, "[СуммаОстаток]");
	СуммаОстатокПрописью = ЧислоПрописью(СуммаОстаток, "Л=ru_RU", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
	СписокПараметров.Вставить( 7, СуммаОстатокПрописью												, "[СуммаОстатокПрописью]");
	СписокПараметров.Вставить( 8, Формат(ТекущаяДата(), "ДФ=MMMMyyyy")								, "[ТекущийМесяц]");
	СписокПараметров.Вставить( 9, Формат(КонецДня(ТекущаяДата())+1, "ДФ=dd.MM.yyyy")				, "[СледующийДень]");
	СписокПараметров.Вставить(10, СсылкаНаОбъект.ИК.Наименование									, "[ИК]");
	СписокПараметров.Вставить(11, СсылкаНаОбъект.ИК.Менеджер.Наименование							, "[Менеджер]");
	Контрагент_Руководитель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаОбъект.Контрагент, "ОсновноеКонтактноеЛицо");
	Результат = ОтветственныеЛицаБППовтИсп.ОтветственныеЛица(СсылкаНаОбъект.Организация, ТекущаяДата());
	Если СсылкаНаОбъект.Пол = Перечисления.ПолФизическогоЛица.Женский Тогда
		Пол = 2;
	ИначеЕсли СсылкаНаОбъект.Пол = Перечисления.ПолФизическогоЛица.Мужской Тогда
		Пол = 1;
	Иначе
		Пол = 1;
	КонецЕсли;
	СписокПараметров.Вставить(12, СокрЛП(Контрагент_Руководитель)									, "[Контрагент_Руководитель]");
	СписокПараметров.Вставить(13, Сред(Контрагент_Руководитель,Найти(Контрагент_Руководитель," ")+1), "[Контрагент_РуководительИО]");
	СписокПараметров.Вставить(14, СклонениеФИО(СокрЛП(Контрагент_Руководитель),3,1)					, "[Контрагент_РуководительДатП]");
	СписокПараметров.Вставить(15, Формат(СрокОплаты, "ДФ=dd.MM.yyyy")								, "[СрокОплаты]");
	СписокПараметров.Вставить(16, ?(Долг>0,Шаблон.ТекстДолга,"")									, "[ТекстДолга]");
	СписокПараметров.Вставить(17, Лев(СокрЛП(СрокОплатыЗДА),10)										, "[СрокОплатыЗДА]"); 
	СтрокаМесяц = "";
	Если МесяцСрокаОплатыЗДА = -1 Тогда
		СтрокаМесяц = "предыдущего периода";
	ИначеЕсли МесяцСрокаОплатыЗДА = 0 Тогда
		СтрокаМесяц = "текущего периода";
	Иначе
		СтрокаМесяц = "следующего периода";
	КонецЕсли;
	СписокПараметров.Вставить(18, СтрокаМесяц														, "[МесяцСрокаОплатыЗДА]"); 
	
	//+ счета 
	Если ТипЗнч(Реализация) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		СтрокаСчета2 = "";
		ТЗСчета = ПолучитьСчета(СсылкаНаОбъект.ДоговорКонтрагента, Реализация);
		Для Каждого СтрСчета из ТЗСчета Цикл
			СтрокаСчета2 = СтрокаСчета2 + "Счет № " + СтрСчета.Ссылка.Номер + ", ";
		КонецЦикла;
		СтрокаСчета2 = Лев(СтрокаСчета2, СтрДлина(СтрокаСчета2)-2);
		СписокПараметров.Вставить(19, СтрокаСчета2														, "[Счет]");
	Иначе
		СписокПараметров.Вставить(19, ""																, "[Счет]");
	КонецЕсли;	
	//- счета
	
	//+ адрес организации
	ОргАдрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(СсылкаНаОбъект.Организация,Перечисления.ТипыКонтактнойИнформации.Адрес,Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации)[0].Представление;
	ОргРеквизиты = "ИНН " + СсылкаНаОбъект.Организация.ИНН + " КПП " + СсылкаНаОбъект.Организация.КПП
	+ " р/с № " + СсылкаНаОбъект.Организация.ОсновнойБанковскийСчет.НомерСчета + " к/с № " + СсылкаНаОбъект.Организация.ОсновнойБанковскийСчет.Банк.КоррСчет
	+ Символы.ПС + СсылкаНаОбъект.Организация.ОсновнойБанковскийСчет.Банк.Наименование + " БИК " + СсылкаНаОбъект.Организация.ОсновнойБанковскийСчет.Банк.Код;
	
	СписокПараметров.Вставить(20, ОргАдрес																, "[АдресОрганизации]");
	СписокПараметров.Вставить(21, СсылкаНаОбъект.Организация.Наименование								, "[КраткоеНаименованиеОрганизации]"); 
	//- адрес организации
	
	СписокПараметров.Вставить(22, СсылкаНаОбъект.Контрагент.НаименованиеПолное							, "[КонтрагентНаименованиеПолное]");
	СписокПараметров.Вставить(23, СсылкаНаОбъект.Организация.НаименованиеПолное							, "[ОрганизацияНаименованиеПолное]");
	Результат = ОтветственныеЛицаБППовтИсп.ОтветственныеЛица(СсылкаНаОбъект.Организация, ТекущаяДата());
	СписокПараметров.Вставить(24, СокрЛП(Результат.РуководительПредставление)							, "[Руководитель]"); 
	Если ТипЗнч(Реализация) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		СписокПараметров.Вставить(25, Формат(Реализация.Дата, "ДФ='MMMM yyyy'")							, "[Период]");
	Иначе	
		СписокПараметров.Вставить(25, ""																, "[Период]"); 
	КонецЕсли;
	//Если Результат.Руководитель.Пол = Перечисления.ПолФизическогоЛица.Женский Тогда
	//	Пол = 2;
	//ИначеЕсли Результат.Руководитель.Пол = Перечисления.ПолФизическогоЛица.Мужской Тогда
	//	Пол = 1;
	//Иначе
	//	Пол = 0;
	//КонецЕсли;
	ДатПадежИнициалы = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(СклонениеФИО(СокрЛП(Контрагент_Руководитель),3,Пол));
	СписокПараметров.Вставить(26, СокрЛП(ДатПадежИнициалы)												, "[Контрагент_РуководительДатП_Инициалы]");
	СписокПараметров.Вставить(27, ОргРеквизиты															, "[РеквизитыОрганизации]");
	СписокПараметров.Вставить(28, Формат(ТекущаяДата()+5*24*60*60, "ДФ=dd.MM.yyyy")						, "[ТекущаяДата5]");
	
	Возврат СписокПараметров;
	
