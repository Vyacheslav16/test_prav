			Орг = "ООО ""БЕКАР-ЭКСПЛУАТАЦИЯ""";
		Иначе
			Орг = Стр.ЗДА.Организация.НаименованиеСокращенное;
		КонецЕсли;	
		
		Тело = Стр.Шаблон.Текст;
