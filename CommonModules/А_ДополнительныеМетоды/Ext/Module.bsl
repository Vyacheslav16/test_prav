
Функция ПолучитьПомеченныеНаУдаление(ПараметрыВыполнения) Экспорт
	
	Если ПараметрыВыполнения.Свойство("ТипМетаданных") И ПараметрыВыполнения.ТипМетаданных <> "" Тогда
		
		Запрос = Новый Запрос;
		
		Если ПараметрыВыполнения.Свойство("КоличествоОбъектов") И ПараметрыВыполнения.КоличествоОбъектов > 0 Тогда
			
			УсловиеПервые = " ПЕРВЫЕ " + СтрЗаменить(Строка(ПараметрыВыполнения.КоличествоОбъектов)," ","");
			
		Иначе
			
			УсловиеПервые = "";
			
		КонецЕсли;
		
		Если ПараметрыВыполнения.Свойство("Период") Тогда
			
			Если ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаНачала) Тогда
				
				Запрос.УстановитьПараметр("ДатаНач", ПараметрыВыполнения.Период.ДатаНачала);
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаОкончания) Тогда
				
				Запрос.УстановитьПараметр("ДатаКон", ПараметрыВыполнения.Период.ДатаОкончания);
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаНачала) И ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаОкончания) Тогда
				
				УсловиеПериод = " И т.Дата Между &ДатаНач И &ДатаКон";
				
			ИначеЕсли ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаНачала) Тогда
				
				УсловиеПериод = " И т.Дата >= &ДатаНач";
				
			ИначеЕсли ЗначениеЗаполнено(ПараметрыВыполнения.Период.ДатаОкончания) Тогда
				
				УсловиеПериод = " И т.Дата <= &ДатаКон";
				
			Иначе
				
				УсловиеПериод = "";
				
			КонецЕсли;
			
		КонецЕсли;
		
		Спс = СтрРазделить(ПараметрыВыполнения.ТипМетаданных, ",", Ложь);
		
		Для Каждого Стр Из Спс Цикл
			
			Если Запрос.Текст = "" Тогда
			
				Запрос.Текст = "ВЫБРАТЬ " + УсловиеПервые + "
				|	т.Ссылка КАК Ссылка
				|ИЗ
				|	" + Стр + " КАК т
				|ГДЕ
				|	т.ПометкаУдаления";
				
				Если СтрНайти(Стр, "Документ.") <> 0 Тогда
					
					Запрос.Текст = Запрос.Текст + УсловиеПериод;
					
				КонецЕсли;
				
			Иначе
				
				Запрос.Текст = Запрос.Текст + "
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ " + УсловиеПервые + "
				|	т.Ссылка
				|ИЗ
				|	" + Стр + " КАК т
				|ГДЕ
				|	т.ПометкаУдаления";
				
				Если СтрНайти(Стр, "Документ.") <> 0 Тогда
					
					Запрос.Текст = Запрос.Текст + УсловиеПериод;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Запрос.Текст = "" Тогда Возврат Неопределено; Иначе
			
			Рез = Запрос.Выполнить().Выгрузить();
		
			Возврат Рез.ВыгрузитьКолонку("Ссылка");
			
		КонецЕсли;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции

Процедура АР17_ОтправкаУведомлений() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ХозрасчетныйОстатки.СуммаОстаток КАК Остаток,
	               |	ХозрасчетныйОстатки.Субконто3 КАК Отгрузка,
	               |	ХозрасчетныйОстатки.Субконто3.Дата КАК ДатаОтгрузки,
	               |	ХозрасчетныйОстатки.Субконто3.СуммаДокумента КАК СуммаОтгрузки,
	               |	ХозрасчетныйОстатки.Организация КАК Организация,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0)
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК ОтсрочкаДней,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.Дата, ДЕНЬ, ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0))
	               |		ИНАЧЕ ХозрасчетныйОстатки.Субконто3.Дата
	               |	КОНЕЦ КАК ОтсрочкаДо,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.Дата, ДЕНЬ, ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0)), &Период, ДЕНЬ)
	               |		ИНАЧЕ РАЗНОСТЬДАТ(ХозрасчетныйОстатки.Субконто3.Дата, &Период, ДЕНЬ)
	               |	КОНЕЦ КАК ПросроченоДней,
	               |	ХозрасчетныйОстатки.Счет КАК Счет,
	               |	ХозрасчетныйОстатки.Субконто1 КАК Контрагент,
	               |	ХозрасчетныйОстатки.Субконто2 КАК ДоговорКонтрагента,
	               |	ХозрасчетныйОстатки.Субконто3 КАК Субконто3,
	               |	ХозрасчетныйОстатки.Валюта КАК Валюта,
	               |	ХозрасчетныйОстатки.Подразделение КАК Подразделение,
	               |	ХозрасчетныйОстатки.СуммаОстаток КАК СуммаОстаток,
	               |	ХозрасчетныйОстатки.Субконто3.СуммаДокумента - ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстаток, 0) КАК СуммаОплачено,
	               |	ХозрасчетныйОстатки.СуммаОстатокДт КАК СуммаОстатокДт,
	               |	ХозрасчетныйОстатки.СуммаОстатокКт КАК СуммаОстатокКт,
	               |	АР17_ЗаключениеДоговораАренды.ИК КАК ИК,
	               |	АР17_ЗаключениеДоговораАренды.ДатаАктаПриемаПередачи КАК ДатаАктаПриемаПередачи,
	               |	ВЫБОР
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = 0
	               |			ТОГДА ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты)
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = 1
	               |			ТОГДА ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты + 1)
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = -1
	               |			ТОГДА ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), МЕСЯЦ, -1), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты)
	               |	КОНЕЦ КАК СрокОплаты,
	               |	РеализацияТоваровУслугУслуги.Номенклатура КАК Услуга,
	               |	РеализацияТоваровУслугУслуги.бит_Сумма КАК Сумма,
	               |	АР17_ЗаключениеДоговораАренды.СуммаЗалога КАК СуммаЗалога,
	               |	АР17_ЗаключениеДоговораАренды.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ Данные
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, , , ) КАК ХозрасчетныйОстатки
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Д_СчетаУчетаПоОрганизациям КАК Д_СчетаУчетаПоОрганизациям
	               |		ПО (ХозрасчетныйОстатки.Счет = Д_СчетаУчетаПоОрганизациям.СчетРасчетаСПокупателямиПоАС
	               |				ИЛИ ХозрасчетныйОстатки.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыСПокупателями))
	               |			И ХозрасчетныйОстатки.Организация = Д_СчетаУчетаПоОрганизациям.Организация
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |		ПО ХозрасчетныйОстатки.Субконто2 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
	               |		ПО ХозрасчетныйОстатки.Субконто3 = РеализацияТоваровУслугУслуги.Ссылка
	               |ГДЕ
	               |	ХозрасчетныйОстатки.СуммаОстаток > 0
	               |	И НЕ РеализацияТоваровУслугУслуги.Сумма ЕСТЬ NULL
	               |	И ВЫБОР
	               |			КОГДА &ИК = ЗНАЧЕНИЕ(Справочник.АР_объектыАренды.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_ЗаключениеДоговораАренды.ИК = &ИК
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |					ИЛИ &Контрагент = НЕОПРЕДЕЛЕНО
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент
	               |		КОНЕЦ
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ХозрасчетныйОстатки.СуммаОстаток,
	               |	ХозрасчетныйОстатки.Субконто3,
	               |	ХозрасчетныйОстатки.Субконто3.Дата,
	               |	ХозрасчетныйОстатки.Субконто3.СуммаДокумента,
	               |	ХозрасчетныйОстатки.Организация,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0)
	               |		ИНАЧЕ 0
	               |	КОНЕЦ,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.Дата, ДЕНЬ, ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0))
	               |		ИНАЧЕ ХозрасчетныйОстатки.Субконто3.Дата
	               |	КОНЕЦ,
	               |	ВЫБОР
	               |		КОГДА ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.Д_ТипОплаты = ЗНАЧЕНИЕ(Перечисление.Д_ТипОплаты.ОтсрочкаПлатежа)
	               |			ТОГДА РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.Дата, ДЕНЬ, ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3.ДоговорКонтрагента.СрокОплаты, 0)), &Период, ДЕНЬ)
	               |		ИНАЧЕ РАЗНОСТЬДАТ(ХозрасчетныйОстатки.Субконто3.Дата, &Период, ДЕНЬ)
	               |	КОНЕЦ,
	               |	ХозрасчетныйОстатки.Счет,
	               |	ХозрасчетныйОстатки.Субконто1,
	               |	ХозрасчетныйОстатки.Субконто2,
	               |	ХозрасчетныйОстатки.Субконто3,
	               |	ХозрасчетныйОстатки.Валюта,
	               |	ХозрасчетныйОстатки.Подразделение,
	               |	ХозрасчетныйОстатки.СуммаОстаток,
	               |	ХозрасчетныйОстатки.Субконто3.СуммаДокумента - ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстаток, 0),
	               |	ХозрасчетныйОстатки.СуммаОстатокДт,
	               |	ХозрасчетныйОстатки.СуммаОстатокКт,
	               |	АР17_ЗаключениеДоговораАренды.ИК,
	               |	АР17_ЗаключениеДоговораАренды.ДатаАктаПриемаПередачи,
	               |	ВЫБОР
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = 0
	               |			ТОГДА ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты)
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = 1
	               |			ТОГДА ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты + 1)
	               |		КОГДА АР17_ЗаключениеДоговораАренды.МесяцСрокаОплаты = -1
	               |			ТОГДА ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ХозрасчетныйОстатки.Субконто3.Дата, МЕСЯЦ), МЕСЯЦ, -1), ДЕНЬ, АР17_ЗаключениеДоговораАренды.СрокОплаты)
	               |	КОНЕЦ,
	               |	РеализацияТоваровУслугАгентскиеУслуги.Номенклатура,
	               |	РеализацияТоваровУслугАгентскиеУслуги.бит_Сумма,
	               |	АР17_ЗаключениеДоговораАренды.СуммаЗалога,
	               |	АР17_ЗаключениеДоговораАренды.Ссылка
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, , , ) КАК ХозрасчетныйОстатки
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Д_СчетаУчетаПоОрганизациям КАК Д_СчетаУчетаПоОрганизациям
	               |		ПО (ХозрасчетныйОстатки.Счет = Д_СчетаУчетаПоОрганизациям.СчетРасчетаСПокупателямиПоАС
	               |				ИЛИ ХозрасчетныйОстатки.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыСПокупателями))
	               |			И ХозрасчетныйОстатки.Организация = Д_СчетаУчетаПоОрганизациям.Организация
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |		ПО ХозрасчетныйОстатки.Субконто2 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК РеализацияТоваровУслугАгентскиеУслуги
	               |		ПО ХозрасчетныйОстатки.Субконто3 = РеализацияТоваровУслугАгентскиеУслуги.Ссылка
	               |ГДЕ
	               |	ХозрасчетныйОстатки.СуммаОстаток > 0
	               |	И НЕ РеализацияТоваровУслугАгентскиеУслуги.Сумма ЕСТЬ NULL
	               |	И ВЫБОР
	               |			КОГДА &ИК = ЗНАЧЕНИЕ(Справочник.АР_объектыАренды.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_ЗаключениеДоговораАренды.ИК = &ИК
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |					ИЛИ &Контрагент = НЕОПРЕДЕЛЕНО
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент
	               |		КОНЕЦ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Данные.Отгрузка КАК Отгрузка,
	               |	Данные.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	Данные.ДатаОтгрузки КАК ДатаОтгрузки
	               |ПОМЕСТИТЬ Договора
	               |ИЗ
	               |	Данные КАК Данные
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
