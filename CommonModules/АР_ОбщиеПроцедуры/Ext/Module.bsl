Процедура ПроведениеРегДока(Договор, Дата)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ПроведениеДоговораАренды.Ссылка
		|ИЗ
		|	Документ.АР17_ПроведениеДоговораАренды КАК АР17_ПроведениеДоговораАренды
		|ГДЕ
		|	АР17_ПроведениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И АР17_ПроведениеДоговораАренды.Дата = &Дата";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		
		РегДок = РЗ.Ссылка.ПолучитьОбъект();
		РегДок.Записать(РежимЗаписиДокумента.Проведение);
		
	КонецЕсли;
	
