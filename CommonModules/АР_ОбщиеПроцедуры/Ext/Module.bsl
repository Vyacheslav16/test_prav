Функция ВыделитьНомер(СтрокаНомера) 
    Номер ="";
    Для Сч=1 По СтрДлина(СтрокаНомера) Цикл
        ПозСимвол = Сред(СтрокаНомера,Сч,1);
        Если КодСимвола(ПозСимвол)>48 И КодСимвола(ПозСимвол)<58 Тогда             
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Номер = Сред(СтрокаНомера,Сч,СтрДлина(СтрокаНомера)- Сч +1);
    Возврат Номер;
КонецФункции

Функция ПолучитьНомерОтчеты(СтрокаНомера) Экспорт

	Номер = СокрЛП(СтрокаНомера);
	НовыйНомер = "";
	Пока Прав(Номер,1)<>"/" Цикл
		Если  Номер<>"" Тогда
			НовыйНомер = Прав(Номер,1) + НовыйНомер;
		 	Номер = Лев(Номер,СтрДлина(Номер)-1);
		Иначе
			Возврат НовыйНомер;		
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат НовыйНомер;
	
