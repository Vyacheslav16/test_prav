Процедура АР_РасчетыПоДоговорамОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		Если ПроверкаНаличияДоговораАрендыПоДоговоруКонтрагента(Источник.ДоговорКонтрагента) Тогда
		//Если ТипЗнч(Источник.СчетНаОплатуПокупателю) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			
			ЗаписьДвиженийРасчетовПоДоговорам(Источник, Источник.Организация, Источник.Контрагент, 
			Источник.ДоговорКонтрагента, НачалоМесяца(Источник.Дата), Источник.Дата, Источник.СуммаДокумента, ВидДвиженияНакопления.Приход);
			
			ПроведениеРегДока(Источник.ДоговорКонтрагента, НачалоМесяца(Источник.Дата));
			
		КонецЕсли;
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПриходныйКассовыйОрдер") Тогда	
		
		Если ПроверкаНаличияДоговораАрендыПоДоговоруКонтрагента(Источник.ДоговорКонтрагента) Тогда
			
			СуммаДокумента = ОпределеитьСуммуДокумента(Источник);
			
			Если СуммаДокумента > 0 Тогда
				
				ЗаписьДвиженийРасчетовПоДоговорам(Источник, Источник.Организация, Источник.Контрагент, Источник.ДоговорКонтрагента, 
				НачалоМесяца(Источник.Дата), Источник.Дата, СуммаДокумента, ВидДвиженияНакопления.Расход);
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеНаРасчетныйСчет") Тогда
		
		Для каждого СтрДвижения Из Источник.Движения.Хозрасчетный Цикл    
			
			Если ПроверкаНаличияДоговораАрендыПоДоговоруКонтрагента(СтрДвижения.СубконтоКт.Договоры) Тогда
				КодКор = СтрДвижения.СчетКт.Код;
				Если СтрДвижения.СчетДт.Код = "51" И (КодКор = "62.01" Или КодКор = "62.02" Или КодКор = "76.06" Или КодКор = "76.09") Тогда
					
					СуммаДокумента = СтрДвижения.Сумма;
					
					Если СуммаДокумента > 0 Тогда  
						
