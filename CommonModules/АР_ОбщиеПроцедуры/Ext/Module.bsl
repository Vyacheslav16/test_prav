Процедура ЗаписьДвиженийРасчетовПоДоговорам(Источник, Организация, Контрагент, ДоговорКонтрагента, Месяц, Период, Сумма, ВидДвижения)
	
	Источник.Движения.АР_РасчетыПоДоговорам.Записывать = Истина;
	
	НСтр = Источник.Движения.АР_РасчетыПоДоговорам.Добавить();
	
	НСтр.ВидДвижения = ВидДвижения;
	
	НСтр.Период = Период; 
	
	НСтр.ДоговорКонтрагента = ДоговорКонтрагента;
	НСтр.Организация = Организация;
	НСтр.Контрагент = Контрагент;
	НСтр.Месяц = Месяц;
	
	НСтр.Сумма = Сумма;
	
	Источник.Движения.Записать();

КонецПроцедуры

Функция ОпределеитьСуммуДокумента(Источник)
	
	МассивСчетовРасчетов = Новый Массив;
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателями);
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами);
	МассивСчетовРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПокупателямиИЗаказчиками);
	
	СуммаДокумента = 0;
	
	Для Каждого Стр Из Источник.РасшифровкаПлатежа Цикл
		
		Если МассивСчетовРасчетов.Найти(Стр.СчетУчетаРасчетовСКонтрагентом) <> Неопределено Тогда
			СуммаДокумента = СуммаДокумента + Стр.СуммаПлатежа;
		КонецЕсли;
				
	КонецЦикла;
	
	Возврат СуммаДокумента;
	
