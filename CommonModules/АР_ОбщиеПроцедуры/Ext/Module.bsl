					КодКор = СтрДвижения.СчетДт.Код;
					Если СтрДвижения.СчетКт.Код = "51" И (КодКор = "62.01" Или КодКор = "62.02" Или КодКор = "76.06" Или КодКор = "76.09")  Тогда
					//Если СтрДвижения.СчетКт.Код = "51" Тогда
						
