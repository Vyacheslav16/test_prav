Функция ПолучитьДанныеИзРегистра(ДоговорКонтрагента,Номенклатура,ОкончаниеПериода)
	
	Запись = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_СтавкиСрезПоследних.ДатаНачалаАренды,
	               |	АР_СтавкиСрезПоследних.ДатаОкончанияАренды,
	               |	АР_СтавкиСрезПоследних.Сумма
	               |ИЗ
	               |	РегистрСведений.АР_Ставки.СрезПоследних(
	               |			&Дата,
	               |			Договор = &Договор
	               |				И Услуга = &Услуга) КАК АР_СтавкиСрезПоследних";
				   
	Запрос.УстановитьПараметр("Дата",ОкончаниеПериода);
	Запрос.УстановитьПараметр("Договор",ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Услуга",Номенклатура);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Запись.Вставить("ДатаНачалаАренды", Выборка.ДатаНачалаАренды);
	Запись.Вставить("ДатаОкончанияАренды", Выборка.ДатаОкончанияАренды);

	Возврат Запись;
	
