		|	УслугиПоВидам КАК УслугиПоВидам";
	
	Запрос.УстановитьПараметр("Дата", НачалоМесяца(ТекущаяДата()));
	Запрос.УстановитьПараметр("ДоговорАренды", Объект.Ссылка);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
	
		СуммаПоДоговоруВТекущемМесяце =  РЗ.СуммаПоДоговору;
		
		СтоимостьКУВТекущемМесяце = РЗ.КУ;
