Функция ЭтоРеквизитПостояннойЧасти(ИмяРеквизита) 
	
	Возврат Макс(Найти(ИмяРеквизита,"ОбеспечительныйПлатеж"),Найти(ИмяРеквизита,"ПеременнаяАренднаяПлата"),Найти(ИмяРеквизита,"ФиксированнаяАренда")) <> 0;
	
КонецФункции

Функция НайтиРеквизитНоменклатуру(Объект,ИмяРеквизита)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга КАК Услуга
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты
	|ГДЕ
	|	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга.Наименование ПОДОБНО &параметр
	|	И АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("ССылка", Объект);
	Запрос.УстановитьПараметр("параметр", "%" + Объект + "%");
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		НоменклатураПоиска = Выборка.Услуга;
	Иначе	
		Если Найти(ИмяРеквизита,"Обеспечительный") <> 0 Тогда
			НоменклатураПоиска = Справочники.Номенклатура.НайтиПоНаименованию("Обеспечительный платеж");
		ИначеЕсли Найти(ИмяРеквизита,"Переменная") <> 0 Тогда
			НоменклатураПоиска = Справочники.Номенклатура.НайтиПоКоду("00-00000027");
		ИначеЕсли Найти(ИмяРеквизита,"Фиксированная") <> 0 Тогда
			НоменклатураПоиска = Справочники.Номенклатура.НайтиПоНаименованию("Фиксированная аренда");
		КонецЕсли;
	КонецЕсли;
	
	Возврат НоменклатураПоиска;
	
КонецФункции


Функция ПолучитьРеквизитПостоянноЧасти(Объект,ИмяРеквизита)
	
	Если Найти(ИмяРеквизита,"ОбеспечительныйПлатеж") <> 0 Тогда
		
		ЧтоИщем = стрЗаменить(ИмяРеквизита,"ОбеспечительныйПлатеж","");
		НоменклатураПоиска = НайтиРеквизитНоменклатуру(Объект,"Обеспечительный");
		
	ИначеЕсли Найти(ИмяРеквизита,"ПеременнаяАренднаяПлата") <> 0 Тогда
		
		ЧтоИщем = стрЗаменить(ИмяРеквизита,"ПеременнаяАренднаяПлата","");
		НоменклатураПоиска = НайтиРеквизитНоменклатуру(Объект,"Переменная");
		
	ИначеЕсли Найти(ИмяРеквизита,"ФиксированнаяАренда") <> 0 Тогда
		
		ЧтоИщем = стрЗаменить(ИмяРеквизита,"ФиксированнаяАренда","");
		НоменклатураПоиска = НайтиРеквизитНоменклатуру(Объект,"Фиксированная");
		
	КонецЕсли;
		
	Если НЕ (ЗначениеЗаполнено(ЧтоИщем) и  ЗначениеЗаполнено(НоменклатураПоиска)) Тогда
	 	Возврат "";
	КонецЕсли;
	
	Если Чтоищем = "Услуга" Тогда
		Возврат НоменклатураПоиска;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Сумма КАК Сумма,
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга.СтавкаНДС,
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты
	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка = &Ссылка
	               |	И АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга = &Услуга";
	
	Запрос.УстановитьПараметр("Ссылка",Объект);
	Запрос.УстановитьПараметр("Услуга",НоменклатураПоиска);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		Если ЧтоИщем = "НДС" Тогда
			Коэф = 0;
			Если Выборка.УслугаСтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда
				Коэф = 0.18;
			ИначеЕсли Выборка.УслугаСтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
				Коэф = 0.2;
			ИначеЕсли Выборка.УслугаСтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
				Коэф = 0.1;
			КонецЕсли;	
				
			
			Возврат Выборка.Сумма * Коэф;
			
		ИначеЕсли ЧтоИщем = "Стоимость" Тогда	
			Возврат Выборка.Сумма;
		КонецЕсли;
		
	Иначе			
		Возврат "";
	КонецЕсли;
	
	
КонецФункции

