Функция ПроверкаНаличияДоговораАрендыПоДоговоруКонтрагента(Договор)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАренды.Ссылка
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента
	|	И АР17_ЗаключениеДоговораАренды.Проведен";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат Истина;
	Иначе	
		Возврат Ложь;
	КонецЕсли;
	
