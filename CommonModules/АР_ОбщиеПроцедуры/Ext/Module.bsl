Функция ПолучитьНомер(Источник)
	
	ДлинаНомера = СтрДлина(СокрЛП(Источник.ДокументОснование.Номер));
	ТипИсточника = ТипЗнч(Источник);
	Письмо = "";
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.АР17_ДополнительноеСоглашение") Тогда
		ТипИсточника = "АР17_ДополнительноеСоглашение";
		Если Источник.ВидОперации = Перечисления.АР_ВидыОперацийДополнительноеСоглашение.Письмо Тогда
			Письмо = "Письмо";
		Иначе
			Письмо = "Доп";
		КонецЕсли;	
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.АР17_РасторжениеДоговораАренды") Тогда
		ТипИсточника = "АР17_РасторжениеДоговораАренды";
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.АР_АктПриемаПередачиПомещенияВАренду") Тогда
		ТипИсточника = "АР_АктПриемаПередачиПомещенияВАренду";
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.АР_АктПриемаВозвратаАрендуемогоПомещения") Тогда
		ТипИсточника = "АР_АктПриемаВозвратаАрендуемогоПомещения";
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.АР_АктДоступа") Тогда
		ТипИсточника = "АР_АктДоступа";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_Док.Номер КАК Номер
	               |ИЗ
	               |	Документ."+ТипИсточника+" КАК АР17_Док
	               |ГДЕ
	               |	АР17_Док.ДоговорКонтрагента = &ДоговорКонтрагента
				   |	И ПОДСТРОКА(АР17_Док.Номер, 1, "+ДлинаНомера+") = &Префикс";
					Если Письмо = "Письмо" Тогда
		            	Запрос.Текст = Запрос.Текст + " и АР17_Док.ВидОперации = ЗНАЧЕНИЕ(Перечисление.АР_ВидыОперацийДополнительноеСоглашение.Письмо)";
					ИначеЕсли Письмо = "Доп" Тогда 
		            	Запрос.Текст = Запрос.Текст + " и АР17_Док.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.АР_ВидыОперацийДополнительноеСоглашение.Письмо)";
					Иначе
						//
					КонецЕсли;
					Запрос.Текст = Запрос.Текст + "
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Номер";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Источник.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Префикс",СокрЛП(Источник.ДокументОснование.Номер));

	Выгрузка = Запрос.Выполнить().Выгрузить();
	Кол = Выгрузка.Количество();
	Если Кол > 0 Тогда
		Возврат СокрЛП(Выгрузка[Кол-1].Номер);
	Иначе
		Возврат "1";
	КонецЕсли;	
	
