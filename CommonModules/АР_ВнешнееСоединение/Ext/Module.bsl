Процедура АР_ПриУстановкеНовогоНомераПриУстановкеНовогоНомера(Источник, СтандартнаяОбработка, Префикс) Экспорт
	
	Возврат;
	
	Если Источник.Дата >= Дата('20190101') Тогда
		
	Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.СчетНаОплатуПокупателю") Тогда //и Источник.Организация.Код = "00-000086"
		Если Источник.Организация.Код = "000000159" Тогда Возврат; КонецЕсли;	
		Префикс = СтрЗаменить(Префикс,"0","");
	КонецЕсли;
		
	ТипИсточника = ТипЗнч(Источник.Ссылка);
	Если ТипИсточника = Тип("ДокументСсылка.ОтчетКомитентуОПродажах") Тогда
		НомерТипа = 1;
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		НомерТипа = 2;
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
		НомерТипа = 4;
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
		НомерТипа = 5;
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.АР17_СчетНаАренду") Тогда
		НомерТипа = 6;
	ИначеЕсли ТипИсточника = Тип("ДокументСсылка.СчетНаОплатуПокупателю") Тогда
		НомерТипа = 7;
	Иначе
		НомерТипа = 0;
	КонецЕсли;
	
	ВидСчетаФактуры = Новый СписокЗначений;
	ВидСчетаФактуры.Добавить(Перечисления.ВидСчетаФактурыВыставленного.НаАванс);
	ВидСчетаФактуры.Добавить(Перечисления.ВидСчетаФактурыВыставленного.НаАвансКомитента);
	ВидСчетаФактуры.Добавить(Перечисления.ВидСчетаФактурыВыставленного.НаАвансКомитентаНаЗакупку);
	
	КодыОрганизаций = Новый Массив;
	КодыОрганизаций.Добавить("000000143");
	КодыОрганизаций.Добавить("000010189");
	КодыОрганизаций.Добавить("00-000041");
	КодыОрганизаций.Добавить("00-000042");
	КодыОрганизаций.Добавить("000000172");
	КодыОрганизаций.Добавить("000006893");
	КодыОрганизаций.Добавить("00-000028");
	КодыОрганизаций.Добавить("00-000019");
	КодыОрганизаций.Добавить("000014386");
	КодыОрганизаций.Добавить("000000151");
	КодыОрганизаций.Добавить("00-000017");
	КодыОрганизаций.Добавить("000009399");
	КодыОрганизаций.Добавить("000014892");
	КодыОрганизаций.Добавить("00-000036");
	КодыОрганизаций.Добавить("00-000006");
	КодыОрганизаций.Добавить("000000142");
	КодыОрганизаций.Добавить("000000152");
	КодыОрганизаций.Добавить("00-000031");	
	КодыОрганизаций.Добавить("00-000051");
	КодыОрганизаций.Добавить("00-000062");
	КодыОрганизаций.Добавить("00-000057");
	КодыОрганизаций.Добавить("00-000063");
	КодыОрганизаций.Добавить("00-000060");
	КодыОрганизаций.Добавить("00-000064");
	КодыОрганизаций.Добавить("00-000057");
	КодыОрганизаций.Добавить("000014377");
	КодыОрганизаций.Добавить("00-000047");
	КодыОрганизаций.Добавить("000000154");
	
	Если 
		КодыОрганизаций.Найти(Источник.Организация.Код) <> Неопределено 
		ИЛИ (Источник.ДополнительныеСвойства.Свойство("бит_бк_УстановитьНомер") И Источник.ДополнительныеСвойства.бит_бк_УстановитьНомер)
		ИЛИ (Источник.Дата >= Дата('20210101') И Источник.Организация.Код <> "000000159")
	Тогда СтандартнаяОбработка = Ложь;		
	КонецЕсли;
		
	Если СтандартнаяОбработка И НомерТипа <> 0 И Префикс = "" Тогда
		
		УстановитьПрефикс(Источник, Префикс, Истина, Истина);
		
	КонецЕсли;
	
	Если НомерТипа = 5 И ВидСчетаФактуры.НайтиПоЗначению(Источник.ВидСчетаФактуры) <> Неопределено Тогда
		
		СтандартнаяОбработка = Истина;
		УстановитьПрефикс(Источник, Лев(Префикс,5), Истина, Истина);
		
	КонецЕсли;
	
	//Если Источник.Организация.Код <> "00-000086" Тогда
	//	СтандартнаяОбработка = Истина;	
	//КонецЕсли;	
	
	Если СтандартнаяОбработка Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если НомерТипа = 1 Тогда Префикс = Лев(Префикс,2) + "-"; КонецЕсли;
	Если НомерТипа = 2 ИЛИ НомерТипа = 5 ИЛИ НомерТипа = 6 Тогда Префикс = ""; КонецЕсли;
	Если НомерТипа > 1 и НомерТипа <> 6 и НомерТипа <> 7 Тогда УстановитьПрефикс(Источник, Префикс, Ложь, Истина); КонецЕсли;
	Если НомерТипа = 6 или НомерТипа = 7 Тогда  Префикс = ""; УстановитьПрефикс(Источник, Префикс, Истина, Истина); КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Префикс",			Префикс); 
	Запрос.УстановитьПараметр("ДатаДок",			Источник.Дата);
	Запрос.УстановитьПараметр("СтрМесяц",			"%-" + Формат(Источник.Дата,"ДФ=ММ") + "/%");
	Запрос.УстановитьПараметр("СтрДень",			"%/" + Формат(Источник.Дата,"ДФ=дд") + "/%");
	Запрос.УстановитьПараметр("ВидСчетаФактуры",	ВидСчетаФактуры);
	
	Если НомерТипа = 1 Тогда ДлПослеПрефикса = 9; ИначеЕсли НомерТипа = 6 или НомерТипа = 7 Тогда ДлПослеПрефикса = 12; Иначе ДлПослеПрефикса = 10; КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Док.Ссылка, ПОДСТРОКА(Док.Номер, 4, " + ДлПослеПрефикса + ") КАК Номер
	|ИЗ
	|	Документ.";
	
	Если НомерТипа = 1 Тогда Запрос.Текст = Запрос.Текст + "ОтчетКомитентуОПродажах"; КонецЕсли;
	Если НомерТипа = 2 Тогда Запрос.Текст = Запрос.Текст + "РеализацияТоваровУслуг"; КонецЕсли;
	Если НомерТипа = 4 Тогда Запрос.Текст = Запрос.Текст + "АР17_НачислениеАренднойПлаты"; КонецЕсли;
	Если НомерТипа = 5 Тогда Запрос.Текст = Запрос.Текст + "СчетФактураВыданный"; КонецЕсли;
	Если НомерТипа = 6 Тогда Запрос.Текст = Запрос.Текст + "АР17_СчетНаАренду"; КонецЕсли;
	Если НомерТипа = 7 Тогда Запрос.Текст = Запрос.Текст + "СчетНаОплатуПокупателю"; КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + " КАК Док
	|ГДЕ
	|	ПОДСТРОКА(Док.Номер, 1, 3) = &Префикс
	|	И Док.Номер ПОДОБНО &СтрМесяц
	|	И Док.Номер ПОДОБНО &СтрДень
	|	И Док.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаДок, МЕСЯЦ) И КОНЕЦПЕРИОДА(&ДатаДок, МЕСЯЦ)";
	
	Если НомерТипа = 6 или НомерТипа = 7 Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПОДСТРОКА(Док.Номер, 1, 3) = &Префикс", "ПОДСТРОКА(Док.Номер, 1, 5) = &Префикс");
		
	КонецЕсли;
	
	Если НомерТипа = 5 Тогда
		
		Запрос.Текст = Запрос.Текст + " 
		|	И НЕ Док.ВидСчетаФактуры В (&ВидСчетаФактуры)";
		
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + "
	|УПОРЯДОЧИТЬ ПО
	|	Док.Номер УБЫВ";
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Если Рез.Следующий() Тогда
		
		Если НомерТипа = 1 Тогда ДлПрав = 3; Иначе ДлПрав = 4; КонецЕсли;
		
		ПоследнийНомерСтрокой = Прав(Рез.Номер,ДлПрав);
		ПоследнийНомерЧислом = Число(ПоследнийНомерСтрокой) + 1;
		ПоследнийНомерСтрокой = СтрЗаменить(Строка(ПоследнийНомерЧислом)," ","");
		Пока СтрДлина(ПоследнийНомерСтрокой) < ДлПрав Цикл
			ПоследнийНомерСтрокой = "0" + ПоследнийНомерСтрокой;
		КонецЦикла;
		
	Иначе
		
		Если НомерТипа = 1 Тогда ПоследнийНомерСтрокой = "001"; ИначеЕсли НомерТипа = 6 Тогда ПоследнийНомерСтрокой = "0001"; Иначе ПоследнийНомерСтрокой = "0001"; КонецЕсли;
		
	КонецЕсли;
	
	Источник.Номер = Префикс + Формат(Источник.Дата, "ДФ=ММ") + "/" + Формат(Источник.Дата, "ДФ=дд") + "/" + ПоследнийНомерСтрокой;
	
	Иначе
	
		АР_ПриУстановкеНовогоНомераПриУстановкеНовогоНомераСтарая(Источник, СтандартнаяОбработка, Префикс);
		
	КонецЕсли;
	
	ЗаписьЖурналаРегистрации(Источник.Номер,,,Источник.Номер);
	
КонецПроцедуры

Процедура УстановитьПрефикс(Источник, Префикс, УстановитьПрефиксИнформационнойБазы, УстановитьПрефиксОрганизации)
	
	ПрефиксИнформационнойБазы = "";
	ПрефиксОрганизации        = "";
	
	Если УстановитьПрефиксИнформационнойБазы Тогда
		
		ПерепрефиксацияОбъектов.ПриОпределенииПрефиксаИнформационнойБазы(ПрефиксИнформационнойБазы);
		
		ДополнитьСтрокуНулямиСлева(ПрефиксИнформационнойБазы, 2);
	КонецЕсли;
	
	Если УстановитьПрефиксОрганизации Тогда
		
		Если РеквизитОрганизацияДоступен(Источник) Тогда
			
			ПрефиксацияОбъектовСобытия.ПриОпределенииПрефиксаОрганизации(
				Источник[ИмяРеквизитаОрганизация(Источник.Метаданные())], ПрефиксОрганизации);
			// Если задана пустая ссылка на организацию.
			Если ПрефиксОрганизации = Ложь Тогда
				
				ПрефиксОрганизации = "";
				
			КонецЕсли;
			
		КонецЕсли;
		
		ДополнитьСтрокуНулямиСлева(ПрефиксОрганизации, 2);
	КонецЕсли;
	
	ШаблонПрефикса = "[ОР][ИБ]-[Префикс]";
	ШаблонПрефикса = СтрЗаменить(ШаблонПрефикса, "[ОР]", ПрефиксОрганизации);
	ШаблонПрефикса = СтрЗаменить(ШаблонПрефикса, "[ИБ]", ПрефиксИнформационнойБазы);
	ШаблонПрефикса = СтрЗаменить(ШаблонПрефикса, "[Префикс]", Префикс);
	
	Префикс = ШаблонПрефикса; //-са
	
КонецПроцедуры

 Процедура АР_ПриУстановкеНовогоНомераПриУстановкеНовогоНомераСтарая(Источник, СтандартнаяОбработка, Префикс) Экспорт
	
	Если (Источник.Организация.Код = "000000143") или (Источник.Организация.Код = "000010189")
		или (Источник.Организация.Код = "00-000041") или (Источник.Организация.Код = "00-000042")
		//bt_sidn_20170217_N
		ИЛИ (Источник.ДополнительныеСвойства.Свойство("бит_бк_УстановитьНомер") И Источник.ДополнительныеСвойства.бит_бк_УстановитьНомер)
		//bt_sidn_20170217_K
		//или (Источник.Организация.Код = "000000142") 
		Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если ТипЗнч(Источник) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
			или ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг")
			или ТипЗнч(Источник) = Тип("ДокументСсылка.ОтчетКомитентуОПродажах") 
			или ТипЗнч(Источник) = Тип("ДокументОбъект.ОтчетКомитентуОПродажах") 
			или ТипЗнч(Источник) = Тип("ДокументСсылка.СчетФактураВыданный") 
			или ТипЗнч(Источник) = Тип("ДокументОбъект.СчетФактураВыданный")
			// + NAI Becar Комментирование Смирнов А.А. от 24.11.2016 10:17
			или ТипЗнч(Источник) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") 
			или ТипЗнч(Источник) = Тип("ДокументОбъект.АР17_НачислениеАренднойПлаты") 
			// - NAI Becar Комментирование Смирнов А.А.
			Тогда
			
			Если ТипЗнч(Источник) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
				или ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") 
				Тогда
					Префикс = "";
					УстановитьПрефикс(Источник, Префикс, Истина, Истина);
					
					Запрос = Новый Запрос;
					Запрос.Текст = "ВЫБРАТЬ
					               |	РеализацияТоваровУслуг.Ссылка,
					               |	ПОДСТРОКА(РеализацияТоваровУслуг.Номер, 6, 8) КАК Номер
					               |ИЗ
					               |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
					               |ГДЕ
					               |	ПОДСТРОКА(РеализацияТоваровУслуг.Номер, 1, 5) = &Префикс
					               |	И РеализацияТоваровУслуг.Номер ПОДОБНО &СтрМесяц
					               |	И МЕСЯЦ(РеализацияТоваровУслуг.Дата) = &месяц
					               |	И ГОД(РеализацияТоваровУслуг.Дата) = &год
					               |
					               |УПОРЯДОЧИТЬ ПО
					               |	РеализацияТоваровУслуг.Номер УБЫВ";
								   
					Запрос.УстановитьПараметр("Префикс",Префикс); 
					Запрос.УстановитьПараметр("месяц",месяц(Источник.Дата));
					Запрос.УстановитьПараметр("год",Год(Источник.Дата));
					//Запрос.УстановитьПараметр("Символ","%/%");
					Запрос.УстановитьПараметр("СтрМесяц","%/"+Формат(Источник.Дата,"ДФ=ММ")+"%");
					
					Выгрузка = Запрос.Выполнить().Выгрузить();
					Выгрузка.Колонки.Добавить("НомерЧисло",Новый ОписаниеТипов("Число"));
					Для Каждого Стр Из Выгрузка Цикл
						Если Найти(Стр.Номер,"/") > 0 Тогда 
							Стр.Номер = Лев(Стр.Номер,Найти(Стр.Номер,"/")-1);
						КонецЕсли;
						Пока Лев(Стр.Номер,1) = "0" или Лев(Стр.Номер,1)= "-" Цикл
							Стр.Номер = Сред(Стр.Номер,2);
						КонецЦикла;
						Стр.НомерЧисло = Число(Стр.Номер);
					КонецЦикла;	
					
					Выгрузка.Сортировать("НомерЧисло УБЫВ");
					
					//Рез = Запрос.Выполнить().Выбрать();
					//Если Рез.Количество() = 0 Тогда
					Если Выгрузка.Количество() = 0 Тогда 
						НовыйНомер = Префикс + "00001" + "/" + Формат(Источник.Дата, "ДФ=ММ");
					Иначе	
						//Пока Рез.Следующий() Цикл 
						Для Каждого Стр Из Выгрузка Цикл
							Попытка 
								Ном = Число(Стр.Номер) + 1;
								Пока СтрДлина(Ном) < 5 Цикл
									Ном = "0" + Ном;
								КонецЦикла;	
								НовыйНомер = Префикс + СтрЗаменить(Ном,Символы.НПП,"") + "/" + Формат(Источник.Дата, "ДФ=ММ");
							Прервать; 
							Исключение 
							КонецПопытки;	
						КонецЦикла;	
					КонецЕсли; 				   
			
			// + NAI Becar Комментирование Смирнов А.А. от 24.11.2016 13:39
			ИначеЕсли ТипЗнч(Источник) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") 
				или ТипЗнч(Источник) = Тип("ДокументОбъект.АР17_НачислениеАренднойПлаты")
				Тогда
					УстановитьПрефикс(Источник, Префикс, Истина, Истина);
				//Префикс = Источник.Организация.Префикс;
				
					Запрос = Новый Запрос;
					Запрос.Текст = "ВЫБРАТЬ
					               |	АР17_НачислениеАренднойПлаты.Ссылка,
					               |	ПОДСТРОКА(АР17_НачислениеАренднойПлаты.Номер, 6, 8) КАК Номер
					               |ИЗ
					               |	Документ.АР17_НачислениеАренднойПлаты КАК АР17_НачислениеАренднойПлаты
					               |ГДЕ
					               |	ПОДСТРОКА(АР17_НачислениеАренднойПлаты.Номер, 1, 5) = &Префикс
									|	И ПОДСТРОКА(АР17_НачислениеАренднойПлаты.Номер, 11, 3) = &СтрМесяц
					               |	И МЕСЯЦ(АР17_НачислениеАренднойПлаты.Дата) = &месяц
					               |	И ГОД(АР17_НачислениеАренднойПлаты.Дата) = &год
					               |
					               |УПОРЯДОЧИТЬ ПО
					               |	Номер УБЫВ";
								   
					Запрос.УстановитьПараметр("Префикс",Префикс); 
					Запрос.УстановитьПараметр("месяц",месяц(Источник.Дата));
					Запрос.УстановитьПараметр("СтрМесяц","/"+Формат(Источник.Дата,"ДФ=ММ"));
					Запрос.УстановитьПараметр("год",Год(Источник.Дата));
					
					Выгрузка = Запрос.Выполнить().Выгрузить();
