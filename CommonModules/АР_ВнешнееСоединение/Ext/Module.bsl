	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗачетыИтог.СуммаЗачета КАК СуммаЗачета,
	|	ЗачетыИтог.СуммаЗачетаНУ КАК СуммаЗачетаНУ,
	|	ЗачетыИтог.Контрагент КАК Контрагент,
	|	ЗачетыИтог.ОстатокАрендатора КАК ОстатокАрендатора,
	|	ЗачетыИтог.ОстатокАрендатораНУ КАК ОстатокАрендатораНУ,
	|	ЗачетыИтог.Договор КАК Договор,
	|	ЗачетыИтог.РТУ КАК РТУ,
	|	ЗачетыИтог.СуммаЗачета / (ЗачетыИтог.СуммаЗачета + ЕСТЬNULL(ЗачетыИтог.ОстатокАрендатора, 0)) КАК ДоляОплаты,
	|	ЗачетыИтог.СуммаЗачетаНУ / (ЗачетыИтог.СуммаЗачетаНУ + ЕСТЬNULL(ЗачетыИтог.ОстатокАрендатораНУ, 0)) КАК ДоляОплатыНУ,
	|	ЗачетыИтог.КорСубконто3 КАК КорСубконто3,
	|	ЗачетыИтог.Комитент КАК Комитент,
	|	ЗачетыИтог.ДоговорКомитента КАК ДоговорКомитента
	|ПОМЕСТИТЬ ЗачетыФильтрНаПрименениеДоходовПоОплате
	|ИЗ
	|	ЗачетыИтог КАК ЗачетыИтог
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИКДоходПоОплате КАК ИКДоходПоОплате
	|			ПО АР17_ЗаключениеДоговораАренды.ИК = ИКДоходПоОплате.ИК
	|		ПО ЗачетыИтог.Договор = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК ОстатокСобств,
	|	ХозрасчетныйОстатки.СуммаНУОстатокКт КАК ОстатокСобствНУ,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты) КАК КонтрагентСобств,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК ДоговорСобств,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто3 КАК Документ.РеализацияТоваровУслуг) КАК РТУ,
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ОстаткиПоСобств
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&МоментРегистратора,
	|			Счет = &Счет76Б,
	|			,
	|			ВЫРАЗИТЬ(Субконто3 КАК Документ.РеализацияТоваровУслуг) В
	|				(ВЫБРАТЬ
	|					ВТ.РТУ КАК РТУ
	|				ИЗ
	|					ЗачетыФильтрНаПрименениеДоходовПоОплате КАК ВТ)) КАК ХозрасчетныйОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиПоСобств.КонтрагентСобств КАК КонтрагентСобств,
	|	ОстаткиПоСобств.ДоговорСобств КАК ДоговорСобств,
	|	ОстаткиПоСобств.РТУ КАК РТУ,
	|	ОстаткиПоСобств.ОстатокСобств * ЗачетыФильтрНаПрименениеДоходовПоОплате.ДоляОплаты КАК Сумма,
	|	ОстаткиПоСобств.ОстатокСобствНУ * ЗачетыФильтрНаПрименениеДоходовПоОплате.ДоляОплатыНУ КАК СуммаНУ,
	|	ОстаткиПоСобств.Организация КАК Организация,
	|	ОстаткиПоСобств.Подразделение КАК Подразделение
	|ИЗ
	|	ЗачетыФильтрНаПрименениеДоходовПоОплате КАК ЗачетыФильтрНаПрименениеДоходовПоОплате
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиПоСобств КАК ОстаткиПоСобств
	|		ПО ЗачетыФильтрНаПрименениеДоходовПоОплате.РТУ = ОстаткиПоСобств.РТУ
	|ГДЕ
	|	ЗачетыФильтрНаПрименениеДоходовПоОплате.КорСубконто3 ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗачетыИтог.Комитент,
	|	ЗачетыИтог.ДоговорКомитента,
	|	ЗачетыИтог.РТУ,
	|	ЗачетыИтог.СуммаЗачета,
	|	ЗачетыИтог.СуммаЗачетаНУ,
	|	ЗачетыИтог.РТУ.Организация,
	|	ЗачетыИтог.РТУ.ПодразделениеОрганизации
	|ИЗ
	|	ЗачетыИтог КАК ЗачетыИтог
	|ГДЕ
	|	НЕ ЗачетыИтог.КорСубконто3 ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("ДатаК", Источник.Дата);
	Запрос.УстановитьПараметр("ДатаН", Источник.Дата);
	Запрос.УстановитьПараметр("МоментРегистратора", Новый Граница(Источник.МоментВремени(), ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Регистратор", Источник.Ссылка);
	Запрос.УстановитьПараметр("Счет7609", ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами);
	Запрос.УстановитьПараметр("Счет76Б", ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников);

	РЗ = Запрос.Выполнить().Выбрать();

	Пока РЗ.Следующий() Цикл
		
		Проводка = Источник.Движения.Хозрасчетный.Добавить();
		Проводка.Активность = Истина;
		Проводка.Период = Источник.Дата;
		Проводка.Организация = РЗ.Организация;
		Проводка.ПодразделениеДт = РЗ.Подразделение;
		Проводка.ПодразделениеКт = РЗ.Подразделение;
		Проводка.Регистратор = Источник.Ссылка;
		
		Проводка.Содержание = "Начисление дохода собственнику при зачете оплаты арендатора";
		
		Проводка.СчетДт = ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПокупателямиИЗаказчиками;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.Сумма = РЗ.Сумма;
		Проводка.СуммаНУДт = РЗ.СуммаНУ;
		Проводка.СуммаНУКт = РЗ.СуммаНУ;
		
	КонецЦикла;
	
	Источник.Движения.Хозрасчетный.Записать();
	
КонецПроцедуры

Функция ПрименяетсяНачислениеПоОплате(Договор=Неопределено, Контрагент=Неопределено) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ДоговорАР,
		|	АР17_ЗаключениеДоговораАренды.ИК КАК ИК
		|ПОМЕСТИТЬ ВТДоговорАР
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|ГДЕ
		|	&УсловиеНаПроверку
		|	И АР17_ЗаключениеДоговораАренды.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АР17_УстановкаПараметровИК.С_ПрименяетсяУчетДоходаСобственникаПоОплате КАК ПрименяетсяУчетДоходаСобственникаПоОплате
		|ИЗ
		|	Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДоговорАР КАК ВТДоговорАР
		|		ПО АР17_УстановкаПараметровИК.ИКСсылка = ВТДоговорАР.ИК
		|ГДЕ
		|	АР17_УстановкаПараметровИК.Проведен
		|	И АР17_УстановкаПараметровИК.С_ПрименяетсяУчетДоходаСобственникаПоОплате";	
	
	Если Договор <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНаПроверку", "АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента");
		Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	ИначеЕсли Контрагент <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНаПроверку", "АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	КонецЕсли;
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции

Процедура ЗаполнитьПоОперации(Объект, Док, Основание) Экспорт
	
	Объект.ДокументОснование = Основание;
	
	Объект.Организация	  = Док.Организация;
	Объект.Сценарий      = Док.Сценарий;
	Объект.Комментарий   = Док.Комментарий;
	Объект.Содержание    = Док.Содержание;
	Объект.Ответственный = Пользователи.ТекущийПользователь();

	ДвиженияБюджетирования = РегистрыБухгалтерии.бит_Бюджетирование.ВыбратьПоРегистратору(Док.Ссылка);

	Пока ДвиженияБюджетирования.Следующий() Цикл

        Если ДвиженияБюджетирования.Период = Док.ДатаСторно Тогда
            Продолжить;       
        КонецЕсли;
        
		Проводка = Объект.Движения.бит_Бюджетирование.Добавить();

		Проводка.СчетДт          = ДвиженияБюджетирования.СчетДт;
		Проводка.СчетКт          = ДвиженияБюджетирования.СчетКт;

		Для каждого Субконто Из ДвиженияБюджетирования.СубконтоДт Цикл
			Проводка.СубконтоДт[Субконто.Ключ] = Субконто.Значение;
		КонецЦикла;

		Для каждого Субконто Из ДвиженияБюджетирования.СубконтоКт Цикл
			Проводка.СубконтоКт[Субконто.Ключ] = Субконто.Значение;
		КонецЦикла;

		Проводка.ВалютаДт        = ДвиженияБюджетирования.ВалютаДт;
		Проводка.ВалютаКт        = ДвиженияБюджетирования.ВалютаКт;
		Проводка.ВалютнаяСуммаДт = ДвиженияБюджетирования.ВалютнаяСуммаДт;
		Проводка.ВалютнаяСуммаКт = ДвиженияБюджетирования.ВалютнаяСуммаКт;
		Проводка.КоличествоДт    = ДвиженияБюджетирования.КоличествоДт;
		Проводка.КоличествоКт    = ДвиженияБюджетирования.КоличествоКт;
		Проводка.НомерЖурнала    = ДвиженияБюджетирования.НомерЖурнала;
		Проводка.Сценарий        = ДвиженияБюджетирования.Сценарий;
        Проводка.ЦФО             = ДвиженияБюджетирования.ЦФО;
		Проводка.Содержание      = ДвиженияБюджетирования.Содержание;
		Проводка.СуммаРегл       = ДвиженияБюджетирования.СуммаРегл;
        Проводка.СуммаУпр        = ДвиженияБюджетирования.СуммаУпр;
        Проводка.СуммаСценарий   = ДвиженияБюджетирования.СуммаСценарий;
		
		Проводка.Организация	 = Док.Организация;
		Проводка.Бюджет			 = ДвиженияБюджетирования.Бюджет;
		Проводка.Период			 = ДвиженияБюджетирования.Период;
        
	КонецЦикла;	
	
КонецПроцедуры

Процедура АР_РасчетыПоДоговорамНовыйОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	//Если Источник.Дата < Дата('20190101') Тогда
	Если Источник.Дата < Дата('20200101') Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Источник.Движения.Найти("Хозрасчетный") = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Источник.Движения.Найти("АР_РасчетыПоДоговорам") = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Источник.Движения.АР_РасчетыПоДоговорам.Прочитать();
	
	Если Источник.Движения.АР_РасчетыПоДоговорам.Количество() > 0 Тогда // Очищаем то что ввели руками или было введено ранее
		
		Источник.Движения.АР_РасчетыПоДоговорам.Очистить();
		Источник.Движения.АР_РасчетыПоДоговорам.Записать();
		
	КонецЕсли;
	
	Если Источник.Движения.Хозрасчетный.Количество() = 0 Тогда
		
		Источник.Движения.Хозрасчетный.Прочитать();
		
	КонецЕсли;
	
	Если Источник.Движения.Хозрасчетный.Количество() = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Табл = Новый ТаблицаЗначений;
	Табл.Колонки.Добавить("Тип");
	Табл.Колонки.Добавить("ДоговорКонтрагента");
	Табл.Колонки.Добавить("ДокументРасчета");
	Табл.Колонки.Добавить("Сумма");
	
	Для Каждого Стр Из Источник.Движения.Хозрасчетный Цикл
		
		Если Стр.Сумма = 0 Тогда Продолжить; КонецЕсли;
		
		КодДт = Стр.СчетДт.Код;
		КодКт = Стр.СчетКт.Код;
		
		ЗДА_Дт = ПолучитьЗДА_(Стр.СубконтоДт.Договоры, КодДт);
		ЗДА_Кт = ПолучитьЗДА_(Стр.СубконтоКт.Договоры, КодКт);
		
		// ДТ
		Если (КодДт = "62.01" ИЛИ КодДт = "76.06" ИЛИ КодДт = "76.09") И ЗДА_Дт <> Неопределено Тогда
			
			ДокументРасчета = ПолучитьДокументРасчета(Стр.СубконтоДт.ДокументыРасчетовСКонтрагентами);
			
			Если ДокументРасчета <> Неопределено Тогда
			
				Нов						=	Табл.Добавить();
				Нов.Тип					=	"Реализация";
				Нов.ДоговорКонтрагента	=	Стр.СубконтоДт.Договоры;
				Нов.ДокументРасчета		=	Стр.СубконтоДт.ДокументыРасчетовСКонтрагентами;
				Нов.Сумма				=	Стр.Сумма;
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Кт
		Если (КодКт = "62.01" Или КодКт = "76.06"  ИЛИ КодКт = "76.09") И ЗДА_Кт <> Неопределено Тогда 
			
			ДокументРасчета = ПолучитьДокументРасчета(Стр.СубконтоКт.ДокументыРасчетовСКонтрагентами);
			
			Если ДокументРасчета <> Неопределено Тогда
			
				Нов						=	Табл.Добавить();
				Нов.Тип					=	"Оплата";
				Нов.ДоговорКонтрагента	=	Стр.СубконтоКт.Договоры;
				Нов.ДокументРасчета		=	Стр.СубконтоКт.ДокументыРасчетовСКонтрагентами;
				Нов.Сумма				=	Стр.Сумма;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Табл.Свернуть("Тип, ДоговорКонтрагента, ДокументРасчета", "Сумма");
	Табл.Сортировать("Тип Убыв");
	
	Для Каждого Стр Из Табл Цикл
		
		Если Стр.Тип = "Реализация" Тогда 
			
			// При корректировке в меньшую сторону не возвращаем данные в план
			Если Стр.Сумма > 0 
				И ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
				И ТипЗнч(Стр.ДокументРасчета) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
					СторнироватьПроведениеДоговораАренды(Источник);
			КонецЕсли;
			
			ПровестиДолг_(Источник, Стр);
			Источник.Движения.АР_РасчетыПоДоговорам.Записать(); // на случай если реализация засчитывает сама по себе оплату
				
		ИначеЕсли Стр.Тип = "Оплата" Тогда
				
			ПровестиОплату(Источник, Стр);
								
		КонецЕсли;
		
	КонецЦикла;
	
	Источник.Движения.АР_РасчетыПоДоговорам.Записать();
	
КонецПроцедуры

Процедура ПровестиДолг_(Источник, Стр)
	
	РасчетыПоДоговорам = Источник.Движения.АР_РасчетыПоДоговорам;
	
	Табл = ПолучитьДанныеЗДА(Стр.ДоговорКонтрагента);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ПолучитьДанныеТаблиц(Запрос, Источник);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЧ.Номенклатура КАК Номенклатура,
	               |	ТЧ.Сумма КАК Сумма
	               |ПОМЕСТИТЬ ВТ1
	               |ИЗ
	               |	ТЧ_Услуги КАК ТЧ
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТЧ.Номенклатура,
	               |	ТЧ.Сумма
	               |ИЗ
	               |	ТЧ_АгентскиеУслуги КАК ТЧ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ1.Номенклатура КАК Номенклатура,
	               |	СУММА(ВТ1.Сумма) КАК Сумма
	               |ПОМЕСТИТЬ ВТ2
	               |ИЗ
	               |	ВТ1 КАК ВТ1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ1.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Табл.Услуга КАК Номенклатура,
	               |	Табл.ГруппаУслуг КАК ГруппаУслуг
	               |ПОМЕСТИТЬ ВТ3
	               |ИЗ
	               |	&Табл КАК Табл
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ2.Номенклатура КАК Номенклатура,
	               |	ЕСТЬNULL(ВТ3.ГруппаУслуг, ЗНАЧЕНИЕ(Справочник.Ар_ГруппыУслуг.БезГруппы)) КАК ГруппаУслуг,
	               |	ВТ2.Сумма КАК Сумма
	               |ИЗ
	               |	ВТ2 КАК ВТ2
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ3 КАК ВТ3
	               |		ПО ВТ2.Номенклатура = ВТ3.Номенклатура
	               |ГДЕ
	               |	ВТ2.Сумма <> 0";
	Запрос.УстановитьПараметр("Табл", Табл);
	
	Рез = Запрос.Выполнить().Выбрать();
	
	СуммаДолга = Стр.Сумма;
	
	Пока Рез.Следующий() Цикл
		
		Если СуммаДолга <> 0 Тогда
		
			Нов						=	РасчетыПоДоговорам.Добавить();
			Нов.Период				=	Источник.Дата;
			Нов.Месяц				=	НачалоМесяца(Стр.ДокументРасчета.Дата);
			Нов.ВидДвижения			=	ВидДвиженияНакопления.Приход;
			Нов.Организация			=	Источник.Организация;
			Нов.Контрагент			=	Стр.ДоговорКонтрагента.Владелец;
			Нов.ДоговорКонтрагента	=	Стр.ДоговорКонтрагента;
			Нов.ДокументРасчетов	=	Стр.ДокументРасчета;
			Нов.ГруппаУслуг			=	?(ЗначениеЗаполнено(Рез.ГруппаУслуг), Рез.ГруппаУслуг, Справочники.АР_ГруппыУслуг.БезГруппы);
			Нов.Номенклатура		=	Рез.Номенклатура;
			Нов.Сумма				=	?(Рез.Сумма < СуммаДолга, Рез.Сумма, СуммаДолга);
			
			СуммаДолга				=	СуммаДолга - Нов.Сумма;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если СуммаДолга <> 0 Тогда
		
		Нов						=	РасчетыПоДоговорам.Добавить();
		Нов.Период				=	Источник.Дата;
		Нов.Месяц				=	?(ЗначениеЗаполнено(Стр.ДокументРасчета), НачалоМесяца(Стр.ДокументРасчета.Дата), НачалоМесяца(Источник.Дата));
		Нов.ВидДвижения			=	ВидДвиженияНакопления.Приход;
		Нов.Организация			=	Стр.ДоговорКонтрагента.Организация;
		Нов.Контрагент			=	Стр.ДоговорКонтрагента.Владелец;
		Нов.ДоговорКонтрагента	=	Стр.ДоговорКонтрагента;
		Нов.ДокументРасчетов	=	Стр.ДокументРасчета;
		Нов.ГруппаУслуг			=	Справочники.АР_ГруппыУслуг.БезГруппы;
		Нов.Номенклатура		=	Справочники.Номенклатура.ПустаяСсылка();
		Нов.Сумма				=	СуммаДолга;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЗДА_(Договор, КодСчета) Экспорт
	
	Если Не ЗначениеЗаполнено(Договор) Тогда
		
		Возврат Неопределено;
		
	ИначеЕсли Договор.ВидДоговора <> Перечисления.ВидыДоговоровКонтрагентов.СПокупателем И КодСчета <> "62.01" Тогда
		
		Возврат Неопределено;
		
	Иначе
	
		Запрос = Новый Запрос;
		Запрос.Текст = "Выбрать Первые 1 Док.Ссылка Из Документ.АР17_ЗаключениеДоговораАренды КАК Док Где Док.ДоговорКонтрагента = &Договор";
		Запрос.УстановитьПараметр("Договор", Договор);
		Рез = Запрос.Выполнить().Выбрать();
		
		Если Рез.Следующий() Тогда Возврат Рез.Ссылка;
		Иначе Возврат Неопределено КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

Функция ПолучитьДокументРасчета(Док)
	
	Если Не ЗначениеЗаполнено(Док) Тогда
		
		Возврат Неопределено;
		
	ИначеЕсли ТипЗнч(Док) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
		Возврат Док;
		
	ИначеЕсли ТипЗнч(Док) = Тип("ДокументСсылка.ДокументРасчетовСКонтрагентом") Тогда
		
		Возврат Док;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции

Процедура ПолучитьДанныеТаблиц(Запрос, Источник)
	
	МетаданныеИсточника = Источник.Метаданные();
	
	Если МетаданныеИсточника.Реквизиты.Найти("СуммаВключаетНДС") <> Неопределено И Источник.СуммаВключаетНДС Тогда
		Запрос.УстановитьПараметр("СуммаВключаетНДС", Истина);
	Иначе
		Запрос.УстановитьПараметр("СуммаВключаетНДС", Ложь);
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ";
	
	ТЧ_Услуги = Неопределено;
	Если МетаданныеИсточника.ТабличныеЧасти.Найти("Услуги") <> Неопределено Тогда
		
		ТЧ_Услуги = Источник.Услуги.Выгрузить();
		
		Запрос.Текст = Запрос.Текст + "
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.Сумма + 
		|	ВЫБОР КОГДА НЕ &СуммаВключаетНДС ТОГДА ТЧ.СуммаНДС ИНАЧЕ 0 КОНЕЦ";
		
		Если МетаданныеИсточника.ТабличныеЧасти.Услуги.Реквизиты.Найти("СуммаДоИзменения") <> Неопределено Тогда
			
			Запрос.Текст = Запрос.Текст + " -
			|	ТЧ.СуммаДоИзменения -
			|	ВЫБОР КОГДА НЕ &СуммаВключаетНДС ТОГДА ТЧ.СуммаНДСДоИзменения ИНАЧЕ 0 КОНЕЦ";
			
		КонецЕсли;
		
	Иначе		
		
		Запрос.Текст = Запрос.Текст + "
		|	Значение(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
		|	0";
		
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + " КАК Сумма
	|ПОМЕСТИТЬ ТЧ_Услуги";
	
	Если ТЧ_Услуги <> Неопределено Тогда
		
		Запрос.УстановитьПараметр("ТЧ_Услуги", ТЧ_Услуги);
		Запрос.Текст = Запрос.Текст + "
		|ИЗ &ТЧ_Услуги КАК ТЧ";
		
	КонецЕсли;
	Запрос.Выполнить();
	
	Запрос.Текст = "ВЫБРАТЬ";
	
	ТЧ_АгентскиеУслуги = Неопределено;
	Если МетаданныеИсточника.ТабличныеЧасти.Найти("АгентскиеУслуги") <> Неопределено Тогда
		
		ТЧ_АгентскиеУслуги = Источник.АгентскиеУслуги.Выгрузить();
		
		Запрос.Текст = Запрос.Текст + "
		|	ТЧ.Номенклатура КАК Номенклатура,
		|	ТЧ.Сумма + 
		|	ВЫБОР КОГДА НЕ &СуммаВключаетНДС ТОГДА ТЧ.СуммаНДС ИНАЧЕ 0 КОНЕЦ";
		
		Если МетаданныеИсточника.ТабличныеЧасти.АгентскиеУслуги.Реквизиты.Найти("СуммаДоИзменения") <> Неопределено Тогда
			
			Запрос.Текст = Запрос.Текст + " -
			|	ТЧ.СуммаДоИзменения -
			|	ВЫБОР КОГДА НЕ &СуммаВключаетНДС ТОГДА ТЧ.СуммаНДСДоИзменения ИНАЧЕ 0 КОНЕЦ";
			
		КонецЕсли;
		
	Иначе		
		
		Запрос.Текст = Запрос.Текст + "
		|	Значение(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
		|	0";
		
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + " КАК Сумма
	|ПОМЕСТИТЬ ТЧ_АгентскиеУслуги";
	
	Если ТЧ_АгентскиеУслуги <> Неопределено Тогда
		
		Запрос.УстановитьПараметр("ТЧ_АгентскиеУслуги", ТЧ_АгентскиеУслуги);
		Запрос.Текст = Запрос.Текст + "
		|ИЗ &ТЧ_АгентскиеУслуги КАК ТЧ";
		
	КонецЕсли;
	Запрос.Выполнить();	
	
КонецПроцедуры

Процедура ПередЗаписьюДокументаЗаполнениеДопСвойств(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый", Источник.ЭтоНовый());
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение 
		И НЕ Источник.ДополнительныеСвойства.ЭтоНовый 
		И Источник.Проведен Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Док.Дата КАК Дата
		|ИЗ
		|	Документ." + Источник.Метаданные().Имя + " КАК Док
		|ГДЕ
		|	Док.Ссылка = &Ссылка";
		Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		Источник.ДополнительныеСвойства.Вставить("ДатаДокументаСдвинутаВперед", Источник.Дата > Выборка.Дата);
	Иначе
		Источник.ДополнительныеСвойства.Вставить("ДатаДокументаСдвинутаВперед", Ложь);
	КонецЕсли;
	
КонецПроцедуры // - NAI Becar Гайфетдинов Р.И.

Процедура Д_ПрефиксРеализацииПриУстановкеНовогоНомера(Источник, СтандартнаяОбработка, Префикс) Экспорт
	
	Если Источник.Организация.Код = "000000159" Тогда	
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг")
			ИЛИ ТипЗнч(Источник) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если Источник.АгентскиеУслуги.Количество() > 0 Тогда
				Если СтрНайти(Источник.АгентскиеУслуги[0].Контрагент.Наименование,"Мегафон") > 0 ИЛИ СтрНайти(Источник.АгентскиеУслуги[0].Контрагент.Наименование,"МЕГАФОН") > 0 Тогда
					СтандартнаяОбработка = Ложь;
					Префикс = "М";
			        УстановитьПрефикс(Источник, Префикс, Истина, Истина);
				Иначе
					СтандартнаяОбработка = Ложь;
					Префикс = "0";
				    УстановитьПрефикс(Источник, Префикс, Истина, Истина);
				КонецЕсли;	
			Иначе
				СтандартнаяОбработка = Ложь;
				Префикс = "0";
			    УстановитьПрефикс(Источник, Префикс, Истина, Истина);
			КонецЕсли;
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	МАКСИМУМ(ПОДСТРОКА(РеализацияТоваровУслуг.Номер, 7, 5)) КАК МаксНомер
			               |ИЗ
			               |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
			               |ГДЕ
			               |	ГОД(РеализацияТоваровУслуг.Дата) = ГОД(&Дата)
			               |	И РеализацияТоваровУслуг.Номер ПОДОБНО ""МН00-%""";
			Запрос.УстановитьПараметр("Дата",Источник.Дата);
			Рез = Запрос.Выполнить().Выгрузить();
			Размер = СтрДлина(Рез[0].МаксНомер);
			Попытка
				МаксНомер = Строка(Число(Рез[0].МаксНомер) + 1);
			Исключение 
				МаксНомер = "1";
			КонецПопытки;
			Пока СтрДлина(МаксНомер) < Размер Цикл
				МаксНомер = "0" + МаксНомер;
			КонецЦикла;
			Источник.Номер = Префикс + СтрЗаменить(МаксНомер, Символы.НПП, "");//Сред(Источник.Номер, СтрДлина(Префикс) + 1);		
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры


