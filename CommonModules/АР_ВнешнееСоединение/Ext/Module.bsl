Функция РеквизитОрганизацияДоступен(Объект)
	
	// Возвращаемое значение функции.
	Результат = Истина;
	
	МетаданныеОбъекта = Объект.Метаданные();
	
	Если   (ОбщегоНазначения.ЭтоСправочник(МетаданныеОбъекта)
		ИЛИ ОбщегоНазначения.ЭтоПланВидовХарактеристик(МетаданныеОбъекта))
		И МетаданныеОбъекта.Иерархический Тогда
		
		ИмяРеквизитаОрганизация = ИмяРеквизитаОрганизация(МетаданныеОбъекта);
		
		РеквизитОрганизация = МетаданныеОбъекта.Реквизиты.Найти(ИмяРеквизитаОрганизация);
		
		Если РеквизитОрганизация = Неопределено Тогда
			
			Если ОбщегоНазначения.ЭтоСтандартныйРеквизит(МетаданныеОбъекта.СтандартныеРеквизиты, ИмяРеквизитаОрганизация) Тогда
				
				// Стандартный реквизит всегда доступен и для элемента и для группы.
				Возврат Истина;
				
			КонецЕсли;
			
			СтрокаСообщения = НСтр("ru = 'Для объекта метаданных %1 не определен реквизит с именем %2.'");
			СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, МетаданныеОбъекта.ПолноеИмя(), ИмяРеквизитаОрганизация);
			ВызватьИсключение СтрокаСообщения;
		КонецЕсли;
			
		Если РеквизитОрганизация.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляГруппы И Не Объект.ЭтоГруппа Тогда
			
			Результат = Ложь;
			
		ИначеЕсли РеквизитОрганизация.Использование = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита.ДляЭлемента И Объект.ЭтоГруппа Тогда
			
			Результат = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ИмяРеквизитаОрганизация(Объект) Экспорт
	
	Если ТипЗнч(Объект) = Тип("ОбъектМетаданных") Тогда
		ПолноеИмя = Объект.ПолноеИмя();
	Иначе
		ПолноеИмя = Объект;
	КонецЕсли;
	
	Реквизит = ПрефиксацияОбъектовПовтИсп.ПрефиксообразующиеРеквизиты().Получить(ПолноеИмя);
	
	Если Реквизит <> Неопределено Тогда
		Возврат Реквизит;
	КонецЕсли;
	
	Возврат "Организация";
	
КонецФункции

Процедура АР_РасчетыПоДоговорамПроведениеОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	//Возврат;
	
	Если Источник.Дата >= Дата('20190101') Тогда
	
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеНаРасчетныйСчет") Тогда
		
			ПроведениеРеализацияПоступленияНаРасчетныйСчет(Источник);
			
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПриходныйКассовыйОрдер") Тогда	
			
			Источник.Движения.АР_РасчетыПоДоговорам.Прочитать();
			Источник.Движения.АР_РасчетыПоДоговорам.Очистить();
			Источник.Движения.АР_РасчетыПоДоговорам.Записывать = Истина;
			
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.СписаниеСРасчетногоСчета") Тогда
			
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.КорректировкаРеализации") Тогда
			
		ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.КорректировкаДолга") Тогда
			
			Источник.Движения.АР_РасчетыПоДоговорам.Прочитать();
			Источник.Движения.АР_РасчетыПоДоговорам.Очистить();
			Источник.Движения.АР_РасчетыПоДоговорам.Записывать = Истина;
			
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроведениеРеализацияПоступленияНаРасчетныйСчет(Источник) Экспорт
	
	//Источник.Движения.АР_РасчетыПоДоговорам.Прочитать();
	//Источник.Движения.АР_РасчетыПоДоговорам.Очистить();
	//Источник.Движения.АР_РасчетыПоДоговорам.Записать();
	//Источник.Движения.АР_РасчетыПоДоговорам.Записывать = Истина;
	
	Если Источник.Движения.Хозрасчетный.Количество() = 0 Тогда
		
		Источник.Движения.Хозрасчетный.Прочитать();
		
	КонецЕсли;
	
	Табл = Новый ТаблицаЗначений;
	Табл.Колонки.Добавить("Тип");
	Табл.Колонки.Добавить("ДоговорКонтрагента");
	Табл.Колонки.Добавить("ДокументРасчета");
	Табл.Колонки.Добавить("Сумма");
	
	Для Каждого Стр Из Источник.Движения.Хозрасчетный Цикл
		
		КодДт = Стр.СчетДт.Код; 
		КодКт = Стр.СчетКт.Код;
		
		Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") И ( // Проводки продажи
		(КодДт = "62.01" И КодКт = "76.06") ИЛИ
		(КодДт = "62.01" И КодКт = "91.01") ИЛИ
		(КодДт = "62.01" И КодКт = "90.01.1") ИЛИ
		(СтрНайти(КодДт,"76.05") <> 0 И КодКт = "90.01.1") ИЛИ
		(КодДт = "76.06" И КодКт = "76.06") ИЛИ
		(КодДт = "76.06" И КодКт = "90.01.1") ИЛИ
		(КодДт = "76.09" И КодКт = "76.06")
		) Тогда
		
			Нов						=	Табл.Добавить();
			Нов.Тип					=	"Реализация";
			Нов.ДоговорКонтрагента	=	Стр.СубконтоДт.Договоры;
			Нов.ДокументРасчета		=	Источник.Ссылка;
			Нов.Сумма				=	Стр.Сумма;
		
		ИначеЕсли ТипЗнч(Стр.СубконтоКт.ДокументыРасчетовСКонтрагентами) = Тип("ДокументСсылка.РеализацияТоваровУслуг") И ( // Проводки оплаты
		(КодДт = "51" И КодКт = "62.01") ИЛИ
		(КодДт = "51" И КодКт = "76.06") ИЛИ
		(КодДт = "51" И КодКт = "76.09") ИЛИ
		(КодДт = "62.02" И КодКт = "62.01") ИЛИ
		(КодДт = "76.09" И КодКт = "76.09")
		) Тогда
		
			Нов						=	Табл.Добавить();
			Нов.Тип					=	"Оплата";
			Нов.ДоговорКонтрагента	=	Стр.СубконтоКт.Договоры;
			Нов.ДокументРасчета		=	Стр.СубконтоКт.ДокументыРасчетовСКонтрагентами;
			Нов.Сумма				=	Стр.Сумма;
			
		Иначе
			
			Если НЕ (
				(КодДт = "51" И КодКт = "62.02") ИЛИ
				(КодДт = "51" И КодКт = "62.04") ИЛИ
				(КодДт = "62.01" И КодКт = "62.01") ИЛИ
				(КодДт = "76.09" И КодКт = "62.01") ИЛИ
				(КодДт = "90.03" И КодКт = "68.02")
				)
				И
				(
				ТипЗнч(Стр.СубконтоКт.ДокументыРасчетовСКонтрагентами) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
				ИЛИ ТипЗнч(Стр.СубконтоДт.ДокументыРасчетовСКонтрагентами) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
				) Тогда
				
					А = 1;
				
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЦикла;
	
	Табл.Свернуть("Тип, ДоговорКонтрагента, ДокументРасчета", "Сумма");
	Табл.Сортировать("Тип Убыв");
	
	ВТ = Табл.Скопировать(,"Тип");
	ВТ.Свернуть("Тип");
	
	Для Каждого Стр Из Табл Цикл
		
		ЗДА = ПолучитьЗДА(Стр.ДоговорКонтрагента);
		
		Если ЗДА <> Неопределено Тогда
			
			Если Стр.Тип = "Реализация" Тогда 
				
				СторнироватьПроведениеДоговораАренды(Источник);
				ПровестиДолг(Источник);
				Источник.Движения.АР_РасчетыПоДоговорам.Записать(); // на случай если реализация засчитывает сама по себе оплату
				
			ИначеЕсли Стр.Тип = "Оплата" И ЗначениеЗаполнено(Стр.ДокументРасчета) И ТипЗнч(Стр.ДокументРасчета) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				
				ПровестиОплату(Источник, Стр);
								
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ВТ.Количество() = 2 Тогда
		
		ЕстьПриход = Ложь; ЕстьРасход = Ложь;
		
		Для Каждого Стр Из Источник.Движения.АР_РасчетыПоДоговорам Цикл
			
			Если Стр.ВидДвижения = ВидДвиженияНакопления.Приход Тогда ЕстьПриход = Истина; КонецЕсли;
			Если Стр.ВидДвижения = ВидДвиженияНакопления.Расход Тогда ЕстьРасход = Истина; КонецЕсли;
			
		КонецЦикла;
		
		Если ЕстьПриход = Ложь ИЛИ ЕстьРасход = Ложь Тогда
				
			А = 1;
				
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЗДА(Договор) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "Выбрать Первые 1 Док.Ссылка Из Документ.АР17_ЗаключениеДоговораАренды КАК Док Где Док.ДоговорКонтрагента = &Договор";
	Запрос.УстановитьПараметр("Договор", Договор);
	Рез = Запрос.Выполнить().Выбрать();
	
	Если Рез.Следующий() Тогда Возврат Рез.Ссылка;
	Иначе Возврат Неопределено КонецЕсли;
	
КонецФункции

Функция ПолучитьДанныеЗДА(Договор)
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	Док.Ссылка КАК Ссылка
	                      |ПОМЕСТИТЬ ВТ
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеДоговораАренды КАК Док
	                      |ГДЕ
	                      |	Док.Проведен
	                      |	И Док.ДоговорКонтрагента = &ДоговорКонтрагента
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	ТЧ.Ссылка КАК Ссылка,
	                      |	ТЧ.Услуга КАК Услуга,
	                      |	ТЧ.ГруппаУслуг КАК ГруппаУслуг
	                      |ПОМЕСТИТЬ Табл
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК ТЧ
	                      |ГДЕ
	                      |	ТЧ.Ссылка В
	                      |			(ВЫБРАТЬ
	                      |				Т.Ссылка
	                      |			ИЗ
	                      |				Вт КАК Т)
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	ТЧ.Ссылка,
	                      |	ТЧ.Услуга,
	                      |	ТЧ.ГруппаУслуг
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты КАК ТЧ
	                      |ГДЕ
	                      |	ТЧ.Ссылка В
	                      |			(ВЫБРАТЬ
	                      |				Т.Ссылка
	                      |			ИЗ
	                      |				Вт КАК Т)
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	ТЧ.Ссылка,
	                      |	ТЧ.Услуга,
	                      |	ТЧ.ГруппаУслуг
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеДоговораАренды.КоммунальныеУслуги КАК ТЧ
	                      |ГДЕ
	                      |	ТЧ.Ссылка В
	                      |			(ВЫБРАТЬ
	                      |				Т.Ссылка
	                      |			ИЗ
	                      |				Вт КАК Т)
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	Т.Услуга КАК Услуга,
	                      |	Т.ГруппаУслуг КАК ГруппаУслуг,
	                      |	ЕСТЬNULL(Спр.Приоритет, 99999) КАК Приоритет,
	                      |	СУММА(0) КАК Остаток
	                      |ИЗ
	                      |	Табл КАК Т
	                      |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.АР_ГруппыУслуг КАК Спр
	                      |		ПО Т.ГруппаУслуг = Спр.Ссылка
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	Т.Услуга,
	                      |	Т.ГруппаУслуг,
	                      |	ЕСТЬNULL(Спр.Приоритет, 99999)
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Приоритет");
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	Табл = Запрос.Выполнить().Выгрузить();
	
	Возврат Табл;
	
КонецФункции

Процедура СторнироватьПроведениеДоговораАренды(Источник)
	
	РасчетыПоДоговорам = Источник.Движения.АР_РасчетыПоДоговорам;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Услуги.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	Услуги.Номенклатура КАК Номенклатура,
	               |	Услуги.Сумма + ВЫБОР
	               |		КОГДА НЕ Услуги.Ссылка.ТипЦен.ЦенаВключаетНДС
	               |			ТОГДА Услуги.СуммаНДС
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК Сумма,
	               |	НАЧАЛОПЕРИОДА(Услуги.Ссылка.Дата, МЕСЯЦ) КАК Месяц
	               |ПОМЕСТИТЬ ВТ1
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.Услуги КАК Услуги
	               |ГДЕ
	               |	Услуги.Ссылка = &Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	АгентскиеУслуги.Ссылка.ДоговорКонтрагента,
	               |	АгентскиеУслуги.Номенклатура,
	               |	АгентскиеУслуги.Сумма + ВЫБОР
	               |		КОГДА НЕ АгентскиеУслуги.Ссылка.ТипЦен.ЦенаВключаетНДС
	               |			ТОГДА АгентскиеУслуги.СуммаНДС
	               |		ИНАЧЕ 0
	               |	КОНЕЦ,
	               |	НАЧАЛОПЕРИОДА(АгентскиеУслуги.Ссылка.Дата, МЕСЯЦ)
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК АгентскиеУслуги
	               |ГДЕ
	               |	АгентскиеУслуги.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ1.Месяц КАК Месяц,
	               |	ВТ1.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	ВТ1.Номенклатура КАК Номенклатура,
	               |	СУММА(ВТ1.Сумма) КАК Сумма
	               |ПОМЕСТИТЬ ВТ2
	               |ИЗ
	               |	ВТ1 КАК ВТ1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ1.Номенклатура,
	               |	ВТ1.ДоговорКонтрагента,
	               |	ВТ1.Месяц
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Рег.ДокументРасчетов КАК ДокументРасчетов,
	               |	Рег.ГруппаУслуг КАК ГруппаУслуг,
	               |	Рег.Номенклатура КАК Номенклатура,
	               |	ВТ2.Сумма КАК Сумма,
	               |	Рег.СуммаОстаток КАК СуммаОстаток
	               |ИЗ
	               |	РегистрНакопления.АР_РасчетыПоДоговорам.Остатки(//&Период
				   |		, ТИПЗНАЧЕНИЯ(ДокументРасчетов) = ТИП(Документ.Ар17_ПроведениеДоговораАренды)) КАК Рег
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ2 КАК ВТ2
	               |		ПО Рег.ДоговорКонтрагента = ВТ2.ДоговорКонтрагента
	               |			И Рег.Номенклатура = ВТ2.Номенклатура
	               |			И Рег.Месяц = ВТ2.Месяц";
	//Запрос.УстановитьПараметр("Период", Источник.МоментВремени());
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
					
		Нов						=	РасчетыПоДоговорам.Добавить();
		Нов.Период				=	Источник.Дата;
		Нов.Месяц				=	НачалоМесяца(Источник.Дата);
		Нов.ВидДвижения			=	ВидДвиженияНакопления.Расход;
		Нов.Организация			=	Источник.Организация;
		Нов.Контрагент			=	Источник.Контрагент;
		Нов.ДоговорКонтрагента	=	Источник.ДоговорКонтрагента;
		Нов.ДокументРасчетов	=	Рез.ДокументРасчетов;
		Нов.ГруппаУслуг			=	?(ЗначениеЗаполнено(Рез.ГруппаУслуг), Рез.ГруппаУслуг, Справочники.АР_ГруппыУслуг.БезГруппы);
		Нов.Номенклатура		=	Рез.Номенклатура;
		Нов.Сумма				=	?(Рез.Сумма > Рез.СуммаОстаток, Рез.СуммаОстаток, Рез.Сумма);
					
	КонецЦикла;
	
КонецПроцедуры

Процедура ПровестиДолг(Источник)
	
	РасчетыПоДоговорам = Источник.Движения.АР_РасчетыПоДоговорам;
	
	Табл = ПолучитьДанныеЗДА(Источник.ДоговорКонтрагента);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЧ.Номенклатура КАК Номенклатура,
	               |	ТЧ.Сумма + ВЫБОР
	               |		КОГДА НЕ ТЧ.Ссылка.СуммаВключаетНДС
	               |			ТОГДА ТЧ.СуммаНДС
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК Сумма
	               |ПОМЕСТИТЬ ВТ1
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.Услуги КАК ТЧ
	               |ГДЕ
	               |	ТЧ.Ссылка = &Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТЧ.Номенклатура,
	               |	ТЧ.Сумма + ВЫБОР
	               |		КОГДА НЕ ТЧ.Ссылка.СуммаВключаетНДС
	               |			ТОГДА ТЧ.СуммаНДС
	               |		ИНАЧЕ 0
	               |	КОНЕЦ
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК ТЧ
	               |ГДЕ
	               |	ТЧ.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ1.Номенклатура КАК Номенклатура,
	               |	СУММА(ВТ1.Сумма) КАК Сумма
	               |ПОМЕСТИТЬ ВТ2
	               |ИЗ
	               |	ВТ1 КАК ВТ1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ1.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Табл.Услуга КАК Номенклатура,
	               |	Табл.ГруппаУслуг КАК ГруппаУслуг
	               |ПОМЕСТИТЬ ВТ3
	               |ИЗ
	               |	&Табл КАК Табл
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ2.Номенклатура КАК Номенклатура,
	               |	ЕСТЬNULL(ВТ3.ГруппаУслуг, ЗНАЧЕНИЕ(Справочник.Ар_ГруппыУслуг.БезГруппы)) КАК ГруппаУслуг,
	               |	ВТ2.Сумма КАК Сумма
	               |ИЗ
	               |	ВТ2 КАК ВТ2
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ3 КАК ВТ3
	               |		ПО ВТ2.Номенклатура = ВТ3.Номенклатура";
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Табл", Табл);
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		
		Нов						=	РасчетыПоДоговорам.Добавить();
		Нов.Период				=	Источник.Дата;
		Нов.Месяц				=	НачалоМесяца(Источник.Дата);
		Нов.ВидДвижения			=	ВидДвиженияНакопления.Приход;
		Нов.Организация			=	Источник.Организация;
		Нов.Контрагент			=	Источник.Контрагент;
		Нов.ДоговорКонтрагента	=	Источник.ДоговорКонтрагента;
		Нов.ДокументРасчетов	=	Источник.Ссылка;
		Нов.ГруппаУслуг			=	?(ЗначениеЗаполнено(Рез.ГруппаУслуг), Рез.ГруппаУслуг, Справочники.АР_ГруппыУслуг.БезГруппы);
		Нов.Номенклатура		=	Рез.Номенклатура;
		Нов.Сумма				=	Рез.Сумма;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПровестиОплату(Источник, Стр)
	
	РасчетыПоДоговорам = Источник.Движения.АР_РасчетыПоДоговорам;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Рег.ГруппаУслуг КАК ГруппаУслуг,
	               |	Рег.Номенклатура КАК Номенклатура,
	               |	Рег.СуммаОстаток КАК СуммаОстаток
	               |ИЗ
	               |	РегистрНакопления.АР_РасчетыПоДоговорам.Остатки(&Период, ДокументРасчетов = &ДокументРасчетов) КАК Рег";
	Запрос.УстановитьПараметр("ДокументРасчетов", Стр.ДокументРасчета);
	Запрос.УстановитьПараметр("Период", Новый Граница(Источник.МоментВремени(), ВидГраницы.Включая));
	
	СуммаКСписанию = Стр.Сумма;
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		
		Если СуммаКСписанию > 0 Тогда
		
			Нов = РасчетыПоДоговорам.Добавить();
			Нов.Период				=	Источник.Дата;
			Нов.Месяц				=	НачалоМесяца(Стр.ДокументРасчета.Дата);
			Нов.ВидДвижения			=	ВидДвиженияНакопления.Расход;
			Нов.Организация			=	Стр.ДоговорКонтрагента.Организация;
			Нов.Контрагент			=	Стр.ДоговорКонтрагента.Владелец;
			Нов.ДоговорКонтрагента	=	Стр.ДоговорКонтрагента;
			Нов.ДокументРасчетов	=	Стр.ДокументРасчета;
			Нов.ГруппаУслуг			=	?(ЗначениеЗаполнено(Рез.ГруппаУслуг), Рез.ГруппаУслуг, Справочники.АР_ГруппыУслуг.БезГруппы);
			Нов.Номенклатура		=	Рез.Номенклатура;
			Нов.Сумма				=	?(Рез.СуммаОстаток > СуммаКСписанию, СуммаКСписанию, Рез.СуммаОстаток);
			
			СуммаКСписанию			=	СуммаКСписанию - Нов.Сумма;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура С_ОтражениеДоходаСобственникаПоОплатеОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		Если ПрименяетсяНачислениеПоОплате(Источник.ДоговорКонтрагента) Тогда
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеНаРасчетныйСчет") Тогда
		
		Если Источник.ВидОперации = Перечисления.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя 
			И ПрименяетсяНачислениеПоОплате(, Источник.Контрагент) Тогда
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.КорректировкаРеализации") Тогда
		
		Если ТипЗнч(Источник.ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
			И ПрименяетсяНачислениеПоОплате(Источник.ДокументРеализации.ДоговорКонтрагента) Тогда
			СформироватьДвиженияСторноНачисленияДоходаПоОплатеОтКорРТУ(Источник, Отказ);
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДвиженияСторноНачисленияДоходаПоОплатеОтКорРТУ(Источник, Отказ)
	
	Источник.Движения.Хозрасчетный.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОборотыДтКт.СуммаОборот КАК СуммаЗачета,
		|	ХозрасчетныйОборотыДтКт.СуммаНУОборотКт КАК СуммаЗачетаНУ,
		|	ВЫРАЗИТЬ(ХозрасчетныйОборотыДтКт.СубконтоДт1 КАК Справочник.Контрагенты) КАК Контрагент,
		|	ВЫРАЗИТЬ(ХозрасчетныйОборотыДтКт.СубконтоДт2 КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
