	|ГДЕ
	|	НЕ АР17_ЗаключениеДоговораАренды.ПометкаУдаления
	|	И АР17_НачислениеАренднойПлаты.Ссылка = &Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ЗАК= "";
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗАК=  Выборка.ссылка1;
	КонецЕсли
