Функция ПлательщикНДСПрименяющийУСН(Организация,Дата)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НастройкиСистемыНалогообложенияСрезПоследних.ПлательщикНДСПрименяющийУСН КАК ПлательщикНДСПрименяющийУСН
	               |ИЗ
	               |	РегистрСведений.НастройкиСистемыНалогообложения.СрезПоследних(&Дата, ) КАК НастройкиСистемыНалогообложенияСрезПоследних
	               |ГДЕ
	               |	НастройкиСистемыНалогообложенияСрезПоследних.Организация = &Организация";
	Запрос.УстановитьПараметр("Дата",Дата);
	Запрос.УстановитьПараметр("Организация",Организация); 
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Возврат Выгрузка[0].ПлательщикНДСПрименяющийУСН;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
