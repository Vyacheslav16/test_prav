	|	АР_Ставки.Сумма КАК Сумма,
	|	АР_Ставки.СуммаПоДоговору КАК СуммаПоДоговору,
	|	АР_Ставки.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	АР_Ставки.ДатаНачалаАренды КАК ДатаНачалаАренды,
	|	АР_Ставки.ДатаОкончанияАренды КАК ДатаОкончанияАренды,
	|	АР_Ставки.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
	|	АР_Ставки.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	//|	АР_Ставки.бит_ЦФО КАК бит_ЦФО,
	//|	АР_Ставки.бит_СтатьяОборотов КАК бит_СтатьяОборотов,
	//|	АР_Ставки.бит_Проект КАК бит_Проект,
	//|	АР_Ставки.БРР КАК БРР,
	|	АР_Ставки.СтавкаНДС КАК СтавкаНДС,
	|	АР_Ставки.СуммаВключаетНДС КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТСтавки
	|ИЗ
	|	РегистрСведений.АР_Ставки КАК АР_Ставки
	|ГДЕ
	|	АР_Ставки.Договор = &Договор
	|	И АР_Ставки.ДатаНачалаАренды <= &КонецПериода
	|	И АР_Ставки.ДатаОкончанияАренды >= &НачалоПериода
	|	И АР_Ставки.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды
	|;
