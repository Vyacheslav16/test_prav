				СтрокаТаб.ПериодКонец = Объект.ОкончаниеПериода; //Мин(ВыборкаДанных.ДатаОкончанияАренды,Объект.ОкончаниеПериода); //-са
			Иначе
				СтрокаТаб.ПериодАренды = Объект.НачалоПериода;			
			КонецЕсли;
			//
		ИначеЕсли СтрокаТаб.СпособНачисления.ИмяПредопределенныхДанных = "КоличестваДнейАренды" Тогда
			АР17_РассчитатьСтрокуНачисления(СтрокаТаб);
			СтрокаТаб.Сумма = СтрокаТаб.Сумма/День(КонецМесяца(СтрокаТаб.ПериодНачало)) * СтрокаТаб.КоличествоДней;
			
			// + NAI Becar Конюшок С.Н. от 28.12.2016 15:50 
			СтрокаТаб.Цена = СтрокаТаб.Сумма / СтрокаТаб.Количество;
