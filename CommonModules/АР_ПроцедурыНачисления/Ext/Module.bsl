Функция ПодготовитьСтруктуруРабочихПериодов(ДоговорКонтрагента, МоментВремени, ПараметрыНачисленияПени)
	
	ТаблицаПоискРабочейДаты = Новый ТаблицаЗначений;
	ТаблицаПоискРабочейДаты.Колонки.Добавить("ВсеДни", Новый ОписаниеТипов("Дата", , ,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаПоискРабочейДаты.Колонки.Добавить("РабочиеДни", Новый ОписаниеТипов("Дата", , ,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	
	ТаблицаКалендарьОтсрочкиСНомером = Новый ТаблицаЗначений;
	ТаблицаКалендарьОтсрочкиСНомером.Колонки.Добавить("ДатаКалендаря", Новый ОписаниеТипов("Дата", , ,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаКалендарьОтсрочкиСНомером.Колонки.Добавить("ПорядковыйНомер", Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
	
	ТаблицаКалендарьПросрочкиСНомером = Новый ТаблицаЗначений;
	ТаблицаКалендарьПросрочкиСНомером.Колонки.Добавить("ДатаКалендаря", Новый ОписаниеТипов("Дата", , ,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаКалендарьПросрочкиСНомером.Колонки.Добавить("ПорядковыйНомер", Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
	
	Запрос = АР_ПроцедурыНачисленияПереопределяемый.ПолучитьЗапросДляРасчетаРабочихДней(ДоговорКонтрагента, МоментВремени);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ПараметрыНачисленияПени.УчитыватьТолькоРабочиеДниОтсрочки Тогда
			Если Выборка.ЭтоРабочийДень Тогда
				НоваяСтрока = ТаблицаКалендарьОтсрочкиСНомером.Добавить();
				НоваяСтрока.ДатаКалендаря = Выборка.Дата;
				НоваяСтрока.ПорядковыйНомер = ТаблицаКалендарьОтсрочкиСНомером.Индекс(НоваяСтрока);
			КонецЕсли;
		Иначе
			НоваяСтрока = ТаблицаКалендарьОтсрочкиСНомером.Добавить();
			НоваяСтрока.ДатаКалендаря = Выборка.Дата;
			НоваяСтрока.ПорядковыйНомер = ТаблицаКалендарьОтсрочкиСНомером.Индекс(НоваяСтрока);
		КонецЕсли;
		
		Если ПараметрыНачисленияПени.УчитыватьТолькоРабочиеДниПросрочки Тогда
			Если Выборка.ЭтоРабочийДень Тогда
				НоваяСтрока = ТаблицаКалендарьПросрочкиСНомером.Добавить();
				НоваяСтрока.ДатаКалендаря = Выборка.Дата;
				НоваяСтрока.ПорядковыйНомер = ТаблицаКалендарьПросрочкиСНомером.Индекс(НоваяСтрока);
			КонецЕсли;
		Иначе
			НоваяСтрока = ТаблицаКалендарьПросрочкиСНомером.Добавить();
			НоваяСтрока.ДатаКалендаря = Выборка.Дата;
			НоваяСтрока.ПорядковыйНомер = ТаблицаКалендарьПросрочкиСНомером.Индекс(НоваяСтрока);
		КонецЕсли;
		
		НоваяСтрока = ТаблицаПоискРабочейДаты.Добавить();
		НоваяСтрока.ВсеДни = Выборка.Дата;
		Если Выборка.ЭтоРабочийДень Тогда
			НоваяСтрока.РабочиеДни = Выборка.Дата;
		КонецЕсли;
		
	КонецЦикла;
	
