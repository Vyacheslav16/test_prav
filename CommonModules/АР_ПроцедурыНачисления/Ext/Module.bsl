				СтрокаТаб.ПериодКонец = КонецПериода(СтрокаТаб.ПериодНачало, Периодичность);
				НоваяСтрокаТаб.ПериодНачало = КонецПериода(СтрокаТаб.ПериодНачало, Периодичность) + 1;
