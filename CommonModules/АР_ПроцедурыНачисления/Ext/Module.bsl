	Если КоличествоВремени = Неопределено Тогда
		Если ((День(НачалоМесяца(НачалоПериода)) <> День(НачалоПериода)) или (День(КонецМесяца(КонецПериода)) <> День(КонецПериода))) и День(НачалоМесяца(НачалоПериода)) <> 1 Тогда
			КоличествоВремени = (НачалоДня(КонецПериода) - НачалоДня(НачалоПериода))/ОдинДень; //количество дней
		Иначе
			КоличествоВремени = (НачалоДня(КонецПериода) - НачалоДня(НачалоПериода))/ОдинДень+1; //количество дней
		КонецЕсли;	
	КонецЕсли;
	
	СтрокаТаблицы.КоличествоДней = КоличествоВремени;
	
	Месяцы = Новый СписокЗначений;
	ГодНачало = Год(НачалоПериода);
	МесяцНачало = Месяц(НачалоПериода);
	МесяцКонец = Месяц(КонецПериода);
	Сумма = 0;
	Если ((День(НачалоМесяца(НачалоПериода)) <> День(НачалоПериода)) или (День(КонецМесяца(КонецПериода)) <> День(КонецПериода))) и День(НачалоМесяца(НачалоПериода)) <> 1 Тогда
		Сумма = Сумма + СтрокаТаблицы.КоличествоДней*СтоимостьОдногоДня;
	Иначе
		Сумма = Сумма + ((День(КонецМесяца(НачалоПериода))- День(НачалоПериода))+1)*СтоимостьОдногоДня;
	КонецЕсли;	
	//Для к = МесяцНачало+1 По МесяцКонец-1 Цикл
	//	ДатаМесяца = Дата(Строка(ГодНачало), к, 1);
	//	Сумма = Сумма + День(КонецМесяца(ДатаМесяца))*СтоимостьОдногоДня;
	//КонецЦикла;	
	
	//Сумма = Сумма + (День(КонецПериода))*СтоимостьОдногоДня;
	
	Возврат Сумма;
