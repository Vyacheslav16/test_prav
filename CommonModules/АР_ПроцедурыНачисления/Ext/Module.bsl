	Запрос.УстановитьПараметр("МоментВремени", Дата(1, 1, 1)); //Объект.МоментВремени()); //-са 
	Запрос.УстановитьПараметр("ДатаКурса", КонецДня(Объект.ДатаКурса));
	
	ПониженныеВидыСтавок = Новый Массив;
	ЗначениеОбщейСтавкиНДС = 0;
	ЗначениеПониженнойСтавкиНДС = 0;
	
	ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
	ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
	
	ОбщаяСтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Общая, Объект.Дата);
	ПониженнаяСтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Пониженная, Объект.Дата);
	
	ЗначениеОбщейСтавкиНДС = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(ОбщаяСтавкаНДС);
