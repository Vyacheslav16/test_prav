Процедура ЗаполнитьДокументДаннымиНачисленияАрендыКоммунальныеУслуги(ДокументОбъект, ИмяТабличнойЧасти, ДанныеНачисления)
	
	Для Каждого Стр Из ДанныеНачисления Цикл
		Если Стр.Цена = 0 Тогда
			Продолжить;
		КонецЕсли;
		СтрТЧ = ДокументОбъект[ИмяТабличнойЧасти].Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЧ,Стр);
		Если ТипЗнч(ДокументОбъект) <> Тип("ДокументОбъект.АР17_СчетНаАренду") Тогда
			СтрТЧ.Субконто = Стр.НоменклатурнаяГруппа;
			СтрТЧ.бит_Аналитика_5 = Стр.БРР;
		КонецЕсли;	
		//СтрТЧ.Субконто = Стр.НоменклатурнаяГруппа;
		АР_ОбщиеПроцедурыПереопределяемый.РассчитатьСуммуНДСТабЧасти(СтрТЧ, ДокументОбъект);	
		Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.АР17_НачислениеАренднойПлаты") Тогда
			ЗаполнитьДанныеПоАгентскимУслугам(СтрТЧ, ДокументОбъект.Организация, ДокументОбъект.ОкончаниеПериода);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

