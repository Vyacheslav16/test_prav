					//ТекстСообщения = "Для объекта аренды """ + ВыборкаДанных.ОбъектАренды + """ по услуге """ + ВыборкаДанных.Номенклатура 
					//+ """ на дату " + Формат(Объект.НачалоПериода, "ДФ=dd.MM.yyyy") + " не задана ставка! " + "(Договор " + ВыборкаДанных.Договор + ")";
					//АР_ОбщиеПроцедурыПереопределяемый.СообщениеПользователю(ТекстСообщения);
				КонецЕсли;
				
				Если КоличествоОбработанныхПериодов>0 Тогда
					//ДанныеУчета[ДанныеУчета.Количество()-1].ПериодКонец = НачалоДня(ВыборкаДанных.ПериодНачало-1);	
				КонецЕсли;
				
				//+са
				//Если Не ЗначениеЗаполнено(ВыборкаДанных.СпособНачисления) Тогда 
				//	Продолжить;
				//КонецЕсли;					
				//-са
				
				Стр = ДанныеУчета.Добавить();
				ЗаполнитьЗначенияСвойств(Стр,ВыборкаДанных);
				//Здесь что-то должно быть про неполный месяц
				//+са
				//Если Месяц(Стр.НачалоПериода) = Месяц(Шапка.Ссылка.ОкончаниеПериода)  
				//	и Год(Стр.НачалоПериода) = Год(Шапка.Ссылка.ОкончаниеПериода)
					//Стр.ПериодНачало = Стр.ДатаНачалаАренды;
				//Стр.ДатаНачалаАренды = Стр.ПериодНачало;
				//КонецЕсли;	
				//-са					
				Если Не ЗначениеЗаполнено(ВыборкаДанных.СтавкаНДС) Тогда
					Стр.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
				Иначе
					Если ВыборкаДанных.Номенклатура.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая 
						и СтавкаНДСПриУСН <> Перечисления.ВидыСтавокНДС.ПустаяСсылка()
							И СтавкаНДСПриУСН <> Перечисления.ВидыСтавокНДС.Общая 
							И ЭтоУпрощенка
							Тогда
							Стр.СтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(СтавкаНДСПриУСН, Объект.Дата);
					КонецЕсли;
				КонецЕсли;
				Если СтавкаНДС <> Неопределено Тогда
					Стр.СтавкаНДС = СтавкаНДС;	
				КонецЕсли;	
				
				
				Если (ТипЗнч(Стр.количество)=тип("null")) или (Стр.количество=0) тогда
					Стр.количество=1;	
				КонецЕсли;
				
				КоличествоОбработанныхПериодов = КоличествоОбработанныхПериодов+1;
				Если КоличествоОбработанныхПериодов = КоличествоПериодов Тогда
					Стр.ПериодКонец = Объект.ОкончаниеПериода; //Мин(ВыборкаДанных.ДатаОкончанияАренды,Объект.ОкончаниеПериода); //-са
				КонецЕсли;
				
			КонецЦикла;	
			
		КонецЦикла;
		
	КонецЦикла;
	
	//необходимо разбить все периоды по периодам договора или периодам способа начисления
	//+са
	Если ТипЗнч(Объект) = Тип("ДокументОбъект.АР17_СчетНаАренду") Тогда
		Режим = "Счет";
	Иначе
		Режим = "Акт"
	КонецЕсли;	
