Процедура СвернутьТЗДанныеУчета(ДанныеУчета)

	Если ДанныеУчета.Количество() = 0 Тогда
	
		Возврат;
	
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеУчета.Номенклатура КАК Номенклатура,
		|	ДанныеУчета.Содержание КАК Содержание,
		|	ДанныеУчета.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
		//|	ДанныеУчета.БРР КАК БРР,
		//|	ДанныеУчета.бит_ЦФО КАК бит_ЦФО,
		//|	ДанныеУчета.бит_СтатьяОборотов КАК бит_СтатьяОборотов,
		//|	ДанныеУчета.бит_Проект КАК бит_Проект,
		|	ДанныеУчета.Цена КАК Цена,
		|	ДанныеУчета.СтавкаСпособаНачисления КАК СтавкаСпособаНачисления,
		|	ДанныеУчета.СпособНачисления КАК СпособНачисления,
		|	ДанныеУчета.СтавкаНДС КАК СтавкаНДС,
		|	ДанныеУчета.Коэффициент КАК Коэффициент,
		|	ДанныеУчета.ПериодАренды КАК ПериодАренды,
		|	ДанныеУчета.КоличествоДней КАК КоличествоДней,
		|	ДанныеУчета.ГруппаУслуг КАК ГруппаУслуг,
		|	ДанныеУчета.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ДанныеУчета.Количество КАК Количество,
		|	ДанныеУчета.Сумма КАК Сумма,
		|	ДанныеУчета.СуммаПоДоговору КАК СуммаПоДоговору,
		|	ДанныеУчета.Код КАК Код,
		|	ДанныеУчета.Начисление КАК Начисление,
		|	ДанныеУчета.Счет КАК Счет,
		|	ДанныеУчета.ПериодНачало КАК ПериодНачало,
		|	ДанныеУчета.ПериодКонец КАК ПериодКонец,
		|	ДанныеУчета.ДатаНачалаАренды КАК ДатаНачалаАренды,
		|	ДанныеУчета.ДатаОкончанияАренды КАК ДатаОкончанияАренды,
		|	ДанныеУчета.ЗаключениеДоговора КАК ЗаключениеДоговора,
		|	ДанныеУчета.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
		|	ДанныеУчета.Акт КАК Акт,
		|	ДанныеУчета.СуммаВключаетНДС КАК СуммаВключаетНДС
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	&ДанныеУчета КАК ДанныеУчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ.Номенклатура) КАК Номенклатура,
		|	МАКСИМУМ(ВТ.Содержание) КАК Содержание,
		|	МАКСИМУМ(ВТ.НоменклатурнаяГруппа) КАК НоменклатурнаяГруппа,
		|	МАКСИМУМ(ВТ.Цена) КАК Цена,
		|	МАКСИМУМ(ВТ.СтавкаСпособаНачисления) КАК СтавкаСпособаНачисления,
		|	МАКСИМУМ(ВТ.СпособНачисления) КАК СпособНачисления,
		|	МАКСИМУМ(ВТ.СтавкаНДС) КАК СтавкаНДС,
		|	МАКСИМУМ(ВТ.Коэффициент) КАК Коэффициент,
		|	МАКСИМУМ(ВТ.ПериодАренды) КАК ПериодАренды,
		|	МАКСИМУМ(ВТ.КоличествоДней) КАК КоличествоДней,
		|	МАКСИМУМ(ВТ.ГруппаУслуг) КАК ГруппаУслуг,
		|	МАКСИМУМ(ВТ.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
		|	МАКСИМУМ(ВТ.Количество) КАК Количество,
		|	МАКСИМУМ(ВТ.Сумма) КАК Сумма,
		|	МАКСИМУМ(ВТ.СуммаПоДоговору) КАК СуммаПоДоговору,
		|	МАКСИМУМ(ВТ.Код) КАК Код,
		|	МАКСИМУМ(ВТ.Начисление) КАК Начисление,
		|	МАКСИМУМ(ВТ.Счет) КАК Счет,
		|	МАКСИМУМ(ВТ.ПериодНачало) КАК ПериодНачало,
		|	МАКСИМУМ(ВТ.ПериодКонец) КАК ПериодКонец,
		|	МИНИМУМ(ВТ.ДатаНачалаАренды) КАК ДатаНачалаАренды,
		|	МАКСИМУМ(ВТ.ДатаОкончанияАренды) КАК ДатаОкончанияАренды,
		|	МАКСИМУМ(ВТ.ЗаключениеДоговора) КАК ЗаключениеДоговора,
		|	ВТ.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
		|	МАКСИМУМ(ВТ.Акт) КАК Акт,
		//|	МАКСИМУМ(ВТ.БРР) КАК БРР,
		//|	МАКСИМУМ(ВТ.бит_ЦФО) КАК бит_ЦФО,
		//|	МАКСИМУМ(ВТ.бит_СтатьяОборотов) КАК бит_СтатьяОборотов,
		//|	МАКСИМУМ(ВТ.бит_Проект) КАК бит_Проект,
		|	ВТ.СуммаВключаетНДС КАК СуммаВключаетНДС
		|ИЗ
		|	ВТ КАК ВТ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ.НомерСтрокиТЧ,
		|	ВТ.СуммаВключаетНДС";
	
	Запрос.УстановитьПараметр("ДанныеУчета", ДанныеУчета);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	ДанныеУчета.Очистить();
	
	Пока РЗ.Следующий() Цикл
	
		 НСтр = ДанныеУчета.Добавить();
		 ЗаполнитьЗначенияСвойств(НСтр, РЗ);
	
	КонецЦикла; 

КонецПроцедуры
