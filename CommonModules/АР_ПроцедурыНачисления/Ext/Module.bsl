Процедура АР17_РассчитатьСтрокуНачисления(СтрокаТаблицы, НачалоПериода = Неопределено, КонецПериода = Неопределено, КоличествоВремени = Неопределено) Экспорт
	
	ОдинДень = 60*60*24;
	Если НачалоПериода = Неопределено Тогда
		//-са
		НачалоПериода = СтрокаТаблицы.ПериодНачало;
		//НачалоПериода = Макс(СтрокаТаблицы.ДатаНачалаАренды, СтрокаТаблицы.ПериодНачало);
	КонецЕсли;
	Если КонецПериода = Неопределено Тогда
		//+са
		//КонецПериода = СтрокаТаблицы.ПериодКонец;
		//ниже вернул из-за расторжения договора
		КонецПериода = Мин(СтрокаТаблицы.ДатаОкончанияАренды, СтрокаТаблицы.ПериодКонец);
		//-са
	КонецЕсли;
	Если КоличествоВремени = Неопределено Тогда
		КоличествоВремени = (НачалоДня(КонецПериода) - НачалоДня(НачалоПериода))/ОдинДень + 1; //количество дней
	КонецЕсли;
	
	СтрокаТаблицы.КоличествоДней = КоличествоВремени;
	КоличествоДнейВМесяце = День(КонецМесяца(НачалоПериода));
	ПериодНачисления = СтрокаТаблицы.СпособНачисления.ПериодНачисления;
	Если ПериодНачисления = Перечисления.Периодичность.Неделя Тогда
		КоличествоВремениПриведенное = КоличествоВремени/7;
	ИначеЕсли ПериодНачисления = Перечисления.Периодичность.День Тогда
		КоличествоВремениПриведенное = КоличествоВремени;
	Иначе
		Если ПериодНачисления = Перечисления.Периодичность.Месяц Тогда
			КоличествоМесяцев = 1;
		ИначеЕсли ПериодНачисления = Перечисления.Периодичность.Квартал Тогда
			КоличествоМесяцев = 3;
		ИначеЕсли ПериодНачисления = Перечисления.Периодичность.Полугодие Тогда
			КоличествоМесяцев = 6;
		ИначеЕсли ПериодНачисления = Перечисления.Периодичность.Год Тогда
			КоличествоМесяцев = 12;
		Иначе
			КоличествоМесяцев = 1;
		КонецЕсли;
			
		Если НачалоДня(НачалоПериода) = НачалоМесяца(НачалоПериода) И 
			НачалоДня(КонецПериода) = НачалоДня(КонецМесяца(НачалоПериода)) Тогда
			КоличествоВремениПриведенное = 1/КоличествоМесяцев;
		ИначеЕсли НачалоДня(НачалоПериода) = НачалоГода(НачалоПериода) И 
			КонецДня(КонецПериода) = КонецГода(КонецПериода) Тогда
			КоличествоВремениПриведенное = (Год(КонецПериода) - Год(НачалоПериода) + 1) * 12 / КоличествоМесяцев;
		Иначе
			ИспользоватьСреднийМесяц = Константы.АР_ИспользоватьСреднийМесяц.Получить();
