	Иначе
		ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
		ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
		ОбщаяСтавкаНДС      = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Общая, Объект.Дата);
		ПониженнаяСтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Пониженная, Объект.Дата);
	КонецЕсли;
	
	ЗначениеОбщейСтавкиНДС      = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(ОбщаяСтавкаНДС);
	ЗначениеПониженнойСтавкиНДС = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(ПониженнаяСтавкаНДС);
	
	ЭтоУпрощенка = Ложь;
	СистемаНалогообложения = УчетнаяПолитика.СистемаНалогообложения(Объект.Организация, Объект.Дата);
	Если СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная и ПлательщикНДСПрименяющийУСН(Объект.Организация,Объект.Дата) Тогда
		ЭтоУпрощенка = Истина;
	КонецЕсли;	
	//
	
	Запрос.УстановитьПараметр("ПониженныеВидыСтавок", ПониженныеВидыСтавок);
	Запрос.УстановитьПараметр("ЗначениеОбщейСтавкиНДС", ЗначениеОбщейСтавкиНДС);
	Запрос.УстановитьПараметр("ЗначениеПониженнойСтавкиНДС", ЗначениеПониженнойСтавкиНДС);
	
	Запрос.УстановитьПараметр("СтавкаНДС", СтавкаНДС);
	
	Запрос.Текст = ПолучитьТекстЗапросаПоНачислениюПостояннойЧасти_АР17();
				
	ВыборкаУслуг = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
