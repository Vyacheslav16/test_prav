	Запрос.УстановитьПараметр("Регистратор", Источник.Ссылка);
	Запрос.УстановитьПараметр("Счет7609", ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами);
	Запрос.УстановитьПараметр("Счет76Б", ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников);
	Запрос.УстановитьПараметр("Счет7606", ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПокупателямиИЗаказчиками);

	РЗ = Запрос.Выполнить().Выбрать();

	Пока РЗ.Следующий() Цикл
		
		Проводка = Источник.Движения.Хозрасчетный.Добавить();
		Проводка.Активность = Истина;
		Проводка.Период = Источник.Дата;
		Проводка.Организация = РЗ.Организация;
		Проводка.ПодразделениеДт = РЗ.Подразделение;
		Проводка.ПодразделениеКт = РЗ.Подразделение;
		Проводка.Регистратор = Источник.Ссылка;
		
		Проводка.Содержание = "Сторно начисления дохода собственнику при зачете оплаты арендатора";
		
		Проводка.СчетДт = ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПокупателямиИЗаказчиками;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.Сумма = (-1) * РЗ.СуммаСторно;
		Проводка.СуммаНУДт = (-1) * РЗ.СуммаСторноНУ;
		Проводка.СуммаНУКт = (-1) * РЗ.СуммаСторноНУ;
		
	КонецЦикла;
	
	Источник.Движения.Хозрасчетный.Записать();

	
КонецПроцедуры


Процедура СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ)
	
	Источник.Движения.Хозрасчетный.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОбороты.СуммаОборотКт КАК СуммаЗачета,
	|	ХозрасчетныйОбороты.СуммаНУОборотКт КАК СуммаЗачетаНУ,
	|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто1 КАК Справочник.Контрагенты) КАК Контрагент,
	|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
	|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто3 КАК Документ.РеализацияТоваровУслуг) КАК РТУ,
	|	ХозрасчетныйОбороты.КорСубконто3 КАК КорСубконто3
	|ПОМЕСТИТЬ ЗачетыПрямойПринц
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(&ДатаН, &ДатаК, Регистратор, Счет = &Счет7609, , , КорСчет = &Счет7609, ) КАК ХозрасчетныйОбороты
	|ГДЕ
	|	ХозрасчетныйОбороты.Регистратор = &Регистратор
	|	И ХозрасчетныйОбороты.Субконто3 ССЫЛКА Документ.РеализацияТоваровУслуг
	|	И ХозрасчетныйОбороты.СуммаОборотКт > 0
	|	И (ХозрасчетныйОбороты.КорСубконто3 ССЫЛКА Документ.ПоступлениеНаРасчетныйСчет
	|			ИЛИ ХозрасчетныйОбороты.КорСубконто3 ССЫЛКА Документ.ДокументРасчетовСКонтрагентом)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗачетыПрямойПринц.СуммаЗачета КАК СуммаЗачета,
	|	ЗачетыПрямойПринц.СуммаЗачетаНУ КАК СуммаЗачетаНУ,
	|	ЗачетыПрямойПринц.Контрагент КАК Контрагент,
	|	ЗачетыПрямойПринц.Договор КАК Договор,
	|	ЗачетыПрямойПринц.РТУ КАК РТУ,
	|	ЗачетыПрямойПринц.КорСубконто3 КАК КорСубконто3,
	|	СчетФактураВыданный.Комитент КАК Комитент,
	|	СчетФактураВыданный.ДоговорКомитента КАК ДоговорКомитента
	|ПОМЕСТИТЬ ЗачетППОпредПр
	|ИЗ
	|	ЗачетыПрямойПринц КАК ЗачетыПрямойПринц
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|		ПО (ЗачетыПрямойПринц.КорСубконто3 = СчетФактураВыданный.ДокументОснование)
	|			И (НЕ СчетФактураВыданный.ПометкаУдаления)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗачетыПрямойПринц.СуммаЗачета,
	|	ЗачетыПрямойПринц.СуммаЗачетаНУ,
	|	ЗачетыПрямойПринц.Контрагент,
	|	ЗачетыПрямойПринц.Договор,
	|	ЗачетыПрямойПринц.РТУ,
	|	ЗачетыПрямойПринц.КорСубконто3,
	|	С_УстановкаПринципалаНаАванс.Комитент,
	|	С_УстановкаПринципалаНаАванс.ДоговорКомитента
	|ИЗ
	|	ЗачетыПрямойПринц КАК ЗачетыПрямойПринц
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.С_УстановкаПринципалаНаАванс КАК С_УстановкаПринципалаНаАванс
	|		ПО ((ВЫРАЗИТЬ(ЗачетыПрямойПринц.КорСубконто3 КАК Документ.ДокументРасчетовСКонтрагентом)) = С_УстановкаПринципалаНаАванс.Основание)
	|			И (НЕ С_УстановкаПринципалаНаАванс.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотКт КАК СуммаЗачета,
	|	ХозрасчетныйОстаткиИОбороты.СуммаНУОборотКт КАК СуммаЗачетаНУ,
