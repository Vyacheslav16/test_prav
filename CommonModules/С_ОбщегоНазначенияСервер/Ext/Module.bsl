	|	ЗачетыИтог.СуммаЗачетаНУ / (ЗачетыИтог.СуммаЗачетаНУ + ЕСТЬNULL(ЗачетыИтог.ОстатокАрендатораНУ, 0)) КАК ДоляОплатыНУ,
	|	ЗачетыИтог.КорСубконто3 КАК КорСубконто3,
	|	ЗачетыИтог.Комитент КАК Комитент,
	|	ЗачетыИтог.ДоговорКомитента КАК ДоговорКомитента
	|ПОМЕСТИТЬ ЗачетыФильтрНаПрименениеДоходовПоОплате
	|ИЗ
	|	ЗачетыИтог КАК ЗачетыИтог
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИКДоходПоОплате КАК ИКДоходПоОплате
	|			ПО АР17_ЗаключениеДоговораАренды.ИК = ИКДоходПоОплате.ИК
	|		ПО ЗачетыИтог.Договор = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК ОстатокСобств,
	|	ХозрасчетныйОстатки.СуммаНУОстатокКт КАК ОстатокСобствНУ,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты) КАК КонтрагентСобств,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК ДоговорСобств,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто3 КАК Документ.РеализацияТоваровУслуг) КАК РТУ,
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ОстаткиПоСобств
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&МоментРегистратора,
	|			Счет = &Счет76Б,
	|			,
	|			ВЫРАЗИТЬ(Субконто3 КАК Документ.РеализацияТоваровУслуг) В
	|				(ВЫБРАТЬ
	|					ВТ.РТУ КАК РТУ
	|				ИЗ
	|					ЗачетыФильтрНаПрименениеДоходовПоОплате КАК ВТ)) КАК ХозрасчетныйОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиПоСобств.КонтрагентСобств КАК КонтрагентСобств,
	|	ОстаткиПоСобств.ДоговорСобств КАК ДоговорСобств,
	|	ОстаткиПоСобств.РТУ КАК РТУ,
	|	ОстаткиПоСобств.ОстатокСобств * ЗачетыФильтрНаПрименениеДоходовПоОплате.ДоляОплаты КАК Сумма,
	|	ОстаткиПоСобств.ОстатокСобствНУ * ЗачетыФильтрНаПрименениеДоходовПоОплате.ДоляОплатыНУ КАК СуммаНУ,
	|	ОстаткиПоСобств.Организация КАК Организация,
	|	ОстаткиПоСобств.Подразделение КАК Подразделение
	|ИЗ
	|	ЗачетыФильтрНаПрименениеДоходовПоОплате КАК ЗачетыФильтрНаПрименениеДоходовПоОплате
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОстаткиПоСобств КАК ОстаткиПоСобств
	|		ПО ЗачетыФильтрНаПрименениеДоходовПоОплате.РТУ = ОстаткиПоСобств.РТУ
	|ГДЕ
	|	ЗачетыФильтрНаПрименениеДоходовПоОплате.КорСубконто3 ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗачетыИтог.Комитент,
	|	ЗачетыИтог.ДоговорКомитента,
	|	ЗачетыИтог.РТУ,
	|	ЗачетыИтог.СуммаЗачета,
	|	ЗачетыИтог.СуммаЗачетаНУ,
	|	ЗачетыИтог.РТУ.Организация,
