	|	ХозрасчетныйОстаткиИОбороты.СуммаНУКонечныйОстатокДт КАК ОстатокАрендатораНУ,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстаткиИОбороты.Субконто3 КАК Документ.РеализацияТоваровУслуг) КАК РТУ
	|ПОМЕСТИТЬ ЗачетыПоДокументу
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&ДатаН, &ДатаК, Регистратор, , Счет = &Счет7609, , ) КАК ХозрасчетныйОстаткиИОбороты
	|ГДЕ
	|	ХозрасчетныйОстаткиИОбороты.Регистратор = &Регистратор
	|	И ХозрасчетныйОстаткиИОбороты.Субконто3 ССЫЛКА Документ.РеализацияТоваровУслуг
	|	И ХозрасчетныйОстаткиИОбороты.СуммаОборотКт > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗачетыПоДокументу.СуммаЗачета КАК СуммаЗачета,
	|	ЗачетыПоДокументу.СуммаЗачетаНУ КАК СуммаЗачетаНУ,
	|	ЗачетыПоДокументу.Контрагент КАК Контрагент,
	|	ЗачетыПоДокументу.ОстатокАрендатора КАК ОстатокАрендатора,
	|	ЗачетыПоДокументу.ОстатокАрендатораНУ КАК ОстатокАрендатораНУ,
	|	ЗачетыПоДокументу.Договор КАК Договор,
	|	ЗачетыПоДокументу.РТУ КАК РТУ,
	|	NULL КАК КорСубконто3,
	|	NULL КАК Комитент,
	|	NULL КАК ДоговорКомитента
	|ПОМЕСТИТЬ ЗачетыИтог
	|ИЗ
	|	ЗачетыПоДокументу КАК ЗачетыПоДокументу
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗачетыПрямойПринц КАК ЗачетыПрямойПринц
	|		ПО ЗачетыПоДокументу.РТУ = ЗачетыПрямойПринц.РТУ
	|ГДЕ
	|	ЗачетыПрямойПринц.Контрагент ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗачетППОпредПр.СуммаЗачета,
	|	ЗачетППОпредПр.СуммаЗачетаНУ,
	|	ЗачетППОпредПр.Контрагент,
	|	NULL,
	|	NULL,
	|	ЗачетППОпредПр.Договор,
	|	ЗачетППОпредПр.РТУ,
	|	ЗачетППОпредПр.КорСубконто3,
	|	ЗачетППОпредПр.Комитент,
	|	ЗачетППОпредПр.ДоговорКомитента
	|ИЗ
