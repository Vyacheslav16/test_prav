Функция ПолучитьПредставлениеПодписантаДляОтчетаАгента(ИК, НаДату, Сторона, Договор=Неопределено, ПредставлениеШапки = Истина) Экспорт
	
	Если ЗначениеЗаполнено(Договор) Тогда
		ДоговорОтбор = Договор;
	Иначе
		ДоговорОтбор = Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	С_НастройкаПодписантовОтчетАгентаСрезПоследних.ПредставлениеШапкаОтчета КАК ПредставлениеШапкаОтчета,
	|	С_НастройкаПодписантовОтчетАгентаСрезПоследних.ПредставлениеПодвалОтчета КАК ПредставлениеПодвалОтчета,
	|	1 КАК Порядок
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	РегистрСведений.С_НастройкаПодписантовОтчетАгента.СрезПоследних(
	|			&Период,
	|			ИК = &ИК
	|				И Сторона = &Сторона
	|				И ВЫБОР
	|					КОГДА &Договор <> НЕОПРЕДЕЛЕНО
	|						ТОГДА Договор = &Договор
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК С_НастройкаПодписантовОтчетАгентаСрезПоследних
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	С_НастройкаПодписантовОтчетАгентаСрезПоследних.ПредставлениеШапкаОтчета,
	|	С_НастройкаПодписантовОтчетАгентаСрезПоследних.ПредставлениеПодвалОтчета,
	|	2
	|ИЗ
	|	РегистрСведений.С_НастройкаПодписантовОтчетАгента.СрезПоследних(
	|			&Период,
	|			ИК = &ИК
	|				И Сторона = &Сторона
	|				И Договор = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК С_НастройкаПодписантовОтчетАгентаСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ.ПредставлениеШапкаОтчета КАК ПредставлениеШапкаОтчета,
	|	ВТ.ПредставлениеПодвалОтчета КАК ПредставлениеПодвалОтчета,
	|	ВТ.Порядок КАК Порядок
	|ИЗ
	|	ВТ КАК ВТ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок";
	
	Запрос.УстановитьПараметр("ИК", ИК);
	Запрос.УстановитьПараметр("Период", НаДату);
	Запрос.УстановитьПараметр("Сторона", Сторона);
	Запрос.УстановитьПараметр("Договор", ДоговорОтбор);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Представление = "";
	
	Если РЗ.Следующий() Тогда
		Если ПредставлениеШапки Тогда
			Представление = РЗ.ПредставлениеШапкаОтчета;
		Иначе
			Представление = РЗ.ПредставлениеПодвалОтчета; 
		КонецЕсли;
	КонецЕсли;
	
	Возврат Представление;
		
КонецФункции

Функция С_ПолучитьТекстЗапросаОбъектовАрендыПоДоговоруАР() Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.Собственник КАК Собственник,
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорСобственника КАК ДоговорСобственника,
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаПередачи КАК ДатаПередачи,
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата КАК ДатаВозврата
	|ПОМЕСТИТЬ ОбъектыПоДоговоруВсе
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка = &ДоговорАР
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыПоДоговоруВсе.ОбъектАренды КАК ОбъектАренды,
	|	ОбъектыПоДоговоруВсе.Собственник КАК Собственник,
	|	ОбъектыПоДоговоруВсе.ДоговорСобственника КАК ДоговорСобственника,
	|	ОбъектыПоДоговоруВсе.ДатаПередачи КАК ДатаПередачи,
	|	ОбъектыПоДоговоруВсе.ДатаВозврата КАК ДатаВозврата
	|ПОМЕСТИТЬ ОбъектыАренды
	|ИЗ
	|	ОбъектыПоДоговоруВсе КАК ОбъектыПоДоговоруВсе
	|ГДЕ
	|	ОбъектыПоДоговоруВсе.ДатаПередачи <= &ДатаК
	|	И ВЫБОР
	|			КОГДА ОбъектыПоДоговоруВсе.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ОбъектыПоДоговоруВсе.ДатаВозврата >= &ДатаН
	|		КОНЕЦ";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция С_ПолучитьТекстЗапросаОбъектовАрендыПоИК() Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АР_ОбъектыАренды.Ссылка КАК ОбъектАренды
	|ПОМЕСТИТЬ ОбъектыАрендыИК
	|ИЗ
	|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	|ГДЕ
	|	АР_ОбъектыАренды.ТипОбъекта = &Помещение
	|	И АР_ОбъектыАренды.МОП > 0
	|	И АР_ОбъектыАренды.Ссылка В ИЕРАРХИИ(&ИК)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАренды.Собственник КАК Собственник,
	|	АР17_ЗаключениеДоговораАренды.ДоговорСобственника КАК ДоговорСобственника
	|ПОМЕСТИТЬ ДоговорАР
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАренды.Ссылка = &ДоговорАР
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыАрендыИК.ОбъектАренды КАК ОбъектАренды,
	|	ДоговорАР.Собственник КАК Собственник,
	|	ДоговорАР.ДоговорСобственника КАК ДоговорСобственника
	|ПОМЕСТИТЬ ОбъектыАренды
	|ИЗ
	|	ОбъектыАрендыИК КАК ОбъектыАрендыИК,
	|	ДоговорАР КАК ДоговорАР";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолучитьСомСоединениеТСЖ() Экспорт
	
	Сервер = "srv-1C2";
	ИмяИБ = "vertical"; 
	Логин = "Рязанова Татьяна";
	Пароль = "";
	
	//Сервер = "HV-01";
	//ИмяИБ = "test2"; 
	//Логин = "Рязанова Татьяна";
	//Пароль = "";
	
	Попытка
		
		COMConnector = Новый COMОбъект("V83.COMConnector");
		
		мИБ = COMConnector.Connect("Srvr=""" + Сервер + """;
		|Ref=""" + ИмяИБ + """;
		|Usr='" + Логин + "';
