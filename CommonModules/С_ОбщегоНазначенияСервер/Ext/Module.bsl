
Функция ПолучитьРеквизитСКлиента(Объект, Реквизит) Экспорт
	
	Возврат Объект[Реквизит];
	
КонецФункции

Функция ПолучитьСтруктуруРаспределенияНДСПоДоговору(ДоговорАренды, Дата) Экспорт
	
	Если ДоговорАренды.ОбъектыАренды.Количество() > 0 Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды КАК ОбъектАренды
		|ПОМЕСТИТЬ ДействПомПоДоговору
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
		|		ПО АР17_ЗаключениеДоговораАренды.Ссылка = АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка
		|ГДЕ
		|	АР17_ЗаключениеДоговораАренды.Ссылка = &Ссылка
		|	И АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаПередачи <= &Дата
		|	И ВЫБОР
		|			КОГДА АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата >= &Дата
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ОбъектАренды КАК ОбъектАренды,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Контрагент КАК Контрагент,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период
		|ПОМЕСТИТЬ СрезСобствВсе
		|ИЗ
		|	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(
		|			&Дата,
		|			ОбъектАренды В
		|				(ВЫБРАТЬ
		|					ВТ.ОбъектАренды
		|				ИЗ
		|					ДействПомПоДоговору КАК ВТ)) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезСобствВсе.ОбъектАренды КАК ОбъектАренды,
		|	МАКСИМУМ(СрезСобствВсе.Период) КАК Период
		|ПОМЕСТИТЬ СрезСобствМакс
		|ИЗ
		|	СрезСобствВсе КАК СрезСобствВсе
		|
		|СГРУППИРОВАТЬ ПО
		|	СрезСобствВсе.ОбъектАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезСобствВсе.ОбъектАренды КАК ОбъектАренды,
		|	СрезСобствВсе.Контрагент КАК Контрагент,
		|	СрезСобствВсе.ОбъектАренды.ЗначениеХарактеристики * (СрезСобствВсе.ДоляСобственника / 100) КАК Доля
		|ПОМЕСТИТЬ ДолиКА
		|ИЗ
		|	СрезСобствВсе КАК СрезСобствВсе
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СрезСобствМакс КАК СрезСобствМакс
		|		ПО СрезСобствВсе.ОбъектАренды = СрезСобствМакс.ОбъектАренды
		|			И СрезСобствВсе.Период = СрезСобствМакс.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	С_НалогообложениеКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
		|	С_НалогообложениеКонтрагентовСрезПоследних.СистемаНалогообложения КАК СистемаНалогообложения
		|ПОМЕСТИТЬ НОКА
		|ИЗ
		|	РегистрСведений.С_НалогообложениеКонтрагентов.СрезПоследних(
		|			&Дата,
		|			Контрагент В
		|				(ВЫБРАТЬ
		|					ВТ.Контрагент
		|				ИЗ
		|					ДолиКА КАК ВТ)) КАК С_НалогообложениеКонтрагентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НОКА.Контрагент КАК Контрагент,
		|	НОКА.СистемаНалогообложения КАК СистемаНалогообложения
		|ИЗ
		|	НОКА КАК НОКА
		|ГДЕ
		|	НОКА.СистемаНалогообложения ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ДолиКА.Доля) КАК Доля,
		|	НОКА.СистемаНалогообложения КАК СистемаНалогообложения
		|ИЗ
		|	ДолиКА КАК ДолиКА
		|		ЛЕВОЕ СОЕДИНЕНИЕ НОКА КАК НОКА
		|		ПО ДолиКА.Контрагент = НОКА.Контрагент
		|
		|СГРУППИРОВАТЬ ПО
		|	НОКА.СистемаНалогообложения";
		
		Запрос.УстановитьПараметр("Дата", Дата);
		Запрос.УстановитьПараметр("Ссылка", ДоговорАренды);
		
		ИндВыб = 6;
		ИндОш = 5;
		
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ОбъектАренды КАК ОбъектАренды,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Контрагент КАК Контрагент,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период
		|ПОМЕСТИТЬ ВТСрезИндСобств
		|ИЗ
		|	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&Период, ОбъектАренды В ИЕРАРХИИ (&ИК)) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
		|ГДЕ
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ОбъектАренды.МОП > 0
		|	И АР_СобственникиОбъектовАрендыСпрСрезПоследних.ОбъектАренды.ТипОбъекта = &Помещение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСрезИндСобств.ОбъектАренды КАК ОбъектАренды,
		|	МАКСИМУМ(ВТСрезИндСобств.Период) КАК Период
		|ПОМЕСТИТЬ СрезИндСобствМакс
		|ИЗ
		|	ВТСрезИндСобств КАК ВТСрезИндСобств
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСрезИндСобств.ОбъектАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСрезИндСобств.ОбъектАренды КАК ОбъектАренды,
		|	ВТСрезИндСобств.Контрагент КАК Контрагент,
		|	ВТСрезИндСобств.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ВТСрезИндСобств.ОбъектАренды.МОП * (ВТСрезИндСобств.ДоляСобственника / 100) КАК Доля
		|ПОМЕСТИТЬ ДолиКА
		|ИЗ
		|	ВТСрезИндСобств КАК ВТСрезИндСобств
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СрезИндСобствМакс КАК СрезИндСобствМакс
		|		ПО ВТСрезИндСобств.ОбъектАренды = СрезИндСобствМакс.ОбъектАренды
		|			И ВТСрезИндСобств.Период = СрезИндСобствМакс.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДолиКА.Доля КАК Доля,
		|	С_НалогообложениеКонтрагентовСрезПоследних.СистемаНалогообложения КАК СистемаНалогообложения,
		|	ДолиКА.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ НОКА
		|ИЗ
		|	ДолиКА КАК ДолиКА
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.С_НалогообложениеКонтрагентов.СрезПоследних(
		|				&Период,
		|				Контрагент В
		|					(ВЫБРАТЬ
		|						ВТ.Контрагент
		|					ИЗ
		|						ДолиКА КАК ВТ)) КАК С_НалогообложениеКонтрагентовСрезПоследних
		|		ПО ДолиКА.Контрагент = С_НалогообложениеКонтрагентовСрезПоследних.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НОКА.Контрагент КАК Контрагент
		|ИЗ
		|	НОКА КАК НОКА
		|ГДЕ
		|	НОКА.СистемаНалогообложения ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	НОКА.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НОКА.СистемаНалогообложения КАК СистемаНалогообложения,
		|	СУММА(НОКА.Доля) КАК Доля
		|ИЗ
		|	НОКА КАК НОКА
		|
		|СГРУППИРОВАТЬ ПО
		|	НОКА.СистемаНалогообложения";
		
		Запрос.УстановитьПараметр("Период", Дата);
		Запрос.УстановитьПараметр("ИК", ДоговорАренды.ИК);
		Запрос.УстановитьПараметр("Помещение", Справочники.АР_ТипыОбъектовАренды.Помещение);

		ИндВыб = 5;
		ИндОш = 4;
		
	КонецЕсли;
	
	РЗП = Запрос.ВыполнитьПакет();
	
	РЗ = РЗП[ИндВыб].Выбрать();
	
	АбсОСНО = 0;
	АбсУСНО = 0;
	
	Пока РЗ.Следующий() Цикл
		
		Если РЗ.СистемаНалогообложения = Перечисления.С_СистемаНалогообложения.ОСНО Тогда
			АбсОСНО = РЗ.Доля;
		ИначеЕсли РЗ.СистемаНалогообложения = Перечисления.С_СистемаНалогообложения.УСНО Тогда
			АбсУСНО = РЗ.Доля;
		Иначе
			
			РЗБНО = РЗП[ИндОш].Выбрать();
			
			Ошибка = "Внимание! Для собственников помещений договора " + Строка(ДоговорАренды) + " не указана система налогообложения!" + Символы.ПС;
			
			Пока РЗБНО.Следующий() Цикл
				Ошибка = Ошибка + "Для контрагента " + Строка(РЗБНО.Контрагент) + " не указана система налогообложения!" + Символы.ПС;
			КонецЦикла;
			
			Сообщить(Ошибка);
			Возврат Неопределено;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если (АбсОСНО+АбсУСНО) <> 0 Тогда
		
		СтруктДолей = Новый Структура;
		СтруктДолей.Вставить("ДоляОСНО", АбсОСНО/(АбсОСНО+АбсУСНО));
		СтруктДолей.Вставить("ДоляУСНО", АбсУСНО/(АбсОСНО+АбсУСНО));
		
		Возврат СтруктДолей;
		
	КонецЕсли;
	
КонецФункции

Функция ПолучитьСистемуНалогобложенияКА(КА, Дата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	С_НалогообложениеКонтрагентовСрезПоследних.СистемаНалогообложения КАК СистемаНалогообложения
		|ИЗ
		|	РегистрСведений.С_НалогообложениеКонтрагентов.СрезПоследних(&Период, Контрагент = &КА) КАК С_НалогообложениеКонтрагентовСрезПоследних";
	
	Запрос.УстановитьПараметр("КА", КА);
	Запрос.УстановитьПараметр("Период", Дата);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.СистемаНалогообложения;
	КонецЕсли;
		
КонецФункции

Функция ПрименяетсяНачислениеПоОплате(Договор=Неопределено, Контрагент=Неопределено) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ДоговорАР,
		|	АР17_ЗаключениеДоговораАренды.ИК КАК ИК
		|ПОМЕСТИТЬ ВТДоговорАР
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|ГДЕ
		|	&УсловиеНаПроверку
		|	И АР17_ЗаключениеДоговораАренды.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АР17_УстановкаПараметровИК.С_ПрименяетсяУчетДоходаСобственникаПоОплате КАК ПрименяетсяУчетДоходаСобственникаПоОплате
		|ИЗ
		|	Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДоговорАР КАК ВТДоговорАР
		|		ПО АР17_УстановкаПараметровИК.ИКСсылка = ВТДоговорАР.ИК
		|ГДЕ
		|	АР17_УстановкаПараметровИК.Проведен
		|	И АР17_УстановкаПараметровИК.С_ПрименяетсяУчетДоходаСобственникаПоОплате";	
	
	Если Договор <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНаПроверку", "АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента");
		Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	ИначеЕсли Контрагент <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНаПроверку", "АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	КонецЕсли;
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции

Функция ПолучитьДоговорАР(Договор) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ДоговорАР
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента
	|	И АР17_ЗаключениеДоговораАренды.Проведен";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.ДоговорАР;
	КонецЕсли;
	
КонецФункции

Процедура С_ОтражениеДоходаСобственникаПоОплатеОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		Если ПрименяетсяНачислениеПоОплате(Источник.ДоговорКонтрагента) Тогда
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеНаРасчетныйСчет") Тогда
		
		Если Источник.ВидОперации = Перечисления.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя 
			И ПрименяетсяНачислениеПоОплате(, Источник.Контрагент) Тогда
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.КорректировкаРеализации") Тогда
		
		Если ТипЗнч(Источник.ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
			И ПрименяетсяНачислениеПоОплате(Источник.ДокументРеализации.ДоговорКонтрагента) Тогда
			СформироватьДвиженияСторноНачисленияДоходаПоОплатеОтКорРТУ(Источник, Отказ);
			СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДвиженияСторноНачисленияДоходаПоОплатеОтКорРТУ(Источник, Отказ)
	
	Источник.Движения.Хозрасчетный.Записать();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОборотыДтКт.СуммаОборот КАК СуммаЗачета,
		|	ХозрасчетныйОборотыДтКт.СуммаНУОборотКт КАК СуммаЗачетаНУ,
		|	ВЫРАЗИТЬ(ХозрасчетныйОборотыДтКт.СубконтоДт1 КАК Справочник.Контрагенты) КАК Контрагент,
