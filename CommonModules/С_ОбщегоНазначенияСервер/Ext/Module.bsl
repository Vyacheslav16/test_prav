	Запрос.УстановитьПараметр("Регистратор", Источник.Ссылка);
	Запрос.УстановитьПараметр("Счет7609", ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами);
	Запрос.УстановитьПараметр("Счет76Б", ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников);

	РЗ = Запрос.Выполнить().Выбрать();

	Пока РЗ.Следующий() Цикл
		
		Проводка = Источник.Движения.Хозрасчетный.Добавить();
		Проводка.Активность = Истина;
		Проводка.Период = Источник.Дата;
		Проводка.Организация = РЗ.Организация;
		Проводка.ПодразделениеДт = РЗ.Подразделение;
		Проводка.ПодразделениеКт = РЗ.Подразделение;
		Проводка.Регистратор = Источник.Ссылка;
		
		Проводка.Содержание = "Начисление дохода собственнику при зачете оплаты арендатора";
		
		Проводка.СчетДт = ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетДт, Проводка.СубконтоДт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПокупателямиИЗаказчиками;
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Контрагенты", РЗ.КонтрагентСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "Договоры", РЗ.ДоговорСобств);
		БухгалтерскийУчет.УстановитьСубконто(Проводка.СчетКт, Проводка.СубконтоКт, "ДокументыРасчетовСКонтрагентами", РЗ.РТУ);
		
		Проводка.Сумма = РЗ.Сумма;
		Проводка.СуммаНУДт = РЗ.СуммаНУ;
		Проводка.СуммаНУКт = РЗ.СуммаНУ;
		
	КонецЦикла;
	
	Источник.Движения.Хозрасчетный.Записать();
	
КонецПроцедуры

Процедура С_ОтражениеДоходовСобственниковЗачетОППриЗаписи(Источник, Отказ) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ОперацияБух") Тогда
		
		ТЗДВ = Источник.Движения.Хозрасчетный.Выгрузить();
		
		Стр7609 = ТЗДВ.Найти(ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами, "СчетКт");
		Если Стр7609 = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Стр76Б = ТЗДВ.Найти(ПланыСчетов.Хозрасчетный.ОтложеныеДоходыСобственников, "СчетДт");
		Если Стр76Б <> Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		СформироватьДвиженияНачисленияДоходаОтПогашенияОстатка(Источник, Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьДолюПринципалаВМОП(ИК, Принципал, ДоговорПринципала, Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ОбъектАренды КАК ОбъектАренды,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Контрагент КАК Контрагент,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
		|	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период
		|ПОМЕСТИТЬ СрезСобственности
		|ИЗ
		|	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&Период, ОбъектАренды В ИЕРАРХИИ (&ИК)) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезСобственности.ОбъектАренды КАК ОбъектАренды,
		|	МАКСИМУМ(СрезСобственности.Период) КАК Период
		|ПОМЕСТИТЬ СрезМакс
		|ИЗ
		|	СрезСобственности КАК СрезСобственности
		|
		|СГРУППИРОВАТЬ ПО
		|	СрезСобственности.ОбъектАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезСобственности.ОбъектАренды КАК ОбъектАренды,
		|	СрезСобственности.Контрагент КАК Контрагент,
		|	СрезСобственности.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	СрезСобственности.ОбъектАренды.АП * (СрезСобственности.ДоляСобственника / 100) КАК ПлощадьСобственника,
		|	СрезСобственности.Период КАК Период
		|ПОМЕСТИТЬ СрезПлощадей
		|ИЗ
		|	СрезСобственности КАК СрезСобственности
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СрезМакс КАК СрезМакс
		|		ПО СрезСобственности.ОбъектАренды = СрезМакс.ОбъектАренды
		|			И СрезСобственности.Период = СрезМакс.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(СрезПлощадей.ПлощадьСобственника) КАК ОбщаяПлощадь
		|ПОМЕСТИТЬ ВТОбщаяПлощадь
		|ИЗ
		|	СрезПлощадей КАК СрезПлощадей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезПлощадей.Контрагент КАК Принципал,
		|	СрезПлощадей.ДоговорКонтрагента КАК ДоговорПринципала,
		|	СУММА(СрезПлощадей.ПлощадьСобственника) КАК ПлощадьСобственника
		|ПОМЕСТИТЬ ПлощадьИскомого
		|ИЗ
		|	СрезПлощадей КАК СрезПлощадей
		|ГДЕ
		|	СрезПлощадей.Контрагент = &Принципал
		|	И СрезПлощадей.ДоговорКонтрагента = &ДоговорПринципала
		|
		|СГРУППИРОВАТЬ ПО
		|	СрезПлощадей.Контрагент,
		|	СрезПлощадей.ДоговорКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлощадьИскомого.Принципал КАК Принципал,
		|	ПлощадьИскомого.ДоговорПринципала КАК ДоговорПринципала,
		|	ПлощадьИскомого.ПлощадьСобственника / ВТОбщаяПлощадь.ОбщаяПлощадь * 100 КАК ДоляПринципалаВМОП
		|ИЗ
		|	ПлощадьИскомого КАК ПлощадьИскомого,
		|	ВТОбщаяПлощадь КАК ВТОбщаяПлощадь";
	
	Запрос.УстановитьПараметр("ИК", ИК);
	Запрос.УстановитьПараметр("Принципал", Принципал);
	Запрос.УстановитьПараметр("ДоговорПринципала", ДоговорПринципала);
	Запрос.УстановитьПараметр("Период", Период);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.ДоляПринципалаВМОП;		
	КонецЕсли;
	
КонецФункции

