// Процедура заполняет документ по данным документа основания
Процедура ЗаполнитьДокументПоОснованию() Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
	// + Рогачев  Андрей от 03.12.2015
		//ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,"Дата,Номер,ПометкаУдаления,Проведен, Передан, Возвращен");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,	"Дата,ПометкаУдаления,Проведен, Передан, Возвращен,ДокументОснование");
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") 
		Тогда
	// + Рогачев  Андрей от 03.12.2015
		//ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,"Дата,Номер,ПометкаУдаления,Проведен,ДокументОснование, Передан, Возвращен");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,"Дата,ПометкаУдаления,Проведен,ДокументОснование, Передан, Возвращен");
	КонецЕсли;
	УслугаАренда = Константы.АР_УслугаАренда.Получить();
	Состав.Очистить();
	
	// + NAI Becar Гайфетдинов Р.И. от 20.11.2015 14:35
	//Для Каждого СтрокаТЧ Из ДокументОснование.ПостояннаяЧастьАренднойПлаты Цикл
	//	//Если СтрокаТЧ.Услуга = УслугаАренда Тогда
	//		НоваяСтрока = Состав.Добавить();
	//		НоваяСтрока.ОбъектАренды = СтрокаТЧ.ОбъектАренды;
	//	//КонецЕсли;
	//КонецЦикла;	
	// - NAI Becar Гайфетдинов Р.И.
	
	// + NAI Becar Комментирование Смирнов А.А. от 25.11.2016 11:11
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_ЗаключениеДоговораАренды")
		или ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") 
		Тогда
		Для Каждого Стр Из ДокументОснование.ОбъектыАренды Цикл
			
			Если ТипЗнч(ДокументОснование) <> Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда// + NAI Becar Комментирование Смирнов А.А. от 29.01.2019 11:55
				Если ЗначениеЗаполнено(Стр.ДатаПередачи) Тогда  // + NAI Becar Конюшок С.Н. от 31.07.2017 16:03 
					Продолжить;
				КонецЕсли;  // - NAI Becar Конюшок С.Н. 
			КонецЕсли; // - NAI Becar Комментирование Смирнов А.А.. от 29.01.2019 11:57
							
			НоваяСтрока = Состав.Добавить();
			НоваяСтрока.ОбъектАренды = Стр.ОбъектАренды;
			НоваяСтрока.Площадь = Стр.Площадь;
		КонецЦикла;	
	КонецЕсли;	
	// - NAI Becar Комментирование Смирнов А.А.	
	
КонецПроцедуры

Процедура ПроверитьСтатусыОбъектов(Отказ)
    		
	// Сделаем проверку на то, что объект по данному договору находится в аренде
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ ВТТабличнаяЧасть
	|ИЗ
	|	&ТабличнаяЧасть КАК ТабличнаяЧасть";
	Запрос.УстановитьПараметр("ТабличнаяЧасть", ЭтотОбъект.Состав.Выгрузить());
	Запрос.Выполнить();
	
	Запрос.УстановитьПараметр("Период", КонецДня(Дата));
	Запрос.УстановитьПараметр("Договор", ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ВАренде", Перечисления.АР_СтатусыОбъектовАренды.ВАренде);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АР_НачислениеАренднойПлатыСостав.ОбъектАренды,
	|	АР_НачислениеАренднойПлатыСостав.НомерСтроки
	|ИЗ
	|	ВТТабличнаяЧасть КАК АР_НачислениеАренднойПлатыСостав
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(&Период, Договор = &Договор) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	|		ПО АР_НачислениеАренднойПлатыСостав.ОбъектАренды = АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды
	|ГДЕ
	|	(НЕ ЕСТЬNULL(АР_СтатусыОбъектовАрендыСрезПоследних.Статус, ""Не установлен"") = &ВАренде)
	|";
	Выборка = Запрос.Выполнить().Выбрать();
	ИмяСписка = "Состав";
	Пока Выборка.Следующий() Цикл 
		//Префикс = "ПостояннаяЧастьАренднойПлаты[" + Формат(Выборка.НомерСтроки - 1, "ЧН=0; ЧГ=") + "].";
		//
		//ТекстСообщения = НСтр("ru = 'Объект аренды """ + Выборка.ОбъектАренды + """ не предусмотрен данным договором'");
		//ТекстСообщения = ОбщегоНазначенияБПКлиентСервер.ПолучитьТекстСообщения("Колонка", "Корректность", НСтр("ru = 'Объект аренды'"),
		//Выборка.НомерСтроки, ИмяСписка, ТекстСообщения);
		//Поле = Префикс + "ОбъектАренды";
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
	КонецЦикла;
	
КонецПроцедуры

