			//СтавкаКороткосрок = ?(стр.ДоходКороткосрок>0,(стр.КороткосрокДоходКотла - РасходыВозмещаемые - стр.КороткосрокДоходКотла * 0.01 - КУ*ДоляНочейКраткосрок)/стр.ПлощадьКотла*стр.ПлощадьНомера,0);
			СтавкаДолгосрок = (стр.ДолгосрокДоходКотла - стр.ДолгосрокДоходКотла * 0.01 - КУ*ДоляНочейДолгосрок)/ стр.ПлощадьКотла * стр.ПлощадьНомера;
			СтавкаКороткосрок = (стр.КороткосрокДоходКотла - РасходыВозмещаемые - стр.КороткосрокДоходКотла * 0.01 - КУ*ДоляНочейКраткосрок)/стр.ПлощадьКотла*стр.ПлощадьНомера;
			//СтавкаДолгосрок = ?(стр.ДоходДолгострок>0,стр.ДоходДолгострок - стр.ДоходДолгострок * 0.01 - (КУ/ стр.ПлощадьКотла * стр.ПлощадьНомера)*ДоляНочейДолгосрок,0);
			//СтавкаКороткосрок = ?(стр.ДоходКороткосрок>0,стр.ДоходКороткосрок - РасходыВозмещаемые/стр.ПлощадьКотла*стр.ПлощадьНомера - стр.ДоходКороткосрок * 0.01 - (КУ/ стр.ПлощадьКотла * стр.ПлощадьНомера)*ДоляНочейКраткосрок,0);
			РасходыВозмещаемыеДолгосрок = стр.ДоходДолгострок * 0.01; 
			РасходыВозмещаемыеКороткосрок = РасходыВозмещаемые/стр.ПлощадьКотла*стр.ПлощадьНомера + стр.ДоходКороткосрок * 0.01;
			ВознаграждениеУКДолгосрок = СтавкаДолгосрок * 0.15;
			ВознаграждениеУККороткосрок = СтавкаКороткосрок * 0.2;
			Если (ВознаграждениеУКДолгосрок + ВознаграждениеУККороткосрок <= 0) ИЛИ ОтетИнвестора.СреднийТариф <= 0 Тогда
				ВознаграждениеУКДолгосрок = 0;
				ВознаграждениеУККороткосрок = 0;
			КонецЕсли;	
			ОтетИнвестора.РасходыУслугиУК = ВознаграждениеУКДолгосрок + ВознаграждениеУККороткосрок;
			ОтетИнвестора.КУ = КУ;    
			ДоходПр = СтавкаДолгосрок - ВознаграждениеУКДолгосрок + СтавкаКороткосрок - ВознаграждениеУККороткосрок;//ОтетИнвестора.СреднийТариф - ОтетИнвестора.РасходыУслугиУК;   
            ОтетИнвестора.ДоходЗаОтчетныйПериод = ДоходПр;
			
			Если стр.ГарантированныйДоход > 0 Тогда
				РазницаВДняхПред = (КонецМесяца(Объект.Период) - КонецДня(стр.ДатаПередачи)) / (60 * 60 * 24) + 1;
				ГДМ = стр.ГарантированныйДоход * РазницаВДняхПред/День(КонецМесяца(Объект.Период)); 
				ДоходПр = ?(ДоходПр > ГДМ,ДоходПр,ГДМ); 
				//ОтетИнвестора.СреднийТариф = ?(ДоходПр > ГДМ,ОтетИнвестора.СреднийТарифОтетИнвестора.СреднийТариф,ГДМ);
			КонецЕсли;			
			ОтетИнвестора.ЧистыйДоход = ДоходПр;
			ОтетИнвестора.ПлощадьКотла = стр.ПлощадьКотла;
			ОтетИнвестора.Эквайринг = (стр.ДолгосрокДоходКотла * 0.01 + стр.КороткосрокДоходКотла * 0.01) * ОтетИнвестора.ДоляПомещения;  
			ОтетИнвестора.ОбщиеРасходыНаУправление = стр.РасходыОбщиеК / стр.КоличествоВсехКотлов;
			//ОтетИнвестора.ОбщиеРасходыНаУправление = ПолучитьРасход(стр.Котел, Истина) * ОтетИнвестора.ДоляПомещения; 
			ОтетИнвестора.Посредники = (ПолучитьРасход(стр.Котел, Истина, Справочники.ПР_ТипыРасходовОтеля.КомиссииСистемБронированияVALO) 
										+ ПолучитьРасход(стр.Котел, Истина, Справочники.ПР_ТипыРасходовОтеля.КомиссииСистемБронированияRAMADA)) * ОтетИнвестора.ДоляПомещения; 
			ОтетИнвестора.Расходники = ПолучитьРасход(стр.Котел, Истина, Справочники.ПР_ТипыРасходовОтеля.РасходныеМатериалыИУслуги) * ОтетИнвестора.ДоляПомещения; 
			//ОтетИнвестора.ОбщиеРасходыНаУправление = ПолучитьРасход(стр.Котел, Истина) * ОтетИнвестора.ДоляПомещения; 
			ОтетИнвестора.Уборка = ПолучитьГРасходыКотла(стр.Котел) * ОтетИнвестора.ДоляПомещения; 
			//ОтетИнвестора.ЧистыйДоход = СтавкаДолгосрок - ВознаграждениеУКДолгосрок + СтавкаКороткосрок - ВознаграждениеУККороткосрок;
		Иначе
		//	ОтетИнвестора.РасходыУслугиУК = ?(стр.ДоходДолгострок=0,0,(стр.ДоходДолгострок - стр.ДоходДолгострок * 0.01) * 0.15) + ?(стр.ДоходКороткосрок=0,0,(стр.ДоходКороткосрок - стр.ДоходКороткосрок * 0.01 - ОтетИнвестора.РасходыВозмещаемые/стр.ПлощадьКотла*стр.ПлощадьНомера - КУ/стр.ПлощадьКотла*стр.ПлощадьНомера) * 0.2);
		//КонецЕсли;	
		//Иначе
			ВыручкаНомера = стр.ДоходДолгострок + стр.ДоходКороткосрок;
			РасходыВозмещаемые = стр.РасходыНомера; // + ВыручкаНомера * 0.01;
			РасходыВозмещаемыеДолгосрок = стр.ДоходДолгострок * 0.01; 
			РасходыВозмещаемыеКороткосрок = РасходыВозмещаемые + стр.ДоходКороткосрок * 0.01;
			СтавкаДолгосрок = ?(НЕ стр.КоличествоДолгосрок+стр.КоличествоКороткосрок = 0,стр.ДоходДолгострок - РасходыВозмещаемыеДолгосрок  - КУ/(стр.КоличествоДолгосрок+стр.КоличествоКороткосрок) * стр.КоличествоДолгосрок,стр.ДоходДолгострок - РасходыВозмещаемыеДолгосрок);
			СтавкаКороткосрок = ?(НЕ стр.КоличествоДолгосрок+стр.КоличествоКороткосрок = 0,стр.ДоходКороткосрок - РасходыВозмещаемыеКороткосрок - КУ/(стр.КоличествоДолгосрок+стр.КоличествоКороткосрок) * стр.КоличествоКороткосрок,стр.ДоходКороткосрок - РасходыВозмещаемыеКороткосрок);
			//СтавкаДолгосрок = ?(стр.ДоходДолгострок>0 И стр.КоличествоДолгосрок > 0,стр.ДоходДолгострок - РасходыВозмещаемыеДолгосрок  - КУ/(стр.КоличествоДолгосрок+стр.КоличествоКороткосрок) * стр.КоличествоДолгосрок,0);
			//СтавкаКороткосрок = ?(стр.ДоходКороткосрок>0 И стр.КоличествоКороткосрок > 0,стр.ДоходКороткосрок - РасходыВозмещаемыеКороткосрок - КУ/(стр.КоличествоДолгосрок+стр.КоличествоКороткосрок) * стр.КоличествоКороткосрок,0);
			ВознаграждениеУКДолгосрок = СтавкаДолгосрок * 0.15;
			ОтетИнвестора.КУ = КУ;    
			ОтетИнвестора.ПлощадьКотла = стр.ПлощадьНомера;    
			ОтетИнвестора.Эквайринг = стр.ДоходДолгострок * 0.01 + стр.ДоходКороткосрок * 0.01;    
			ОтетИнвестора.ОбщиеРасходыНаУправление = стр.РасходыОбщиеП; 
			ВознаграждениеУККороткосрок = СтавкаКороткосрок * 0.2;
			Если (ВознаграждениеУКДолгосрок + ВознаграждениеУККороткосрок <= 0) ИЛИ ОтетИнвестора.СреднийТариф <= 0 Тогда
				ВознаграждениеУКДолгосрок = 0;
				ВознаграждениеУККороткосрок = 0;
			КонецЕсли;
			ОтетИнвестора.Уборка = ПолучитьГРасходыНомера(стр.ОбъектАренды); 
		КонецЕсли;
		ОУ = РасходыНомера(стр.ОбъектАренды, Справочники.ПР_ТипыРасходовОтеля.ОсвежающаяУборка);
		Если НЕ ОУ = Неопределено Тогда
			ОтетИнвестора.ОУКолво = ОУ.Количество;
			ОтетИнвестора.ОУТариф = ОУ.Тариф;
		КонецЕсли;	
		Уб = РасходыНомера(стр.ОбъектАренды, Справочники.ПР_ТипыРасходовОтеля.УборкаКраткосрок);
		Если Не Уб = Неопределено Тогда
			ОтетИнвестора.Убор = Уб.Количество;
			ОтетИнвестора.УборТариф = Уб.Тариф;
		КонецЕсли;
		ПерБ = РасходыНомера(стр.ОбъектАренды, Справочники.ПР_ТипыРасходовОтеля.перестил);    
		Если Не ПерБ = Неопределено  Тогда
			ОтетИнвестора.Перестил = ПерБ.Количество;
			ОтетИнвестора.ПерестилТариф = ПерБ.Тариф; 
		КонецЕсли;
		ЗастБ = РасходыНомера(стр.ОбъектАренды, Справочники.ПР_ТипыРасходовОтеля.застил);
		Если Не ЗастБ = Неопределено  Тогда
			ОтетИнвестора.Застил = ЗастБ.Количество;
			ОтетИнвестора.ЗастилТариф = ЗастБ.Тариф;
		КонецЕсли;
		Если стр.ЭтоКотел Тогда
			ОтетИнвестора.ЧестныйДоход	=  СтавкаДолгосрок - ВознаграждениеУКДолгосрок + СтавкаКороткосрок - ВознаграждениеУККороткосрок;
			ОтетИнвестора.ЧестныйРасход	= стр.РасходыНомера + (стр.ДоходДолгострок + стр.ДоходКороткосрок) * 0.01;
			ОтетИнвестора.ЧестнаяКУ		= 0;//ПолучитьКУ(Объект.Период,стр.Ссылка,стр.ОбъектАренды, Ложь, Неопределено, Неопределено);  
			ОтетИнвестора.НеустойкаГарант = ?(ОтетИнвестора.ДоходЗаОтчетныйПериод - ОтетИнвестора.ЧистыйДоход < 0,- ОтетИнвестора.ДоходЗаОтчетныйПериод + ОтетИнвестора.ЧистыйДоход, 0);
		Иначе
			ОтетИнвестора.ЧестныйДоход 	= СтавкаДолгосрок - ВознаграждениеУКДолгосрок + СтавкаКороткосрок - ВознаграждениеУККороткосрок;
			ОтетИнвестора.ЧестныйРасход	= ОтетИнвестора.РасходыВозмещаемые;
			ОтетИнвестора.ЧестнаяКУ		= ОтетИнвестора.КУ;
			
			ОтетИнвестора.РасходыУслугиУК = ВознаграждениеУКДолгосрок + ВознаграждениеУККороткосрок;
			ОтетИнвестора.ЧистыйДоход = СтавкаДолгосрок - ВознаграждениеУКДолгосрок + СтавкаКороткосрок - ВознаграждениеУККороткосрок;
            ОтетИнвестора.ДоходЗаОтчетныйПериод = ОтетИнвестора.ЧистыйДоход;
			Если КУ>0 и ОтетИнвестора.ЧистыйДоход = 0 Тогда
				ОтетИнвестора.ЧистыйДоход = -КУ;	
			КонецЕсли;
		КонецЕсли;	
		//КонецЕсли;
		ОтетИнвестора.УдержанияИзДохода = ОтетИнвестора.Оснащение;
		ОтетИнвестора.КВыплате = ОтетИнвестора.ЧистыйДоход - ОтетИнвестора.Оснащение;
		
		Попытка
			ОтетИнвестора.Записать(РежимЗаписиДокумента.Проведение);
		Исключение	
			ОтетИнвестора.Записать(РежимЗаписиДокумента.Запись); 
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьРасход(Помещение, ЭтоКотел, ТипРасхода);
	Запрос = Новый Запрос;
	Если ТипЗнч(Помещение) = Тип("СправочникСсылка.ПР_Котлы") Тогда
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
		               |	МАКСИМУМ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи) КАК ДатаПередачи,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент КАК Контрагент,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента
		               |ПОМЕСТИТЬ ЗДАМАКС
		               |ИЗ
		               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
		               |ГДЕ
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК = &ИК
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаОкончания
		               |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаНачала
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен = ИСТИНА
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды
		               |ПОМЕСТИТЬ ЗДА
		               |ИЗ
		               |	ЗДАМАКС КАК ЗДАМАКС
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
		               |		ПО ЗДАМАКС.ОбъектАренды = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды
		               |			И ЗДАМАКС.Контрагент = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент
		               |			И ЗДАМАКС.ДоговорКонтрагента = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента
		               |			И ЗДАМАКС.ДатаПередачи = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи
		               |ГДЕ
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК = &ИК
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен = ИСТИНА
		               |	И НЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ПрограммаДоходности = ЗНАЧЕНИЕ(Справочник.АР_ПрограммыДоходности.ПустаяСсылка)
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел = &Котел
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЕСТЬNULL(СУММА(ПР_ОтельРасходыНомера.Расход), 0) КАК Расход
		               |ИЗ
		               |	ЗДА КАК ЗДА
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПР_Отель.РасходыНомера КАК ПР_ОтельРасходыНомера
		               |		ПО ЗДА.ОбъектАренды = ПР_ОтельРасходыНомера.Номер
		               |ГДЕ
		               |	ПР_ОтельРасходыНомера.Ссылка = &Док
		               |	И ПР_ОтельРасходыНомера.ТипРасхода = &ТипРасхода";  
		Запрос.УстановитьПараметр("ДатаНачала",НачалоМесяца(Объект.Период));
		Запрос.УстановитьПараметр("ДатаОкончания",КонецМесяца(Объект.Период));
		Запрос.УстановитьПараметр("Котел",Помещение);
		Запрос.УстановитьПараметр("ИК",Объект.ИК);
	Иначе	
		Запрос.Текст = "ВЫБРАТЬ
		               |	ЕстьNULL(СУММА(ПР_ОтельРасходыНомера.Расход),0) КАК Расход
		               |ИЗ
		               |	Документ.ПР_Отель.РасходыНомера КАК ПР_ОтельРасходыНомера
		               |ГДЕ
		               |	ПР_ОтельРасходыНомера.Номер = &Номер
		               |	И ПР_ОтельРасходыНомера.Ссылка = &Док
		               |	И ПР_ОтельРасходыНомера.ТипРасхода = &ТипРасхода";  
		Запрос.УстановитьПараметр("Номер",Помещение);
	КонецЕсли;
	Запрос.УстановитьПараметр("Док",Объект.Ссылка);
	Запрос.УстановитьПараметр("ТипРасхода",ТипРасхода);
	Рез = Запрос.Выполнить().Выгрузить(); 
	Возврат Рез[0].Расход;
КонецФункции	
	
Функция ПолучитьГРасходыКотла(Котел)
	Запрос = Новый Запрос;
	Если ТипЗнч(Котел) = Тип("СправочникСсылка.ПР_Котлы") Тогда
		Запрос.Текст = "ВЫБРАТЬ
