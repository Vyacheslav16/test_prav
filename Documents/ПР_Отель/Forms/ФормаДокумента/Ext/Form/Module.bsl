Процедура ЗагрузитьДальше15(НомерАп,ЗастилНомер,ПерестилНомер,ОсУборкаНомер,УК,РМ,КомВало,КомРамада)
	Если Не ЗастилНомер = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Количество = ЗастилНомер;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.застил");
	КонецЕсли;	
	Если Не ПерестилНомер = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Количество = ПерестилНомер;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.перестил");
	КонецЕсли;	
	Если Не ОсУборкаНомер = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Количество = ОсУборкаНомер;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.ОсвежающаяУборка");
	КонецЕсли;	
	Если Не УК = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Количество = УК;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.УборкаКраткосрок");
	КонецЕсли;	
	Если Не РМ = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Расход = РМ;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.РасходныеМатериалыИУслуги");
	КонецЕсли;	
	Если Не КомВало = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Расход = КомВало;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.КомиссииСистемБронированияVALO");
	КонецЕсли;	
	Если Не КомРамада = 0 Тогда 
		РН = Объект.РасходыНомера.Добавить();
		РН.Номер = НомерАп;
		РН.Расход = КомРамада;
		РН.ТипРасхода = ПредопределенноеЗначение("Справочник.ПР_ТипыРасходовОтеля.КомиссииСистемБронированияRAMADA");
	КонецЕсли;
КонецПроцедуры 

Функция НайтиНомер(Номер)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ОбъектыАренды.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	               |ГДЕ
	               |	АР_ОбъектыАренды.Наименование = &Наименование
	               |	И АР_ОбъектыАренды.ТипОбъекта = &ТипПомещения";
	Запрос.УстановитьПараметр("Наименование",Номер);
	Запрос.УстановитьПараметр("ТипПомещения",Справочники.АР_ТипыОбъектовАренды.Офис);
	Рез = Запрос.Выполнить().Выгрузить(); 
	Если Рез.Количество() = 0 тогда
		ВОЗВРАТ НЕОПРЕДЕЛЕНО;
	ИНАЧЕ
		Возврат Рез[0].Ссылка; 
	КонецЕсли;
	
КонецФункции	

Процедура ДобавитьДоходД(НомерАп,ДатаНачала,ДатаОкончания,Количество,Доход) 
	Если Количество > 0 Тогда	
		ДД = Объект.ДоходыДолгосрок.Добавить();
		ДД.Номер = НомерАп;
		ДД.ДатаНачала = ДатаНачала;
		ДД.ДатаОкончания = ДатаОкончания;
		ДД.Количество = Количество;
		ДД.Доход = Доход;          
		Если Не Количество = 0 И Объект.ТурНалог Тогда
			Если Доход / Количество > 10000 Тогда  
				ДД.ТурНалог = Доход * 0.01;
			Иначе
				ДД.ТурНалог = Количество * 100;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры	

Процедура ДобавитьДоходК(НомерАп,ДатаНачала,ДатаОкончания,Количество,Доход)  
	Если Количество > 0 Тогда	
		ДД = Объект.ДоходыКороткосрок.Добавить();
		ДД.Номер = НомерАп;
		ДД.ДатаНачала = ДатаНачала;
		ДД.ДатаОкончания = ДатаОкончания;
		ДД.Количество = Количество;
		ДД.Доход = Доход;
		Если Не Количество = 0 И Объект.ТурНалог Тогда
			Если Доход / Количество > 10000 Тогда  
				ДД.ТурНалог = Доход * 0.01;
			Иначе
				ДД.ТурНалог = Количество * 100;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры	


Процедура ДобавитьРасход(НаимРасхода,СуммаРасхода,ДП) 
	Если Не СуммаРасхода = 0 Тогда	
		РО = Объект.РасходыОбщие.Добавить();
		Расход = Справочники.ПР_ТипыРасходовОтеля.НайтиПоНаименованию(НаимРасхода);
		Если Расход = Справочники.ПР_ТипыРасходовОтеля.ПустаяСсылка() Тогда
			Расход = Справочники.ПР_ТипыРасходовОтеля.СоздатьЭлемент();
			Расход.Наименование = НаимРасхода;
			Расход.Записать();
			Расход = Расход.Ссылка;
		КонецЕсли;
		РО.ТипРасхода = Расход;
		РО.Расход = СуммаРасхода;
		РО.ДоходнаяПрограмма = ДП;
	КонецЕсли;
КонецПроцедуры	

