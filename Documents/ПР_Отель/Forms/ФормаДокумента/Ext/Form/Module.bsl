Процедура СоздатьОтчетыНаСервереНовый()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	               |	МАКСИМУМ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи) КАК ДатаПередачи,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент КАК Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	МИНИМУМ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи) КАК ДатаПередачиМин
	               |ПОМЕСТИТЬ ЗДАМАКС
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |ГДЕ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК = &ИК
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаОкончания
	               |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаНачала
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен = ИСТИНА
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка КАК Ссылка,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи КАК ДатаПередачи,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата КАК ДатаВозврата,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ПрограммаДоходности КАК ПрограммаДоходности,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Гарантированныйдоход КАК Гарантированныйдоход,
	               |	НЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел = ЗНАЧЕНИЕ(Справочник.ПР_Котлы.ПустаяСсылка) КАК ЭтоКотел,
	               |	ВЫБОР
	               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи < НАЧАЛОПЕРИОДА(&ДатаОкончания, МЕСЯЦ)
	               |			ТОГДА ВЫБОР
	               |					КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ)
	               |							ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
	               |						ТОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь
	               |					ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь * (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаОкончания, МЕСЯЦ), АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ) + 1) / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаОкончания, МЕСЯЦ), КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ), ДЕНЬ) + 1)
	               |				КОНЕЦ
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ)
	               |						ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
	               |					ТОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь * (РАЗНОСТЬДАТ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи, КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ), ДЕНЬ) + 1) / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаОкончания, МЕСЯЦ), КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ), ДЕНЬ) + 1)
	               |				ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь * (РАЗНОСТЬДАТ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи, АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ) + 1) / (РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&ДатаОкончания, МЕСЯЦ), КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ), ДЕНЬ) + 1)
	               |			КОНЕЦ
	               |	КОНЕЦ КАК Площадь,
	               |	ВЫБОР
	               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел = ЗНАЧЕНИЕ(Справочник.ПР_Котлы.ПустаяСсылка)
	               |			ТОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды
	               |		ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел
	               |	КОНЕЦ КАК Котел,
	               |	ВЫБОР
