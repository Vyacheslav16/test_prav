&НаКлиенте
Процедура ЗагрузитьПродолжить()
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Документ Excel (*.xls, *.xlsx)|*.xls;*.xlsx|";
	Диалог.Заголовок = "Расходы";
	Если Диалог.Выбрать() Тогда
	     Путь = Диалог.ПолноеИмяФайла;
	
		Попытка
			Эксель = Новый COMОбъект("Excel.Application"); 
		Исключение
			Сообщить(ОписаниеОшибки()); 
			Возврат;
		КонецПопытки;
		Книга = Эксель.WorkBooks.Open(Путь);
		
		Лист = Книга.Sheets("5. Расх.часть инд."); 
	   	ХЗ2 = СтрЗаменить(СокрЛП(Лист.Cells(2,2).Value),Символы.НПП,""); 
	   	ХЗ3 = СтрЗаменить(СокрЛП(Лист.Cells(3,2).Value),Символы.НПП,""); 
	   	ХЗ4 = СтрЗаменить(СокрЛП(Лист.Cells(4,2).Value),Символы.НПП,""); 
	   	ХЗ5 = СтрЗаменить(СокрЛП(Лист.Cells(5,2).Value),Символы.НПП,""); 
		ЗагрузитьДальше1(ХЗ2,ХЗ3,ХЗ4,ХЗ5); 
		ВсегоСтрок = Лист.Cells(1,1).SpecialCells(11).Row;
		Для НС = 2 по ВсегоСтрок Цикл
		//Для НС = 2 по 497 Цикл
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,8).Value),"-","") = "" Тогда
				Продолжить;
			КонецЕСли;
			НомерАп				= НайтиНомер(СтрЗаменить(СокрЛП(Лист.Cells(НС,8).Value),Символы.НПП,"")); 
			Если НомерАп = Неопределено ТОгда 
				Сообщить(СтрЗаменить(СокрЛП(Лист.Cells(НС,8).Value),Символы.НПП,"") + "Ну и еще " + строка(НС));
				Возврат;
			КонецЕсли;
			Если НЕ ПринадлЭлементу(НомерАП,Объект.ИК) Тогда
				Продолжить;
			КонецЕсли;
			//Категория 			= СтрЗаменить(СокрЛП(Лист.Cells(НС,10).Value),Символы.НПП,"");
			ЗастилНомер			= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,16).Value),Символы.НПП,""));
			ПерестилНомер		= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,12).Value),Символы.НПП,""));
			ОсУборкаНомер		= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,15).Value),Символы.НПП,""));
			УК					= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,14).Value),Символы.НПП,""));
			РМ					= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,17).Value),Символы.НПП,""));
			КомВало				= Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,18).Value),Символы.НПП,""));
			КомРамада	 		= 0;//Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,19).Value),Символы.НПП,""));
		    ЗагрузитьДальше15(НомерАп,ЗастилНомер,ПерестилНомер,ОсУборкаНомер,УК,РМ,КомВало,КомРамада);
		КонецЦикла;
		
		Книга = Эксель.WorkBooks.Open(Путь);
		
		Лист = Книга.Sheets("4.Расходная часть аренды");
		ВсегоСтрок = Лист.Cells(1,1).SpecialCells(11).Row;
		Для НС = 2 по ВсегоСтрок Цикл 
			НаимРасхода = СтрЗаменить(СокрЛП(Лист.Cells(НС,1).Value),Символы.НПП,""); 
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,2).Value),Символы.НПП,"") = "" Тогда
				Продолжить;
			КонецЕсли;
			СуммаРасхода = Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,2).Value),Символы.НПП,""));   
			ДП = Найти(СокрЛП(Лист.Cells(НС,3).Value),"доходная прг.") > 0;
			ДобавитьРасход(НаимРасхода,СуммаРасхода,ДП);
		КонецЦикла;
		Эксель.WorkBooks.Close();
		Эксель.Quit(); 
	КонецЕсли;

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Документ Excel (*.xls, *.xlsx)|*.xls;*.xlsx|";
	Диалог.Заголовок = "Доходы";
	Если Диалог.Выбрать() Тогда
	     Путь = Диалог.ПолноеИмяФайла;
	
		Попытка
			Эксель = Новый COMОбъект("Excel.Application"); 
		Исключение
			Сообщить(ОписаниеОшибки()); 
			Возврат;
		КонецПопытки;
		Книга = Эксель.WorkBooks.Open(Путь);
		
		Лист = Книга.Sheets("Долгосрок");
		ВсегоСтрок = Лист.Cells(1,1).SpecialCells(11).Row;
		Для НС = 2 по ВсегоСтрок Цикл 
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,1).Value),"-","") = "" Тогда
				Продолжить;
			КонецЕсли;
			Если СокрЛП(Лист.Cells(НС,1).Value) = "" Тогда
				Продолжить;
			КонецЕсли;
			НомерАп	= НайтиНомер(СтрЗаменить(СокрЛП(Лист.Cells(НС,1).Value),"-",""));  
			Если НомерАп = Неопределено ТОгда 
				Продолжить;
			КонецЕсли;
			//Сообщить(СокрЛП(Лист.Cells(НС,1).Value) + " - " + Строка(НомерАп));
			Если НЕ ПринадлЭлементу(НомерАП,Объект.ИК) Тогда
				Продолжить;
			КонецЕсли;
			ДатаНачала = СокрЛП(Лист.Cells(НС,6).Value);
			ДатаОкончания = СокрЛП(Лист.Cells(НС,7).Value); 
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,9).Value),Символы.НПП,"") = "" Тогда
				Продолжить;
			КонецЕсли;
			Количество = Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,9).Value),Символы.НПП,""));  
			Доход = СтрЗаменить(СокрЛП(Лист.Cells(НС,10).Value),Символы.НПП,"");
			ДобавитьДоходД(НомерАп,ДатаНачала,ДатаОкончания,Количество,Доход);
		КонецЦикла;

		Лист = Книга.Sheets("Краткосрок");
		ВсегоСтрок = Лист.Cells(1,1).SpecialCells(11).Row;
		Для НС = 2 по ВсегоСтрок Цикл 
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,1).Value),"-","") = "" Тогда
				Продолжить;
			КонецЕсли;
			НомерАп	= НайтиНомер(СтрЗаменить(СокрЛП(Лист.Cells(НС,1).Value),"-","")); 
			Если СокрЛП(Лист.Cells(НС,1).Value) = "" Тогда
				Продолжить;
			КонецЕсли;
			ДатаНачала = СокрЛП(Лист.Cells(НС,6).Value);
			ДатаОкончания = СокрЛП(Лист.Cells(НС,7).Value);  
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,9).Value),Символы.НПП,"") = "" Тогда
				Продолжить;
			КонецЕсли;
			Количество = Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,9).Value),Символы.НПП,""));  
			Доход = СтрЗаменить(СокрЛП(Лист.Cells(НС,10).Value),Символы.НПП,"");
			ДобавитьДоходК(НомерАп,ДатаНачала,ДатаОкончания,Количество,Доход);
		КонецЦикла;
		Эксель.WorkBooks.Close();
		Эксель.Quit();

	КонецЕсли;

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Документ Excel (*.xls, *.xlsx)|*.xls;*.xlsx|";
	Диалог.Заголовок = "Оснащение";
	Если Диалог.Выбрать() Тогда
	     Путь = Диалог.ПолноеИмяФайла;
	
		Попытка
			Эксель = Новый COMОбъект("Excel.Application"); 
		Исключение
			Сообщить(ОписаниеОшибки()); 
			Возврат;
		КонецПопытки;
		Книга = Эксель.WorkBooks.Open(Путь);
		
		Лист = Книга.Sheets("Лист1");
		ВсегоСтрок = Лист.Cells(1,1).SpecialCells(11).Row;
		Для НС = 2 по ВсегоСтрок Цикл 
			НомерАп	= НайтиНомер(СтрЗаменить(СокрЛП(Лист.Cells(НС,5).Value),Символы.НПП,"")); 
			Если СокрЛП(Лист.Cells(НС,5).Value) = "" Тогда
				Продолжить;
			КонецЕсли;
			Если НЕ ПринадлЭлементу(НомерАП,Объект.ИК) Тогда
				Продолжить;
			КонецЕсли;
			Если СтрЗаменить(СокрЛП(Лист.Cells(НС,9).Value),Символы.НПП,"") = "" Тогда
				Продолжить;
			КонецЕсли;
			СуммаОс = Число(СтрЗаменить(СокрЛП(Лист.Cells(НС,10).Value),Символы.НПП,""));  
			Договор = СокрЛП(Лист.Cells(НС,7).Value);
			ДобавитьОснащение(НомерАп,СуммаОс,Договор);
		КонецЦикла;
		Эксель.WorkBooks.Close();
		Эксель.Quit();
	КонецЕсли;
	
КонецПроцедуры  


Функция ПринадлЭлементу(Номер,ИК)
	Возврат Номер.ПринадлежитЭлементу(ИК);
КонецФункции

Процедура ДобавитьОснащение(НомерАп,СуммаОс,Договор) 
	Если СуммаОс > 0 Тогда	
		РО = Объект.РасходыОснащения.Добавить();
		РО.Номер = НомерАп;
		РО.Расход = СуммаОс;
		РО.Договор = Договор;
	КонецЕсли;
КонецПроцедуры	

