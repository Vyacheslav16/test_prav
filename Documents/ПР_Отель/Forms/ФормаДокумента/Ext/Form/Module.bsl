	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи КАК ДатаПередачи,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата КАК ДатаВозврата,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ПрограммаДоходности КАК ПрограммаДоходности,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Гарантированныйдоход КАК Гарантированныйдоход,
	               |	НЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел = ЗНАЧЕНИЕ(Справочник.ПР_Котлы.ПустаяСсылка) КАК ЭтоКотел,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Котел КАК Котел
	               |ПОМЕСТИТЬ ЗДА
	               |ИЗ
	               |	ЗДАМАКС КАК ЗДАМАКС
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |		ПО ЗДАМАКС.ОбъектАренды = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды
	               |			И ЗДАМАКС.Контрагент = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент
	               |			И ЗДАМАКС.ДоговорКонтрагента = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента
	               |			И ЗДАМАКС.ДатаПередачи = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи
	               |ГДЕ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК = &ИК
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен = ИСТИНА
	               |	И НЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ПрограммаДоходности = ЗНАЧЕНИЕ(Справочник.АР_ПрограммыДоходности.ПустаяСсылка)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПР_ОтельРасходыНомера.Номер КАК Номер,
	               |	СУММА(ЕСТЬNULL(ПР_ОтельРасходыНомера.Количество, 0)) КАК Количество,
	               |	СУММА(ВЫБОР
	               |			КОГДА ЕСТЬNULL(ПР_ОтельРасходыНомера.Количество, 0) > 0
	               |				ТОГДА ПР_ОтельРасходыНомера.Количество * ПР_ОтельТарифы.Цена
	               |			ИНАЧЕ ЕСТЬNULL(ПР_ОтельРасходыНомера.Расход, 0)
	               |		КОНЕЦ) КАК Сумма,
	               |	ПР_ОтельРасходыНомера.ТипРасхода КАК ТипРасхода,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ПР_ОтельРасходыНомера.Количество, 0) > 0
	               |			ТОГДА ПР_ОтельТарифы.Цена
	               |		ИНАЧЕ ЕСТЬNULL(ПР_ОтельРасходыНомера.Расход, 0)
	               |	КОНЕЦ КАК Тариф
	               |ПОМЕСТИТЬ РасходыНомера1
	               |ИЗ
	               |	Документ.ПР_Отель.РасходыНомера КАК ПР_ОтельРасходыНомера
	               |		{ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПР_Отель.Тарифы КАК ПР_ОтельТарифы
	               |		ПО ПР_ОтельРасходыНомера.ТипРасхода = ПР_ОтельТарифы.ТипРасхода
	               |			И ПР_ОтельРасходыНомера.Номер.КлассПомещения = ПР_ОтельТарифы.КатегорияНомера}
	               |ГДЕ
	               |	(ПР_ОтельРасходыНомера.Ссылка = &Ссылка
	               |			ИЛИ ПР_ОтельРасходыНомера.Ссылка ЕСТЬ NULL)
	               |	И (ПР_ОтельТарифы.Ссылка = &Ссылка
	               |			ИЛИ ПР_ОтельТарифы.Ссылка ЕСТЬ NULL)
	               |	И ПР_ОтельРасходыНомера.Количество > 0
	               |	И ПР_ОтельРасходыНомера.Номер = &Номер
	               |	И ПР_ОтельРасходыНомера.ТипРасхода = &ТипРасхода
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПР_ОтельРасходыНомера.ТипРасхода,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ПР_ОтельРасходыНомера.Количество, 0) > 0
	               |			ТОГДА ПР_ОтельТарифы.Цена
	               |		ИНАЧЕ ЕСТЬNULL(ПР_ОтельРасходыНомера.Расход, 0)
	               |	КОНЕЦ,
	               |	ПР_ОтельРасходыНомера.Номер
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РасходыНомера1.Номер КАК Номер,
	               |	СУММА(ЕСТЬNULL(РасходыНомера1.Количество, 0)) КАК Количество,
	               |	РасходыНомера1.Сумма КАК Сумма,
	               |	РасходыНомера1.ТипРасхода КАК ТипРасхода,
	               |	РасходыНомера1.Тариф КАК Тариф
	               |ИЗ
	               |	РасходыНомера1 КАК РасходыНомера1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	РасходыНомера1.Сумма,
	               |	РасходыНомера1.ТипРасхода,
	               |	РасходыНомера1.Тариф,
	               |	РасходыНомера1.Номер";
	Запрос.УстановитьПараметр("Номер",Номер);
	Запрос.УстановитьПараметр("ТипРасхода",ТипРасхода);
	Запрос.УстановитьПараметр("ДатаНачала",НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("ДатаОкончания",КонецМесяца(Объект.Период));
	Запрос.УстановитьПараметр("ИК",Объект.ИК);
	Запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе	
		Возврат Рез[0]; 
	КонецЕсли;	
КонецФункции	
	
Функция КоличествоДнейДолгосрок(Пом)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ПР_ОтельДоходыДолгосрок.Количество) КАК Количество
	               |ИЗ
	               |	Документ.ПР_Отель.ДоходыДолгосрок КАК ПР_ОтельДоходыДолгосрок
	               |ГДЕ
	               |	ПР_ОтельДоходыДолгосрок.Номер = &Номер
	               |	И ПР_ОтельДоходыДолгосрок.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Номер",Пом);
	Запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;	
КонецФункции

