Функция ПолучитьДолюДоговора(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	СУММА(ВЫБОР
	               |			КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи < НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ)
	               |				ТОГДА ВЫБОР
	               |						КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ)
	               |								ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
	               |							ТОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ), КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ), ДЕНЬ) + 1
	               |						ИНАЧЕ РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ), АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ) + 1
	               |					КОНЕЦ
	               |			ИНАЧЕ ВЫБОР
	               |					КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ)
	               |							ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
	               |						ТОГДА РАЗНОСТЬДАТ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи, КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ), ДЕНЬ) + 1
	               |					ИНАЧЕ РАЗНОСТЬДАТ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи, АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ) + 1
	               |				КОНЕЦ
	               |		КОНЕЦ) КАК Поле1
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |ГДЕ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= КОНЕЦПЕРИОДА(&Дата, МЕСЯЦ)
	               |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= НАЧАЛОПЕРИОДА(&Дата, МЕСЯЦ)
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ДоговорКонтрагента"; 
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Дата",КонецМесяца(Объект.Период));
	Рез = Запрос.Выполнить().Выгрузить();
	Возврат Рез[0].Поле1;	
	
