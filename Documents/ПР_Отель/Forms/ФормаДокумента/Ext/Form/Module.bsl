		Если НайденныеСтроки.Количество()>0 Тогда
			ОтетИнвестора.СтоимостьЗавтраков = НайденныеСтроки[0].Расход;
		КонецЕсли;
        ОтетИнвестора.ТекущийРемонт = ОтетИнвестора.Выручка*0.03;
		ОтетИнвестора.РасходыСумма = ОтетИнвестора.КомиссионноеВознаграждение+ОтетИнвестора.СтоимостьЗавтраков+ОтетИнвестора.ТекущийРемонт;
		ОтетИнвестора.СреднийТариф = ОтетИнвестора.Выручка - ОтетИнвестора.РасходыСумма;
		ОтетИнвестора.СуммаДохода = ОтетИнвестора.Выручка - ОтетИнвестора.РасходыСумма;
		//ОтетИнвестора.ПлощадьКотла = 6316;
		ОтетИнвестора.ДоляПомещения = стр.ПлощадьНомера / ОтетИнвестора.ПлощадьКотла * 100;
		ОтетИнвестора.СовокупныйДоход = ПолучитьСовокупныйДоход(стр.Ссылка, ОтетИнвестора.Ссылка,ОтетИнвестора.Период) + ОтетИнвестора.ДоходЗаОтчетныйПериод;
		ОтетИнвестора.Капитализация = ПолучитьКапитализацию(стр.Ссылка, ОтетИнвестора.Период);
		ОтетИнвестора.ДоходСКапитализацией = ОтетИнвестора.СовокупныйДоход + ОтетИнвестора.Капитализация;
		ОтетИнвестора.ТекущаяСтоимость = стр.Ссылка.СуммаДоговора;//-
		ОтетИнвестора.РасходыИнвестора = ОтетИнвестора.РасходыСумма + ОтетИнвестора.РасходыУслугиУК;//-
		ОтетИнвестора.КВыплате = ОтетИнвестора.СуммаДохода * ОтетИнвестора.ДоляПомещения / 200;  
		ОтетИнвестора.ПрочиеРасходы = ОтетИнвестора.СуммаДохода - (ОтетИнвестора.СуммаДохода / 1.82 );
		ОтетИнвестора.СуммаКРаспределению = ОтетИнвестора.СуммаДохода - ОтетИнвестора.ПрочиеРасходы;
		ОтетИнвестора.ДоходЗаОтчетныйПериод = ОтетИнвестора.СуммаКРаспределению * стр.ПлощадьНомера / ОтетИнвестора.ПлощадьКотла;//ОтетИнвестора.СуммаКРаспределению/ОтетИнвестора.ПлощадьКотла*стр.ПлощадьНомера;
		ОтетИнвестора.РасходыУслугиУК = ОтетИнвестора.ДоходЗаОтчетныйПериод * 0.09;
		ОтетИнвестора.ЧистыйДоход = ОтетИнвестора.КВыплате;
		
		Попытка
			ОтетИнвестора.Записать(РежимЗаписиДокумента.Проведение);
		Исключение	
			ОтетИнвестора.Записать(РежимЗаписиДокумента.Запись); 
		КонецПопытки; 
				//Прервать;

	КонецЦикла;
	СоздатьЗагрузкуОтеля();
КонецПроцедуры             

Функция ПолучитьКапитализацию(ЗАД,Период)
	Ошибки = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Стоимость КАК Стоимость
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ТекущаяСтоимость КАК АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость
	               |ГДЕ
	               |	АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Дата <= &Дата
	               |	И АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Дата,
	               |	АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Стоимость
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораТекущаяСтоимость.Дата УБЫВ";
	Запрос.УстановитьПараметр("Дата",НачалоМесяца(Период));
	Запрос.УстановитьПараметр("Ссылка",ЗАД);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() > 0 Тогда
		ТекущаяСтоимость = Рез[0].Стоимость;
		Возврат ТекущаяСтоимость - ЗАД.СуммаДоговора;
	КонецЕсли;
	Возврат 0;	
КонецФункции
	
Функция ПолучитьСовокупныйДоход(ЗАД,ОтчетИнвестора,Период)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(СУММА(АР17_Д_ОтчетИнвестора.ДоходЗаОтчетныйПериод),0) КАК ДоходЗаОтчетныйПериод
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	АР17_Д_ОтчетИнвестора.Ссылка <> &Ссылка
	               |	И АР17_Д_ОтчетИнвестора.ДоговорИнвестора = &ДоговорИнвестора
	               |	И АР17_Д_ОтчетИнвестора.Проведен
	               |	И АР17_Д_ОтчетИнвестора.Период < &Период";
	Запрос.УстановитьПараметр("ДоговорИнвестора",ЗАД);
	Запрос.УстановитьПараметр("ССылка",ОтчетИнвестора);  
	Запрос.УстановитьПараметр("Период",Период); 
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() > 0 Тогда
		Возврат Рез[0].ДоходЗаОтчетныйПериод;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции	
	
Процедура СоздатьЗагрузкуОтеля();
	Док = НайтиЗагрузкуОтеля();
	Если Док = Документы.ПР_ЗагрузкаОтеля.ПустаяСсылка() Тогда
		Док = Документы.ПР_ЗагрузкаОтеля.СоздатьДокумент();
	Иначе
		Док = Док.ПолучитьОбъект();  
	КонецЕсли;
	Док.Дата = ТекущаяДата();
	Док.Месяц = НачалоМесяца(Объект.Период);
	Док.ИК = Объект.ИК;      
	Док.ВыручкаД = ДоходДолгосрок;
	Док.ВыручкаК = ДоходКороткосрок;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПР_ОтельДоходыКороткосрок.Номер) КАК КоличествоНомеровК,
	               |	СУММА(ПР_ОтельДоходыКороткосрок.Количество) КАК КоличествоДнейК
	               |ПОМЕСТИТЬ КС
	               |ИЗ
	               |	Документ.ПР_Отель.ДоходыКороткосрок КАК ПР_ОтельДоходыКороткосрок
	               |ГДЕ
	               |	ПР_ОтельДоходыКороткосрок.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПР_ОтельДоходыДолгосрок.Номер) КАК КоличествоНомеровД,
	               |	СУММА(ПР_ОтельДоходыДолгосрок.Количество) КАК КоличествоДнейД
	               |ПОМЕСТИТЬ ДС
	               |ИЗ
	               |	Документ.ПР_Отель.ДоходыДолгосрок КАК ПР_ОтельДоходыДолгосрок
	               |ГДЕ
	               |	ПР_ОтельДоходыДолгосрок.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ДС.КоличествоНомеровД, 0) КАК КоличествоНомеровД,
	               |	ЕСТЬNULL(ДС.КоличествоДнейД, 0) КАК КоличествоДнейД,
	               |	ЕСТЬNULL(КС.КоличествоНомеровК, 0) КАК КоличествоНомеровК,
	               |	ЕСТЬNULL(КС.КоличествоДнейК, 0) КАК КоличествоДнейК
	               |ИЗ
	               |	КС КАК КС,
	               |	ДС КАК ДС";
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Рез = Запрос.Выполнить().Выгрузить();
    КоличествоДней = День(КонецМесяца(Объект.Период));
	Док.ЗагрузкаД = ?(Рез[0].КоличествоНомеровД=0,0,Рез[0].КоличествоДнейД / (КоличествоДней *Рез[0].КоличествоНомеровД) * 100);
	Док.ЗагрузкаК = ?(Рез[0].КоличествоНомеровК=0,0,Рез[0].КоличествоДнейК / (КоличествоДней *Рез[0].КоличествоНомеровК) * 100);   
	Док.СреднийТарифД = ?(Рез[0].КоличествоДнейД=0,0,ДоходДолгосрок / Рез[0].КоличествоДнейД);
	Док.СреднийТарифК = ?(Рез[0].КоличествоДнейК=0,0,ДоходКороткосрок / Рез[0].КоличествоДнейК); 
	Док.Записать(РежимЗаписиДокумента.Проведение);
КонецПроцедуры

Функция НайтиЗагрузкуОтеля()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПР_ЗагрузкаОтеля.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ПР_ЗагрузкаОтеля КАК ПР_ЗагрузкаОтеля
	               |ГДЕ
	               |	ПР_ЗагрузкаОтеля.Месяц = &Месяц
	               |	И ПР_ЗагрузкаОтеля.ИК = &ИК";
	Запрос.УстановитьПараметр("ИК",Объект.ИК);
	Запрос.УстановитьПараметр("Месяц",НачалоМесяца(Объект.Период));
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат Документы.ПР_ЗагрузкаОтеля.ПустаяСсылка();
	Иначе
		Возврат Рез[0].Ссылка;
	КонецЕсли;
КонецФункции	

Функция ПолучитьПереплату(Дог)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(АР17_Д_ОтчетИнвестора.ЧистыйДоход) КАК ЧистыйДоход,
	               |	СУММА(АР17_Д_ОтчетИнвестора.ДоходЗаОтчетныйПериод) КАК ДоходЗаОтчетныйПериод
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	АР17_Д_ОтчетИнвестора.ДоговорИнвестора = &ДоговорИнвестора
	               |	И АР17_Д_ОтчетИнвестора.Проведен";
	Запрос.УстановитьПараметр("ДоговорИнвестора",Дог);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат 0;
	Иначе
		Возврат Рез[0].ЧистыйДоход - Рез[0].ДоходЗаОтчетныйПериод;
	КонецЕсли;
	
КонецФункции	

Функция ПрошелГод(Дог)
	Если Год(КонецМесяца(Объект.Период)) - Год(КонецМесяца(Дог.ОбъектыАренды[0].ДатаПередачи)) > 0 И Месяц(КонецМесяца(Объект.Период)) = Месяц(НачалоМесяца(Дог.ОбъектыАренды[0].ДатаПередачи)-1) Тогда
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ДоходЗаГод(Дог)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(АР17_Д_ОтчетИнвестора.ДоходЗаОтчетныйПериод) КАК ДоходЗаОтчетныйПериод,
	               |	СУММА(АР17_Д_ОтчетИнвестора.ЧестныйДоход) КАК ЧестныйДоход
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	АР17_Д_ОтчетИнвестора.ДоговорИнвестора = &ДоговорИнвестора
	               |	И АР17_Д_ОтчетИнвестора.Проведен
	               |	И АР17_Д_ОтчетИнвестора.Период МЕЖДУ &ПериодН И &ПериодК";
	Запрос.УстановитьПараметр("ДоговорИнвестора",Дог); 
	НачП = НачалоМесяца(НачалоМесяца(НачалоМесяца(Объект.Период) - 1) - 1);
	Запрос.УстановитьПараметр("ПериодН",Дата(Год(НачП) - 1, Месяц(НачП),01));
	Запрос.УстановитьПараметр("ПериодК",НачалоМесяца(Объект.Период) - 1);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат 0;
	Иначе 
		Возврат Рез[0].ДоходЗаОтчетныйПериод;
	КонецЕсли;	
		
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Доход = Объект.ДоходыДолгосрок.Итог("Доход") + Объект.ДоходыКороткосрок.Итог("Доход");
	ДоходДолгосрок = Объект.ДоходыДолгосрок.Итог("Доход");
	ДоходКороткосрок = Объект.ДоходыКороткосрок.Итог("Доход");
	РасходыОбщие = Объект.РасходыОбщие.Итог("Расход");
	РасходыНомера = ПолучитьРасходыНомера();
	Расходы = РасходыНомера + РасходыОбщие;    
	ТурНалогИтог = Объект.ДоходыДолгосрок.Итог("ТурНалог") + Объект.ДоходыКороткосрок.Итог("ТурНалог");
	ТурНалогДолгосрок = Объект.ДоходыДолгосрок.Итог("ТурНалог");
	ТурНалогКороткосрок = Объект.ДоходыКороткосрок.Итог("ТурНалог");
КонецПроцедуры

Функция ПолучитьРасходыНомера()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ВЫБОР
	               |			КОГДА ЕСТЬNULL(ПР_ОтельРасходыНомера.Количество, 0) > 0
	               |				ТОГДА ПР_ОтельРасходыНомера.Количество * ПР_ОтельТарифы.Цена
	               |			ИНАЧЕ ЕСТЬNULL(ПР_ОтельРасходыНомера.Расход, 0)
	               |		КОНЕЦ) КАК Сумма
	               |ИЗ
	               |	Документ.ПР_Отель.РасходыНомера КАК ПР_ОтельРасходыНомера
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПР_Отель.Тарифы КАК ПР_ОтельТарифы
	               |		ПО ПР_ОтельРасходыНомера.ТипРасхода = ПР_ОтельТарифы.ТипРасхода
	               |			И ПР_ОтельРасходыНомера.Номер.КлассПомещения = ПР_ОтельТарифы.КатегорияНомера
	               |ГДЕ
	               |	(ПР_ОтельРасходыНомера.Ссылка = &Ссылка
	               |			ИЛИ ПР_ОтельРасходыНомера.Ссылка ЕСТЬ NULL)
	               |	И (ПР_ОтельТарифы.Ссылка = &Ссылка
	               |			ИЛИ ПР_ОтельТарифы.Ссылка ЕСТЬ NULL)"; 
	Запрос.УстановитьПараметр("Ссылка",Объект.Ссылка);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат 0;
	Иначе
		Возврат Рез[0].Сумма;
	КонецЕсли;
КонецФункции	

&НаКлиенте
Процедура ЗагрузкаОтеля(Команда)
	СоздатьЗагрузкуОтеля();
