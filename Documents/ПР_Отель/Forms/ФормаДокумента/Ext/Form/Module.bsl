Функция НайтиОИ(Период,Ссылка,ОбъектАренды)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_Д_ОтчетИнвестора.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	КОНЕЦПЕРИОДА(АР17_Д_ОтчетИнвестора.Период, МЕСЯЦ) = &Дата
	               |	И АР17_Д_ОтчетИнвестора.ДоговорИнвестора = &Ссылка
	               |	И АР17_Д_ОтчетИнвестора.Помещение = &Помещение
	               |	И АР17_Д_ОтчетИнвестора.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("Дата",Период);
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.УстановитьПараметр("Помещение",ОбъектАренды);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Рез[0].Ссылка;
	КонецЕсли;
	
