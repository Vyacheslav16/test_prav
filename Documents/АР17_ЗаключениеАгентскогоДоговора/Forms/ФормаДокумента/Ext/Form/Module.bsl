	КонецЦикла;
	Для Каждого СтрокаТЧ Из Объект.УсловияАгентскогоВознаграждения Цикл
		ОбщаяСумма = ОбщаяСумма +  СтрокаТЧ.Сумма; //СтрокаТЧ.Количество*СтрокаТЧ.Ставка;
	КонецЦикла;

    Объект.СтрокаОбъекты = Лев(СтрокаОбъекты,СтрДлина(СтрокаОбъекты)-2);
	Объект.ОбщаяПлощадь = ОбщаяПлощадь;	
	Объект.ОбщаяСумма = ОбщаяСумма;
	
	Если Объект.ОбъектыАренды.Количество() = 0 Тогда
		Сообщить("Не заполнено помещение.");
		Отказ = Истина;
	КонецЕсли;	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		//Если Не ОткрытЛС() Тогда
		//	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);	
