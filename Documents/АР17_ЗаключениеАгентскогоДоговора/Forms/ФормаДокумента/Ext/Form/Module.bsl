&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда 
		ОткрытьЛС()
	КонецЕсли;
КонецПроцедуры	

Процедура ОткрытьЛС()
	ЛСчет = Справочники.КВП_ЛицевыеСчета.СоздатьЭлемент();
	ЛСчет.Наименование = Объект.ДоговорТО; 
	ЛСчет.Адрес = Справочники.УПЖКХ_Помещения.НайтиПоНаименованию(Объект.ОбъектыАренды[0].ОбъектАренды);
	ЛСчет.Записать();
	СформироватьДокументыЗакрытия(Объект.ОбъектыАренды[0].ОбъектАренды, Объект.ОбъектыАренды[0].ДатаПередачи, Объект.Контрагент, Объект.ДоговорТО);
	ДокОЛС = Документы.КВП_ОткрытиеЛицевогоСчета.НайтиПоРеквизиту("ЛицевойСчет",ЛСчет.Ссылка);
	Если ДокОЛС = Документы.КВП_ОткрытиеЛицевогоСчета.ПустаяСсылка() Тогда
		ДокОЛС = Документы.КВП_ОткрытиеЛицевогоСчета.СоздатьДокумент();
		ДокОЛС.Дата = Дата(Объект.ОбъектыАренды[0].ДатаПередачи);
		ДокОЛС.ЛицевойСчет = ЛСчет.Ссылка;
		ДокОЛС.Контрагент = Объект.Контрагент;
		ДокОЛС.ОтветственныйСобственник = Объект.Контрагент; 
		ДокОЛС.ВладелецКонтрагент = Истина;
		ДокОЛС.ДоляЧислитель = 1;
		ДокОЛС.ДоляЗнаменатель = 1; 
		ДокОЛС.КоличествоЗарегистрированных = 1;   
		ДокОЛС.ОбъектОснование = ЛСчет.Ссылка;
		ДокОЛС.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;	
	ДокУСВ = Документы.УПЖКХ_УправлениеСведениямиДляВзаиморасчетовПоЛицевымСчетам.НайтиПоРеквизиту("Объект",Справочники.УПЖКХ_Помещения.НайтиПоНаименованию(Объект.ОбъектыАренды[0].ОбъектАренды));
	Если ДокУСВ = Документы.УПЖКХ_УправлениеСведениямиДляВзаиморасчетовПоЛицевымСчетам.ПустаяСсылка() Тогда
		ДокУСВ = Документы.УПЖКХ_УправлениеСведениямиДляВзаиморасчетовПоЛицевымСчетам.СоздатьДокумент();
		ДокУСВ.Дата = Объект.ОбъектыАренды[0].ДатаПередачи;
		ДокУСВ.Организация = Объект.Организация;
		ДокУСВ.Объект = Справочники.УПЖКХ_Помещения.НайтиПоНаименованию(Объект.ОбъектыАренды[0].ОбъектАренды);
		НовСтр = ДокУСВ.СведенияДляВзаиморасчетов.Добавить();
		НовСтр.ЛицевойСчет = ЛСчет.Ссылка;
		НовСтр.Контрагент = ЛСчет.Владелец;
		НовСтр.ДоговорКонтрагента = Объект.ДоговорТО;
		ДокУСВ.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;
КонецПроцедуры	
	
Процедура СформироватьДокументыЗакрытия(НомерПомещения, ДатаДоговора, Контрагент, ДоговорБух)  
    Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КВП_ЛицевыеСчета.Ссылка КАК Ссылка,
	               |	КВП_ОткрытиеЛицевогоСчета.Дата КАК Дата
	               |ИЗ
	               |	Документ.КВП_ОткрытиеЛицевогоСчета КАК КВП_ОткрытиеЛицевогоСчета
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КВП_ЛицевыеСчета КАК КВП_ЛицевыеСчета
	               |		ПО КВП_ОткрытиеЛицевогоСчета.ЛицевойСчет = КВП_ЛицевыеСчета.Ссылка
	               |ГДЕ
	               |	КВП_ЛицевыеСчета.Адрес = &Адрес
	               |	И (КВП_ОткрытиеЛицевогоСчета.Контрагент <> &Контрагент
	               |			ИЛИ КВП_ЛицевыеСчета.Наименование <> &Наименование)
	               |	И НЕ КВП_ЛицевыеСчета.ПометкаУдаления";
	Запрос.УстановитьПараметр("Адрес",Справочники.УПЖКХ_Помещения.НайтиПоНаименованию(НомерПомещения));
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	Запрос.УстановитьПараметр("Наименование",ДоговорБух);
	Рез = Запрос.Выполнить().Выгрузить();
	Для каждого стр Из Рез Цикл
		Если НачалоДня(стр.Дата) >= НачалоДня(ДатаДоговора) Тогда
			Док = стр.Ссылка.ПолучитьОбъект();
			Док.ПометкаУдаления = Истина;
			Док.Записать();
		Иначе
			Запрос.Текст = "ВЫБРАТЬ
			               |	КВП_ЗакрытиеЛицевогоСчета.Ссылка КАК Ссылка
			               |ИЗ
			               |	Документ.КВП_ЗакрытиеЛицевогоСчета КАК КВП_ЗакрытиеЛицевогоСчета
			               |ГДЕ
			               |	КВП_ЗакрытиеЛицевогоСчета.ЛицевойСчет = &ЛицевойСчет
			               |	И КВП_ЗакрытиеЛицевогоСчета.Проведен";
			Запрос.УстановитьПараметр("ЛицевойСчет",стр.Ссылка);
			Рез2 = Запрос.Выполнить().Выгрузить();
			Если Рез2.Количество() = 0 Тогда
				ДокЗакр = Документы.КВП_ЗакрытиеЛицевогоСчета.СоздатьДокумент();
				ДокЗакр.Дата = КонецДня(НачалоДня(ДатаДоговора)-1);
				ДокЗакр.ЛицевойСчет = стр.Ссылка;
				ДокЗакр.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОбъектыОбъектАрендыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПараметрыОбъекты = Новый Структура;
	ПараметрыОбъекты.Вставить("ИК",Объект.ИК);
	ПараметрыОбъекты.Вставить("ТекущееЗначение",ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ОбъектАренды);
	ФормаВыбора = ПолучитьФорму("Справочник.АР_ОбъектыАренды.ФормаВыбора", ПараметрыОбъекты, Элемент);
	ФормаВыбора.Элементы.Список.ТекущаяСтрока = ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ОбъектАренды;
	ФормаВыбора.Открыть();
КонецПроцедуры


&НаКлиенте
Процедура ИКНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ПараметрыВыбора1 = Новый Массив;//(Элемент.ПараметрыВыбора);
	НовыйПараметр = Новый ПараметрВыбора("ТипОбъекта", ТипИК());
	ПараметрыВыбора1.Очистить();
	ПараметрыВыбора1.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора1);
КонецПроцедуры

