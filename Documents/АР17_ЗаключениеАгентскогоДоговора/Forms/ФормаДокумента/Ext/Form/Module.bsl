Процедура ЗаполнитьТЧ(НомерСтроки,ОбъектАренды)
	
	Стр = Объект.ОбъектыАренды[НомерСтроки-1];
	Если Стр.ОбъектАренды.МОП > 0 Тогда	
		Стр.ТипПомещения = "МОП";
	ИначеЕсли Стр.ОбъектАренды.АП > 0 Тогда
		Стр.ТипПомещения = "АП";
	ИначеЕсли Стр.ОбъектАренды.ТП > 0 Тогда
		Стр.ТипПомещения = "ТП";
	ИначеЕсли Стр.ОбъектАренды.ВП > 0 Тогда
		Стр.ТипПомещения = "ВП";
	КонецЕсли;
	// Расположение
	Стр.Расположение = СокрЛП(Стр.ОбъектАренды.Родитель.Родитель.Родитель) + ", " + СокрЛП(Стр.ОбъектАренды.Родитель.Родитель);
	Стр.Площадь = Стр.ОбъектАренды.ЗначениеХарактеристики;
	Стр.КлассПомещения = Стр.ОбъектАренды.КлассПомещения;
	
КонецПроцедуры	

&НаКлиенте
Процедура ДоговорыМОПДоговорКонтрагентаПриИзменении(Элемент)
	ТекущийЭлемент.ТекущиеДанные.ПлощадьМОП = ЗаполнитьПлощадьМОП(ТекущийЭлемент.ТекущиеДанные.ДоговорКонтрагента);
КонецПроцедуры

Функция ЗаполнитьПлощадьМОП(ДоговорКонтрагента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка КАК Ссылка,
	               |	СУММА(АР_ОбъектыАренды.МОП) КАК МОП
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	               |		ПО АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды = АР_ОбъектыАренды.Ссылка
	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.МОП;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
	
КонецФункции	

&НаСервере
Процедура ИКПриИзмененииНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_УстановкаПараметровИКНоменклатура.Номенклатура КАК Номенклатура,
	               |	АР17_УстановкаПараметровИКНоменклатура.Содержание КАК Содержание
	               |ИЗ
	               |	Документ.АР17_УстановкаПараметровИК.Номенклатура КАК АР17_УстановкаПараметровИКНоменклатура
	               |ГДЕ
	               |	АР17_УстановкаПараметровИКНоменклатура.Ссылка.ИКСсылка = &ИК";
	Запрос.УстановитьПараметр("ИК",Объект.ИК);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 Тогда
		Объект.УсловияАгентскогоВознаграждения.Очистить();	
	КонецЕсли;
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.УсловияАгентскогоВознаграждения.Добавить();
		НоваяСтрока.Услуга = Выборка.Номенклатура;
		НоваяСтрока.Содержание = Выборка.Содержание;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ИКПриИзменении(Элемент)
	ИКПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоРаспределениюНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор КАК Регистратор
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&КонецПериода, ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.Регистратор КАК Регистратор,
	               |	АР_РаспределениеДолейСобственниковОбъектыАренды.ОбъектАренды КАК ОбъектАренды
	               |ИЗ
	               |	ВТ КАК ВТ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |			АР_РаспределениеДолейСобственниковСобственники.Ссылка КАК Ссылка,
	               |			КОЛИЧЕСТВО(АР_РаспределениеДолейСобственниковСобственники.НомерСтроки) КАК Количество
	               |		ИЗ
	               |			Документ.АР_РаспределениеДолейСобственников.Собственники КАК АР_РаспределениеДолейСобственниковСобственники
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			АР_РаспределениеДолейСобственниковСобственники.Ссылка) КАК ВложенныйЗапрос
	               |		ПО ВТ.Регистратор = ВложенныйЗапрос.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР_РаспределениеДолейСобственников.ОбъектыАренды КАК АР_РаспределениеДолейСобственниковОбъектыАренды
	               |		ПО ВТ.Регистратор = АР_РаспределениеДолейСобственниковОбъектыАренды.Ссылка
	               |ГДЕ
	               |	ВложенныйЗапрос.Количество = 1
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_РаспределениеДолейСобственниковОбъектыАренды.ОбъектАренды,
	               |	ВТ.Регистратор
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ОбъектАренды";
	
	Запрос.УстановитьПараметр("КонецПериода",Объект.Дата);
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Объект.ДоговорКонтрагента);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл	
		НоваяСтрока = Объект.ОбъектыАренды.Добавить();
		НоваяСтрока.ОбъектАренды = Выборка.ОбъектАренды;
		ТаблицаОбъектыОбъектАренды(НоваяСтрока);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоРаспределению(Команда)
	ЗаполнитьПоРаспределениюНаСервере();
КонецПроцедуры

&НаСервере
Процедура ТаблицаОбъектыОбъектАренды(НоваяСтрока)
	// определим тип помещения
	Если НоваяСтрока.ОбъектАренды.МОП > 0 Тогда	
		НоваяСтрока.ТипПомещения = "МОП";
	ИначеЕсли НоваяСтрока.ОбъектАренды.АП > 0 Тогда
		НоваяСтрока.ТипПомещения = "АП";
	ИначеЕсли НоваяСтрока.ОбъектАренды.ТП > 0 Тогда
		НоваяСтрока.ТипПомещения = "ТП";
	ИначеЕсли НоваяСтрока.ОбъектАренды.ВП > 0 Тогда
		НоваяСтрока.ТипПомещения = "ВП";
	КонецЕсли;
	// Расположение
	НоваяСтрока.Расположение = СокрЛП(НоваяСтрока.ОбъектАренды.Родитель.Родитель.Родитель) + ", " + СокрЛП(НоваяСтрока.ОбъектАренды.Родитель.Родитель);
	НоваяСтрока.Площадь = НоваяСтрока.ОбъектАренды.ЗначениеХарактеристики;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Ответственный =ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПриОткрытииНаСервере(); 
	Если Найти(Строка(Объект.ПрограммаДоходности),"Гарант") > 0 Тогда
		Элементы.ГарантированныйДоход.Видимость = Истина;
	Иначе
		Элементы.ГарантированныйДоход.Видимость = Ложь; 
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриОткрытииНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ШтрихКоды.СсылкаНаОбъект КАК Ссылка,
	|	ШтрихКоды.ШтрихКод КАК ШК
	|ИЗ
	|	РегистрСведений.АР_ШтрихКоды КАК ШтрихКоды
	|ГДЕ
	|	ШтрихКоды.СсылкаНаОбъект = &СсылкаНаОбъект";
	//|	ШтрихКоды.ШтрихКод ПОДОБНО &ШтрихКод";
	//Запрос.УстановитьПараметр("ШтрихКод","%" + СтрШК + "%");
	//Запрос.УстановитьПараметр("СсылкаНаОбъект",СсылкаНаОбъект);
	Запрос.УстановитьПараметр("СсылкаНаОбъект",ЭтаФорма.Объект.Ссылка);
	//МассивСсылок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	МассивСсылок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ШК");
	
	Если МассивСсылок.Количество() = 1 Тогда
		ЭтотОбъект.ШК= МассивСсылок[0];
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Ответственный =ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;

КонецПроцедуры

