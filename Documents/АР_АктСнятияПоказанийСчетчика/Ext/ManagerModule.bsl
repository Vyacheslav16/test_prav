	|ГДЕ
	|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка";
	
	ПервыйДокумент = Истина;
	
	Для каждого Документ Из МассивОбъектов Цикл
		
		Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.Макет");
		
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ЗапросШапка.УстановитьПараметр("Ссылка", Документ);
		Шапка = ЗапросШапка.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = "Акт снятия показаний счетчика №" + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Шапка.Номер, Истина, Истина) + " от " + Формат(Шапка.Дата,"ДФ='д ММММ гггг'") + " г.";
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		Если Шапка.СпособЗаполнения = 1 Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокАрендатор");
			ОбластьМакета.Параметры.Арендатор = "Арендатор: " + Шапка.Контрагент.НаименованиеПолное;
			ОбластьМакета.Параметры.Договор = "Договор: " + Шапка.ДоговорКонтрагента.Наименование;
			ТабличныйДокумент.Вывести(ОбластьМакета);	
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокУслуга");
			ОбластьМакета.Параметры.Услуга = "Услуга: " + Шапка.Услуга.НаименованиеПолное;
			ТабличныйДокумент.Вывести(ОбластьМакета);	
		КонецЕсли;
		
		ЕстьСчетчики = ПолучитьФункциональнуюОпцию("АР_ВестиУчетТарифицируемыхУслугПоСчетчикам");
		
		// Вывод шапки таблицы
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Номер");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		Если Шапка.СпособЗаполнения = 0 Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Арендатор");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Услуга");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка|ОбъектАренды");
		ТабличныйДокумент.Присоединить(ОбластьМакета);
		Если (Шапка.СпособЗаполнения = 0) и (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика) Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Площадь");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		Если Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Телефон");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		Если ЕстьСчетчики Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Счетчик");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка|ФактическиеПоказания");
		ТабличныйДокумент.Присоединить(ОбластьМакета);
		Если Шапка.СпособЗаполнения = 1 или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
			или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
			или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
			или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Показания");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		Если Шапка.СпособЗаполнения = 1 или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
			или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
			или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
			или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Разница");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		Если Шапка.СпособЗаполнения = 1 или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
			или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
			или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
			или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Тариф");
			ТабличныйДокумент.Присоединить(ОбластьМакета);
		КонецЕсли;
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка|Сумма");
		ТабличныйДокумент.Присоединить(ОбластьМакета);
		
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Выборка = Запрос.Выполнить().Выбрать();
		
		ПлощадьИтого = 0; 	
		РазницаИтого = 0;	
		СуммаИтого = 0;
		
		ВыводимАрендатора = Ложь;
		ВыводимУслугу = Ложь;
		ВыводимТелефон = Ложь;
		ВыводимСчетчики = Ложь;
		ВыводимПоказания = Ложь;
		ВыводимТариф = Ложь;
		ВыводимПлощадь = Ложь;
		ВыводимРазницу = Ложь;
		
		Пока Выборка.Следующий() Цикл
			ОбластьМакета = Макет.ПолучитьОбласть("Строка|Номер");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Вывести(ОбластьМакета);
			Если Шапка.СпособЗаполнения = 0 Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Арендатор");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимАрендатора = Истина;
			Иначе
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Услуга");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимУслугу = Истина;
			КонецЕсли;
			ОбластьМакета = Макет.ПолучитьОбласть("Строка|ОбъектАренды");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Присоединить(ОбластьМакета);
			Если (Шапка.СпособЗаполнения = 0) и (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика) Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Площадь");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ПлощадьИтого = ПлощадьИтого + Выборка.Площадь;
				ВыводимПлощадь = Истина;
			КонецЕсли;
			Если Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Телефон");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимТелефон = Истина;
			КонецЕсли;
			Если ЕстьСчетчики Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Счетчик");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимСчетчики = Истина;			
			КонецЕсли;
			ОбластьМакета = Макет.ПолучитьОбласть("Строка|ФактическиеПоказания");
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Присоединить(ОбластьМакета);
			Если Шапка.СпособЗаполнения = 1 или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
				или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
				или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
				или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Показания");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимПоказания = Истина;
			КонецЕсли;
			Если Шапка.СпособЗаполнения или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
				или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
				или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
				или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Разница");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				РазницаИтого = РазницаИтого + Выборка.Разница;
				ВыводимРазницу = Истина;
			КонецЕсли;
			Если Шапка.СпособЗаполнения или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ПоказаниеПропорциональноПлощадиОбъектов)
				или (Шапка.СпособРасчета = Перечисления.АР_СпособыРасчетаУслуг.ФиксированнойСуммой)
				или (Не ЗначениеЗаполнено(Шапка.СпособРасчета))
				или (Шапка.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров) Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("Строка|Тариф");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ТабличныйДокумент.Присоединить(ОбластьМакета);
				ВыводимТариф = Истина;
			КонецЕсли;
			ОбластьМакета = Макет.ПолучитьОбласть("Строка|Сумма");
			СуммаИтого = СуммаИтого + Выборка.Сумма;
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ТабличныйДокумент.Присоединить(ОбластьМакета);  
		КонецЦикла; 
		
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("Итоги|Номер"));
		Если ВыводимАрендатора Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Арендатор"));
		КонецЕсли;
		Если ВыводимУслугу Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Услуга"));
		КонецЕсли;
		ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|ОбъектАренды"));
		Если ВыводимПлощадь Тогда
			ОбластьИтогов = Макет.ПолучитьОбласть("Итоги|Площадь");
			ОбластьИтогов.Параметры.ПлощадьИтого = ПлощадьИтого;
			ТабличныйДокумент.Присоединить(ОбластьИтогов);
		КонецЕсли;
		Если ВыводимТелефон Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Телефон"));
		КонецЕсли;
		Если ВыводимСчетчики Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Счетчик"));
		КонецЕсли;
		ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|ФактическиеПоказания"));
		Если ВыводимПоказания Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Показания"));
		КонецЕсли;
		Если ВыводимРазницу Тогда
			ОбластьИтогов = Макет.ПолучитьОбласть("Итоги|Разница");
			ОбластьИтогов.Параметры.РазницаИтого = РазницаИтого;
			ТабличныйДокумент.Присоединить(ОбластьИтогов);
		КонецЕсли;
		Если ВыводимТариф Тогда
			ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("Итоги|Тариф"));
		КонецЕсли;
		ОбластьИтогов = Макет.ПолучитьОбласть("Итоги|Сумма");
		ОбластьИтогов.Параметры.СуммаИтого = СуммаИтого;
		ТабличныйДокумент.Присоединить(ОбластьИтогов);
	
		ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
		ОбластьМакета.Параметры.Ответственный = Шапка.Ответственный.Наименование;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
		НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
		
КонецФункции

Функция ПечатьАктаПоСчетчикамЭл(МассивОбъектов, ОбъектыПечати, АктМОП)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Если Не АктМОП Тогда
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамЭл");
	Иначе
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамЭлМОП");
	КонецЕсли;
		
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетАктПоСчетчикамЭл");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("ВидРесурса", Перечисления.АР_ВидРесурса.Электроэнергия);
		Если АктМОП Тогда
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Общий);
		Иначе
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Индивидуальный);
		КОнецЕсли;
		
		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.Организация = Документ.Организация.НаименованиеСокращенное;
			ОбластьМакета.Параметры.Дата = Формат(Документ.Дата, "ДЛФ=ДД");
			Если АктМОП Тогда
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания электросчетчиков на объекте "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение  эл.энергии в Местах общего пользования";
			Иначе
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания электросчетчиков на объекте "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение эл.энергии в помещениях Арендатора";
			КонецЕСли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//Найдем КА
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				Контрагент = ВыборкаГруппы.Контрагент;
			//Иначе
			//	Контрагент = Документ.Контрагент;
			КОнецЕсли;
			//найдем долю в МОП для КА
			Если АктМОП Тогда
				ДоляВМОП = ВыборкаГруппы.ДоляВМОП;
			КонецЕсли;
			
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Выборка = ВыборкаГруппы.Выбрать();
			//строки
			ТекНомерСтроки = 0;
			Пока Выборка.Следующий() Цикл
				ТекНомерСтроки = ТекНомерСтроки + 1;
				ОбластьМакета = Макет.ПолучитьОбласть("Строка");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
			
			 //итого
			ОбластьМакета = Макет.ПолучитьОбласть("Итого");
			ОбластьМакета.Параметры.ИтогоПотребление = ВыборкаГруппы.Потребление;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//итого для акта МОП
			Если АктМоп Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("ИтогоМОП");
				ОбластьМакета.Параметры.ИтогоДоляПоДоговору = Строка(ДоляВМОП) + "%";
				ОбластьМакета.Параметры.ИтогоДоляПотребления = ВыборкаГруппы.ИтогПотребление;
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЕсли;
			
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				ОбластьМакета.Параметры.Арендатор = ВыборкаГруппы.Контрагент.Наименование;
			Иначе
				ОбластьМакета.Параметры.Арендатор = Документ.Контрагент.Наименование;
			КОнецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ПолучитьТекстЗапроса(ТипДокумента)
	
	Если ТипДокумента = "АктПоСчетчикамЭл" Тогда
		
		Текст = 
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаНачалоПериода КАК ПредыдущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода КАК ТекущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды КАК МестоУстановки,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Контрагент КАК Контрагент,
		|	ЕСТЬNULL(АР_АктСнятияПоказанийСчетчикаПоказания.Потребление, 0) КАК Потребление,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НомерСчетчика КАК СерийныйНомер,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды.Адрес КАК ОбъектАрендыАдрес,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.КоэффициентТрансформации КАК КоэффициентТрансформации
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.ВидСчетчика = &ВидСчетчика
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса = &ВидРесурса
		|
		|УПОРЯДОЧИТЬ ПО
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды
		|ИТОГИ
		|	СУММА(Потребление),
		|	МАКСИМУМ(ОбъектАрендыАдрес)
		|ПО
		|	Контрагент";
		
		Возврат Текст;
	ИначеЕсли ТипДокумента = "АктПоСчетчикамЭлМОП" Тогда
		
		Текст = 
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаНачалоПериода КАК ПредыдущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода КАК ТекущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды КАК МестоУстановки,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Контрагент КАК Контрагент,
		|	ЕСТЬNULL(АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода - АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаНачалоПериода, 0) * АР_АктСнятияПоказанийСчетчикаПоказания.КоэффициентТрансформации КАК Потребление,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НомерСчетчика КАК СерийныйНомер,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды.Адрес КАК ОбъектАрендыАдрес,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.КоэффициентТрансформации КАК КоэффициентТрансформации,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ДоляВМОП КАК ДоляВМОП,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Потребление КАК ИтогПотребление
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.ВидСчетчика = &ВидСчетчика
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса = &ВидРесурса
		|
		|УПОРЯДОЧИТЬ ПО
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды
		|ИТОГИ
		|	СУММА(Потребление),
		|	МАКСИМУМ(ОбъектАрендыАдрес),
		|	МАКСИМУМ(ДоляВМОП),
		|	СУММА(ИтогПотребление)
		|ПО
		|	Контрагент";
		
		Возврат Текст;
	
		
	ИначеЕсли ТипДокумента = "СправкаРасчетЭл" Тогда
		Текст =
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаНачалоПериода КАК ПредыдущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода КАК ТекущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Контрагент КАК Контрагент,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик КАК Счетчик,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НомерСчетчика КАК СерийныйНомер,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Цена КАК Тариф,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Сумма КАК СтоимостьСНДС,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	0 КАК ПотреблениеМОП,
		|	0 КАК СтоимостьМОП,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.КоэффициентТрансформации КАК КоэффициентТрансформации,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Потребление КАК Потребление,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ДоляВМОП КАК ДоляВМОП
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.ВидСчетчика = &ИндСчетчик
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса = &ВидРесурса
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	NULL,
		|	NULL,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Контрагент,
		|	NULL,
		|	NULL,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Цена,
		|	0,
		|	NULL,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Потребление,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Сумма,
		|	NULL,
		|	0,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ДоляВМОП
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.ВидСчетчика = &ОбщСчетчик
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса = &ВидРесурса
		|
		|УПОРЯДОЧИТЬ ПО
		|	Счетчик
		|ИТОГИ
		|	МАКСИМУМ(Тариф),
		|	СУММА(СтоимостьСНДС),
		|	МАКСИМУМ(ДоговорКонтрагента),
		|	СУММА(ПотреблениеМОП),
		|	СУММА(СтоимостьМОП),
		|	СУММА(Потребление),
		|	МАКСИМУМ(ДоляВМОП)
		|ПО
		|	Контрагент";
		
		Возврат Текст;
	ИначеЕсли ТипДокумента = "АктПоСчетчикамВода" Тогда	 
		Текст =
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды КАК МестоУстановки,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Контрагент КАК Контрагент,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик КАК Счетчик,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НомерСчетчика КАК СерийныйНомер,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ОбъектАренды.Адрес КАК ОбъектАрендыАдрес,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса КАК ВидРесурса,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Потребление КАК Потребление,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаНачалоПериода КАК ПредыдущиеПоказания,
		|	АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода КАК ТекущиеПоказания,
		|	NULL КАК КоэфНаработки,
		|	NULL КАК ОтчетноеВремя,
		|	NULL КАК ВремяНаработки,
		|	0 КАК ФактПотребление
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияВодоснабжение КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.ВидСчетчика = &ВидСчетчика
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса В(&МассивВидовРесурсов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ОбъектАренды,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Контрагент,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик.НомерСчетчика,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ОбъектАренды.Адрес,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик.НазваниеРесурса.ВидРесурса,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ГВСПотреблениеТеплоносительКуб,
		|	АР_ПоказанияСчетчиковСрезПоследних.ГВСТеплоносительКуб,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ГВСТеплоносительКуб,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.КоэффициентНаработки,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ОтчетноеВремя,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ВремяНаработки,
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.ГВСПотреблениеТеплоносительКуб
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияТеплоснабжение КАК АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АР_ПоказанияСчетчиков.СрезПоследних(&Период, ) КАК АР_ПоказанияСчетчиковСрезПоследних
		|		ПО АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик = АР_ПоказанияСчетчиковСрезПоследних.Счетчик
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик.ВидСчетчика = &ВидСчетчика
		|	И АР_АктСнятияПоказанийСчетчикаПоказанияТеплоснабжение.Счетчик.НазваниеРесурса.ВидРесурса В(&МассивВидовРесурсов)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Контрагент
		|ИТОГИ
		|	МАКСИМУМ(ОбъектАрендыАдрес),
		|	СУММА(Потребление),
		|	СУММА(ФактПотребление)
		|ПО
		|	Контрагент";
		
		Возврат Текст;
		
	ИначеЕсли ТипДокумента = "АктПоСчетчикамВодаМОП" Тогда	 
		Текст =
		"ВЫБРАТЬ
