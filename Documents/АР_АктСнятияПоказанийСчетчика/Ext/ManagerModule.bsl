// Печать

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Акт") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "Акт", "Акт снятия показаний счетчика", ПечатьАкта(МассивОбъектов, ОбъектыПечати));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораЭл") Тогда //эл
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораЭл", "Акт снятия показаний по счетчикам арендатора (эл. энергия)", ПечатьАктаПоСчетчикамЭл(МассивОбъектов, ОбъектыПечати, Ложь));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПЭл") Тогда //эл
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПЭл", "Акт снятия показаний по счетчикам МОП (эл. энергия)", ПечатьАктаПоСчетчикамЭл(МассивОбъектов, ОбъектыПечати, Истина));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СправкаРасчетЭл") Тогда //эл
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СправкаРасчетЭл", "Справка-расчет переменной арендной платы (эл. энергия)", ПечатьСправкаРасчетЭл(МассивОбъектов, ОбъектыПечати));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораВода") Тогда  //вода
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораВода", "Акт снятия показаний по счетчикам арендатора (водоотведение)", ПечатьАктаПоСчетчикамВода(МассивОбъектов, ОбъектыПечати, Ложь));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПВода") Тогда  //вода
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПВода", "Акт снятия показаний по счетчикам МОП (водоотведение)", ПечатьАктаПоСчетчикамВода(МассивОбъектов, ОбъектыПечати, Истина));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СправкаРасчетВода") Тогда  //вода
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СправкаРасчетВода", "Справка-расчет переменной арендной платы (водоотведение)", ПечатьСправкаРасчетВода(МассивОбъектов, ОбъектыПечати));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораТепло") Тогда  //тепло
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамАрендатораТепло", "Акт снятия показаний по счетчикам арендатора (тепловая энергия)", ПечатьАктаПоСчетчикамТепло(МассивОбъектов, ОбъектыПечати,Ложь));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПТепло") Тогда  //тепло
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктПоСчетчикамМОПТепло", "Акт снятия показаний по счетчикам МОП (тепловая энергия)", ПечатьАктаПоСчетчикамТепло(МассивОбъектов, ОбъектыПечати,Истина));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СправкаРасчетТепло") Тогда //тепло
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СправкаРасчетТепло", "Справка-расчет переменной арендной платы (тепловая энергия)", ПечатьСправкаРасчетТепло(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
	
КонецПроцедуры

Функция ПечатьСправкаРасчетТепло(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапроса("СправкаРасчетТепло");
	
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетСправкаРасчетТепло");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("ОбщСчетчик", Перечисления.АР_ВидыСчетчиков.Общий);
		Запрос.УстановитьПараметр("ИндСчетчик",  Перечисления.АР_ВидыСчетчиков.Индивидуальный);
		//Запрос.УстановитьПараметр("ВидРесурса", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоРасходомерам);
		Запрос.УстановитьПараметр("ВидРесурса2", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам);
		
		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.ТекстЗаголовка = "Справка-расчет переменной арендной платы (тепловая энергия) за " + Формат(Документ.Дата, "ДФ='ММММ гггг'");
			
			//Проверим, печатаем по нескольким контрагентам из одного акта или по одному контрагенту и берём его из шапки
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				ОбластьМакета.Параметры.ДоговорАренды = ВыборкаГруппы.ДоговорКонтрагентаНаименование + " " +ВыборкаГруппы.Контрагент.Наименование;
				Контрагент = ВыборкаГруппы.Контрагент;				
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Выборка = ВыборкаГруппы.Выбрать();
			//строки
			ТекНомерСтроки = 0;
			//ИтогМОППотребление = 0;
			//ИтогМОПСтоимость = 0;
			Тариф = Документ.ТарифТепло;
			Пока Выборка.Следующий() Цикл
				
				ТекНомерСтроки = ТекНомерСтроки + 1;
				ОбластьМакета = Макет.ПолучитьОбласть("Строка");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
				ОбластьМакета.Параметры.Тариф =Тариф;
				ТабличныйДокумент.Вывести(ОбластьМакета);
				
			КонецЦикла;
			
			
			
			//итого
			ОбластьМакета = Макет.ПолучитьОбласть("Итого");
			ОбластьМакета.Параметры.ИтогоПотреблениеВМОП = ВыборкаГруппы.ПотреблениеМОП;
			ОбластьМакета.Параметры.ИтогоПотребление = ВыборкаГруппы.РадиаторПотребление + ВыборкаГруппы.ВентПотребление + ВыборкаГруппы.ГВСПотребление + ОбластьМакета.Параметры.ИтогоПотреблениеВМОП;
			
			ОбластьМакета.Параметры.ИтогоСтоимостьВМОП = ВыборкаГруппы.СтоимостьМОПСНДС;
			ОбластьМакета.Параметры.ИтогоСтоимостьСНДС = ВыборкаГруппы.СуммаПоТеплоснабжению; 
			
			ОбластьМакета.Параметры.Тариф = Тариф;
			
			ОбластьМакета.Параметры.ИтогоНДС = (ОбластьМакета.Параметры.ИтогоСтоимостьСНДС/118)*18; 
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции


Функция ПечатьАктаПоСчетчикамТепло(МассивОбъектов, ОбъектыПечати,АктМОП)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Если Не АктМОП Тогда 
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамТепло");
	Иначе
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамТеплоМОП");
	КонецЕсли;
	
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетАктПоСчетчикамТепло");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		Запрос.УстановитьПараметр("Ссылка", Документ);
		//Запрос.УстановитьПараметр("ВидРесурса", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоРасходомерам);
		Запрос.УстановитьПараметр("ВидРесурса2", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам);
		Если АктМОП Тогда
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Общий);
		Иначе
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Индивидуальный);
		КОнецЕсли;
		
		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.Организация = Документ.Организация.НаименованиеСокращенное;
			ОбластьМакета.Параметры.Дата = Формат(Документ.Дата, "ДЛФ=ДД");
			Если АктМОП Тогда
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания теплосчетчиков "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение тепловой энергии в Местах общего пользования";
			Иначе
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания теплосчетчиков "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение тепловой энергии в помещениях Арендатора";
			КонецЕСли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//Найдем КА
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				Контрагент = ВыборкаГруппы.Контрагент;
			Иначе
				Контрагент = Документ.Контрагент;
			КОнецЕсли;
		
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Выборка = ВыборкаГруппы.Выбрать();
			//строки
			ТекНомерСтроки = 0;
			Пока Выборка.Следующий() Цикл
				ТекНомерСтроки = ТекНомерСтроки + 1;
				ОбластьМакета = Макет.ПолучитьОбласть("Строка");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
				ТабличныйДокумент.Вывести(ОбластьМакета);
				
			КонецЦикла;
			
			 //итого
			ОбластьМакета = Макет.ПолучитьОбласть("Итого");
			ИтогоПотребление = ВыборкаГруппы.РадиаторПотребление + ВыборкаГруппы.ВентПотребление + ВыборкаГруппы.ГВСПотребление;
			ОбластьМакета.Параметры.ИтогоПотребление = ИтогоПотребление; 
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//итого для акта МОП
			Если АктМоп Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("ИтогоМОП");
				ОбластьМакета.Параметры.ИтогоДоляПоДоговору = Строка(ВыборкаГруппы.ДоляВМОП) + "%";
				ОбластьМакета.Параметры.ИтогоДоляПотребления = ВыборкаГруппы.ИтогоПотребление;
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЕсли;
			
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				ОбластьМакета.Параметры.Арендатор = Контрагент.Наименование;
			Иначе
				ОбластьМакета.Параметры.Арендатор = Контрагент.Наименование;
			КОнецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ПечатьАктаПоСчетчикамВода(МассивОбъектов, ОбъектыПечати, АктМОП)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Если Не АктМоп Тогда
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамВода");
	Иначе
		Запрос.Текст = ПолучитьТекстЗапроса("АктПоСчетчикамВодаМОП");
	КонецЕсли;
	
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетАктПоСчетчикамВода");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		//запрос по нескольким видам ресурсов счетчика, добавим их в массив
		МассивВидовРесурсов = Новый Массив;
		МассивВидовРесурсов.Добавить(Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам); 
		МассивВидовРесурсов.Добавить(Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам);
		//МассивВидовРесурсов.Добавить(Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоРасходомерам);
		МассивВидовРесурсов.Добавить(Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам);
		
		Запрос.УстановитьПараметр("Период", ДобавитьМесяц(Документ.ОкончаниеПериода, -1));
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("МассивВидовРесурсов", МассивВидовРесурсов);
		
		Если АктМОП Тогда
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Общий);
		Иначе
			Запрос.УстановитьПараметр("ВидСчетчика", Перечисления.АР_ВидыСчетчиков.Индивидуальный);
		КОнецЕсли;
		
		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.Организация = Документ.Организация.НаименованиеСокращенное;
			ОбластьМакета.Параметры.Дата = Формат(Документ.Дата, "ДЛФ=ДД");
			Если АктМОП Тогда
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания счетчиков водоснабжения на объекте "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение холодного и горячего водоснабжения и водоотведения в Местах общего пользования.";
			Иначе
				ОбластьМакета.Параметры.ТекстЗаголовка = "Настоящий акт составлен в том, что зафиксированы следующие показания счетчиков водоснабжения на объекте "+ВыборкаГруппы.ОбъектАрендыАдрес+", за " + НРег(Строка(Формат(Документ.Дата, "ДФ='ММММ гггг'"))) +", учитывающих потребителение холодного и горячего водоснабжения и водоотведения в помещениях Арендатора.";
			КонецЕСли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			//заполним таблицы формы
			//создадим ТЗ с итогами по таблицам
			КвалификаторыЧисла = 
			Новый КвалификаторыЧисла(10, 3, ДопустимыйЗнак.Любой);
			ОписаниеЧисла = Новый ОписаниеТипов("Число", КвалификаторыЧисла);
			
			ТЗИтогов = Новый ТаблицаЗначений;
			ТЗИтогов.Колонки.Добавить("ИтогПоТаблице", ОписаниеЧисла);
			
			ТЗИтоговМОП = Новый ТаблицаЗначений;
			ТЗИтоговМОП.Колонки.Добавить("ИтогПоТаблице", ОписаниеЧисла);
			
			//Найдем КА
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				Контрагент = ВыборкаГруппы.Контрагент;
			Иначе
				Контрагент = Документ.Контрагент;
			КОнецЕсли;
			
			Выборка = ВыборкаГруппы.Выбрать();
			
			ТабличныйДокумент = ЗаполнениеТаблицыВодоснабжения(ТабличныйДокумент, Выборка, Макет, ВыборкаГруппы,АктМоп,ТЗИтогов,1,Документ,ТЗИтоговМОП);
			Выборка.Сбросить();
			ТабличныйДокумент = ЗаполнениеТаблицыВодоснабжения(ТабличныйДокумент, Выборка, Макет, ВыборкаГруппы,АктМоп,ТЗИтогов,2,Документ,ТЗИтоговМОП);
			Выборка.Сбросить();
			ТабличныйДокумент = ЗаполнениеТаблицыВодоснабжения(ТабличныйДокумент, Выборка, Макет, ВыборкаГруппы,АктМоп,ТЗИтогов,3,Документ,ТЗИтоговМОП);
			
			//таблица 4 - водоотведение
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаВодоотведение");
			ТабличныйДокумент.Вывести(ОбластьМакета);

			ИтогоВодоотведение = 0;
			ОбластьМакета = Макет.ПолучитьОбласть("СтрокаВодоотведение");
			ОбластьМакета.Параметры.Источник =  "1. Холодное водоснабжение по расходомерам";
			ОбластьМакета.Параметры.Потребление = ТЗИтогов[0].ИтогПоТаблице; 
			ИтогоВодоотведение = ИтогоВодоотведение + ТЗИтогов[0].ИтогПоТаблице;
			ТабличныйДокумент.Вывести(ОбластьМакета);

			ОбластьМакета = Макет.ПолучитьОбласть("СтрокаВодоотведение");
			ОбластьМакета.Параметры.Источник =  "2. Горячее водоснабжение по расходомерам";
			ОбластьМакета.Параметры.Потребление = ТЗИтогов[1].ИтогПоТаблице;
			ИтогоВодоотведение = ИтогоВодоотведение + ТЗИтогов[1].ИтогПоТаблице;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("СтрокаВодоотведение");
			ОбластьМакета.Параметры.Источник =  "3. Горячее водоснабжение по теплосчетчикам";
			ОбластьМакета.Параметры.Потребление = ТЗИтогов[2].ИтогПоТаблице;
			ИтогоВодоотведение = ИтогоВодоотведение + ТЗИтогов[2].ИтогПоТаблице;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ИтогоВодоотведение");
			ОбластьМакета.Параметры.ИтогоПотребление = ИтогоВодоотведение;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//итого для акта МОП
			Если АктМоп Тогда
				ОбластьМакета = Макет.ПолучитьОбласть("ИтогоМОПВодоотведение");
				
				ОбластьМакета.Параметры.ИтогоДоляПоДоговору = Строка(ВыборкаГруппы.ДоляАрендатораВМОП) + "%";
				ОбластьМакета.Параметры.ИтогоДоляПотребления = ИтогоВодоотведение * (ВыборкаГруппы.ДоляАрендатораВМОП/100);
				
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЕсли;
			//конец табл 4

			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				ОбластьМакета.Параметры.Арендатор = ВыборкаГруппы.Контрагент.Наименование;
			Иначе
				ОбластьМакета.Параметры.Арендатор = Документ.Контрагент.Наименование;
			КОнецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ЗаполнениеТаблицыВодоснабжения(ТабличныйДокумент, Выборка, Макет, ВыборкаГруппы, АктМоп,ТЗИтогов, НомерТаблицы, Документ,ТЗИтоговМОП)
	
	Если НомерТаблицы = 1 Тогда
		
		ОбластьШапка =  Макет.ПолучитьОбласть("ШапкаРасходомер");
		ОбластьШапка.Параметры.ЗаголовокШапки = "1. Холодное водоснабжение по расходомерам";
		ОбластьСтрока = "СтрокаРасходомер";
		ОбластьИтог = Макет.ПолучитьОбласть("ИтогоРасходомер");
		ВидРесурсаСчетчикаДляЗаполнения = Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам;
		ПолеДляИтогов = "Потребление";
		//Если АктМОП Тогда
		//	ПолеДляИтоговМОП = "ПотреблениеИтог" 
		//КонецЕсли;	
	ИначеЕсли НомерТаблицы = 2 Тогда
		
		ОбластьШапка =  Макет.ПолучитьОбласть("ШапкаРасходомер");
		ОбластьШапка.Параметры.ЗаголовокШапки = "2. Горячее водоснабжение по расходомерам";
		ОбластьСтрока = "СтрокаРасходомер";
		ОбластьИтог = Макет.ПолучитьОбласть("ИтогоРасходомер");
		ВидРесурсаСчетчикаДляЗаполнения = Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам;
		//ВидРесурсаСчетчикаДляЗаполнения2 = Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоРасходомерам;
		ПолеДляИтогов = "Потребление";
		//Если АктМОП Тогда
		//	ПолеДляИтоговМОП = "ПотреблениеИтог" 
		//КонецЕсли;	
	ИначеЕсли НомерТаблицы = 3 Тогда
		
		ОбластьШапка =  Макет.ПолучитьОбласть("ШапкаТеплосчетчик");
		ОбластьШапка.Параметры.ЗаголовокШапки = "3. Горячее водоснабжение по теплосчетчикам";
		ОбластьСтрока = "СтрокаТеплосчетчик";
		ОбластьИтог = Макет.ПолучитьОбласть("ИтогоТеплосчетчик");
		ВидРесурсаСчетчикаДляЗаполнения = Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам;
		ПолеДляИтогов = "ФактПотребление";
		//Если АктМОП Тогда
		//	ПолеДляИтоговМОП = "ПотреблениеИтог" 
		//КонецЕсли;	
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьШапка);
	
	//строки
	ИтогПоТаблице = 0;
	ИтогПоТаблицеМОП = 0;
	ТекНомерСтроки = 0;
	Пока Выборка.Следующий() Цикл
		Если  Выборка.ВидРесурса = ВидРесурсаСчетчикаДляЗаполнения Тогда
			ТекНомерСтроки = ТекНомерСтроки + 1;
			ОбластьМакета = Макет.ПолучитьОбласть(ОбластьСтрока);
			ОбластьМакета.Параметры.Заполнить(Выборка);
			ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ИтогПоТаблице = ИтогПоТаблице+ Выборка[ПолеДляИтогов];
			Если АктМоп Тогда
				ИтогПоТаблицеМОП =  ИтогПоТаблицеМОП+ Выборка.ПотреблениеИтог;
			КонецЕсли;
		КонецЕСли;
	КонецЦикла;
	НСТР = ТЗИтогов.Вставить(НомерТаблицы -1);
	НСТР.ИтогПоТаблице = ИтогПоТаблице;
	НСТР = ТЗИтоговМОП.Вставить(НомерТаблицы -1);
	НСТР.ИтогПоТаблице = ИтогПоТаблицеМОП;

	//итого
	ОбластьИтог.Параметры.ИтогоПотребление = ИтогПоТаблице;
	ТабличныйДокумент.Вывести(ОбластьИтог);
	
	//итого для акта МОП
	Если АктМоп Тогда
		Если НомерТаблицы = 3 Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ИтогоМОПТеплосчетчик");
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("ИтогоМОПРасходомер");
		КонецЕсли;
		
		ОбластьМакета.Параметры.ИтогоДоляПоДоговору = Строка(ВыборкаГруппы.ДоляАрендатораВМОП) + "%";
		ОбластьМакета.Параметры.ИтогоДоляПотребления = ИтогПоТаблицеМОП;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КОнецФункции

Функция ПечатьСправкаРасчетВода(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапроса("СправкаРасчетВода");
	
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетСправкаРасчетВода");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("Общий", Перечисления.АР_ВидыСчетчиков.Общий);
		Запрос.УстановитьПараметр("ХолоднаяВода", Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам);
		Запрос.УстановитьПараметр("ГорВодаПоРасхМерам", Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам);
		Запрос.УстановитьПараметр("ГВСПоТеплСчетчикам", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоТеплосчетчикам);
		//Запрос.УстановитьПараметр("ГВСРасхМерам", Перечисления.АР_ВидРесурса.ТепловаяЭнергияГВСПоРасходомерам);
		Запрос.УстановитьПараметр("ПустойВид", Перечисления.АР_ВидыСчетчиков.ПустаяСсылка());
		//определим долю в моп для ка

		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.ТекстЗаголовка = "Справка-расчет переменной арендной платы (водопотребление) за " + Формат(Документ.Дата, "ДФ='ММММ гггг'");
			
			//Проверим, печатаем по нескольким контрагентам из одного акта или по одному контрагенту и берём его из шапки
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				ОбластьМакета.Параметры.ДоговорАренды = ВыборкаГруппы.ДоговорКонтрагента.Наименование + " " +ВыборкаГруппы.Контрагент.Наименование;
				Контрагент = ВыборкаГруппы.Контрагент;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//найдем долю в МОП для КА
			ДоляВМОП = ВыборкаГруппы.ДоляВМОП;

			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Выборка = ВыборкаГруппы.Выбрать();
			//строки
			Выборка.Следующий();
			
			Если Выборка.ВидСчетчика = Перечисления.АР_ВидыСчетчиков.Индивидуальный Тогда	
				ОбластьМакета = Макет.ПолучитьОбласть("Строки");
				ОбластьМакета.Параметры.Заголовок = "Потребление в арендуемых помещениях";
				ОбластьМакета.Параметры.Заполнить(Выборка);
				//тарифы
				ОбластьМакета.Параметры.ТарифХВ = Документ.ТарифХолВодоснабжение;
				ОбластьМакета.Параметры.ТарифГВРасхМеры = Документ.ТарифГорВодоснабжение;
				ОбластьМакета.Параметры.ТарифГВСТеплСч = Документ.ТарифТеплоносительКуб;
				ОбластьМакета.Параметры.ТарифВодоотведение = Документ.ТарифВодоотведение;
				
				//
				ТабличныйДокумент.Вывести(ОбластьМакета);
				//строки
				Выборка.Следующий();
			КонецЕсли;
			
			ОбластьМакета = Макет.ПолучитьОбласть("Строки");
			ОбластьМакета.Параметры.Заголовок = "Потребление в Местах общего пользования";
			ОбластьМакета.Параметры.Заполнить(Выборка);
			//тарифы
			ОбластьМакета.Параметры.ТарифХВ = Документ.ТарифХолВодоснабжение;
			ОбластьМакета.Параметры.ТарифГВРасхМеры = Документ.ТарифГорВодоснабжение;
			ОбластьМакета.Параметры.ТарифГВСТеплСч = Документ.ТарифТеплоносительКуб;
			ОбластьМакета.Параметры.ТарифВодоотведение = Документ.ТарифВодоотведение;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//итого
			ОбластьМакета = Макет.ПолучитьОбласть("Итого");
			ОбластьМакета.Параметры.ИтогоСтоимостьСНДС = ВыборкаГруппы.СуммаИтог;
			ОбластьМакета.Параметры.ИтогоНДС = (ОбластьМакета.Параметры.ИтогоСтоимостьСНДС/118)*18;

			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
КонецФункции

Функция ЗаполнениеСтрокиДляСправкиРасчетаПоВодопотреблению(ТабличныйДокумент, Выборка, Макет, ВыборкаГруппы,ТекНомерСтроки,Ресурс)
	ОбластьМакета = Макет.ПолучитьОбласть("Строка");
	ОбластьМакета.Параметры.Заполнить(Выборка);
	ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
	ОбластьМакета.Параметры.Ресурс = Ресурс;
	
	ТабличныйДокумент.Вывести(ОбластьМакета);
	Возврат ТабличныйДокумент;
	
КонецФункции


Функция ПечатьСправкаРасчетЭл(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АктСнятияПоказанийСчетчика_АктПоСчетчикам";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапроса("СправкаРасчетЭл");
	
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР_АктСнятияПоказанийСчетчика.МакетСправкаРасчетЭл");
	
	ПервыйДокумент = Истина;
	
	Для Каждого Документ Из МассивОбъектов Цикл
		
		//выполним запрос и обойдем по группировкам по арендадателям, нужно чтобы на каждого арендателя сформировать отдельный док
		Запрос.УстановитьПараметр("Ссылка", Документ);
		Запрос.УстановитьПараметр("ИндСчетчик", Перечисления.АР_ВидыСчетчиков.Индивидуальный);
		Запрос.УстановитьПараметр("ОбщСчетчик", Перечисления.АР_ВидыСчетчиков.Общий);
		Запрос.УстановитьПараметр("ВидРесурса", Перечисления.АР_ВидРесурса.Электроэнергия);
		
		ВыборкаГруппы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппы.Следующий() Цикл
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

			Если НЕ ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			Иначе
				ПервыйДокумент = Ложь;
			КонецЕсли;
			//заголовок
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			ОбластьМакета.Параметры.ТекстЗаголовка = "Справка-расчет переменной арендной платы (эл.энергия) за " + Формат(Документ.Дата, "ДФ='ММММ гггг'");
			
			//Проверим, печатаем по нескольким контрагентам из одного акта или по одному контрагенту и берём его из шапки
			Если ЗначениеЗаполнено(ВыборкаГруппы.Контрагент) Тогда
				Дог = "";
				Если ЗначениеЗаполнено(ВыборкаГруппы.ДоговорКонтрагента) Тогда
				Дог = ВыборкаГруппы.ДоговорКонтрагента.Наименование + " ";
				КОнецЕсли;
				ОбластьМакета.Параметры.ДоговорАренды = Дог + ВыборкаГруппы.Контрагент.Наименование;
				Контрагент = ВыборкаГруппы.Контрагент;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);

			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Выборка = ВыборкаГруппы.Выбрать();
			//строки
			ТекНомерСтроки = 0;
			Пока Выборка.Следующий() Цикл
				Если Выборка.Счетчик = Null Тогда
					Продолжить;
				КонецЕсли;
				ТекНомерСтроки = ТекНомерСтроки + 1;
				ОбластьМакета = Макет.ПолучитьОбласть("Строка");
				ОбластьМакета.Параметры.Заполнить(Выборка);
				ОбластьМакета.Параметры.Номер = ТекНомерСтроки;
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
			
			//итого
			ОбластьМакета = Макет.ПолучитьОбласть("Итого");
			
			ОбластьМакета.Параметры.ПотреблениеМОП = ВыборкаГруппы.ПотреблениеМОП;
			ОбластьМакета.Параметры.СтоимостьМОПСНДС = ВыборкаГруппы.СтоимостьМОП;
			
			ОбластьМакета.Параметры.ТарифМОП = ВыборкаГруппы.Тариф;
			
			ОбластьМакета.Параметры.ИтогоПотребление = ВыборкаГруппы.Потребление + ОбластьМакета.Параметры.ПотреблениеМОП;
			ОбластьМакета.Параметры.ИтогоСтоимостьСНДС = ВыборкаГруппы.СтоимостьСНДС + ОбластьМакета.Параметры.СтоимостьМОПСНДС;
			ОбластьМакета.Параметры.ИтогоНДС = (ОбластьМакета.Параметры.ИтогоСтоимостьСНДС /118)*18;

			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//подпись
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
			ОбластьМакета.Параметры.Арендодатель = Документ.Организация.НаименованиеСокращенное;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// В табличном документе зададим имя области, в которую был 
			// выведен объект. Нужно для возможности печати покомплектно.
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Документ);
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
КонецФункции

Функция ПечатьАкта(МассивОбъектов, ОбъектыПечати)
	
