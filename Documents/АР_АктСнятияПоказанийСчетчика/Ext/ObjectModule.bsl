#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

	
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ
#Область ПроцедурыИФункцииОбщегоНазначения
// Процедура заполняет документ по данным документа основания
Процедура ЗаполнитьДокументПоОснованию() Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
		
		Организация = ДокументОснование.Организация;
		Контрагент = ДокументОснование.Контрагент;
		ДоговорКонтрагента = ДокументОснование.ДоговорКонтрагента;
		НачалоПериода = ДокументОснование.ФактическоеНачало;
		ОкончаниеПериода = НачалоДня(ТекущаяДата());
		ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика;
		СпособЗаполнения = 1;
		
		ЗаполнитьСтрокиПоКонтрагенту();
		
		Если Показания.Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("За указанный период нет действующих договоров на тарифицированные услуги");
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР_АктСнятияПоказанийсчетчика") Тогда
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокументОснование,, "Дата, Номер, ДокументОснование");
		СдвинутьПериод();
		
		Показания.Загрузить(ДокументОснование.Показания.Выгрузить());
		Для Каждого СтрокаТЧ Из Показания Цикл
			СтрокаТЧ.ПоказаниеНаНачалоПериода = СтрокаТЧ.ПоказаниеНаКонецПериода;
			СтрокаТЧ.ПоказаниеНаКонецПериода = 0;
			СтрокаТЧ.ФактическоеНачало = НачалоПериода;
			СтрокаТЧ.ФактическоеОкончание = ОкончаниеПериода;
		КонецЦикла;
		
	КонецЕсли;
		
КонецПроцедуры

// Процедура предназначена для заполнения табличной части всеми объектами аренды
// по выбранному договору и контрагенту с видом "Тарифицируемая услуга"
Процедура ЗаполнитьСтрокиПоконтрагенту() Экспорт
	
 	Если ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика Тогда
		ЗаполнитьСтрокиПоказанияСчетчика();
	Иначе
		ЗаполнитьСтрокиТелефонныйТрафик();
	КонецЕсли;

КонецПроцедуры

Процедура РаспределитьПоказанияСчетчиков() Экспорт
	
	// Проверим, что все счетчики различные
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаПоказаний", Показания.Выгрузить());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоказанияСчетчиков.Счетчик,
	|	ПоказанияСчетчиков.ПоказаниеНаКонецПериода - ПоказанияСчетчиков.ПоказаниеНаНачалоПериода КАК Разница,
	|	ПоказанияСчетчиков.ПоказаниеНаКонецПериода,
	|	ПоказанияСчетчиков.ПоказаниеНаНачалоПериода
	|ПОМЕСТИТЬ ВТПоказанияСчетчика
	|ИЗ
	|	&ТаблицаПоказаний КАК ПоказанияСчетчиков";
	Запрос.Выполнить();
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(Показания.Счетчик) КАК КоличествоРазличных,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Показания.Счетчик) КАК Количество
	|ИЗ
	|	ВТПоказанияСчетчика КАК Показания";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Не Выборка.КоличествоРазличных = Выборка.Количество Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Счетчики не должны повторяться в строках табличной части");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	// Делаем распределение показаний
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды КАК ОбъектАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор КАК Договор,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ЗаключениеДоговора КАК ЗаключениеДоговора,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды КАК ДатаНачалаАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды КАК ДатаОкончанияАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга КАК Услуга,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик КАК Счетчик,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика КАК КоэффициентОтнесенияСчетчика,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор
	|ПОМЕСТИТЬ ВТАктуальныеПериодыАренды
	|ИЗ
	|	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(&КонецПериода, Услуга = &Услуга) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	|ГДЕ
	|	(АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|			ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &НачалоПериода
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды >= &КонецПериода)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТАктуальныеПериодыАренды.ОбъектАренды,
	|	ВТАктуальныеПериодыАренды.Договор,
	|	ВТАктуальныеПериодыАренды.ЗаключениеДоговора,
	|	ВТАктуальныеПериодыАренды.ДатаНачалаАренды,
	|	ВТАктуальныеПериодыАренды.ДатаОкончанияАренды,
	|	ВТАктуальныеПериодыАренды.Услуга,
	|	ВТАктуальныеПериодыАренды.Счетчик,
	|	ВТАктуальныеПериодыАренды.КоэффициентОтнесенияСчетчика,
	|	ВТАктуальныеПериодыАренды.Регистратор
	|ПОМЕСТИТЬ ВТПоследнийПериодАренды
	|ИЗ
	|	ВТАктуальныеПериодыАренды КАК ВТАктуальныеПериодыАренды
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ВТАктуальныеПериодыАренды.ОбъектАренды КАК ОбъектАренды,
	|			ВТАктуальныеПериодыАренды.ЗаключениеДоговора КАК ЗаключениеДоговора,
	|			ВТАктуальныеПериодыАренды.Услуга КАК Услуга,
	|			МАКСИМУМ(ВТАктуальныеПериодыАренды.ДатаНачалаАренды) КАК ДатаНачалаАренды
	|		ИЗ
	|			ВТАктуальныеПериодыАренды КАК ВТАктуальныеПериодыАренды
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ВТАктуальныеПериодыАренды.ЗаключениеДоговора,
	|			ВТАктуальныеПериодыАренды.ОбъектАренды,
	|			ВТАктуальныеПериодыАренды.Услуга) КАК ВложенныйЗапрос
	|		ПО ВТАктуальныеПериодыАренды.ОбъектАренды = ВложенныйЗапрос.ОбъектАренды
	|			И ВТАктуальныеПериодыАренды.Услуга = ВложенныйЗапрос.Услуга
	|			И ВТАктуальныеПериодыАренды.ЗаключениеДоговора = ВложенныйЗапрос.ЗаключениеДоговора
	|			И ВТАктуальныеПериодыАренды.ДатаНачалаАренды = ВложенныйЗапрос.ДатаНачалаАренды
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТПоследнийПериодАренды.ОбъектАренды,
	|	ВТПоследнийПериодАренды.Договор КАК ДоговорКонтрагента,
	|	ВТПоследнийПериодАренды.Услуга,
	|	ВТПоказанияСчетчика.Счетчик,
	|	ВТПоследнийПериодАренды.КоэффициентОтнесенияСчетчика,
	|	АР_Ставки.Ставка КАК Ставка,
	|	АР_Ставки.Площадь КАК Площадь,
	|	ВЫБОР
	|		КОГДА АР_Ставки.Период <= &НачалоПериода
	|				И ВТПоследнийПериодАренды.ДатаНачалаАренды <= &НачалоПериода
	|			ТОГДА &НачалоПериода
	|		КОГДА АР_Ставки.Период <= ВТПоследнийПериодАренды.ДатаНачалаАренды
	|				И &НачалоПериода <= ВТПоследнийПериодАренды.ДатаНачалаАренды
	|			ТОГДА ВТПоследнийПериодАренды.ДатаНачалаАренды
	|		ИНАЧЕ АР_Ставки.Период
	|	КОНЕЦ КАК ФактическоеНачало,
	|	ВЫБОР
	|		КОГДА ВТПоследнийПериодАренды.ДатаОкончанияАренды < &КонецПериода
	|			ТОГДА ВТПоследнийПериодАренды.ДатаОкончанияАренды
	|		ИНАЧЕ &КонецПериода
	|	КОНЕЦ КАК ФактическоеОкончание,
	|	ВТПоследнийПериодАренды.Договор.Владелец КАК Контрагент,
	|	ВТПоказанияСчетчика.Разница * ВТПоследнийПериодАренды.КоэффициентОтнесенияСчетчика КАК Количество,
	|	ВТПоказанияСчетчика.ПоказаниеНаНачалоПериода,
	|	ВТПоказанияСчетчика.ПоказаниеНаКонецПериода
	|ИЗ
	|	ВТПоказанияСчетчика КАК ВТПоказанияСчетчика
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПоследнийПериодАренды КАК ВТПоследнийПериодАренды
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки.СрезПоследних(&КонецПериода, ) КАК АР_Ставки
	|			ПО ВТПоследнийПериодАренды.Договор = АР_Ставки.Договор
	|				И ВТПоследнийПериодАренды.ОбъектАренды = АР_Ставки.ОбъектАренды
	|				И ВТПоследнийПериодАренды.Услуга = АР_Ставки.Услуга
	|		ПО (ВТПоследнийПериодАренды.Счетчик = ВТПоказанияСчетчика.Счетчик)";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ОкончаниеПериода);
	Запрос.УстановитьПараметр("Услуга", Услуга);
	
	Показания.Очистить();
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		Если ЗначениеЗаполнено(Выборка.Ставка) Тогда
			НоваяСтрока.Цена = АР_ОбщиеПроцедуры.ПолучитьСтавку(Выборка.Ставка, ОкончаниеПериода);
			НоваяСтрока.Сумма = НоваяСтрока.Цена * Выборка.Количество;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура предназначена для заполнения табличной части всеми объектами аренды
// по выбранной услуге
Процедура ЗаполнитьСтрокиПоУслуге(АдресВременногоХранилища =  Неопределено) Экспорт
	
 	Если ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика Тогда
		ЗаполнитьСтрокиПоказанияСчетчикаПоУслуге(АдресВременногоХранилища);
	Иначе
		ЗаполнитьСтрокиТелефонныйТрафикПоУслуге(АдресВременногоХранилища);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьСтрокиПоказанияСчетчика()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СрезИзмененияСтавок.Услуга КАК Услуга,
	|	СрезИзмененияСтавок.ОбъектАренды КАК ОбъектАренды,
	|	АР_Ставки.Ставка КАК Ставка,
	|	АР_Ставки.Площадь КАК Площадь,
	|	НАЧАЛОПЕРИОДА(ВЫБОР
	|			КОГДА АР_Ставки.Период < &НачалоПериода
	|				ТОГДА ВЫБОР
	|						КОГДА СрезИзмененияСтавок.ДатаНачалаАренды < &НачалоПериода
	|							ТОГДА &НачалоПериода
	|						ИНАЧЕ СрезИзмененияСтавок.ДатаНачалаАренды
	|					КОНЕЦ
	|			КОГДА АР_Ставки.Период < СрезИзмененияСтавок.ДатаНачалаАренды
	|				ТОГДА СрезИзмененияСтавок.ДатаНачалаАренды
	|			ИНАЧЕ АР_Ставки.Период
	|		КОНЕЦ, ДЕНЬ) КАК ФактическоеНачало,
	|	СрезИзмененияСтавок.ДатаНачалаАренды,
	|	СрезИзмененияСтавок.ДатаОкончанияАренды,
	|	СрезИзмененияСтавок.Услуга.СтавкаНДС КАК СтавкаНДС,
	|	СрезИзмененияСтавок.Договор КАК ДоговорКонтрагента,
	|	СрезИзмененияСтавок.Договор.Владелец КАК Контрагент,
	|	СрезИзмененияСтавок.Счетчик,
	|	СрезИзмененияСтавок.КоэффициентОтнесенияСчетчика
	|ИЗ
	|	(ВЫБРАТЬ
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Услуга КАК Услуга,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды КАК ОбъектАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Договор КАК Договор,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ЗаключениеДоговора КАК ЗаключениеДоговора,
	|		МАКСИМУМ(АР_Ставки.Период) КАК Период,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды КАК ДатаНачалаАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды КАК ДатаОкончанияАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик КАК Счетчик,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика КАК КоэффициентОтнесенияСчетчика
	|	ИЗ
	|		РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(
	|				&КонецПериода,
	|				Договор = &Договор
	|					И ((НЕ Услуга.АР_ПостояннаяЧастьОплаты)
	|						И (НЕ Услуга.АР_ТелефонИнтернет))) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	|			ПО (АР_Ставки.Период <= ВЫБОР
	|					КОГДА АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды < &НачалоПериода
	|						ТОГДА &НачалоПериода
	|					ИНАЧЕ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды
	|				КОНЕЦ)
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.Услуга = АР_Ставки.Услуга
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды = АР_Ставки.ОбъектАренды
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.Договор = АР_Ставки.Договор
	|				И (АР_СтатусыОбъектовАрендыСрезПоследних.Статус = &ВАренде)
	|				И (АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|					ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|					ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &НачалоПериода
	|						И АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды >= &КонецПериода)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Услуга,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Договор,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ЗаключениеДоговора,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика) КАК СрезИзмененияСтавок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	|		ПО СрезИзмененияСтавок.Услуга = АР_Ставки.Услуга
	|			И СрезИзмененияСтавок.ОбъектАренды = АР_Ставки.ОбъектАренды
	|			И СрезИзмененияСтавок.Период = АР_Ставки.Период
	|			И СрезИзмененияСтавок.Договор = АР_Ставки.Договор
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды,
	|	АР_Ставки.Ставка,
	|	АР_Ставки.Площадь,
	|	НАЧАЛОПЕРИОДА(АР_Ставки.Период, ДЕНЬ),
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга.СтавкаНДС,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор.Владелец,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика
	|ИЗ
	|	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(
	|			&КонецПериода,
	|			Договор = &Договор
	|				И ((НЕ Услуга.АР_ПостояннаяЧастьОплаты)
	|					И (НЕ Услуга.АР_ТелефонИнтернет))) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	|		ПО АР_СтатусыОбъектовАрендыСрезПоследних.Услуга = АР_Ставки.Услуга
	|			И АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды = АР_Ставки.ОбъектАренды
	|			И (АР_Ставки.Период МЕЖДУ ВЫБОР
	|				КОГДА АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды < &НачалоПериода
	|					ТОГДА &НачалоПериода
	|				ИНАЧЕ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды
	|			КОНЕЦ И ВЫБОР
	|				КОГДА АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды > &КонецПериода
	|					ТОГДА &КонецПериода
	|				ИНАЧЕ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды
	|			КОНЕЦ)
	|			И АР_СтатусыОбъектовАрендыСрезПоследних.Договор = АР_Ставки.Договор
	|			И (АР_СтатусыОбъектовАрендыСрезПоследних.Статус = &ВАренде)
	|			И (АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|				ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|				ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &НачалоПериода
	|					И АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды >= &КонецПериода)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Услуга,
	|	ОбъектАренды,
	|	ФактическоеНачало
	|ИТОГИ ПО
	|	Услуга,
	|	ОбъектАренды";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ОкончаниеПериода);
	Запрос.УстановитьПараметр("Договор", ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ВАренде", Перечисления.АР_СтатусыОбъектовАренды.ВАренде);
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ДанныеУчета = Новый ТаблицаЗначений;
	ДанныеУчета.Колонки.Добавить("Контрагент");
	ДанныеУчета.Колонки.Добавить("ДоговорКонтрагента");
	ДанныеУчета.Колонки.Добавить("Услуга");
	ДанныеУчета.Колонки.Добавить("ОбъектАренды");
	ДанныеУчета.Колонки.Добавить("ФактическоеНачало");
	ДанныеУчета.Колонки.Добавить("ФактическоеОкончание");
	ДанныеУчета.Колонки.Добавить("Ставка");
	ДанныеУчета.Колонки.Добавить("Площадь");
	ДанныеУчета.Колонки.Добавить("СтавкаНДС");
	ДанныеУчета.Колонки.Добавить("Сумма");
	ДанныеУчета.Колонки.Добавить("Счетчик");
	ДанныеУчета.Колонки.Добавить("КоэффициентОтнесенияСчетчика");
	
		
	Пока Выборка.Следующий() Цикл
		//обход по услугам
		
		ВыборкаОбъектов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		Пока ВыборкаОбъектов.Следующий() Цикл
			//обход по объектам аренды
			ВыборкаДанных = ВыборкаОбъектов.Выбрать();
			
			КоличествоПериодов = ВыборкаДанных.Количество();
			КоличествоОбработанныхПериодов = 0;
			
			Пока ВыборкаДанных.Следующий() Цикл
				//обход по периодам изменения параметров начисления арендной платы
				Если КоличествоОбработанныхПериодов>0 Тогда
					ДанныеУчета[ДанныеУчета.Количество()-1].ФактическоеОкончание = НачалоДня(ВыборкаДанных.ФактическоеНачало-1);	
				КонецЕсли;
				
				Стр = ДанныеУчета.Добавить();
				ЗаполнитьЗначенияСвойств(Стр,ВыборкаДанных);
							
				КоличествоОбработанныхПериодов = КоличествоОбработанныхПериодов+1;
				Если КоличествоОбработанныхПериодов = КоличествоПериодов Тогда
					Стр.ФактическоеОкончание = Мин(ВыборкаДанных.ДатаОкончанияАренды,ОкончаниеПериода);
				КонецЕсли;
				
			КонецЦикла;	
			
		КонецЦикла;
		
	КонецЦикла;
	
	Показания.Очистить();
	Для Каждого СтрокаТаб Из ДанныеУчета Цикл
		НоваяСтрока = Показания.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаб);
		НоваяСтрока.Цена = АР_ОбщиеПроцедуры.ПолучитьСтавку(СтрокаТаб.Ставка, ОкончаниеПериода);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСтрокиПоказанияСчетчикаПоУслуге(АдресВременногоХранилища =  Неопределено)
	
	Если АдресВременногоХранилища =  Неопределено Тогда
		СписокДоговоров = Новый СписокЗначений;
		СписокОбъектовАренды = Новый СписокЗначений;
	Иначе
		СписокДоговоров = Новый СписокЗначений;
		СписокОбъектовАренды = Новый СписокЗначений;
		ТаблицаЗначений = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
		СписокДоговоров.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ДоговорСсылка"));
		СписокОбъектовАренды.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ОбъектАрендыСсылка"));
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СрезИзмененияСтавок.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	СрезИзмененияСтавок.ОбъектАренды КАК ОбъектАренды,
	|	АР_Ставки.Ставка КАК Ставка,
	|	НАЧАЛОПЕРИОДА(ВЫБОР
	|			КОГДА АР_Ставки.Период < &НачалоПериода
	|				ТОГДА ВЫБОР
	|						КОГДА СрезИзмененияСтавок.ДатаНачалаАренды < &НачалоПериода
	|							ТОГДА &НачалоПериода
	|						ИНАЧЕ СрезИзмененияСтавок.ДатаНачалаАренды
	|					КОНЕЦ
	|			КОГДА АР_Ставки.Период < СрезИзмененияСтавок.ДатаНачалаАренды
	|				ТОГДА СрезИзмененияСтавок.ДатаНачалаАренды
	|			ИНАЧЕ АР_Ставки.Период
	|		КОНЕЦ, ДЕНЬ) КАК ФактическоеНачало,
	|	СрезИзмененияСтавок.ДатаНачалаАренды,
	|	СрезИзмененияСтавок.ДатаОкончанияАренды,
	|	СрезИзмененияСтавок.Услуга.СтавкаНДС КАК СтавкаНДС,
	|	СрезИзмененияСтавок.ДоговорКонтрагента.Владелец КАК Контрагент,
	|	АР_Ставки.Площадь КАК Площадь,
	|	СрезИзмененияСтавок.Услуга,
	|	СрезИзмененияСтавок.Счетчик,
	|	СрезИзмененияСтавок.КоэффициентОтнесенияСчетчика
	|ИЗ
	|	(ВЫБРАТЬ
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Договор КАК ДоговорКонтрагента,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды КАК ОбъектАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Услуга КАК Услуга,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ЗаключениеДоговора КАК ЗаключениеДоговора,
	|		МАКСИМУМ(АР_Ставки.Период) КАК Период,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды КАК ДатаНачалаАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды КАК ДатаОкончанияАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик КАК Счетчик,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика КАК КоэффициентОтнесенияСчетчика
	|	ИЗ
	|		РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(
	|				&КонецПериода,
	|				услуга = &услуга
	|					И (НЕ Услуга.АР_ПостояннаяЧастьОплаты
	|						И НЕ Услуга.АР_ТелефонИнтернет)
	|					И (&НетОтбора
	|						ИЛИ Договор В (&СписокДоговоров))
	|					И (&НетОтбора
	|						ИЛИ ОбъектАренды В (&СписокОбъектовАренды))) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	|			ПО (АР_Ставки.Период <= ВЫБОР
	|					КОГДА АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды < &НачалоПериода
	|						ТОГДА &НачалоПериода
	|					ИНАЧЕ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды
	|				КОНЕЦ)
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.Услуга = АР_Ставки.Услуга
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды = АР_Ставки.ОбъектАренды
	|				И АР_СтатусыОбъектовАрендыСрезПоследних.Договор = АР_Ставки.Договор
	|				И (АР_СтатусыОбъектовАрендыСрезПоследних.Статус = &ВАренде)
	|				И (АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|					ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &КонецПериода
	|					ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &НачалоПериода
	|						И АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды >= &КонецПериода)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Услуга,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Договор,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ЗаключениеДоговора,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.Счетчик,
	|		АР_СтатусыОбъектовАрендыСрезПоследних.КоэффициентОтнесенияСчетчика) КАК СрезИзмененияСтавок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	|		ПО СрезИзмененияСтавок.ОбъектАренды = АР_Ставки.ОбъектАренды
	|			И СрезИзмененияСтавок.Период = АР_Ставки.Период
	|			И СрезИзмененияСтавок.Услуга = АР_Ставки.Услуга
	|			И СрезИзмененияСтавок.ДоговорКонтрагента = АР_Ставки.Договор
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды,
	|	АР_Ставки.Ставка,
	|	НАЧАЛОПЕРИОДА(АР_Ставки.Период, ДЕНЬ),
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга.СтавкаНДС,
	|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор.Владелец,
