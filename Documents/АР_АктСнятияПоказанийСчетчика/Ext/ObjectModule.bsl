Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Контроль наличия дублей ввода показаний счетчиков
	Запрос = Новый Запрос("Выбрать Первые 1 Док.Ссылка Из Документ.АР_АктСнятияПоказанийСчетчика КАК Док Где Док.Проведен И Док.ИК = &ИК
	|И (Док.НачалоПериода Между &ДатаНач И &ДатаКон ИЛИ Док.ОкончаниеПериода Между &ДатаНач И &ДатаКон) И Док.Ссылка <> &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ИК", ИК);
	Запрос.УстановитьПараметр("ДатаНач", НачалоПериода);
	Запрос.УстановитьПараметр("ДатаКон", ОкончаниеПериода);
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда Отказ = Истина; КонецЕсли;
	
	//СуммаДокумента = УчетНДСПереопределяемый.ПолучитьСуммуДокументаСНДС(ЭтотОбъект);
	//КСН 1110 сумма дока
	СуммаДока = Показания.Итог("Сумма"); 
	СуммаДока = СуммаДока + ПоказанияВодоснабжение.Итог("Сумма");
	СуммаДока = СуммаДока + ПоказанияВодоснабжение.Итог("СуммаВодоотведение");
	СуммаДока = СуммаДока + ПоказанияТеплоснабжение.Итог("СуммаПоТеплоснабжению");
	СуммаДока = СуммаДока + ПоказанияТеплоснабжение.Итог("ГВССуммаТеплоносительКуб");
	СуммаДокумента = СуммаДока;

	// Очистим контрагентов и договоры в ТЧ либо в шапке в зависимости от способа заполнения
	Если СпособЗаполнения = 1 Тогда
		Для Каждого СтрокаТЧ Из Показания Цикл
			СтрокаТЧ.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
			СтрокаТЧ.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЦикла;
	Иначе 
		Контрагент = Справочники.Контрагенты.ПустаяСсылка();
		ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

