Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Исключаем из проверки реквизиты, заполнение которых стало необязательным:
	МассивНепроверяемыхРеквизитов = Новый Массив();
			
	Если СпособЗаполнения = 1 Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Услуга");
		МассивНепроверяемыхРеквизитов.Добавить("Показания.Контрагент");
		МассивНепроверяемыхРеквизитов.Добавить("Показания.ДоговорКонтрагента");
	Иначе
		МассивНепроверяемыхРеквизитов.Добавить("Контрагент");
		МассивНепроверяемыхРеквизитов.Добавить("ДоговорКонтрагента");
		МассивНепроверяемыхРеквизитов.Добавить("Показания.Услуга");
	КонецЕсли;
	
	Если НЕ ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Показания.НомерТелефона");
	КонецЕсли;
	
	// Проверим, что период заполнен корректно
	Если ЗначениеЗаполнено(ОкончаниеПериода) Тогда
		Если НачалоПериода > ОкончаниеПериода Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Окончание периода превышает начало периода действия договора",, "Объект.ОкончаниеПериода");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	// Сделаем проверку на вид услуг
	Если СпособЗаполнения = 0 Тогда
		Если Услуга.АР_ТелефонИнтернет И ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Услуга """ + Услуга + """ может использоваться только для вида операции ""Трафик телефонных номеров""", ЭтотОбъект, "Услуга", "Объект", Отказ);
		ИначеЕсли Не Услуга.АР_ТелефонИнтернет И ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Услуга """ + Услуга + """ может использоваться только для вида операции ""Показания счетчика""", ЭтотОбъект, "Услуга", "Объект", Отказ);
		КонецЕсли;
	Иначе
		Для Каждого СтрокаТЧ Из Показания Цикл
			Префикс = "Показания[" + Формат(СтрокаТЧ.НомерСтроки - 1, "ЧН=0; ЧГ=") + "].";	
			Поле = Префикс + "Услуга";
			Если СтрокаТЧ.Услуга.АР_ТелефонИнтернет И ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика Тогда
				ТекстСообщения = "Услуга """ + Услуга + """ может использоваться только для вида операции ""Показания счетчика""";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
			ИначеЕсли Не СтрокаТЧ.Услуга.АР_ТелефонИнтернет И ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ТрафикТелефонныхНомеров Тогда 
				ТекстСообщения = "Услуга """ + Услуга + """ может использоваться только для вида операции ""Трафик телефонных номеров""";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ПроверитьЗаполнениеТабличнойЧасти(Отказ);
	
	// Удаляем из проверяемых реквизитов все, по которым автоматическая проверка не нужна:
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	// ПОДГОТОВКА ПРОВЕДЕНИЯ ПО ДАННЫМ ДОКУМЕНТА

	ПроведениеСервер.ПодготовитьНаборыЗаписейКПроведению(ЭтотОбъект);
	Если РучнаяКорректировка Тогда
		Возврат;
	КонецЕсли;

	ПараметрыПроведения = Документы.АР_АктСнятияПоказанийСчетчика.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	// ПОДГОТОВКА ПРОВЕДЕНИЯ ПО ДАННЫМ ИНФОРМАЦИОННОЙ БАЗЫ

	// ФОРМИРОВАНИЕ ДВИЖЕНИЙ                                           
	 
	//АР_ОбщиеПроцедуры.СформироватьДвиженияПоРегистру(ПараметрыПроведения.Начисления, Движения, "АР_НачисленияПоТарифицируемымУслугам", Отказ); // + NAI Becar Конюшок С.Н. от 18.01.2017 10:55  
	
	//КСН фиксация показаний счетчиков
	
	ТаблПоказаний = СформироватьТаблПоказаний();
	
	Движения.АР_ПоказанияСчетчиков.Записывать = Истина;
	
	Пока ТаблПоказаний.Следующий() Цикл
		
		Запись = Движения.АР_ПоказанияСчетчиков.Добавить();
		Запись.Регистратор = Ссылка;
		Запись.Период    = ОкончаниеПериода;
		ЗаполнитьЗначенияСвойств(Запись,ТаблПоказаний);
		
	КонецЦикла;
	
	ЗагрузкаВДоговор();
	
	ЗагрузкаОбщихСчетчиков();
			
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)

	ПроведениеСервер.ПодготовитьНаборыЗаписейКОтменеПроведения(ЭтотОбъект);
	Движения.Записать();

КонецПроцедуры

#КонецОбласти

#Область ОбработкаДанных

Процедура ЗагрузкаВДоговор()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Электроэнергия.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Электроэнергия.Сумма КАК СуммаЭлектричество,
	|	0 КАК СуммаПоТеплоснабжению,
	|	0 КАК СуммаХВ,
	|	0 КАК СуммаВодоотведение,
	|	0 КАК ГВССуммаВодоотведениеТеплоносительКуб,
	|	0 КАК ГВССумма,
	|	0 КАК СуммаГВ
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК Электроэнергия
	|ГДЕ
	|	Электроэнергия.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ХолоднаяВода.ДоговорКонтрагента,
	|	0,
	|	0,
	|	ХолоднаяВода.Сумма,
	|	ХолоднаяВода.СуммаВодоотведение,
	|	0,
	|	0,
	|	0
	|ИЗ
	|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияВодоснабжение КАК ХолоднаяВода
	|ГДЕ
	|	ХолоднаяВода.Ссылка = &Ссылка
	|	И ХолоднаяВода.Счетчик.НазваниеРесурса.ВидРесурса = ЗНАЧЕНИЕ(Перечисление.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ГорячаяВода.ДоговорКонтрагента,
	|	0,
	|	0,
	|	0,
	|	ГорячаяВода.СуммаВодоотведение,
	|	0,
	|	0,
	|	ГорячаяВода.Сумма
	|ИЗ
	|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияВодоснабжение КАК ГорячаяВода
	|ГДЕ
	|	ГорячаяВода.Ссылка = &Ссылка
	|	И ГорячаяВода.Счетчик.НазваниеРесурса.ВидРесурса = ЗНАЧЕНИЕ(Перечисление.АР_ВидРесурса.ГорячаяВодаПоРасходомерам)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Теплоснабжение.ДоговорКонтрагента,
	|	0,
	|	Теплоснабжение.СуммаПоТеплоснабжению,
	|	0,
	|	0,
	|	Теплоснабжение.ГВССуммаВодоотведениеТеплоносительКуб,
	|	Теплоснабжение.ГВССуммаТеплоносительКуб,
	|	0
	|ИЗ
	|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияТеплоснабжение КАК Теплоснабжение
	|ГДЕ
	|	Теплоснабжение.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	СУММА(ВТ.СуммаЭлектричество) КАК СуммаЭлектричество,
	|	СУММА(ВТ.СуммаПоТеплоснабжению) КАК СуммаПоТеплоснабжению,
	|	СУММА(ВТ.СуммаВодоотведение) КАК СуммаВодоотведение,
	|	СУММА(ВТ.ГВССуммаВодоотведениеТеплоносительКуб) КАК ГВССуммаВодоотведениеТеплоносительКуб,
	|	СУММА(ВТ.ГВССумма) КАК ГВССумма,
	|	СУММА(ВТ.СуммаХВ) КАК СуммаХВ,
	|	СУММА(ВТ.СуммаГВ) КАК СуммаГВ
	|ПОМЕСТИТЬ ВТГрупп
	|ИЗ
	|	ВТ КАК ВТ
	|ГДЕ
	|	ВТ.ДоговорКонтрагента <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ЗаключениеДоговораАренды,
	|	ВТГрупп.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ЕСТЬNULL(ВТГрупп.СуммаЭлектричество, 0) КАК СуммаЭлектричество,
	|	ЕСТЬNULL(ВТГрупп.СуммаПоТеплоснабжению, 0) КАК СуммаПоТеплоснабжению,
	|	ЕСТЬNULL(ВТГрупп.СуммаВодоотведение, 0) КАК СуммаВодоотведение,
	|	ЕСТЬNULL(ВТГрупп.ГВССуммаВодоотведениеТеплоносительКуб, 0) КАК ГВССуммаВодоотведениеТеплоносительКуб,
	|	ЕСТЬNULL(ВТГрупп.СуммаХВ, 0) КАК СуммаХВ,
	|	ЕСТЬNULL(ВТГрупп.ГВССумма, 0) КАК ГВССумма,
	|	ЕСТЬNULL(ВТГрупп.СуммаЭлектричество, 0) + ЕСТЬNULL(ВТГрупп.СуммаПоТеплоснабжению, 0) + ЕСТЬNULL(ВТГрупп.СуммаВодоотведение, 0) + ЕСТЬNULL(ВТГрупп.ГВССуммаВодоотведениеТеплоносительКуб, 0) + ЕСТЬNULL(ВТГрупп.СуммаХВ, 0) + ЕСТЬNULL(ВТГрупп.ГВССумма, 0) КАК СуммаВсего,
	|	ЕСТЬNULL(ВТГрупп.СуммаГВ, 0) КАК СуммаГВ
	|ИЗ
	|	ВТГрупп КАК ВТГрупп
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|		ПО ВТГрупп.ДоговорКонтрагента = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	|ГДЕ
	|	НЕ АР17_ЗаключениеДоговораАренды.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	РЗ = Запрос.Выполнить().Выбрать();
	КУ = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
	
	СодержаниеКУ = ПолучитьСодержаниеКУИзИК(КУ);
	
	Пока РЗ.Следующий() Цикл
		Если РЗ.СуммаВсего > 0 Тогда 
			Док = РЗ.ЗаключениеДоговораАренды.ПолучитьОбъект();
			
			Отбор = Новый Структура("АктСнятияПоказаний", Ссылка);
			Строки= Док.КоммунальныеУслуги.НайтиСтроки(Отбор);
			
			Если ЗначениеЗаполнено(Строки) Тогда
				Для Каждого Стр Из Строки Цикл
					Док.КоммунальныеУслуги.Удалить(Стр);
				КонецЦикла;
			КонецЕсли;
			
			Если РЗ.СуммаЭлектричество > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Электроэнергия;
				НСтр.Сумма =  РЗ.СуммаЭлектричество;
				НСтр.Тариф = ТарифЭлектроэнергия;
				НСтр.Услуга = КУ;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Коммунальные услуги, электроэнергия.";
				КонецЕсли;
			КонецЕсли;
			
			Если РЗ.СуммаХВ > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
				НСтр.Сумма =  РЗ.СуммаХВ;
				НСтр.Услуга = КУ;
				НСтр.Тариф = ТарифХолВодоснабжение;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Коммунальные услуги, холодное водоснабжение.";
				КонецЕсли;
			КонецЕсли;
			
			Если РЗ.СуммаГВ > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
				НСтр.Сумма =  РЗ.СуммаГВ;
				НСтр.Услуга = КУ;
				НСтр.Тариф = ТарифГорВодоснабжение;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Коммунальные услуги, горячее водоснабжение.";
				КонецЕсли;
			КонецЕсли;
			
			Если РЗ.СуммаВодоотведение > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
				НСтр.Сумма =  РЗ.СуммаВодоотведение+РЗ.ГВССуммаВодоотведениеТеплоносительКуб;
				НСтр.Услуга = КУ;
				НСтр.Тариф = ТарифВодоотведение;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Коммунальные услуги, водоотведение.";
				КонецЕсли;
			КонецЕсли;
			
			Если РЗ.СуммаПоТеплоснабжению > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Теплоснабжение;
				НСтр.Сумма =  РЗ.СуммаПоТеплоснабжению;
				НСтр.Тариф = ТарифТепло;
				НСтр.Услуга = КУ;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Коммунальные услуги, теплоснабжение.";
				КонецЕсли;
			КонецЕсли;
			
			Если РЗ.ГВССумма > 0 Тогда
				НСтр = ДобавлениеСтроки(Док);
				НСтр.ВидКоммунальныхУслуг =  Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
				НСтр.Сумма =  РЗ.ГВССумма;
				НСтр.Тариф = ТарифТеплоносительКуб;
				НСтр.Услуга = КУ;
				Если СодержаниеКУ <> Неопределено Тогда
					НСтр.Содержание = СодержаниеКУ;
				Иначе
					НСтр.Содержание = "Горячее водоснабжение по теплосчетчику.";
				КонецЕсли;
			КонецЕсли;
			
			Док.Записать(РежимЗаписиДокумента.Проведение);	
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Функция СформироватьТаблПоказаний()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик КАК Счетчик,
		|	МАКСИМУМ(АР_АктСнятияПоказанийСчетчикаПоказания.ПоказаниеНаКонецПериода) КАК ПоказаниеНаКонецПериода,
		|	МАКСИМУМ(АР_АктСнятияПоказанийСчетчикаПоказания.Потребление) КАК Потребление
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка = &Ссылка
		|	И АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик.НазваниеРесурса.ВидРесурса = &Эл
		|
		|СГРУППИРОВАТЬ ПО
		|	АР_АктСнятияПоказанийСчетчикаПоказания.Счетчик
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Счетчик,
		|	МАКСИМУМ(АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.ПоказаниеНаКонецПериода),
		|	МАКСИМУМ(АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Потребление)
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияВодоснабжение КАК АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Ссылка = &Ссылка
		|	И (АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Счетчик.НазваниеРесурса.ВидРесурса = &ГВ
		|			ИЛИ АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Счетчик.НазваниеРесурса.ВидРесурса = &ХВ)
		|
		|СГРУППИРОВАТЬ ПО
		|	АР_АктСнятияПоказанийСчетчикаПоказанияВодоснабжение.Счетчик
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Счетчик КАК Счетчик,
		|	МАКСИМУМ(ВТ.ПоказаниеНаКонецПериода) КАК Показания,
		|	МАКСИМУМ(ВТ.Потребление) КАК Потребление
		|ИЗ
		|	ВТ КАК ВТ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ.Счетчик";
	
	Запрос.УстановитьПараметр("ХВ", Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам);
	Запрос.УстановитьПараметр("ГВ", Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам);
	Запрос.УстановитьПараметр("Эл", Перечисления.АР_ВидРесурса.Электроэнергия);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	ТаблПоказаний = Запрос.Выполнить().Выбрать();

	Возврат ТаблПоказаний;
	
КонецФункции

Функция ПолучитьСодержаниеКУИзИК(КУ)

	Если ЗначениеЗаполнено(ИК) Тогда
		Запрос1 = Новый Запрос;
		Запрос1.Текст = 
		"ВЫБРАТЬ
		|	АР17_УстановкаПараметровИКНоменклатура.Содержание
		|ИЗ
		|	Документ.АР17_УстановкаПараметровИК.Номенклатура КАК АР17_УстановкаПараметровИКНоменклатура
		|ГДЕ
		|	АР17_УстановкаПараметровИКНоменклатура.Ссылка.ИКСсылка = &ИКСсылка
		|	И АР17_УстановкаПараметровИКНоменклатура.Ссылка.Проведен
		|	И НЕ АР17_УстановкаПараметровИКНоменклатура.Ссылка.ПометкаУдаления
		|	И АР17_УстановкаПараметровИКНоменклатура.Номенклатура = &Номенклатура";
		
		Запрос1.УстановитьПараметр("ИКСсылка", ИК);
		Запрос1.УстановитьПараметр("Номенклатура", КУ);
		
		РЗ1 = Запрос1.Выполнить().Выбрать();
		
		Если РЗ1.Следующий() Тогда
			Возврат РЗ1.Содержание;
		КонецЕсли;
		
	КонецЕсли; 

КонецФункции 
 
Функция ДобавлениеСтроки(Док)
	
	НСтр = Док.КоммунальныеУслуги.Добавить();
	НСтр.ДатаНачалаПериода = НачалоПериода;
	НСтр.ДатаОкончанияПериода = ОкончаниеПериода;
	НСтр.Месяц = Формат(ОкончаниеПериода, "ДФ=ММММ"); 
	НСтр.АктСнятияПоказаний  = Ссылка; 
	Возврат НСтр;
	
КонецФункции

Процедура ЗагрузкаОбщихСчетчиков()
	
	// Выборка общих счетчиков из документа
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Спр.НазваниеРесурса КАК Счетчик,
	               |	ВЫБОР
	               |		КОГДА Спр.ВидСчетчика = ЗНАЧЕНИЕ(Перечисление.АР_ВидыСчетчиков.Общий)
	               |			ТОГДА ТЧ.Потребление
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК ПотреблениеОбщее,
	               |	ВЫБОР
	               |		КОГДА Спр.ВидСчетчика = ЗНАЧЕНИЕ(Перечисление.АР_ВидыСчетчиков.Общий)
	               |			ТОГДА 0
	               |		ИНАЧЕ ТЧ.Потребление
	               |	КОНЕЦ КАК ПотреблениеИндиуидуальное
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК ТЧ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АР_Счетчики КАК Спр
	               |		ПО ТЧ.Счетчик = Спр.Ссылка
	               |ГДЕ
	               |	ТЧ.Ссылка = &Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Спр.НазваниеРесурса,
	               |	ВЫБОР
	               |		КОГДА Спр.ВидСчетчика = ЗНАЧЕНИЕ(Перечисление.АР_ВидыСчетчиков.Общий)
	               |			ТОГДА ТЧ.Потребление
	               |		ИНАЧЕ 0
	               |	КОНЕЦ,
	               |	ВЫБОР
	               |		КОГДА Спр.ВидСчетчика = ЗНАЧЕНИЕ(Перечисление.АР_ВидыСчетчиков.Общий)
	               |			ТОГДА 0
	               |		ИНАЧЕ ТЧ.Потребление
	               |	КОНЕЦ
	               |ИЗ
	               |	Документ.АР_АктСнятияПоказанийСчетчика.ПоказанияВодоснабжение КАК ТЧ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АР_Счетчики КАК Спр
	               |		ПО ТЧ.Счетчик = Спр.Ссылка
	               |ГДЕ
	               |	ТЧ.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.Счетчик КАК Счетчик,
	               |	СУММА(ВТ.ПотреблениеОбщее) КАК ПотреблениеОбщее,
	               |	СУММА(ВТ.ПотреблениеИндиуидуальное) КАК ПотреблениеИндиуидуальное
	               |ИЗ
	               |	ВТ КАК ВТ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ.Счетчик";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда Возврат; КонецЕсли;
	КУ = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
	
	Выборка = Рез.Выбрать();
	
	// Поиск ЗДА по ИК
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ИК", ИК);
	Запрос.Текст = "ВЫБРАТЬ
	               |	Спр.Ссылка КАК Ссылка,
	               |	ТЧ.Ссылка КАК ЗДА
	               |ПОМЕСТИТЬ Помещения
	               |ИЗ
	               |	Справочник.АР_ОбъектыАренды КАК Спр
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК ТЧ
	               |		ПО Спр.Ссылка = ТЧ.ОбъектАренды
	               |ГДЕ
	               |	Спр.Ссылка В ИЕРАРХИИ(&ИК)
	               |	И Спр.ТипОбъекта = ЗНАЧЕНИЕ(Справочник.АР_ТипыОбъектовАренды.Помещение)";
	Запрос.Выполнить();
	
	// Определение периодов изменения площадей внутри месяца
	Периоды = Новый СписокЗначений;
	Периоды.Добавить(ОкончаниеПериода);
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ Рег.Период Из РегистрСведений.Ар_ПлощадиОбъектов КАК Рег Внутреннее Соединение Помещения КАК П По Рег.Объект = П.Ссылка 
	|Где Рег.Период > &НачалоПериода И Рег.Период < &КонецПериода";
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ОкончаниеПериода);
	Рез = Запрос.Выполнить().Выбрать();
	Пока Рез.Следующий() Цикл Периоды.Добавить(Рез.Период); КонецЦикла;
	Периоды.СортироватьПоЗначению();
	
	// Определение периодов начисления и площадей каждого из помещений
	ТекНачало = НачалоПериода;
	Табл = Новый ТаблицаЗначений;
	Табл.Колонки.Добавить("ЗДА");
	Табл.Колонки.Добавить("Помещение");
	Табл.Колонки.Добавить("Площадь");
	Табл.Колонки.Добавить("НачалоПериода");
	Табл.Колонки.Добавить("КонецПериода");
	Для Каждого сПериод Из Периоды Цикл
		
		мПериод = сПериод.Значение;
		
		Запрос.Текст = "ВЫБРАТЬ Помещения.ЗДА КАК ЗДА, Помещения.Ссылка КАК Помещение, ЕСТЬNULL(Рег.Площадь, 0) КАК Площадь
		|ИЗ Помещения КАК Помещения ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Ар_ПлощадиОбъектов.СрезПоследних(&Период, ) КАК Рег ПО Помещения.Ссылка = Рег.Объект";
		Запрос.УстановитьПараметр("Период", ТекНачало);
		Результат = Запрос.Выполнить().Выбрать();
		Пока Результат.Следующий() Цикл
			Нов = Табл.Добавить();
			ЗаполнитьЗначенияСвойств(Нов, Результат);
			Нов.НачалоПериода = ТекНачало;
			Нов.КонецПериода = мПериод;
		КонецЦикла;
		
		// Смещаем тек начало на значение из массива
		ТекНачало = мПериод;
		
	КонецЦикла;
	
	// Дополним таблицу общей арендопригодной площадью
	Табл1 = Табл.Скопировать();
	Табл1.Свернуть("НачалоПериода, КонецПериода", "Площадь");
	Табл.Колонки.Добавить("АПП");
	Для Каждого Стр Из Табл1 Цикл
		
		Отбор = Новый Структура;
		Отбор.Вставить("НачалоПериода", Стр.НачалоПериода);
		Отбор.Вставить("КонецПериода", Стр.КонецПериода);
		Поиск = Табл.НайтиСтроки(Отбор);
		Для Каждого мСтр Из Поиск Цикл мСтр.АПП = Стр.Площадь; КонецЦикла;
		
	КонецЦикла;
	
	Табл.Сортировать("ЗДА, НачалоПериода, КонецПериода");
	
	// Заполним данные в ЗДА согласно показаниям счетчиков и долей собственников
	текЗДА = Неопределено;
	ДнейВМесяце = (КонецДня(ОкончаниеПериода) + 1) - НачалоДня(НачалоПериода);
	ДнейВМесяце = ДнейВМесяце / (60*60*24);
	Для Каждого Стр Из Табл Цикл
		
		// Определение доли помещения
		Если Стр.АПП = 0 Тогда Доля = 0; Иначе Доля = Стр.Площадь/Стр.АПП; КонецЕсли;
		
		// Определение доли в месяце от колличества дней
		ДнейВПериоде = НачалоДня(Стр.КонецПериода) - НачалоДня(Стр.НачалоПериода);
		ДнейВПериоде = (ДнейВПериоде / (60*60*24)) + ?(Стр.НачалоПериода = НачалоПериода, 1, 0);
		ДоляПериода = ДнейВПериоде/ДнейВМесяце;
		
		Если Доля > 0 И ДоляПериода > 0 Тогда
		
			Если текЗДА <> Стр.ЗДА Тогда
				Если текЗДА <> Неопределено Тогда
					текЗДА.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
				КонецЕсли;
				текЗДА = Стр.ЗДА.ПолучитьОбъект();
			КонецЕсли;
		
			Водоотведение = 0;
			
			Пока Выборка.Следующий() Цикл
				
				КРаспределению = Выборка.ПотреблениеОбщее - Выборка.ПотреблениеИндиуидуальное;
				
				Если КРаспределению > 0 Тогда
					
					Кол								=	КРаспределению*Доля*ДоляПериода;
					
					НСтр							=	текЗДА.КоммунальныеУслуги.Добавить();
					НСтр.ДатаНачалаПериода			=	Стр.НачалоПериода;
					НСтр.ДатаОкончанияПериода		=	Стр.КонецПериода;
					НСтр.Месяц						=	Формат(Стр.КонецПериода, "ДФ=ММММ"); 
					НСтр.АктСнятияПоказаний			=	Ссылка;
					НСтр.Услуга						=	КУ;
					
					Если Выборка.Счетчик.ВидРесурса = Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам Тогда
						
						Водоотведение = Водоотведение + Кол*ТарифВодоотведение;
						
						НСтр.Сумма					=	Кол*ТарифХолВодоснабжение;
						НСтр.Тариф					=	ТарифХолВодоснабжение;
						НСтр.ВидКоммунальныхУслуг	=	Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
						НСтр.Содержание				=	"Коммунальные услуги, холодное водоснабжение(МОП).";
						
					ИначеЕсли Выборка.Счетчик.ВидРесурса = Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам Тогда
						
						Водоотведение = Водоотведение + Кол*ТарифВодоотведение;
						
						НСтр.Сумма					=	Кол*ТарифГорВодоснабжение;
						НСтр.Тариф					=	ТарифГорВодоснабжение;
						НСтр.ВидКоммунальныхУслуг	=	Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
						НСтр.Содержание				=	"Коммунальные услуги, горячее водоснабжение(МОП).";
						
					ИначеЕсли Выборка.Счетчик.ВидРесурса = Перечисления.АР_ВидРесурса.Электроэнергия Тогда
						
						НСтр.Сумма					=	Кол*ТарифЭлектроэнергия;
						НСтр.Тариф					=	ТарифЭлектроэнергия;
						НСтр.ВидКоммунальныхУслуг	=	Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Электроэнергия;
						НСтр.Содержание				=	"Коммунальные услуги, электроэнергия(МОП).";
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если Водоотведение > 0 Тогда
				
				НСтр						=	текЗДА.КоммунальныеУслуги.Добавить();
				НСтр.ДатаНачалаПериода		=	Стр.НачалоПериода;
				НСтр.ДатаОкончанияПериода	=	Стр.КонецПериода;
				НСтр.Месяц					=	Формат(Стр.КонецПериода, "ДФ=ММММ"); 
				НСтр.АктСнятияПоказаний		=	Ссылка;
				НСтр.Услуга					=	КУ;
				НСтр.Сумма					=	Водоотведение;
				НСтр.Тариф					=	ТарифВодоотведение;
				НСтр.Содержание				=	"Коммунальные услуги, водоотведение (МОП).";
				НСтр.ВидКоммунальныхУслуг	=	Перечисления.АР_ТипАктаСнятияПоказанийСчетчика.Водоснабжение;
				
			КонецЕсли;
			
			Выборка.Сбросить();
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если текЗДА <> Неопределено Тогда
				
		текЗДА.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
				
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
