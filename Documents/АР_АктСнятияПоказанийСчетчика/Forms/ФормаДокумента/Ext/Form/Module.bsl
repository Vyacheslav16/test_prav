&НаСервере
Процедура РасчетИтогаДокумента()
	
	СуммаДока = Объект.Показания.Итог("Сумма"); 
	СуммаДока = СуммаДока + Объект.ПоказанияВодоснабжение.Итог("Сумма");
	СуммаДока = СуммаДока + Объект.ПоказанияВодоснабжение.Итог("СуммаВодоотведение");
	СуммаДока = СуммаДока + Объект.ПоказанияТеплоснабжение.Итог("СуммаПоТеплоснабжению");
	СуммаДока = СуммаДока + Объект.ПоказанияТеплоснабжение.Итог("ГВССуммаТеплоносительКуб");
	Объект.СуммаДокумента = СуммаДока;
	
