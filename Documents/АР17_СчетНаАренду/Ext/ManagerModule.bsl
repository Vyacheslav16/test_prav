&НаСервере
Функция ПечатьРасчетПени(МассивОбъектов, ОбъектыПечати, СПечатью = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	
	ТекСчет =  МассивОбъектов.Получить(0).Ссылка;
	Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР17_СчетНаАренду.РасчетПени");	
	//Макет = ПолучитьМакет("РасчетПени");
	// Получаем области макета для вывода в табличный документ
	ОбластьМакета            = Макет.ПолучитьОбласть("Шапка");
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАренды.ИК КАК ИК,
	               |	АР_ЗаключениеДоговораАренды.Контрагент КАК Контрагент,
	               |	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента КАК договор,
	               |	АР_ЗаключениеДоговораАренды.СтавкаПени Как СтавкаПени
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ТекСчет.ДоговорКонтрагента);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ИнфаПроКомплекс = Выборка.ИК;
		ИнфаПроАрендатора = Выборка.Контрагент;
		ИнфаПроДоговор = Выборка.договор;
		СтавкаПени = Выборка.СтавкаПени;
		
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(АР_СчетНаАрендуСостав.ДолгЗаПериод) КАК ДолгЗаПериод,
	               |	СУММА(АР_СчетНаАрендуСостав.КоличествоДнейПросрочки) КАК КоличествоДнейПросрочки,
	               |	АР_СчетНаАрендуСостав.Номенклатура КАК Номенклатура,
	               |	АР_СчетНаАрендуСостав.ПериодАренды КАК ПериодАренды,
	               |	МИНИМУМ(АР_СчетНаАрендуСостав.СрокОплаты) КАК СрокОплаты,
				   |	Сумма(АР_СчетНаАрендуСостав.Сумма) Как СуммаПени
	               |ИЗ
	               |	Документ.АР17_СчетНаАренду.Состав КАК АР_СчетНаАрендуСостав
	               |ГДЕ
	               |	АР_СчетНаАрендуСостав.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СчетНаАрендуСостав.Номенклатура,
	               |	АР_СчетНаАрендуСостав.Количество,
	               |	АР_СчетНаАрендуСостав.КоличествоДней,
	               |	АР_СчетНаАрендуСостав.ПериодАренды";
	Запрос.УстановитьПараметр("Ссылка",ТекСчет);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		
		НаименованиеПлатежа = "Постоянная арендная плата";
		ПериодНачисления =  Формат(Выборка.ПериодАренды, "ДФ=dd.MM.yyyy");;
		СуммаЗадолженности =  Выборка.ДолгЗаПериод;
		ПериодРасчета = "С " + Формат(Выборка.СрокОплаты, "ДФ=dd.MM.yyyy") + " по " +  Формат(Выборка.СрокОплаты + 60*60*24*Выборка.КоличествоДнейПросрочки, "ДФ=dd.MM.yyyy");
		КолвоДнейПросрочки = Выборка.КоличествоДнейПросрочки;
		СуммаПени = Выборка.СуммаПени;
		
	КонецЕсли;
	
	
	ОбластьМакета.Параметры.ИнфаПроСчет = ТекСчет.Номер + " от "+ Формат(ТекСчет.Дата, "ДФ=dd.MM.yyyy");
	ОбластьМакета.Параметры.ДатаРасчетаПени = Формат(ТекСчет.Дата, "ДФ=dd.MM.yyyy");
	ОбластьМакета.Параметры.ИнфаПроКомплекс = ИнфаПроКомплекс;
	ОбластьМакета.Параметры.ИнфаПроАрендатора = ИнфаПроАрендатора;
	ОбластьМакета.Параметры.ИнфаПроДоговор = ИнфаПроДоговор;
	
	ОбластьМакета.Параметры.НаименованиеПлатежа = "Постоянная арендная плата";
	ОбластьМакета.Параметры.ПериодНачисления = ПериодНачисления;
	ОбластьМакета.Параметры.СуммаЗадолженности = СуммаЗадолженности;
	ОбластьМакета.Параметры.ПериодРасчета = ПериодРасчета;
	ОбластьМакета.Параметры.КолвоДнейПросрочки = КолвоДнейПросрочки;

	
	//ОбластьМакета.Параметры.ОкпоИсполнителя = Шапка.Поставщик.КодПоОКПО;
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
	
	ОбластьМакета            = Макет.ПолучитьОбласть("Шапкаставок");
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
	ОбластьМакета            = Макет.ПолучитьОбласть("СтрокаСтавок");
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАрендыПени.СтавкаПениСДня КАК СтавкаПениСДня,
	               |	АР_ЗаключениеДоговораАрендыПени.СтавкаПениПослеНовойДаты КАК СтавкаПениПослеНовойДаты
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.Пени КАК АР_ЗаключениеДоговораАрендыПени
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАрендыПени.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента";
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ТекСчет.ДоговорКонтрагента);
	РезЗап = Запрос.Выполнить();
	
	Если РезЗап.Пустой() Тогда
		ОбластьМакета            = Макет.ПолучитьОбласть("СтрокаСтавок");
		ОбластьМакета.Параметры.Ставка = СтавкаПени;
		ОбластьМакета.Параметры.КоличествоДней = "Постоянная ставка"; 
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
	Иначе	
	    Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ОбластьМакета            = Макет.ПолучитьОбласть("СтрокаСтавок");
			ОбластьМакета.Параметры.Ставка = Выборка.СтавкаПениПослеНовойДаты;
			ОбластьМакета.Параметры.КоличествоДней = Выборка.СтавкаПениСдня; 
		
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		
		КонецЦикла;
	
	КонецЕсли;
	
	ОбластьМакета            = Макет.ПолучитьОбласть("ИтогПени");
	ОбластьМакета.Параметры.ИтогоПени = СуммаПени;	
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
	ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
	Возврат ТабличныйДокумент;	
	
КонецФункции
// - NAI Becar Матюхин Н.О.

// Функция формирует табличный документ с печатной формой заказа или счета,
// разработанного методистами
//
// Возвращаемое значение:
//  Табличный документ - сформированная печатная форма
//
Функция ПечатьСчета(МассивОбъектов, ОбъектыПечати, Сводный, БезЕдИзм = Ложь, ЕстьПрефикс = Ложь) Экспорт

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АР_СчетНаАренду_СчетЗаказ";
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("УслугаАренда",   Константы.АР_УслугаАренда.Получить());
	
	// + NAI Becar Матюхин Н.О. от 24.10.2016 17:03 по заявке № 
	ЭтоОплатаПени = Ложь;
	Если МассивОбъектов.Количество() > 0 И МассивОбъектов[0].ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаПени Тогда
		ЭтоОплатаПени = Истина;
	КонецЕсли;	
	// - NAI Becar Матюхин Н.О.
	
	Если ЭтоОплатаПени Тогда
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуПокупателюОплатаПени();
	ИначеЕсли Сводный = Неопределено Тогда
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуПокупателю();
	ИначеЕсли Сводный Тогда
		Если БезЕдИзм Тогда  // + NAI Becar Конюшок С.Н. от 07.02.2017 17:51 
			ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуСводный(Истина);
		Иначе
			ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуСводный();
		КонецЕсли;
	Иначе
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуРазвернутый();
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;

	Шапка = Запрос.Выполнить().Выбрать();
	Шапка1 = Запрос.Выполнить().Выгрузить(); //-са
	
	ПервыйДокумент = Истина;
	
	Пока Шапка.СледующийПоЗначениюПоля("Ссылка") Цикл
		
		//+са
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_ЗаключениеДоговораАренды.Ссылка
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
		
		Запрос.УстановитьПараметр("ДоговорКонтрагента", Шапка.ДоговорКонтрагента);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		НайденныйДоговор = Выборка.Ссылка;	
		//-са

		
		Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР17_СчетНаАренду.СчетЗаказ");

		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Выводим шапку накладной
		
		СведенияОПолучателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		ОбластьМакета       = Макет.ПолучитьОбласть("ЗаголовокСчета");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.ИНН = СведенияОПолучателе.ИНН;
		ОбластьМакета.Параметры.КПП = СведенияОПолучателе.КПП;
		Если ТипЗнч(Шапка.СтруктурнаяЕдиница) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
			РС = ПолучитьРС(Выборка.Ссылка,Шапка.Дата);
			Если СокрЛП(РС) = "" Тогда
				ОбластьМакета.Параметры.БИКБанкаПолучателя               = Шапка.БикБанкаПолучателя;
				ОбластьМакета.Параметры.БанкПолучателя                   = Шапка.БанкПолучателя;
				ОбластьМакета.Параметры.БанкПолучателяПредставление      = СокрЛП(Шапка.НаименованиеБанкаПолучателя);
				ОбластьМакета.Параметры.СчетБанкаПолучателя              = Шапка.СчетБанкаПолучателя;
				ОбластьМакета.Параметры.СчетБанкаПолучателяПредставление = Шапка.СчетБанкаПолучателя;
				//ОбластьМакета.Параметры.СчетПолучателяПредставление      = Шапка.НомерСчетаПолучателя;
				ОбластьМакета.Параметры.СчетПолучателяПредставление      = ?(СокрЛП(ПолучитьРС(Выборка.Ссылка,Шапка.Дата)) <> "",СокрЛП(ПолучитьРС(Выборка.Ссылка,Шапка.Дата).НомерСчета),Шапка.НомерСчетаПолучателя); //-са
				ОбластьМакета.Параметры.СчетПолучателя                   = Шапка.НомерСчетаПолучателя;
			Иначе
				// + NAI Becar Комментирование Смирнов А.А. от 06.06.2019 10:34
				ОбластьМакета.Параметры.БИКБанкаПолучателя               = РС.Банк.Код;
				ОбластьМакета.Параметры.БанкПолучателя                   = РС.Банк;
				ОбластьМакета.Параметры.БанкПолучателяПредставление      = СокрЛП(РС.Банк.Наименование);
				ОбластьМакета.Параметры.СчетБанкаПолучателя              = РС.Банк.КоррСчет;
				ОбластьМакета.Параметры.СчетБанкаПолучателяПредставление = РС.Банк.КоррСчет;
				ОбластьМакета.Параметры.СчетПолучателяПредставление      = РС.НомерСчета;
