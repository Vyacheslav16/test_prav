////////////////////////////////////////////////////////////////////////////////
// Печать

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Счет") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "Счет", "Счет на оплату", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Неопределено));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетСводный") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СчетСводный", "Счет на оплату (сводный по услугам)", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетРазвернутый") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СчетРазвернутый", "Счет на оплату (по объектам)", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Ложь));
	КонецЕсли;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетСводныйБезЕдИзм") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СчетСводныйБезЕдИзм", "Счет на оплату (сводный по услугам) без единиц измерения", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина,Истина));
	КонецЕсли;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьСчетСводныйСПрефиксом") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПечатьСчетСводныйСПрефиксом", "Счет на оплату (сводный по услугам)", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина, Ложь, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьСчетСводныйБезЕдИзмСПрефиксом") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПечатьСчетСводныйБезЕдИзмСПрефиксом", "Счет на оплату (сводный по услугам) без единиц измерения", ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина, Истина, Истина));
	КонецЕсли;
	
	//// + NAI Becar Матюхин Н.О. от 27.10.2016 14:59 по заявке № 115298
	//Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "РасчетПени") Тогда
	//    УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "РасчетПени", "Расчет пени", ПечатьРасчетПени(МассивОбъектов, ОбъектыПечати, Ложь));
	//КонецЕсли;
	//// - NAI Becar Матюхин Н.О.
	
КонецПроцедуры

