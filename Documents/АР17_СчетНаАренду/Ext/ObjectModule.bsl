Функция РассчитатьСуммуДепозитаПоБУ(Основание)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	АР17_ЗаключениеДоговораАренды.СуммаЗалога,
		|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
		|ПОМЕСТИТЬ ДоговорИСумма
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР17_ЗаключениеДоговораАренды.Ссылка = &Ссылка
		|	И НЕ АР17_ЗаключениеДоговораАренды.ПометкаУдаления
		|	И АР17_ЗаключениеДоговораАренды.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ДоговорИСумма.СуммаЗалога, 0) - ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстатокКт, 0) КАК ОстатокДепозита
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(
		|			&Период,
		|			Счет.Код = ""62.04""
		|				ИЛИ Счет.Код = ""76.09.1"",
		|			,
		|			Субконто2 = &ДоговорКА) КАК ХозрасчетныйОстатки,
		|	ДоговорИСумма КАК ДоговорИСумма";
	
	Запрос.УстановитьПараметр("ДоговорКА", Основание.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("Ссылка", Основание);
	////////Запрос.УстановитьПараметр("Счет6204", Счет6204);
	////////Запрос.УстановитьПараметр("Счет76061", Счет76061);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		
		Возврат РЗ.ОстатокДепозита;
		
	Иначе
		
		Возврат 0;
		
	КонецЕсли;
		
КонецФункции

Функция ПолучитьДепозитИзИК(Основание)

	Запрос = Новый Запрос();
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	АР_УстановкаПараметровИКНоменклатура.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.АР17_УстановкаПараметровИК.Номенклатура КАК АР_УстановкаПараметровИКНоменклатура
	|ГДЕ
	|	АР_УстановкаПараметровИКНоменклатура.ГруппаУслуг = &ГруппаУслуг
	|	И АР_УстановкаПараметровИКНоменклатура.Ссылка.ИКСсылка = &ИКСсылка";
	
	Запрос.УстановитьПараметр("ИКСсылка",Основание.ИК);
	Запрос.УстановитьПараметр("ГруппаУслуг",Справочники.АР_ГруппыУслуг.ОбеспечительныйПлатеж);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Номенклатура;	
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции // ()


// Процедура предназначена для заполнения строк табличной части документа в случае выставления счета на аренду
Процедура ЗаполнитьСтроки(ПостояннаяЧастьОплаты, ЗаполнятьСпециальныйКурс = Ложь, ПризнакСчета = Ложь, ТЗ = Неопределено,Инд = Ложь, СтавкаНДС = Неопределено, СуммаВключаетНДС = Неопределено) Экспорт
	
	Если ПостояннаяЧастьОплаты Тогда
		АР_ПроцедурыНачисления.АР17_ПолучитьПостояннуюЧастьОплаты(ЭтотОбъект,"Состав",ПризнакСчета, ТЗ, Инд, СтавкаНДС, СуммаВключаетНДС);
	Иначе
		АР_ПроцедурыНачисления.АР17_ПолучитьПеременнуюЧастьОплаты(ЭтотОбъект,"Состав",ПризнакСчета, ТЗ, Инд, СтавкаНДС, СуммаВключаетНДС);
	КонецЕсли;
	
	// Проверим, если валюта документа и валюта строки совпадают, 
	// то изменим при необходимости курс на специальный
	Если ЗаполнятьСпециальныйКурс Тогда
		Если Состав.Количество() > 0 Тогда
			Если ВалютаДокумента = Состав[0].СпособНачисления.Валюта Тогда
				СтруктураКурса = АР_ПроцедурыНачисления.ПолучитьКурсВалюты(ВалютаДокумента, ДатаКурса, ДоговорКонтрагента);
				Если  КурсВзаиморасчетов <> СтруктураКурса.Курс Тогда
					КурсВзаиморасчетов = СтруктураКурса.Курс;
					КратностьВзаиморасчетов = СтруктураКурса.Кратность;
				КонецЕсли;
			КонецЕсли;  
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
