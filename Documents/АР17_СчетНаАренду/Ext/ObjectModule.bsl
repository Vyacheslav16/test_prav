	КонецЕсли;
	
	// Посчитать суммы документа и записать ее в соответствующий реквизит шапки для показа в журналах
	СуммаДокумента = УчетНДСПереопределяемый.ПолучитьСуммуДокументаСНДС(ЭтотОбъект,"Состав");
	
	АР_ОбщиеПроцедуры.УстановкаДатыПереданДокумента(ЭтотОбъект, РежимЗаписи);// + NAI Becar Конюшок С.Н. от 19.01.2017 17:21 
	
	ОтменаПроведения = Ложь; // + NAI Becar Комментирование Смирнов А.А. от 15.02.2017 10:34
	
