#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Перем ОтменаПроведения;	
	
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Процедура ПроверитьСтатусыОбъектовАренды(Отказ)

	Если НеКонтролироватьСоответствиеСодержаниюДоговора ИЛИ Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Если ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаАренды Тогда
		Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
		Запрос.УстановитьПараметр("КонецПериода", ОкончаниеПериода);
		Запрос.УстановитьПараметр("Период", КонецДня(Дата));
		Запрос.УстановитьПараметр("Договор", ДоговорКонтрагента);
		Запрос.УстановитьПараметр("Состав", Состав.Выгрузить());
		Запрос.Текст =
		"ВЫБРАТЬ
		|	АР_СчетНаАрендуСостав.НомерСтроки,
		|	АР_СчетНаАрендуСостав.Номенклатура КАК Услуга,
		|	АР_СчетНаАрендуСостав.ОбъектАренды,
		|	&Договор КАК ДоговорКонтрагента,
		|	&НачалоПериода КАК НачалоПериода,
		|	&КонецПериода КАК ОкончаниеПериода
		|ПОМЕСТИТЬ ПериодыДокумента
		|ИЗ
		|	&Состав КАК АР_СчетНаАрендуСостав
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга,
		|	АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды,
		|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор,
		|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды,
		|	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды
		|ПОМЕСТИТЬ ПериодыАренды
		|ИЗ
		|	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(&Период, Договор = &Договор) КАК АР_СтатусыОбъектовАрендыСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыДокумента.НомерСтроки,
		|	ПериодыДокумента.Услуга,
		|	ПериодыДокумента.ОбъектАренды,
		|	ПериодыДокумента.НачалоПериода,
		|	ПериодыДокумента.ОкончаниеПериода,
		|	ВЫБОР
		|		КОГДА ПериодыАренды.ОбъектАренды ЕСТЬ NULL 
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Ошибка
		|ИЗ
		|	ПериодыДокумента КАК ПериодыДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПериодыАренды КАК ПериодыАренды
		|		ПО ПериодыДокумента.ОкончаниеПериода >= ПериодыАренды.ДатаНачалаАренды
		|			И ПериодыДокумента.НачалоПериода <= ПериодыАренды.ДатаОкончанияАренды
		|			И ПериодыДокумента.ДоговорКонтрагента = ПериодыАренды.Договор
		|			И ПериодыДокумента.ОбъектАренды = ПериодыАренды.ОбъектАренды
		|			И ПериодыДокумента.Услуга = ПериодыАренды.Услуга
		|ГДЕ
		|	ВЫБОР
		|			КОГДА ПериодыАренды.ОбъектАренды ЕСТЬ NULL 
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ";
	Иначе
		Запрос.УстановитьПараметр("Период", КонецДня(Дата));
		Запрос.УстановитьПараметр("ВАренде", Перечисления.АР_СтатусыОбъектовАренды.ВАренде);
		Запрос.УстановитьПараметр("Договор", ДоговорКонтрагента);
		Запрос.УстановитьПараметр("Состав", Состав.Выгрузить());
		Запрос.Текст =
		"ВЫБРАТЬ
		|	АР_СчетНаАрендуСостав.НомерСтроки,
		|	АР_СчетНаАрендуСостав.Номенклатура КАК Услуга,
		|	АР_СчетНаАрендуСостав.ОбъектАренды,
		|	&Договор КАК ДоговорКонтрагента
		|ПОМЕСТИТЬ ВТСостав
		|ИЗ
		|	&Состав КАК АР_СчетНаАрендуСостав
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СчетНаАрендуСостав.ОбъектАренды,
		|	СчетНаАрендуСостав.Услуга,
		|	СчетНаАрендуСостав.НомерСтроки,
		|	ЕСТЬNULL(АР_СтатусыОбъектовАрендыСрезПоследних.Статус, ""Не установлен"") КАК Статус
		|ИЗ
		|	ВТСостав КАК СчетНаАрендуСостав
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(&Период, Договор = &Договор) КАК АР_СтатусыОбъектовАрендыСрезПоследних
		|		ПО СчетНаАрендуСостав.ОбъектАренды = АР_СтатусыОбъектовАрендыСрезПоследних.ОбъектАренды
		|			И СчетНаАрендуСостав.Услуга = АР_СтатусыОбъектовАрендыСрезПоследних.Услуга
		|			И (АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &Период)
		|ГДЕ
		|	(НЕ ЕСТЬNULL(АР_СтатусыОбъектовАрендыСрезПоследних.Статус, ""Не установлен"") = &ВАренде)";
	КонецЕсли;	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если ЗначениеЗаполнено(Выборка.Услуга) И ЗначениеЗаполнено(Выборка.ОбъектАренды) Тогда
			Префикс = "Состав[" + Формат(Выборка.НомерСтроки - 1, "ЧН=0; ЧГ=") + "].";
			ТекстСообщения = "Услуга """ + Выборка.Услуга + """ по объекту аренды """ + Выборка.ОбъектАренды + """ не предусмотрена по данному договору";
			ТекстСообщения = ОбщегоНазначенияБПКлиентСервер.ПолучитьТекстСообщения("Колонка", "КОРРЕКТНОСТЬ",
				НСтр("ru = 'Услуга'"), Выборка.НомерСтроки, НСтр("ru = 'Состав счета'"), ТекстСообщения);
			Поле = Префикс + "Номенклатура";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура предназначена для заполнения строк табличной части документа в случае выставления счета на оплату пени
// ПриемникСообщений -- контекст управляемой формы для вывода сообщения
Процедура ЗаполнитьСтрокиПени(ТабСЧетаОтЗДА = Неопределено) Экспорт
	
	Данные = АР_ПроцедурыНачисления.НачислениеПени(ДоговорКонтрагента, Дата);
	
	// + NAI Becar Матюхин Н.О. от 22.09.2016 14:51 по заявке № 97999
	Если ЗначениеЗаполнено(Данные) И ТабСчетаотЗДА <> Неопределено Тогда
	// - NAI Becar Матюхин Н.О.
	
		УслугаПени = Константы.Ар_УслугаПени.Получить();
		
		СоставСтруктуры = "";
		Для каждого ТекКолонка Из Данные.Колонки Цикл
		    СоставСтруктуры = СоставСтруктуры + ТекКолонка.Имя + ",";
		КонецЦикла;
	    СтруктураПервойСтроки = Новый Структура(Лев(СоставСтруктуры,СтрДлина(СоставСтруктуры)-1));
		
		ПерваяСтрокаДанные = Данные[0];
		ЗаполнитьЗначенияСвойств(СтруктураПервойСтроки,ПерваяСтрокаДанные);
		Данные.Очистить();
		
		
		Для каждого СтрТабСчетаЗДА Из ТабСчетаотЗДА Цикл
			Нстрока = Данные.Добавить();
			ЗаполнитьЗначенияСвойств(Нстрока,СтруктураПервойСтроки);
			
			Нстрока.ДолгЗаПериод = СтрТабСчетаЗДА.СуммаДолга;
			Нстрока.КоличествоДнейПросрочки = СтрТабСчетаЗДА.СрокОплаты;
			НСтрока.СрокОплаты = СтрТабСчетаЗДА.НачалоНачисления;
			Нстрока.Сумма = СтрТабСчетаЗДА.Пени;
			НСтрока.Цена = СтрТабСчетаЗДА.Пени;
			НСтрока.Номенклатура = УслугаПени;
			
		КонецЦикла;
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные) Тогда
		Состав.Загрузить(Данные);
	Иначе
		// + NAI Becar Матюхин Н.О. от 22.09.2016 14:51 по заявке № 97999
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ДокументНеЗаполнен",Истина);
		// - NAI Becar Матюхин Н.О.
		Состав.Очистить();
	КонецЕсли;
			
	Для Каждого СтрокаТЧ Из Состав Цикл
		НаименованиеПолное = СтрокаТЧ.Номенклатура.НаименованиеПолное;
		Если ПустаяСтрока(НаименованиеПолное) Тогда
			СтрокаТЧ.Содержание = СтрокаТЧ.Номенклатура.Наименование;
		Иначе
			СтрокаТЧ.Содержание = НаименованиеПолное;
		КонецЕсли;
		ОбработкаТабличныхЧастейКлиентСервер.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ, ЭтотОбъект.СуммаВключаетНДС);
	КонецЦикла;
	
КонецПроцедуры

// Процедура предназначена для заполнения строк табличной части документа по актуальным	данным о депозите
Процедура ЗаполнитьСтрокиДепозит(Основание = Неопределено,ТЗДепозит = Неопределено, Переформировать = Ложь) Экспорт
	
	// + NAI Becar Комментирование Смирнов А.А. от 16.03.2017 11:22
	////////////////////////АР_ПроцедурыНачисления.АР17_ПолучитьПостояннуюЧастьОплаты(ЭтотОбъект,"Состав",Истина, ТЗДепозит);
	////////////////////////АР_ПроцедурыНачисления.АР17_ПолучитьПеременнуюЧастьОплаты(ЭтотОбъект,"Состав",Истина, ТЗДепозит);
	////////////////////////
	СоставТЗ = ЭтотОбъект.Состав.Выгрузить();
	СоставТЗ.Колонки.Добавить("НеУдалять",Новый ОписаниеТипов("Булево"));
	//////////////////
	НомерСтроки = 0;
	Пока НомерСтроки < СоставТЗ.Количество() Цикл
		СтрокаТаб = СоставТЗ[НомерСтроки];
		Если ТЗДепозит <> Неопределено Тогда
			//Если СЗ.НайтиПоЗначению(СтрокаТаб.Содержание) <> Неопределено 
			Если ТЗДепозит.Найти(СтрокаТаб.Номенклатура) <> Неопределено 
				Тогда
				СтрокаТаб.НеУдалять = Истина;
			КонецЕсли;
		КонецЕсли;	
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	НомерСтроки = 0;
	Пока НомерСтроки < СоставТЗ.Количество() Цикл
		СтрокаТаб = СоставТЗ[НомерСтроки];
		Если СтрокаТаб.НеУдалять = Ложь //и ПризнакСчета = Истина 
			Тогда
			СоставТЗ.Удалить(НомерСтроки);
			НомерСтроки = 0;
		Иначе
			НомерСтроки = НомерСтроки + 1;
		КонецЕсли;
	КонецЦикла;
	//////////////////
	
	//ТЗДепозит = СоставТЗ.Скопировать();
	// - NAI Becar Комментирование Смирнов А.А.
	
	Если Состав.Количество() > 0 Тогда
		#Если Клиент Тогда
		Если Вопрос("Табличная часть будет перезаполнена. Продолжить?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;
		#КонецЕсли
		Состав.Очистить();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Основание) Тогда
		ДобавитьСтрокуДепозита(Основание, ТЗДепозит, Переформировать);
	Иначе
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Дата", Дата);
		Запрос.УстановитьПараметр("Договор", ДоговорКонтрагента);
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор
		|ИЗ
		|	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(&Дата, Договор = &Договор) КАК АР_СтатусыОбъектовАрендыСрезПоследних
		|ГДЕ
		|	(АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды
		|			ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор ССЫЛКА Документ.АР17_ДополнительноеСоглашение)
		|	И АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор.УчитыватьЗалог
		|	И АР_СтатусыОбъектовАрендыСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.АР_СтатусыОбъектовАренды.ВАренде)
		|	И АР_СтатусыОбъектовАрендыСрезПоследних.Договор = &Договор
		|	И АР_СтатусыОбъектовАрендыСрезПоследних.Регистратор.Контрагент = &Контрагент";
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			ДобавитьСтрокуДепозита(Выборка.Регистратор,ТЗДепозит, Переформировать);	
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Процедура предназначена для заполнения строк табличной части документа по актуальным	данным о депозите
Процедура ДобавитьСтрокуДепозита(Основание,ТЗДепозит,Переформировать) Экспорт 
	
	// + NAI Becar Комментирование Смирнов А.А. от 30.01.2017 17:39
	////////////////////Депозит.Очистить();
	////////////////////Если ТЗДепозит <> Неопределено Тогда
	////////////////////	Для Каждого Стр Из ТЗДепозит Цикл
	////////////////////		//Если Переформировать Тогда
	////////////////////		//	Если Депозит.Найти(Стр.Номенклатура,"Номенклатура") <> Неопределено Тогда 
	////////////////////		//		НовСтрока = Депозит.Найти(Стр.Номенклатура,"Номенклатура");
	////////////////////		//		НовСтрока.Сумма = Стр.Сумма;
	////////////////////		//	Иначе
	////////////////////		//		НовСтрока = Депозит.Добавить();
	////////////////////		//		НовСтрока.Номенклатура = Стр.Номенклатура;
	////////////////////		//		НовСтрока.Сумма = Стр.Сумма;
	////////////////////		//	КонецЕсли;
	////////////////////		//Иначе 	
	////////////////////			НовСтрока = Депозит.Добавить();
	////////////////////			НовСтрока.Номенклатура = Стр.Номенклатура;
	////////////////////			НовСтрока.Сумма = Стр.Сумма;
	////////////////////		//КонецЕсли;	
	////////////////////	КонецЦикла;	
	////////////////////КонецЕсли;	
	// - NAI Becar Комментирование Смирнов А.А.
	
	Для Каждого Стр ИЗ Основание.ДепозитСодержаниеИК Цикл
	
		ВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
		Коэфф = 1;
		Если НЕ Основание.ВалютаДепозита = ВалютаДокумента Тогда
			СтруктураКурсаДепозита = РаботаСКурсамиВалют.ПолучитьКурсВалюты(?(ЗначениеЗаполнено(Основание.ВалютаДепозита), Основание.ВалютаДепозита, ВалютаРегламентированногоУчета), Дата);
			КурсДепозита      = СтруктураКурсаДепозита.Курс;
			КратностьДепозита = СтруктураКурсаДепозита.Кратность;
			Коэфф = КурсДепозита / КурсВзаиморасчетов * КратностьДепозита / КратностьВзаиморасчетов;
		КонецЕсли;
		СтрокаТЧ = Состав.Добавить();
		СтрокаТЧ.Содержание = Стр.Содержание; //"Страховой депозит по договору " + Основание.ДоговорКонтрагента;
		СтрокаТЧ.Количество = 1;
		// + NAI Becar Комментирование Смирнов А.А. от 31.01.2017 12:30
		//СтрокаТЧ.Цена = Коэфф * Основание.СуммаЗалога;
		//СтрокаТЧ.Сумма = Коэфф * Основание.СуммаЗалога;
		//СтрокаТЧ.СтавкаНДС = Основание.СтавкаНДСЗалога;
		//////////////////СуммаЗалога = Депозит.Итог("Сумма");
		
		СуммаЗалога = РассчитатьСуммуДепозитаПоБУ(Основание); // + NAI Becar Конюшок С.Н. от 21.09.2017 13:15 
		
		СтрокаТЧ.Цена = Коэфф * СуммаЗалога;
		СтрокаТЧ.Сумма = Коэфф * СуммаЗалога;
		СтрокаТЧ.СтавкаНДС = Основание.СтавкаНДСЗалога;
		// - NAI Becar Комментирование Смирнов А.А.
		
			// + Рогачев  Андрей от 21.07.2016  № 106552
