	НовСтр.ДоговорКонтрагента = Объект.АгентскийДоговор.ДоговорКонтрагента;
	НовСтр.ЗадолженностьПередПринципаломНачало = ПолучитьЗадолженностьПередПринципалом();
	НовСтр.СуммаНачисленногоДохода = Объект.ДоходОтПомещений.Итог("НачисленоАрендыЗаПомещениеПринципала") + 
	Объект.ДоходОтОбщегоИмущества.Итог("НачисленоАрендыОтОбщегоИмуществаПоПринципалу");
	НовСтр.ОбщаяСуммаПоступившихАП = Объект.ДоходОтОбщегоИмущества.Итог("СуммаПоступившихПлатежейОтОбщегоИмуществаПоПринципалу") +
	Объект.ДоходОтПомещений.Итог("СуммаПоступившихПлатежейЗаПомещениеПринципала");
	НовСтр.СуммаАгентскогоВознаграждения = Объект.ВознагражденияАгента.Итог("Сумма"); //8
	//
	ПроцентВознаграждения = 0;
	//НайденныеСтроки = Объект.АгентскийДоговор.УсловиеПеречисленияПринципалу.НайтиСтроки(ПараметрыОтбора);
	Если Объект.АгентскийДоговор.УсловиеПеречисленияПринципалу.Количество()>0 Тогда
		ПроцентВознаграждения = Объект.АгентскийДоговор.УсловиеПеречисленияПринципалу[0].Ставка;
	Иначе
		ПроцентВознаграждения = 0;
	КонецЕсли;	
	НовСтр.СуммаАгентскогоВознагражденияПослеПоступленияДС = УправлениеПомещениемМОП + УправлениеПомещениемПомещение + УправлениеПомещениемПомещение +
	Окр((Объект.ДоходОтПомещений.Итог("НачисленоАрендыЗаПомещениеПринципала")+Объект.ДоходОтОбщегоИмущества.Итог("НачисленоАрендыОтОбщегоИмуществаПоПринципалу"))*ПроцентВознаграждения,2);
	НовСтр.СуммаУдержания = Объект.ДополнительныеРасходы.Итог("Сумма");
	НовСтр.СуммаПодлежащаяПеречислению = НовСтр.ОбщаяСуммаПоступившихАП - НовСтр.СуммаАгентскогоВознаграждения;
	НовСтр.СуммаПеречисленнаяПринципалу = ПолучитьПоступления()-НовСтр.СуммаАгентскогоВознаграждения;//12
	НовСтр.ЗадолженностьПередПринципаломКонец = НовСтр.ЗадолженностьПередПринципаломНачало+НовСтр.СуммаПодлежащаяПеречислению-
	НовСтр.СуммаПеречисленнаяПринципалу-Объект.ДополнительныеРасходы.Итог("Сумма");//13
	НовСтр.СуммаПодлежащаяПеречислениюПринципалу = НовСтр.СуммаНачисленногоДохода-НовСтр.СуммаАгентскогоВознагражденияПослеПоступленияДС-НовСтр.СуммаУдержания;
	
