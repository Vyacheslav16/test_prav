	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ссылка = &Ссылка
	               |	И АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.ДатаОкончанияСрокаАренды >= &НачалоПериода
	               |	И АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды <= &КонецПериода";
	
	Запрос.УстановитьПараметр("Ссылка",ДоговорАренды);
	Запрос.УстановитьПараметр("НачалоПериода",Объект.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",Объект.ОкончаниеПериода);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Свернуть(,"Ставка");
	Если Выгрузка.Количество()>0 Тогда
		Возврат Выгрузка[0].Ставка;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
	
КонецФункции	

Функция ПолучитьДоговорАренды(ДоговорКонтрагента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАренды.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;	
	
КонецФункции	

