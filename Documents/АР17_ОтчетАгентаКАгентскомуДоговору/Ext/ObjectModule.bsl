						Если КонецДня(СтрПлощадь.ДатаВозврата) = КонецМесяца(СтрПлощадь.ДатаВозврата) Тогда
							КоличествоДней1 = КоличествоДней;
						КонецЕсли;	
						Если Число(Лев(СтрДни.ДатаОкончанияСрокаАренды,2))<КоличествоДней и КоличествоДней<>КоличествоДнейВМесяце Тогда Продолжить; КонецЕсли;
						//НовСтр.Сумма = НовСтр.Сумма + (АгентскийДоговор.ОбъектыАренды.Итог("Площадь")*СтрДни.Ставка/12)*ДоляПринципала(АгентскийДоговор.ДоговорКонтрагента,СтрПлощадь.ДатаВозврата-1)/100/СтрДни.КоличествоДнейВМесяце*КоличествоДней1;
						НовСтр.Сумма = НовСтр.Сумма + (ДоходОтПомещений[0].ПлощадьПоДоговору*СтрДни.Ставка/12)*ДоляПринципала(АгентскийДоговор.ДоговорКонтрагента,СтрПлощадь.ДатаВозврата-1)/100/СтрДни.КоличествоДнейВМесяце*КоличествоДней1;
						КоличествоДней = КоличествоДней-КоличествоДней1;
					КонецЕсли;	
					
					УправлениеПомещениемПомещение = НовСтр.Сумма;
					
				Иначе
					НовСтр.Сумма = Стр.Сумма*ПлощадьНаНачало/12/КоличествоДнейВМесяце*КоличествоДней/100/СтрДни.КоличествоДнейВМесяце*СтрДни.КоличествоДней;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;	
		
	КонецЦикла;
	
	ИтогДополнительныеРасходы = 0;
	Если ВводСуммы Тогда
		ИтогДополнительныеРасходы = СуммаОтчета;
	Иначе	
		Для Каждого Стр Из ОтчетКомитента.Товары Цикл
			ИтогДополнительныеРасходы = ИтогДополнительныеРасходы + Стр.Сумма;
		КонецЦикла;
	КонецЕсли;	
	
	//Расчет дополнительных расходов, понесенных агентом
	Списания = ПолучитьСписания();
	Для Каждого Списание из Списания Цикл
		НовСтр = ДополнительныеРасходы.Добавить();
		Новстр.Контрагент = Организация;
		Новстр.ДоговорКонтрагента = АгентскийДоговор.ДоговорКонтрагента;
		Новстр.Услуга = Списание.НазначениеПлатежа;
		НовСтр.Сумма = Списание.СуммаДокумента;
	КонецЦикла;	
	
	НовСтр = РасчетыПоПеречислениюПринципалу.Добавить();
	НовСтр.Контрагент = АгентскийДоговор.Контрагент;
	НовСтр.ДоговорКонтрагента = АгентскийДоговор.ДоговорКонтрагента;
	НовСтр.ЗадолженностьПередПринципаломНачало = ПолучитьЗадолженностьПередПринципалом3(); //ПолучитьЗадолженностьПередПринципалом()-ПолучитьЗадолженностьПередПринципалом2();
	НовСтр.СуммаНачисленногоДохода = ДоходОтПомещений.Итог("НачисленоАрендыЗаПомещениеПринципала")+ДоходОтОбщегоИмущества.Итог("НачисленоАрендыОтОбщегоИмуществаПоПринципалу");
	НовСтр.ОбщаяСуммаПоступившихАП = ВсегоДоходы; //Оплачено_Итог+ПолучитьСуммуНДС(Оплачено_Итог,АгентскийДоговор.СтавкаНДС);
	НовСтр.СуммаАгентскогоВознаграждения = СуммаНачисленныхАП_2(АгентскийДоговор.ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода,ПланыСчетов.Хозрасчетный.НайтиПоРеквизиту("КодБыстрогоВыбора","6201"));
	Если НовСтр.СуммаАгентскогоВознаграждения = 0 Тогда
		НовСтр.СуммаАгентскогоВознаграждения = ВознагражденияАгента.Итог("Сумма");	
	КонецЕсли;	
	
	ПроцентВознаграждения = 0;
	СуммаВознагражденияИтог = 0;
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Услуга", Справочники.Номенклатура.УправлениеАрендой);
	НайденныеСтроки = ВознагражденияАгента.НайтиСтроки(ПараметрыОтбора);
	Если НайденныеСтроки.Количество()>0 Тогда
		СуммаВознагражденияИтог = ВознагражденияАгента.Итог("Сумма") - НайденныеСтроки[0].Сумма;
		ПроцентВознаграждения = НайденныеСтроки[0].Ставка;
	Иначе
		СуммаВознагражденияИтог = 0;
		ПроцентВознаграждения = 0;
	КонецЕсли;
	
	НачисленоПринципал_Итог = ДоходОтПомещений.Итог("НачисленоАрендыЗаПомещениеПринципала");
	НачисленоПринципалБезНДС_Итог	= Окр(НачисленоПринципал_Итог-ПолучитьСуммуНДС(НачисленоПринципал_Итог,АгентскийДоговор.СтавкаНДС),2);
	
	НачисленоАренды_Итог = ДоходОтОбщегоИмущества.Итог("НачисленоАрендыОтОбщегоИмуществаПоПринципалу");
	НачисленоАрендыБезНДС_Итог	= Окр(НачисленоАренды_Итог-ПолучитьСуммуНДС(НачисленоАренды_Итог,АгентскийДоговор.СтавкаНДС),2);
	
	НовСтр.СуммаАгентскогоВознагражденияПослеПоступленияДС = СуммаВознагражденияИтог+Окр((НачисленоПринципалБезНДС_Итог+НачисленоАрендыБезНДС_Итог+НачисленоАрендыОтОбщегоИмуществаПоПринципалу_Итог)*ПроцентВознаграждения/100,2);
	НовСтр.СуммаУдержания = СуммаНачисленныхАП_(АгентскийДоговор.ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода,ПланыСчетов.Хозрасчетный.НайтиПоРеквизиту("КодБыстрогоВыбора","51"));
	НовСтр.СуммаПодлежащаяПеречислению = НовСтр.ОбщаяСуммаПоступившихАП-НовСтр.СуммаАгентскогоВознаграждения-ИтогДополнительныеРасходы;
	//НовСтр.ОбщаяСуммаПоступившихАП - НовСтр.СуммаАгентскогоВознаграждения;
	НовСтр.СуммаПеречисленнаяПринципалу = СуммаНачисленныхАП_2(АгентскийДоговор.ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода,ПланыСчетов.Хозрасчетный.НайтиПоРеквизиту("КодБыстрогоВыбора","51"))
			- НовСтр.СуммаУдержания;

	НовСтр.ЗадолженностьПередПринципаломКонец = Остатки(НачалоПериода,ОкончаниеПериода,АгентскийДоговор.ДоговорКонтрагента,ПланыСчетов.Хозрасчетный.НайтиПоРеквизиту("КодБыстрогоВыбора","7606"));
	НовСтр.СуммаПодлежащаяПеречислениюПринципалу = НовСтр.СуммаНачисленногоДохода-НовСтр.СуммаАгентскогоВознагражденияПослеПоступленияДС-НовСтр.СуммаУдержания;
	
КонецПроцедуры

Функция СуммаНачисленныхАП_(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода,КорСчет)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СУММА(ХозрасчетныйОбороты.СуммаОборот) КАК СуммаОборот,
	               |	ХозрасчетныйОбороты.Регистратор КАК Регистратор
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Обороты(&НачалоПериода, &КонецПериода, Регистратор, Счет.Код = ""76.06"", , Субконто2 = &ДоговорКонтрагента, КорСчет = &КорСчет, ) КАК ХозрасчетныйОбороты
	               |ГДЕ
	               |	ХозрасчетныйОбороты.Регистратор.Контрагент.ИНН = &ИНН
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ХозрасчетныйОбороты.Регистратор";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ИНН", "7701795140");
	
	Запрос.УстановитьПараметр("КорСчет", КорСчет);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Возврат Выгрузка.Итог("СуммаОборот");
	Иначе
		Возврат 0;
	КонецЕсли;	
КонецФункции	

Функция Остатки(НачалоПериода,ОкончаниеПериода,ДоговорКонтрагента,КорСчет)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокКт КАК СуммаОстатокКт
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(, &КонецПериода, , , Счет.Код = ""76.06"", , Субконто2 = &ДоговорКонтрагента) КАК ХозрасчетныйОстаткиИОбороты";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	
	Запрос.УстановитьПараметр("КорСчет", КорСчет);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Возврат Выгрузка[0].СуммаОстатокКт;
	Иначе
		Возврат 0;
	КонецЕсли;	
КонецФункции	

Функция СуммаНачисленныхАП_2(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода,КорСчет)
	Запрос = Новый Запрос;
