					Выгрузка[к].ДоляСобственника=Выгрузка[0].ДоляСобственника;
					Выгрузка[к].КоличествоДнейОплата = (КонецДня(Выгрузка[к].Период)+1 - НачалоДня(Выгрузка[к].НачалоМесяца)-86400)/86400;
					Выгрузка[к].КоличествоДней = Выгрузка[к].КоличествоДнейОплата;
					
					НовСтр = Выгрузка.Добавить();
					НовСтр.ДоляСобственника=ДоляСобственника_;
					НовСтр.КоличествоДнейОплата=((КонецДня(Выгрузка[к].КонецМесяца)+1 - НачалоДня(Выгрузка[к].Период-1)) -86400)/86400;
					НовСтр.КоличествоДнейМесяцаОплата=Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					НовСтр.КоличествоДней=((КонецДня(Выгрузка[к].КонецМесяца)+1 - НачалоДня(Выгрузка[к].Период-1)) -86400)/86400;
					НовСтр.КоличествоДнейВМесяце=Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					НовСтр.НачалоМесяца = Выгрузка[к].НачалоМесяца;
					НовСтр.КонецМесяца = Выгрузка[к].КонецМесяца;
					НовСтр.Период = Выгрузка[к].КонецМесяца;
					НовСтр.Период2 = Выгрузка[к].КонецМесяца;
					НовСтр.Начислено = Истина;
					Если (к<>0 и Выгрузка[к-1].Период=Выгрузка[к-1].НачалоМесяца и Выгрузка[к-1].Период=Выгрузка[к-1].НачалоМесяца) Тогда
						Выгрузка.Удалить(Выгрузка[к-1]);
					КонецЕсли;
					
					Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					Если (Выгрузка[к].Период)<НачалоМесяца(ОкончаниеПериода) Тогда
						Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2)); //Число(Лев(КонецМесяца(ОкончаниеПериода),2));
					КонецЕсли;
				Иначе	
					//Денис++
					Если стр.Период > НачалоПериода Тогда
						Выгрузка[к].КоличествоДней = окр((КонецМесяца(Стр.КонецМесяца) - стр.Период) /60/60/24,0);
						//Выгрузка[к].КоличествоДнейОплата = Выгрузка[к].КоличествоДней;
						Выгрузка[к].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						Если к > 0 Тогда
							Выгрузка[к-1].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2)) - Выгрузка[к].КоличествоДней;// - 1;
							//Выгрузка[к-1].КоличествоДней = Выгрузка[к-1].КоличествоДней - Выгрузка[к].КоличествоДней - 1;
							Выгрузка[к-1].Начислено = Истина;
							//Выгрузка[к-1].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
							//Выгрузка[к-1].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2)) - Выгрузка[к].КоличествоДней;// - 1;
							Выгрузка[к-1].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						КонецЕсли;
					Иначе		
						Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						Выгрузка[к].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						//Выгрузка[к].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
					КонецЕсли;
					//Денис--
					//Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
					Если Выгрузка.Количество() = к+1 Тогда
						Выгрузка[к].Начислено = Истина;//Стр.Начислено;
					КонецЕсли;	
				КонецЕсли;	
				
			КонецЕсли;
			
			к=к+1;
		КонецЦикла;
		
		к=0;
		Для Каждого Стр Из Выгрузка Цикл
			Если к<>0 и Выгрузка[к].ДоляСобственника = Выгрузка[к-1].ДоляСобственника Тогда
				Выгрузка[к].КоличествоДнейОплата = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
				Выгрузка.Удалить(Выгрузка[к-1]);
			КонецЕсли;
		к=к+1;
		КонецЦикла;

		//Если Стр.Период2<КонецДня(ОкончаниеПериода) и (Стр.Период2>НачалоПериода)
		//	//и Стр.Период2 <> Стр.КонецМесяца 
		//	Тогда 
		//	Стр.Начислено = Истина; 
