	               |	ВТ2.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ РН2
	               |ИЗ
	               |	Пост КАК Пост
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ2 КАК ВТ2
	               |		ПО Пост.Регистратор = ВТ2.СубконтоДт3
	               |ГДЕ
	               |	Пост.Сумма <> 0
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Пост.Регистратор,
	               |	Пост.Сумма,
	               |	ВТ2.Номенклатура,
	               |	ВТ2.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	РН.Регистратор КАК Регистратор,
	               |	ВЫБОР
	               |		КОГДА РН.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя)
	               |				ИЛИ РН.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ПрочееПоступление)
	               |			ТОГДА РН.СуммаОборот
	               |		ИНАЧЕ РН.Сумма
	               |	КОНЕЦ КАК СуммаОборот
	               |ПОМЕСТИТЬ Об
	               |ИЗ
	               |	РН КАК РН
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	РН2.Регистратор,
	               |	ВЫБОР
	               |		КОГДА РН2.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя)
	               |				ИЛИ РН2.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ПрочееПоступление)
	               |			ТОГДА РН2.СуммаОборот
	               |		ИНАЧЕ РН2.Сумма
	               |	КОНЕЦ
	               |ИЗ
	               |	РН2 КАК РН2
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Об.Регистратор КАК Регистратор,
	               |	Об.СуммаОборот КАК СуммаОборот
	               |ИЗ
	               |	Об КАК Об
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Об.Регистратор,
	               |	Об.СуммаОборот";
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорАренды);
	Запрос.УстановитьПараметр("АгентскийДоговорДата",АгентскийДоговор.Дата);
	Запрос.УстановитьПараметр("СтавкаНДС",АгентскийДоговор.СтавкаНДС);  
	
	Запрос.УстановитьПараметр("НачалоПериодаР",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериодаР",КонецМесяца(ОкончаниеПериода));
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Свернуть(,"СуммаОборот");
	Если Выгрузка.Количество()>0 Тогда
		Возврат Выгрузка[0].СуммаОборот;
	Иначе
		Возврат 0;
	КонецЕсли;	
КонецФункции	

Функция ПолучитьСтавку(ДоговорАренды)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.СпособНачисления = ЗНАЧЕНИЕ(Справочник.АР_СпособыНачисленияАренднойПлаты.Директивный)
	               |			ТОГДА (ВЫРАЗИТЬ(АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ставка КАК ЧИСЛО(15, 2))) * 12
	               |		ИНАЧЕ АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ставка
	               |	КОНЕЦ КАК Ставка,
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты
	               |ГДЕ
	               |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка = &Ссылка
	               |	И АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ДатаОкончанияСрокаАренды >= &НачалоПериода
	               |	И АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды <= &КонецПериода
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ВТ.Ставка, АР17_НачислениеАренднойПлатыСостав.Цена) КАК Ставка
	               |ИЗ
	               |	ВТ КАК ВТ
	               |		ПОЛНОЕ СОЕДИНЕНИЕ Документ.АР17_НачислениеАренднойПлаты.Состав КАК АР17_НачислениеАренднойПлатыСостав
	               |		ПО ВТ.ДоговорКонтрагента = АР17_НачислениеАренднойПлатыСостав.Ссылка.ДоговорКонтрагента
	               |ГДЕ
	               |	АР17_НачислениеАренднойПлатыСостав.Ссылка.Дата >= &НачалоПериода
	               |	И АР17_НачислениеАренднойПлатыСостав.Ссылка.Дата <= &КонецПериода
	               |	И АР17_НачислениеАренднойПлатыСостав.Ссылка.Проведен
	               |	И АР17_НачислениеАренднойПлатыСостав.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЕСТЬNULL(ВТ.Ставка, АР17_НачислениеАренднойПлатыСостав.Цена)";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорАренды.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Ссылка",ДоговорАренды);
	Запрос.УстановитьПараметр("НачалоПериода",НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(ОкончаниеПериода));
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Свернуть(,"Ставка");
	Если Выгрузка.Количество()>0 Тогда
		Возврат Выгрузка[0].Ставка;
	Иначе
		Возврат 0;
	КонецЕсли;	
