	Запрос.УстановитьПараметр("КорСчет", КорСчет);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Возврат Макс(Выгрузка[0].СуммаОборот,-Выгрузка[0].СуммаОборот);
	Иначе
		Возврат 0;
	КонецЕсли;	
КонецФункции	

Функция ПолучитьЗадолженностьПередПринципалом3()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.Ссылка КАК Ссылка,
	               |	NULL КАК СуммаОстаток,
	               |	АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.ЗадолженностьПередПринципаломНачало + АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.СуммаПодлежащаяПеречислению - АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.СуммаПеречисленнаяПринципалу КАК Сумма
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	Документ.АР17_ОтчетАгентаКАгентскомуДоговору.РасчетыПоПеречислениюПринципалу КАК АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу
	               |ГДЕ
	               |	АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.Ссылка.Проведен = ИСТИНА
	               |	И АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.Ссылка.АгентскийДоговор.ДоговорКонтрагента = &ДоговорКонтрагента
	               |	И АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.Ссылка.НачалоПериода <= &ДатаК
	               |	И АР17_ОтчетАгентаКАгентскомуДоговоруРасчетыПоПеречислениюПринципалу.Ссылка.ОкончаниеПериода >= &ДатаН
	               |	И НАЧАЛОПЕРИОДА(&НачалоПериода, МЕСЯЦ) <> ДАТАВРЕМЯ(2019, 4, 1, 0, 0, 0)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	NULL,
	               |	АР_РасчетыПоДоговорамОстатки.СуммаОстаток,
	               |	NULL
	               |ИЗ
	               |	РегистрНакопления.АР_РасчетыПоДоговорам.Остатки(&ДатаОкончания, ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_РасчетыПоДоговорамОстатки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ВЫБОР
	               |		КОГДА НЕ ВТ.Ссылка ЕСТЬ NULL
	               |			ТОГДА ВТ.Сумма
	               |		ИНАЧЕ ВТ.СуммаОстаток
	               |	КОНЕЦ КАК СуммаОстаток,
	               |	ВТ.Ссылка КАК Ссылка
	               |ИЗ
	               |	ВТ КАК ВТ";
	Запрос.УстановитьПараметр("ДатаОкончания",КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("НачалоПериода",НачалоДня(НачалоПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",АгентскийДоговор.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("ДатаН",НачалоМесяца(НачалоПериода-1));
	Запрос.УстановитьПараметр("ДатаК",КонецМесяца(НачалоПериода-1));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.СуммаОстаток;
КонецФункции	

Функция ПолучитьПлощадь(ДатаН,ДатаК,УчитыватьНеСдается)
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаН
		               |			ТОГДА &ДатаН
		               |		ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи
		               |	КОНЕЦ КАК ДатаПередачи,
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаК
		               |				ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
		               |			ТОГДА &ДатаК
		               |		ИНАЧЕ КОНЕЦПЕРИОДА(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ)
		               |	КОНЕЦ КАК ДатаВозврата,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.НеСдается КАК НеСдается
		               |ПОМЕСТИТЬ ВТ
		               |ИЗ
		               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
		               |ГДЕ
		               |	(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаК
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи = ДАТАВРЕМЯ(1, 1, 1))
		               |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаН
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка = &Ссылка";
					   Если УчитыватьНеСдается Тогда
						   Запрос.Текст = Запрос.Текст + 
		               "	И НЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.НеСдается";
					   КонецЕсли;
					   Запрос.Текст = Запрос.Текст + "
		               |;
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаПередачи КАК Дата1
		               |ПОМЕСТИТЬ ВТ1
		               |ИЗ
		               |	ВТ КАК ВТ
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаВозврата
		               |ИЗ
		               |	ВТ КАК ВТ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СУММА(ВТ.Площадь) КАК Площадь,
		               |	ВТ1.Дата1 КАК Дата1
		               |ИЗ
		               |	ВТ КАК ВТ
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ1 КАК ВТ1
		               |		ПО ВТ.ДатаВозврата >= ВТ1.Дата1
		               |			И ВТ.ДатаПередачи <= ВТ1.Дата1
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВТ1.Дата1";
		
		Запрос.УстановитьПараметр("Ссылка",ЭтотОбъект.АгентскийДоговор);
		Запрос.УстановитьПараметр("ДатаН",ДатаН);
		Запрос.УстановитьПараметр("ДатаК",ДатаК);
		Выгрузка = Запрос.Выполнить().Выгрузить();
		
		к=0;
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("ДатаПередачи");
		ТЗ.Колонки.Добавить("ДатаВозврата");
		ТЗ.Колонки.Добавить("Площадь");
		ТЗ.Колонки.Добавить("КоличествоДней");
		
		Кол = Выгрузка.Количество();
		ХЗ = Истина;
		Если Кол>0 Тогда
			Пока хз Цикл
				Если Выгрузка[к+1].Дата1-Выгрузка[к].Дата1 > 86400 Тогда
					НовСтр = ТЗ.Добавить();
					НовСтр.ДатаПередачи = Выгрузка[к].Дата1;
					НовСтр.ДатаВозврата = Выгрузка[к+1].Дата1;
					Если НовСтр.ДатаВозврата = КонецМесяца(Выгрузка[к].Дата1) Тогда
						Новстр.КоличествоДней = ((КонецДня(Выгрузка[к+1].Дата1)+1 - НачалоДня(Выгрузка[к].Дата1)))/86400;
					Иначе	
						Новстр.КоличествоДней = (НачалоДня(Выгрузка[к+1].Дата1)-НачалоДня(Выгрузка[к].Дата1))/86400;
					КонецЕсли;	
					НовСтр.Площадь = Выгрузка[к].Площадь;
				КонецЕсли;
				Если Кол = к+2 Тогда хз=Ложь; КонецЕсли;
				к=к+1;
			КонецЦикла;
		КонецЕсли;	
		
		Возврат ТЗ;
		
КонецФункции			

Функция ПолучитьПлощадь_(ДатаН,ДатаК,ДоговорКонтрагента)
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаПередачи <= &ДатаН
		               |				ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
		               |			ТОГДА &ДатаН
		               |		ИНАЧЕ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаПередачи
		               |	КОНЕЦ КАК ДатаПередачи,
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата >= &ДатаК
		               |			ТОГДА &ДатаК
		               |		ИНАЧЕ ВЫБОР
		               |				КОГДА АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
		               |					ТОГДА &ДатаК
		               |				ИНАЧЕ КОНЕЦПЕРИОДА(АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата, ДЕНЬ)
		               |			КОНЕЦ
		               |	КОНЕЦ КАК ДатаВозврата,
		               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Площадь КАК Площадь,
		               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
		               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорКонтрагента КАК ДоговорКонтрагента,
		               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаПередачи КАК ДатаПередачи1,
		               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата КАК ДатаВозврата1
		               |ПОМЕСТИТЬ ВТ
		               |ИЗ
		               |	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
		               |ГДЕ
		               |	(АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата >= &ДатаН
		               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
		               |	И АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаПередачи КАК Дата1,
		               |	ВТ.ДоговорКонтрагента КАК ДоговорКонтрагента
		               |ПОМЕСТИТЬ ВТ1
		               |ИЗ
		               |	ВТ КАК ВТ
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаВозврата,
		               |	ВТ.ДоговорКонтрагента
		               |ИЗ
		               |	ВТ КАК ВТ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаНачала <= &ДатаН
		               |			ТОГДА &ДатаН
		               |		ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаНачала
		               |	КОНЕЦ КАК ДатаПередачи,
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаОкончания >= &ДатаК
		               |				ИЛИ АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
		               |			ТОГДА &ДатаК
		               |		ИНАЧЕ КОНЕЦПЕРИОДА(АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаОкончания, ДЕНЬ)
		               |	КОНЕЦ КАК ДатаВозврата,
		               |	АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ПлощадьМОП КАК ПлощадьМОП,
		               |	АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДоговорКонтрагента КАК ДоговорКонтрагента
		               |ПОМЕСТИТЬ ВТ_
		               |ИЗ
		               |	ВТ1 КАК ВТ1
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора.ДоговорыМОП КАК АР17_ЗаключениеАгентскогоДоговораДоговорыМОП
		               |		ПО ВТ1.ДоговорКонтрагента = АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДоговорКонтрагента
		               |ГДЕ
		               |	(АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаНачала <= &ДатаК
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1))
		               |	И (АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаОкончания >= &ДатаН
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1))
		               |	И АР17_ЗаключениеАгентскогоДоговораДоговорыМОП.Ссылка = &Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СУММА(ВТ.Площадь) КАК Площадь,
		               |	ВТ1.Дата1 КАК Дата1,
		               |	ВТ.ДоговорКонтрагента КАК ДоговорКонтрагента
		               |ПОМЕСТИТЬ ВТ2
		               |ИЗ
		               |	ВТ КАК ВТ
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ1 КАК ВТ1
		               |		ПО ВТ.ДатаВозврата >= ВТ1.Дата1
		               |			И ВТ.ДатаПередачи <= ВТ1.Дата1
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВТ1.Дата1,
		               |	ВТ.ДоговорКонтрагента
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ВТ2.Площадь - ЕСТЬNULL(ВТ_.ПлощадьМОП, 0) КАК Площадь,
		               |	ВТ2.Дата1 КАК Дата1,
		               |	ЕСТЬNULL(ВТ_.ПлощадьМОП, 0) КАК ПлощадьМОП
		               |ИЗ
		               |	ВТ2 КАК ВТ2
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ КАК ВТ_
		               |		ПО ВТ2.ДоговорКонтрагента = ВТ_.ДоговорКонтрагента
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВТ2.Дата1,
		               |	ЕСТЬNULL(ВТ_.ПлощадьМОП, 0),
		               |	ВТ2.Площадь - ЕСТЬNULL(ВТ_.ПлощадьМОП, 0)";
		
		Запрос.УстановитьПараметр("Ссылка",ЭтотОбъект.АгентскийДоговор);
		Запрос.УстановитьПараметр("ДатаН",ДатаН);
		Запрос.УстановитьПараметр("ДатаК",ДатаК);
		Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
		Запрос.УстановитьПараметр("ДатаОкончания",ЭтотОбъект.ОкончаниеПериода);
		
		Выгрузка = Запрос.Выполнить().Выгрузить();
		
		к=0;
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("ДатаПередачи");
		ТЗ.Колонки.Добавить("ДатаВозврата");
		ТЗ.Колонки.Добавить("Площадь");
		ТЗ.Колонки.Добавить("КоличествоДней");
		
		Кол = Выгрузка.Количество();
		ХЗ = Истина;
		Если Кол>0 Тогда
			Пока хз Цикл
				Если Выгрузка[к+1].Дата1-Выгрузка[к].Дата1 > 86400 Тогда
					НовСтр = ТЗ.Добавить();
					НовСтр.ДатаПередачи = Выгрузка[к].Дата1;
					НовСтр.ДатаВозврата = Выгрузка[к+1].Дата1;
					Если НовСтр.ДатаВозврата = КонецМесяца(Выгрузка[к].Дата1) Тогда
						Новстр.КоличествоДней = ((КонецДня(Выгрузка[к+1].Дата1)+1 - НачалоДня(Выгрузка[к].Дата1)))/86400;
					Иначе	
						Новстр.КоличествоДней = (НачалоДня(Выгрузка[к+1].Дата1)-НачалоДня(Выгрузка[к].Дата1))/86400;
					КонецЕсли;	
					НовСтр.Площадь = Выгрузка[к].Площадь;
				КонецЕсли;
				Если Кол = к+2 Тогда хз=Ложь; КонецЕсли;
				к=к+1;
			КонецЦикла;
		КонецЕсли;	
		
		Возврат ТЗ;
		
