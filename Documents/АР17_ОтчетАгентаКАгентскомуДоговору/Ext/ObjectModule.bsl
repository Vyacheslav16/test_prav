Функция НазначениеПлатежа1(ДоговорАренды,НачалоПериода,ОкончаниеПериода,АгентскийДоговор)
	
	Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	СУММА(РеализацияТоваровУслугАгентскиеУслуги.Сумма - РеализацияТоваровУслугАгентскиеУслуги.СуммаНДС) КАК СуммаОборот,
		               |	ХозрасчетныйОборотыДтКт.Регистратор КАК РН,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата КАК Период,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3 КАК Сделка
		               |ИЗ
		               |	РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
		               |			&НачалоПериода,
		               |			&КонецПериода,
		               |			Регистратор,
		               |			,
		               |			,
		               |			СчетКт.Код = ""62.01""
		               |				ИЛИ СчетКт.Код = ""62.02""
		               |				ИЛИ СчетКт.Код = ""76.09"",
		               |			,
		               |			) КАК ХозрасчетныйОборотыДтКт
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК РеализацияТоваровУслугАгентскиеУслуги
		               |		ПО ХозрасчетныйОборотыДтКт.СубконтоКт3 = РеализацияТоваровУслугАгентскиеУслуги.Ссылка
		               |ГДЕ
		               |	ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) = ТИП(Документ.ПоступлениеНаРасчетныйСчет)
		               |	И ХозрасчетныйОборотыДтКт.СубконтоКт2 = &ДоговорКонтрагента
		               |	И ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата МЕЖДУ &АгентскийДоговорДата И &КонецПериода
		               |	И РеализацияТоваровУслугАгентскиеУслуги.Номенклатура.АР_КоммунальныеУслуги = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ХозрасчетныйОборотыДтКт.СчетКт,
		               |	ХозрасчетныйОборотыДтКт.Регистратор,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ
		               |	СУММА(РеализацияТоваровУслугУслуги.Сумма + РеализацияТоваровУслугУслуги.СуммаНДС),
		               |	ХозрасчетныйОборотыДтКт.Регистратор,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3
		               |ИЗ
		               |	РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
		               |			&НачалоПериода,
		               |			&КонецПериода,
		               |			Регистратор,
		               |			,
		               |			,
		               |			СчетКт.Код = ""62.01""
		               |				ИЛИ СчетКт.Код = ""62.02""
		               |				ИЛИ СчетКт.Код = ""76.09"",
		               |			,
		               |			) КАК ХозрасчетныйОборотыДтКт
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
		               |		ПО ХозрасчетныйОборотыДтКт.СубконтоКт3 = РеализацияТоваровУслугУслуги.Ссылка
		               |ГДЕ
		               |	ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) = ТИП(Документ.ПоступлениеНаРасчетныйСчет)
		               |	И ХозрасчетныйОборотыДтКт.СубконтоКт2 = &ДоговорКонтрагента
		               |	И ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата МЕЖДУ &АгентскийДоговорДата И &КонецПериода
		               |	И РеализацияТоваровУслугУслуги.Номенклатура.АР_КоммунальныеУслуги = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ХозрасчетныйОборотыДтКт.СчетКт,
		               |	ХозрасчетныйОборотыДтКт.Регистратор,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата,
		               |	ХозрасчетныйОборотыДтКт.СубконтоКт3
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Период УБЫВ";

	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(ОкончаниеПериода)); //КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорАренды);
	Запрос.УстановитьПараметр("АгентскийДоговорДата",АгентскийДоговор.Дата);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Колонки.Добавить("НачалоМесяца", Новый ОписаниеТипов("Дата"));
	Выгрузка.Колонки.Добавить("КонецМесяца", Новый ОписаниеТипов("Дата"));
	Для Каждого Стр из Выгрузка Цикл
		Если Стр.Сделка <> Неопределено Тогда
			Стр.НачалоМесяца = НачалоМесяца(Стр.Сделка.Дата);
			Стр.КонецМесяца = КонецМесяца(Стр.Сделка.Дата);
		КонецЕсли;	
	КонецЦикла;
	Выгрузка.Свернуть("НачалоМесяца,КонецМесяца");
	Выгрузка.Сортировать("НачалоМесяца");
	
	Возврат Выгрузка;
	
