Функция ТабОплата(Договор,НачалоПериода,ОкончаниеПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ВложенныйЗапрос.СуммаОборот) КАК СуммаОборот,
	               |	ЕСТЬNULL(КОНЕЦПЕРИОДА(ВложенныйЗапрос.СделкаДата, МЕСЯЦ), ДАТАВРЕМЯ(1, 1, 1)) КАК Дата
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ХозрасчетныйОборотыДтКт.СуммаОборот КАК СуммаОборот,
	               |		ХозрасчетныйОборотыДтКт.Регистратор КАК РН,
	               |		ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата КАК СделкаДата
	               |	ИЗ
	               |		РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
	               |				&НачалоПериода,
	               |				&КонецПериода,
	               |				Регистратор,
	               |				,
	               |				,
	               |				СчетКт.Код = ""62.01""
	               |					ИЛИ СчетКт.Код = ""62.02""
	               |					ИЛИ СчетКт.Код = ""76.09"",
	               |				,
	               |				) КАК ХозрасчетныйОборотыДтКт
	               |	ГДЕ
	               |		ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) <> ТИП(Документ.РеализацияТоваровУслуг)
	               |		И ХозрасчетныйОборотыДтКт.СубконтоКт2 = &ДоговорКонтрагента
	               |		И ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) <> ТИП(Документ.ПоступлениеНаРасчетныйСчет)
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.СуммаПлатежа - ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.СуммаНДС,
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Ссылка,
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Сделка.Дата
	               |	ИЗ
	               |		Документ.ПоступлениеНаРасчетныйСчет.РасшифровкаПлатежа КАК ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа
	               |	ГДЕ
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	               |		И ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.ДоговорКонтрагента = &ДоговорКонтрагента) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЕСТЬNULL(КОНЕЦПЕРИОДА(ВложенныйЗапрос.СделкаДата, МЕСЯЦ), ДАТАВРЕМЯ(1, 1, 1))";
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(ОкончаниеПериода)); //КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("СтрокаСобственник","Общедолевая собственность");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка;
	//Если Выборка.Следующий() Тогда
	//	Возврат Выборка.ДоляСобственника;
	//Иначе
	//	Возврат 0;
	//КонецЕсли;
	
