	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Обороты(&НачалоПериода, &КонецПериода, , Счет.Код = ""76.06"", , Субконто2 = &ДоговорКонтрагента, КорСчет = &КорСчет, ) КАК ХозрасчетныйОбороты";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
