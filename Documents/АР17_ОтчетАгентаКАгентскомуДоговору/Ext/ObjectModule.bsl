
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	ЗаполнитьДок(ДанныеЗаполнения);
КонецПроцедуры

Процедура ЗаполнитьДок(ДанныеЗаполнения) Экспорт
	
	АгентскийДоговор = ДанныеЗаполнения;
	Если НачалоПериода=Дата(1,1,1) или НачалоПериода<АгентскийДоговор.Дата Тогда
		НачалоПериода = АгентскийДоговор.Дата;
	КонецЕсли;
	
	КоличествоДней = ((НачалоДня(ОкончаниеПериода)-НачалоДня(НачалоПериода))/(60*60*24))+1;
	КоличествоДнейВМесяце = Число(Сред(КонецМесяца(НачалоПериода), 1, 2));
	
	// Шапка
	Организация = АгентскийДоговор.Организация;
	Контрагент = АгентскийДоговор.Контрагент;
	ИК = АгентскийДоговор.ИК;
	Ответственный = ПараметрыСеанса.ТекущийПользователь;
	
	ОбъектыАренды.Очистить();
	ДоходОтПомещений.Очистить();
	ДоходОтОбщегоИмущества.Очистить();
	ВознагражденияАгента.Очистить();
	ДополнительныеРасходы.Очистить();
	РасчетыПоПеречислениюПринципалу.Очистить();
	// Объекты
	ТаблицаОбъектыАренды = АгентскийДоговор.ОбъектыАренды.Выгрузить();
	Здание = "";
	Для Каждого Стр Из ТаблицаОбъектыАренды Цикл
		Родитель = Стр.ОбъектАренды.Родитель;
		НоваяСтр = ОбъектыАренды.Добавить();
		НоваяСтр.ТипОбъекта = Стр.ОбъектАренды.ТипОбъекта;
		НоваяСтр.ОбъектАренды = Стр.ОбъектАренды;
		НоваяСтр.Площадь = Стр.ОбъектАренды.ЗначениеХарактеристики;
	КонецЦикла;
	
	//+
	// Объекты 2
	ЗапросОбъекты = Новый Запрос;
	ЗапросОбъекты.Текст = "ВЫБРАТЬ
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	                      |ГДЕ
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка = &Ссылка
	                      |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи < &ОкончаниеПериода или АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи=ДАТАВРЕМЯ(1,1,1))
	                      |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > &НачалоПериода или АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата=ДАТАВРЕМЯ(1,1,1))
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь";
	
	ЗапросОбъекты.УстановитьПараметр("Ссылка",АгентскийДоговор);
	ЗапросОбъекты.УстановитьПараметр("НачалоПериода",НачалоПериода);
	ЗапросОбъекты.УстановитьПараметр("ОкончаниеПериода",ОкончаниеПериода);
	тзОбъектыАренды = ЗапросОбъекты.Выполнить().Выгрузить();
	Площадь2 = 0;
	Для Каждого Стр Из тзОбъектыАренды Цикл	
		Площадь2 = Площадь2+Стр.Площадь;
	КонецЦикла;	
	//-
	
	// Доход от помещений
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектыНедвижимости", ОбъектыАренды.Выгрузить(,"ОбъектАренды"));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецДня(ОкончаниеПериода));
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АР17_ЗаключениеДоговораАренды.Контрагент.Ссылка КАК Арендатор,
	|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента.Ссылка КАК ДоговорКонтрагента,
	|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ДоговорАренды,
	|	АР17_ЗаключениеДоговораАренды.ОбъектыАренды.(
	|		СУММА(Площадь) КАК Площадь
	|	) КАК ПлощадьПоАрендатору
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	//|	АР17_ЗаключениеДоговораАренды.ОбъектыАренды.ДатаПередачи <= &НачалоПериода
	//|	И АР17_ЗаключениеДоговораАренды.ОбъектыАренды.ДатаВозврата <= &ОкончаниеПериода
	//|	АР17_ЗаключениеДоговораАренды.ОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	//|	И 
	|	АР17_ЗаключениеДоговораАренды.Проведен = ИСТИНА
	|	И АР17_ЗаключениеДоговораАренды.ОбъектыАренды.ОбъектАренды.Ссылка В(&ОбъектыНедвижимости)";
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Свернуть("Арендатор, ДоговорКонтрагента, ДоговорАренды","ПлощадьПоАрендатору");
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Выгрузка.ВыгрузитьКолонку("ДоговорКонтрагента"));
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АР_РасчетыПоДоговорам.Период КАК Период,
	|	АР_РасчетыПоДоговорам.НомерСтроки КАК НомерСтроки,
	|	АР_РасчетыПоДоговорам.ВидДвижения КАК ВидДвижения,
	|	АР_РасчетыПоДоговорам.Месяц КАК Месяц,
	|	АР_РасчетыПоДоговорам.ДоговорКонтрагента.Ссылка КАК ДоговорКонтрагентаСсылка,
	|	АР_РасчетыПоДоговорам.Сумма КАК Сумма,
	|	АР_РасчетыПоДоговорам.Регистратор.Ссылка КАК РегистраторСсылка
	|ИЗ
	|	РегистрНакопления.АР_РасчетыПоДоговорам КАК АР_РасчетыПоДоговорам
	|ГДЕ
	|	АР_РасчетыПоДоговорам.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|	И АР_РасчетыПоДоговорам.ДоговорКонтрагента.Ссылка В(&ДоговорКонтрагента)
	|	И ТИПЗНАЧЕНИЯ(АР_РасчетыПоДоговорам.Регистратор) = ТИП(Документ.ПоступлениеНаРасчетныйСчет)";
	ВыгрузкаРасчетПоДоговоррам = Запрос.Выполнить().Выгрузить();
	
	КоличествоДнейВыбрано = Окр((КонецДня(ОкончаниеПериода) - НачалоПериода) / 60 / 60 / 24);
	КоличествоДнейВМесяце = День(КонецМесяца(ОкончаниеПериода));
	
	ПлощадьПоДоговору=0;
	ОплаченоПринципал_Итог = 0;
	
	Для Каждого СтрАрендатор Из Выгрузка Цикл
		
		НовСтрАрендатор = ДоходОтПомещений.Добавить();
		НовСтрАрендатор.ДоговорАренды = СтрАрендатор.ДоговорАренды;
		НовСтрАрендатор.Контрагент = СтрАрендатор.Арендатор;
		НовСтрАрендатор.ДоговорКонтрагента = СтрАрендатор.ДоговорКонтрагента;
		НовСтрАрендатор.От = СтрАрендатор.ДоговорКонтрагента.Дата;
		Для Каждого СтрПостояннаяЧастьАренднойПлаты Из СтрАрендатор.ДоговорАренды.ПостояннаяЧастьАренднойПлаты Цикл
			Если (СтрПостояннаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды <= НачалоПериода) И (СтрПостояннаяЧастьАренднойПлаты.ДатаОкончанияСрокаАренды >= ОкончаниеПериода) Тогда
				ПлощадьМОП = ПлощадьМОП(СтрАрендатор.ДоговорАренды);
				НовСтрАрендатор.ПлощадьПоДоговору = СтрПостояннаяЧастьАренднойПлаты.Количество - ПлощадьМОП;
				НовСтрАрендатор.Ставка = СтрПостояннаяЧастьАренднойПлаты.Ставка;
				НовСтрАрендатор.СпособНачисления = СтрПостояннаяЧастьАренднойПлаты.СпособНачисления;
				ПлощадьПоДоговору = ПлощадьПоДоговору+СтрПостояннаяЧастьАренднойПлаты.Количество;
			КонецЕСли;
		КонецЦикла;
		
		ДоговорАренды = ПолучитьДоговорАренды(НовСтрАрендатор.ДоговорКонтрагента);
		Ставка = ?(НовСтрАрендатор.Ставка=Неопределено,0,НовСтрАрендатор.Ставка);
		НовСтрАрендатор.НачисленоВОтчетномПериоде = Окр(НовСтрАрендатор.ПлощадьПоДоговору*Ставка/12,2);
		
		Отбор = Новый Структура;
		Отбор.Вставить("ВидДвижения", ВидДвиженияНакопления.Расход);
		Отбор.Вставить("ДоговорКонтрагентаСсылка", СтрАрендатор.ДоговорКонтрагента);
		КопияТабНачисленоАПП = ВыгрузкаРасчетПоДоговоррам.Скопировать(Отбор);
		
		НовСтрАрендатор.ОплаченоВОтчетномПериоде = ОплаченоВОтчетномПериоде(ДоговорАренды.ДоговорКонтрагента);
		
		СтрокаНазначениеПлатежа = "";
		НазначениеПлатежа = Новый ТаблицаЗначений;
		НазначениеПлатежа.Колонки.Добавить("ДатаПериодаОплаты");
		Для Каждого СтрПостНаРС Из КопияТабНачисленоАПП Цикл
			Для Каждого СтрРасшифровкаПлатежа Из СтрПостНаРС.РегистраторСсылка.РасшифровкаПлатежа Цикл
				НовСтрДатаОплаты = НазначениеПлатежа.Добавить();
				Если СтрРасшифровкаПлатежа.СпособПогашенияЗадолженности = Перечисления.СпособыПогашенияЗадолженности.ПоДокументу Тогда
					НовСтрДатаОплаты.ДатаПериодаОплаты = Формат(СтрРасшифровкаПлатежа.Сделка.Дата, "ДФ=""ММММ гггг""");
				Иначе
					НовСтрДатаОплаты.ДатаПериодаОплаты = Формат(СтрПостНаРС.РегистраторСсылка.Дата, "ДФ=""ММММ гггг""");
				КонецЕСли;
			КонецЦикла;
		КонецЦикла;
		НазначениеПлатежа.Свернуть("ДатаПериодаОплаты");
		Для Каждого СтрНазначениеПлатежа Из НазначениеПлатежа Цикл
			СтрокаНазначениеПлатежа = СтрокаНазначениеПлатежа + Строка(СтрНазначениеПлатежа.ДатаПериодаОплаты) + "; ";
		КонецЦикла;	
		НовСтрАрендатор.НазначениеПлатежа = СтрокаНазначениеПлатежа;
		
		ПлощадьНаНачало=0;
		НачисленоАрендыЗаПомещениеПринципала=0;
		тзОбъектыАренды = АгентскийДоговор.ОбъектыАренды.Выгрузить();
		//тзОбъектыАренды.Свернуть("ДатаПередачи,ДатаВозврата,НеСдается", "Площадь");
		
		Для Каждого Стр из тзОбъектыАренды Цикл
			Если (Стр.ДатаПередачи > ОкончаниеПериода и Стр.ДатаПередачи<>Дата(1,1,1)) или (Стр.ДатаВозврата<НачалоПериода и Стр.ДатаВозврата <> Дата(1,1,1)) Тогда Продолжить; КонецЕсли;
			Если Стр.НеСдается Тогда Продолжить; КонецЕсли;
			ПлощадьНаНачало = ПлощадьНаНачало + Стр.Площадь;
			////Денис++
			Если Стр.ДатаПередачи > НачалоДня(НачалоПериода) Тогда
				ХЗ = ((НачалоДня(ОкончаниеПериода)-НачалоДня(Стр.ДатаПередачи))/(60*60*24))+1;
			Иначе 
				ХЗ = КоличествоДней;
			КонецЕсли;
			//НачисленоАрендыЗаПомещениеПринципала = НачисленоАрендыЗаПомещениеПринципала + ? (НовСтрАрендатор.ПлощадьПоДоговору=0,0,Окр((НовСтрАрендатор.НачисленоВОтчетномПериоде * Стр.Площадь/ НовСтрАрендатор.ПлощадьПоДоговору)/ КоличествоДнейВМесяце*КоличествоДней,2));
			НачисленоАрендыЗаПомещениеПринципала = НачисленоАрендыЗаПомещениеПринципала + ? (НовСтрАрендатор.ПлощадьПоДоговору=0,0,Окр((НовСтрАрендатор.НачисленоВОтчетномПериоде * Стр.Площадь/ НовСтрАрендатор.ПлощадьПоДоговору)/ КоличествоДнейВМесяце*ХЗ,2));
			///Денис--
		КонецЦикла;
		
		НовСтрАрендатор.НачисленоАрендыЗаПомещениеПринципала = НачисленоАрендыЗаПомещениеПринципала;
		
		
		
		СуммаПоступившихПлатежейЗаПомещениеПринципала=0;
		//ТабОплата = ТабОплата(НовСтрАрендатор.ДоговорКонтрагента,НачалоДня(НачалоПериода),КонецДня(ОкончаниеПериода));
		ТабОплата = ОплаченоВОтчетномПериоде_(ДоговорАренды.ДоговорКонтрагента,НачалоДня(НачалоПериода),КонецДня(ОкончаниеПериода),АгентскийДоговор,НачалоДня(НачалоПериода),КонецДня(ОкончаниеПериода));
		ТабОплата.Свернуть("Дата","СуммаОборот");
		//Если ТабОплата.Количество()>0 Тогда
		Для Каждого СтрОплата Из ТабОплата Цикл
			//ТабПлощадь = ПолучитьПлощадь(НачалоМесяца(ТабОплата[0].Регистратор.Дата),КонецМесяца(ТабОплата[0].Регистратор.Дата));
			//+
			тзПериоды = НазначениеПлатежа1(ДоговорАренды.ДоговорКонтрагента,НачалоДня(НачалоПериода),КонецДня(ОкончаниеПериода),АгентскийДоговор);
			тзПлощадьПоДоговору = ПлощадьПоДоговору(ДоговорАренды.ДоговорКонтрагента,тзПериоды);
			ПлощадьПоДоговору = ?(тзПлощадьПоДоговору.Количество()=0,0,тзПлощадьПоДоговору[0].Количество);
			//-
			ТабПлощадь = ПолучитьПлощадь_(НачалоМесяца(СтрОплата.Дата),КонецМесяца(СтрОплата.Дата),ДоговорАренды.ДоговорКонтрагента);
			КоличествоДнейВМесяцеПлощадь =  Число(Лев(КонецМесяца(КонецМесяца(СтрОплата.Дата)),2));
			ПлощадьНаНачало = 0;
			НовСтрАрендатор.ПлощадьПоДоговору = ?(ТабПлощадь.Количество()=0,0,ТабПлощадь[0].Площадь); 
			Для Каждого СтрПлощадь Из ТабПлощадь Цикл
				//ПлощадьНаНачало	= ПлощадьНаНачало + СтрПлощадь.Площадь/КоличествоДнейВМесяцеПлощадь*СтрПлощадь.КоличествоДней;
				тзПроверка = ПроверкаПоПлощади(ДоговорАренды.ДоговорКонтрагента);
				Если тзПроверка[0].ДатаПередачи > СтрОплата.Дата Тогда 
					НовСтрАрендатор.ОплаченоВОтчетномПериоде = 0; 
					Продолжить; 
				КонецЕсли;
				СуммаПоступившихПлатежейЗаПомещениеПринципала = 
				//СуммаПоступившихПлатежейЗаПомещениеПринципала + НовСтрАрендатор.ОплаченоВОтчетномПериоде*ПлощадьНаНачало/ПлощадьПоДоговору/КоличествоДнейВМесяце*КоличествоДнейВыбрано;
				СуммаПоступившихПлатежейЗаПомещениеПринципала + 
				?(ПлощадьПоДоговору=0,0,НовСтрАрендатор.ОплаченоВОтчетномПериоде*СтрПлощадь.Площадь/ПлощадьПоДоговору*Площадь2/КоличествоДнейВМесяцеПлощадь*СтрПлощадь.КоличествоДней/СтрПлощадь.Площадь);
			КонецЦикла;	

			СуммаПоступившихПлатежейЗаПомещениеПринципала = Окр(СуммаПоступившихПлатежейЗаПомещениеПринципала,2);
		КонецЦикла;	
		//КонецЕсли;	
		
		НовСтрАрендатор.Ставка = ПолучитьСтавку(НовСтрАрендатор.ДоговорАренды);
		НовСтрАрендатор.СуммаПоступившихПлатежейЗаПомещениеПринципала = СуммаПоступившихПлатежейЗаПомещениеПринципала;
		
		ОплаченоПринципал_Итог = ОплаченоПринципал_Итог + СуммаПоступившихПлатежейЗаПомещениеПринципала;
		
		Если НовСтрАрендатор.НачисленоАрендыЗаПомещениеПринципала=0 и НовСтрАрендатор.СуммаПоступившихПлатежейЗаПомещениеПринципала=0 Тогда
			ДоходОтПомещений.Удалить(НовСтрАрендатор.НомерСтроки-1);
