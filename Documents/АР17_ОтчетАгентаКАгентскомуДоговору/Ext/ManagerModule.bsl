Функция ПолучитьПлощадьВПериоде(Объект,ДоговорКонтрагента,НачалоМесяца,КонецМесяца)
	
	НайденныеДоговоры = Объект.АгентскийДоговор.ДоговорыМОП.Найти(ДоговорКонтрагента, "ДоговорКонтрагента");
	
	Структура = Новый Структура ("ДоговорКонтрагента",ДоговорКонтрагента);
	НайденныеДоговоры = Объект.АгентскийДоговор.ДоговорыМОП.Выгрузить(Структура);

	Для Каждого СтрДог Из НайденныеДоговоры Цикл
		Если (СтрДог.ДатаОкончания<>Дата(1,1,1)) или (СтрДог.ДатаНачала<>Дата(1,1,1)) Тогда
			Если (СтрДог.ДатаОкончания<>Дата(1,1,1)) Тогда
				Если СтрДог.ДатаОкончания >= НачалоМесяца Тогда
					Возврат СтрДог.ПлощадьМОП;
				КонецЕсли;
			КонецЕсли;
			Если (СтрДог.ДатаНачала<>Дата(1,1,1)) Тогда
				Если СтрДог.ДатаНачала <= КонецМесяца и (СтрДог.ДатаОкончания=Дата(1,1,1)) Тогда
					Возврат СтрДог.ПлощадьМОП;
				КонецЕсли;
			КонецЕсли;
		Иначе
			Возврат СтрДог.ПлощадьМОП;
		КонецЕсли;	
	КонецЦикла;

	Возврат 0;
	
