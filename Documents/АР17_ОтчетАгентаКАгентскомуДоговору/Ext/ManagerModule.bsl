Функция ПолучитьПлощадь(ДатаН,ДатаК,АгентскийДоговор)
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаН
		               |			ТОГДА &ДатаН
		               |		ИНАЧЕ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи
		               |	КОНЕЦ КАК ДатаПередачи,
		               |	ВЫБОР
		               |		КОГДА АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаК
		               |				ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
		               |			ТОГДА &ДатаК
		               |		ИНАЧЕ КОНЕЦПЕРИОДА(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата, ДЕНЬ)
		               |	КОНЕЦ КАК ДатаВозврата,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь,
		               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды
		               |ПОМЕСТИТЬ ВТ
		               |ИЗ
		               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
		               |ГДЕ
		               |	(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи <= &ДатаК
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи = ДАТАВРЕМЯ(1, 1, 1))
		               |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата >= &ДатаН
		               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1))
		               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка = &Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаПередачи КАК Дата1
		               |ПОМЕСТИТЬ ВТ1
		               |ИЗ
		               |	ВТ КАК ВТ
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВТ.ДатаВозврата
		               |ИЗ
		               |	ВТ КАК ВТ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СУММА(ВТ.Площадь) КАК Площадь,
		               |	ВТ1.Дата1 КАК Дата1
		               |ИЗ
		               |	ВТ КАК ВТ
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ1 КАК ВТ1
		               |		ПО ВТ.ДатаВозврата >= ВТ1.Дата1
		               |			И ВТ.ДатаПередачи <= ВТ1.Дата1
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВТ1.Дата1";
		
		Запрос.УстановитьПараметр("Ссылка",АгентскийДоговор);
		Запрос.УстановитьПараметр("ДатаН",ДатаН);
		Запрос.УстановитьПараметр("ДатаК",ДатаК);
		Выгрузка = Запрос.Выполнить().Выгрузить();
		
		к=0;
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("ДатаПередачи");
		ТЗ.Колонки.Добавить("ДатаВозврата");
		ТЗ.Колонки.Добавить("Площадь");
		ТЗ.Колонки.Добавить("КоличествоДней");
		
		Кол = Выгрузка.Количество();
		ХЗ = Истина;
		Если Кол>0 Тогда
			Пока хз Цикл
				Если Выгрузка[к+1].Дата1-Выгрузка[к].Дата1 > 86400 Тогда
					НовСтр = ТЗ.Добавить();
					НовСтр.ДатаПередачи = Выгрузка[к].Дата1;
					НовСтр.ДатаВозврата = Выгрузка[к+1].Дата1;
					Если НовСтр.ДатаВозврата = КонецМесяца(Выгрузка[к].Дата1) Тогда
						Новстр.КоличествоДней = ((КонецДня(Выгрузка[к+1].Дата1)+1 - НачалоДня(Выгрузка[к].Дата1)))/86400;
					Иначе	
						Новстр.КоличествоДней = (НачалоДня(Выгрузка[к+1].Дата1)-НачалоДня(Выгрузка[к].Дата1))/86400;
					КонецЕсли;	
					НовСтр.Площадь = Выгрузка[к].Площадь;
				КонецЕсли;
				Если Кол = к+2 Тогда хз=Ложь; КонецЕсли;
				к=к+1;
			КонецЦикла;
		КонецЕсли;	
		
		Возврат ТЗ;
		
КонецФункции			


