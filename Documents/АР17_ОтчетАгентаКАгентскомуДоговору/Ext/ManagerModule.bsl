		Если Стр.Сделка <> Неопределено Тогда
			Стр.НачалоМесяца = НачалоМесяца(Стр.Сделка.Дата);
			Стр.КонецМесяца = КонецМесяца(Стр.Сделка.Дата);
		КонецЕсли;	
	КонецЦикла;
	Выгрузка.Свернуть("НачалоМесяца,КонецМесяца");
	Выгрузка.Сортировать("НачалоМесяца");
	
	Возврат Выгрузка;
	
КонецФункции	

Функция ТабОплата(Договор,НачалоПериода,ОкончаниеПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ВложенныйЗапрос.СуммаОборот) КАК СуммаОборот,
	               |	ЕСТЬNULL(КОНЕЦПЕРИОДА(ВложенныйЗапрос.СделкаДата, МЕСЯЦ), ДАТАВРЕМЯ(1, 1, 1)) КАК Дата
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ХозрасчетныйОборотыДтКт.СуммаОборот КАК СуммаОборот,
	               |		ХозрасчетныйОборотыДтКт.Регистратор КАК РН,
	               |		ХозрасчетныйОборотыДтКт.СубконтоКт3.Дата КАК СделкаДата
	               |	ИЗ
	               |		РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
	               |				&НачалоПериода,
	               |				&КонецПериода,
	               |				Регистратор,
	               |				,
	               |				,
	               |				СчетКт.Код = ""62.01""
	               |					ИЛИ СчетКт.Код = ""62.02""
	               |					ИЛИ СчетКт.Код = ""76.09"",
	               |				,
	               |				) КАК ХозрасчетныйОборотыДтКт
	               |	ГДЕ
	               |		ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) <> ТИП(Документ.РеализацияТоваровУслуг)
	               |		И ХозрасчетныйОборотыДтКт.СубконтоКт2 = &ДоговорКонтрагента
	               |		И ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) <> ТИП(Документ.ПоступлениеНаРасчетныйСчет)
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.СуммаПлатежа - ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.СуммаНДС,
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Ссылка,
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Сделка.Дата
	               |	ИЗ
	               |		Документ.ПоступлениеНаРасчетныйСчет.РасшифровкаПлатежа КАК ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа
	               |	ГДЕ
	               |		ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	               |		И ПоступлениеНаРасчетныйСчетРасшифровкаПлатежа.ДоговорКонтрагента = &ДоговорКонтрагента) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЕСТЬNULL(КОНЕЦПЕРИОДА(ВложенныйЗапрос.СделкаДата, МЕСЯЦ), ДАТАВРЕМЯ(1, 1, 1))";
	
	//Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 2
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор КАК Регистратор,
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период
	//               |ИЗ
	//               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&КонецПериода, ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
	//               |
	//               |СГРУППИРОВАТЬ ПО
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника,
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор,
	//               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период
	//               |
	//               |УПОРЯДОЧИТЬ ПО
	//               |	Период УБЫВ";
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(ОкончаниеПериода)); //КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("СтрокаСобственник","Общедолевая собственность");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка;
	//Если Выборка.Следующий() Тогда
	//	Возврат Выборка.ДоляСобственника;
	//Иначе
	//	Возврат 0;
	//КонецЕсли;
	
КонецФункции	

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "Печать", "Печать", ПечатьОтчета(МассивОбъектов, ОбъектыПечати, Ложь));
	
КонецПроцедуры

Функция ПолучитьСклонениеДолжности(Объект)
    
    Запрос = Новый Запрос;
    Запрос.Текст =  "ВЫБРАТЬ
                    |   СклоненияПредставленийОбъектов.РодительныйПадеж КАК РодительныйПадеж
                    |ИЗ
                    |   РегистрСведений.СклоненияПредставленийОбъектов КАК СклоненияПредставленийОбъектов
                    |ГДЕ
                    |   СклоненияПредставленийОбъектов.Объект = &Объект";
    Запрос.УстановитьПараметр("Объект", Объект);
    
    Результат = Запрос.Выполнить(); 
    Если Не Результат.Пустой() Тогда
        Выборка = Результат.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.РодительныйПадеж;
    Иначе
        Возврат Неопределено
    КонецЕсли;  
 
КонецФункции  //ПолучитьСклонениеДолжности()

Функция ПечатьОтчета(МассивОбъектов, ОбъектыПечати, Сводный) Экспорт
	
	Объект = МассивОбъектов;
	
	КоличествоДней = ((НачалоДня(Объект.ОкончаниеПериода)-НачалоДня(Объект.НачалоПериода))/(60*60*24))+1;
	КоличествоДнейВМесяце = Число(Сред(КонецМесяца(Объект.НачалоПериода), 1, 2));
	
	//Создаем табличный документ, выводим в него все, что нам необходимо.
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы=ОриентацияСтраницы.Ландшафт;
	
	Макет = Документы.АР17_ОтчетАгентаКАгентскомуДоговору.ПолучитьМакет("Печать");
	
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	
	ОблЗаголовок.Параметры.ДатаПечатиДокумента = Формат(ТекущаяДата(), "ДЛФ=Д");
	ОблЗаголовок.Параметры.НомерАгентскогоДоговора = МассивОбъектов.АгентскийДоговор.Номер;
	ОблЗаголовок.Параметры.ДатаАгентскогоДоговора = Формат(Объект.АгентскийДоговор.Дата, "ДЛФ=Д");
	ОблЗаголовок.Параметры.НачалоПериода = Формат(Объект.НачалоПериода, "ДЛФ=Д");
	ОблЗаголовок.Параметры.ОкончаниеПериода = Формат(Объект.ОкончаниеПериода, "ДЛФ=Д");
	ОблЗаголовок.Параметры.Организация = Объект.Организация.НаименованиеСокращенное;	
	
	//ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(Объект.Организация, Объект.АгентскийДоговор.ДатаПодписанияДоговора);
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_УстановкаПараметровИК.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
	               |ГДЕ
	               |	АР17_УстановкаПараметровИК.ИКСсылка = &ИКСсылка";
	Запрос.УстановитьПараметр("ИКСсылка",Объект.ИК);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ФИОРуководителя = Выборка.Ссылка.ПечатьУправляющий;
		Пол = ?(ФИОРуководителя.ФизическоеЛицо.Пол = Перечисления.ПолФизическогоЛица.Женский,2,1);
		ДолжностьРуководителя = ПолучитьДолжность(ФИОРуководителя);
		//ОбщегоНазначения.Просклонять(ФИОРуководителя, 2, ФИОРуководителя,Пол);
		//
		ДолжностьРуководителяРП = СклонениеПредставленийОбъектов.ПросклонятьПредставление(ДолжностьРуководителя, 2, ДолжностьРуководителяРП);
		ОблЗаголовок.Параметры.ДолжностьРуководителяРП = ДолжностьРуководителяРП;
		ФИОРуководителяРП = СклонениеПредставленийОбъектов.ПросклонятьФИО(ФИОРуководителя, 2, ФИОРуководителяРП,Пол);
		ОблЗаголовок.Параметры.ФИОРуководителяРП = ФИОРуководителяРП;
		Если Пол = Перечисления.ПолФизическогоЛица.Женский Тогда
			Действующий = "действующей";
		Иначе
			Действующий = "действующего"
		КонецЕсли;	
		ОблЗаголовок.Параметры.Действующий = Действующий;
		ОблЗаголовок.Параметры.Основание = Выборка.Ссылка.ПечатьДоверенность;
	КонецЕсли;
	
	ОблЗаголовок.Параметры.Контрагент = Объект.Контрагент.НаименованиеПолное;
	
	ТабДокумент.Вывести(ОблЗаголовок);
	
	Для Каждого Стр Из Объект.АгентскийДоговор.УсловияАгентскогоВознагражденияПечать Цикл
		ОблУсловияАгентскогоВознагражденияПечать = Макет.ПолучитьОбласть("УсловияАгентскогоВознагражденияПечать");
		ОблУсловияАгентскогоВознагражденияПечать.Параметры.УсловияАгентскогоВознагражденияПечать = СокрЛП(Стр.НомерСтроки) + ". " +Стр.Содержание;
		ТабДокумент.Вывести(ОблУсловияАгентскогоВознагражденияПечать);
	КонецЦикла;
	ОблЗаголовок1 = Макет.ПолучитьОбласть("Заголовок1");
	ТабДокумент.Вывести(ОблЗаголовок1);
	
	Для Каждого Стр Из Объект.АгентскийДоговор.УсловиеПеречисленияПринципалуПечать Цикл
		ОблУсловиеПеречисленияПринципалуПечать = Макет.ПолучитьОбласть("УсловиеПеречисленияПринципалуПечать");
		ОблУсловиеПеречисленияПринципалуПечать.Параметры.УсловиеПеречисленияПринципалуПечать = СокрЛП(Стр.НомерСтроки) + ". " +Стр.Содержание;
		ТабДокумент.Вывести(ОблУсловиеПеречисленияПринципалуПечать);
	КонецЦикла;
	
	// Объекты
	ЗапросОбъекты = Новый Запрос;
	ЗапросОбъекты.Текст = "ВЫБРАТЬ
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь
	                      |ИЗ
	                      |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	                      |ГДЕ
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка = &Ссылка
	                      |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи < &ОкончаниеПериода или АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи=ДАТАВРЕМЯ(1,1,1))
	                      |	И (АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата > &НачалоПериода или АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаВозврата=ДАТАВРЕМЯ(1,1,1))
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
	                      |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь";
	
	ЗапросОбъекты.УстановитьПараметр("Ссылка",Объект.АгентскийДоговор);
	ЗапросОбъекты.УстановитьПараметр("НачалоПериода",Объект.НачалоПериода);
	ЗапросОбъекты.УстановитьПараметр("ОкончаниеПериода",Объект.ОкончаниеПериода);
	тзОбъектыАренды = ЗапросОбъекты.Выполнить().Выгрузить();
	
	ПП = 1;
	ТаблицаЭтажей = Новый ТаблицаЗначений;
	ТаблицаЭтажей.Колонки.Добавить("Этаж");
	Шапка_Объект = Макет.ПолучитьОбласть("Шапка_Объект");
	ТабДокумент.Вывести(Шапка_Объект);
	Для Каждого Стр Из тзОбъектыАренды Цикл	
		ОблОбъект = Макет.ПолучитьОбласть("Объект");
		ОблОбъект.Параметры.ПП = ПП;
		ОблОбъект.Параметры.КадастровыйНомер = ?(СокрЛП(Стр.ОбъектАренды.ЗаписьВРеестре)="",СокрЛП(Стр.ОбъектАренды.Родитель.ЗаписьВРеестре),"");
		ОблОбъект.Параметры.Адрес = Стр.ОбъектАренды.Родитель.Родитель.Родитель.Адрес;
		ОблОбъект.Параметры.Этаж = Лев(Стр.ОбъектАренды.Родитель.Родитель,1);
		ОблОбъект.Параметры.Площадь = Стр.Площадь;
		ТабДокумент.Вывести(ОблОбъект);
		НоваяСтрока = ТаблицаЭтажей.Добавить();
		НоваяСтрока.Этаж = ОблОбъект.Параметры.Этаж;
		ПП = ПП+1;
	КонецЦикла;
	Если тзОбъектыАренды.Количество()>0 Тогда
		Подвал_Объект = Макет.ПолучитьОбласть("Подвал_Объект");
		Подвал_Объект.Параметры.ПП = ПП;
		Здание = Стр.ОбъектАренды.Родитель.Родитель.Родитель;
		Подвал_Объект.Параметры.Доля = Формат(ДоляПринципала(Объект.АгентскийДоговор.ДоговорКонтрагента,Объект.НачалоПериода,Объект.ОкончаниеПериода),"ЧДЦ=3");
		Подвал_Объект.Параметры.КадастровыйНомер = ПолучитьКадастровыйНомер(Объект.ИК);
		Подвал_Объект.Параметры.Адрес = Здание.Адрес;
		ТаблицаЭтажей = ПолучитьЭтажи(Здание);	
		ТаблицаЭтажей.Свернуть("Этаж");
		Этаж = "";
		Для Каждого Стр из ТаблицаЭтажей Цикл
			Этаж = Этаж + Лев(Стр.Этаж,1) + ", ";
		КонецЦикла;
		Этаж = Сред(Этаж,0,СтрДлина(Этаж)-2);
		Подвал_Объект.Параметры.Этаж = Этаж;
		
		ПлощадьПоДоговору = 0;
		Для Каждого СтрДоход из Объект.ДоходОтОбщегоИмущества Цикл		
			ПлощадьПоДоговору = ПлощадьПоДоговору + СтрДоход.ПлощадьВОбщемИмуществе;
		КонецЦикла;	
		
		ПлощадьПоДоговору = ПолчитьПлощадьИзИК(Объект.ИК);
		Если ПлощадьПоДоговору = "" Тогда	
			Подвал_Объект.Параметры.Площадь = ПлощадьМОП(Объект.ИК);
		Иначе	
			Подвал_Объект.Параметры.Площадь = ПлощадьПоДоговору;
		КонецЕсли;	
		ТабДокумент.Вывести(Подвал_Объект);
	КонецЕсли;	
	
	// Доход от помещений
	КоличествоДнейВыбрано = Окр((КонецДня(Объект.ОкончаниеПериода) - Объект.НачалоПериода) / 60 / 60 / 24);
	КоличествоДнейВМесяце = День(КонецМесяца(Объект.ОкончаниеПериода));
	ОплаченоПринципал_Итог = 0;
	
	ПП = 1;
	Шапка_Доход = Макет.ПолучитьОбласть("Шапка_Доход");
	ТабДокумент.Вывести(Шапка_Доход);
	Для Каждого Стр Из Объект.ДоходОтПомещений Цикл
		ОблДоход = Макет.ПолучитьОбласть("Доход");
		ОблДоход.Параметры.ПП = ПП;
		ПП = ПП+1;
		ОблДоход.Параметры.Наименование = Стр.Контрагент.Наименование;
		ОблДоход.Параметры.Номер = СокрЛП(Стр.ДоговорАренды.Номер);
		ОблДоход.Параметры.Дата = Формат(Стр.ДоговорАренды.Дата,"ДЛФ=Д");
		ОблДоход.Параметры.Площадь = Стр.ПлощадьПоДоговору;
		ОблДоход.Параметры.Ставка = Стр.Ставка;
		ОблДоход.Параметры.Начислено = Стр.НачисленоВОтчетномПериоде;
		ОблДоход.Параметры.Оплачено = Стр.ОплаченоВОтчетномПериоде;
