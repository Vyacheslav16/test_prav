		               |	Пост.Сумма КАК СуммаОборот,
		               |	СУММА(ВТ.Сумма) КАК Сумма,
		               |	ВТ.Ссылка КАК Ссылка
		               |ПОМЕСТИТЬ РН
		               |ИЗ
		               |	Пост КАК Пост
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ КАК ВТ
		               |		ПО Пост.СубконтоКт3 = ВТ.Ссылка
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Пост.Регистратор,
		               |	Пост.Сумма,
		               |	ВТ.Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	Пост.Регистратор КАК Регистратор,
		               |	Пост.Сумма КАК СуммаОборот,
		               |	СУММА(ВТ2.Сумма) КАК Сумма,
		               |	ВТ2.Ссылка КАК Ссылка
		               |ПОМЕСТИТЬ РН2
		               |ИЗ
		               |	Пост КАК Пост,
		               |	ВТ2 КАК ВТ2
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Пост.Регистратор,
		               |	Пост.Сумма,
		               |	ВТ2.Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	РН.Регистратор КАК Регистратор,
		               |	ВЫБОР
		               |		КОГДА РН.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя)
		               |			ТОГДА РН.СуммаОборот
		               |		ИНАЧЕ РН.Сумма
		               |	КОНЕЦ КАК СуммаОборот,
		               |	РН.Ссылка КАК Ссылка
		               |ПОМЕСТИТЬ Об
		               |ИЗ
		               |	РН КАК РН
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ
		               |	РН2.Регистратор,
		               |	ВЫБОР
		               |		КОГДА РН2.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеДенежныхСредств.ОплатаПокупателя)
		               |			ТОГДА РН2.СуммаОборот
		               |		ИНАЧЕ РН2.Сумма
		               |	КОНЕЦ,
		               |	РН2.Ссылка
		               |ИЗ
		               |	РН2 КАК РН2
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	Об.Регистратор КАК Регистратор,
		               |	Об.СуммаОборот КАК СуммаОборот,
		               |	Об.Ссылка КАК Сделка
		               |ИЗ
		               |	Об КАК Об
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Об.Регистратор,
		               |	Об.СуммаОборот,
		               |	Об.Ссылка";

		
	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(ОкончаниеПериода)); //КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорАренды);
	Запрос.УстановитьПараметр("АгентскийДоговорДата",АгентскийДоговор.Дата);
	
	Запрос.УстановитьПараметр("НачалоПериодаР",НачалоМесяца(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериодаР",КонецМесяца(ОкончаниеПериода));
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Колонки.Добавить("Месяц");
	Для Каждого Стр из Выгрузка Цикл
		Если Стр.Сделка <> Неопределено и Стр.СуммаОборот<>Null Тогда
			Стр.Месяц = Формат(Стр.Сделка.Дата, "ДФ='ММММ'");
		КонецЕсли;	
	КонецЦикла;
	Выгрузка.Свернуть("Месяц");
	Значение = "";
	Для Каждого Стр из Выгрузка Цикл
		Если Стр.Месяц <> Неопределено Тогда
			Значение = Стр.Месяц + ", " + Значение;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Лев(Значение,СтрДлина(Значение)-2);
	
