Функция ЗадолженностьПередПринципаломНачалоБух(НачалоПериода,ОкончаниеПериода,ДоговорКонтрагента) 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ХозрасчетныйОстатки.СуммаОстатокКт КАК СуммаОстатокКт
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Остатки(&НачалоПериода, Счет.Код = ""76.06"", , Субконто2 = &ДоговорКонтрагента) КАК ХозрасчетныйОстатки";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Возврат Выгрузка[0].СуммаОстатокКт;
	Иначе
		Возврат 0;
	КонецЕсли;	
