Функция ПолучитьДолжность(Сотрудник)
		
	Запрос = НОвый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТекущиеКадровыеДанныеСотрудников.ТекущаяДолжность КАК ТекущаяДолжность
	               |ИЗ
	               |	РегистрСведений.ТекущиеКадровыеДанныеСотрудников КАК ТекущиеКадровыеДанныеСотрудников
	               |ГДЕ
	               |	ТекущиеКадровыеДанныеСотрудников.Сотрудник = &Сотрудник";
	Запрос.УстановитьПараметр("Сотрудник",Сотрудник);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.ТекущаяДолжность;	
	
КонецФункции		

Функция ДоляПринципала(Договор,НачалоПериода,ОкончаниеПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период
	               |ИЗ
	               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&КонецПериода, ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
	               |ГДЕ
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор.СтрокаСобственник = &СтрокаСобственник
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Период УБЫВ";
	
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("СтрокаСобственник","Общедолевая собственность");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ДоляСобственника;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции	

Функция ДоляПринципала_(Договор,НачалоПериода,ОкончаниеПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_СобственникиОбъектовАрендыСпр.ДоляСобственника КАК ДоляСобственника,
	               |	МАКСИМУМ(АР_СобственникиОбъектовАрендыСпр.Период) КАК Период,
	               |	АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента КАК ДоговорКонтрагента
	               |ИЗ
	               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр КАК АР_СобственникиОбъектовАрендыСпр
	               |ГДЕ
	               |	АР_СобственникиОбъектовАрендыСпр.Регистратор.СтрокаСобственник = &СтрокаСобственник
	               |	И АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СобственникиОбъектовАрендыСпр.ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента";
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("СтрокаСобственник","Общедолевая собственность");
	
	Выборка = Запрос.Выполнить().Выбрать();
	тзВыгрузка = Запрос.Выполнить().Выгрузить();
	
	//
	Построитель = Новый ПостроительЗапроса;
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(тзВыгрузка);

	тОтбор = Построитель.Отбор.Добавить("Период");
	тОтбор.ВидСравнения = ВидСравнения.БольшеИлиРавно;
	тОтбор.Значение = НачалоПериода;
	тОтбор.Использование = Истина;

	Построитель.Выполнить();
	Выгрузка = Построитель.Результат.Выгрузить();
	//
	
	Выгрузка.Колонки.Добавить("КоличествоДней");
	Для Каждого Стр Из Выгрузка Цикл
		Если Стр.Период < НачалоПериода Тогда
			Стр.Период = НачалоПериода;
		КонецЕсли;
	КонецЦикла;	
	
	к=0;
	Пока Выгрузка.Количество()>к Цикл
		Если к+1 = Выгрузка.Количество() Тогда
			Выгрузка[к].Период = КонецДня(ОкончаниеПериода);
		Иначе	
			Выгрузка[к].Период = Выгрузка[к+1].Период;	
		КонецЕсли;
		к=к+1;
	КонецЦикла;

	Возврат Выгрузка;
	
КонецФункции	

Функция ДоляПринципала1(Договор,НачалоПериода,ОкончаниеПериода,тзПериоды)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ1.НачалоМесяца КАК НачалоМесяца,
	               |	ТЗ1.КонецМесяца КАК КонецМесяца
	               |ПОМЕСТИТЬ ТЗ
	               |ИЗ
	               |	&ТЗ1 КАК ТЗ1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период КАК Период,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника КАК ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоговорКонтрагента КАК ДоговорКонтрагента
	               |ПОМЕСТИТЬ СрезПоследних
	               |ИЗ
	               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр.СрезПоследних(&КонецПериода, ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_СобственникиОбъектовАрендыСпрСрезПоследних
	               |ГДЕ
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Регистратор.СтрокаСобственник = &СтрокаСобственник
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.Период,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпрСрезПоследних.ДоговорКонтрагента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР_СобственникиОбъектовАрендыСпр.ДоляСобственника КАК ДоляСобственника,
	               |	МИНИМУМ(АР_СобственникиОбъектовАрендыСпр.Период) КАК Период,
	               |	АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	НАЧАЛОПЕРИОДА(АР_СобственникиОбъектовАрендыСпр.Период, МЕСЯЦ) КАК НачалоМесяца,
	               |	КОНЕЦПЕРИОДА(АР_СобственникиОбъектовАрендыСпр.Период, МЕСЯЦ) КАК КонецМесяца
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	РегистрСведений.АР_СобственникиОбъектовАрендыСпр КАК АР_СобственникиОбъектовАрендыСпр
	               |ГДЕ
	               |	АР_СобственникиОбъектовАрендыСпр.Регистратор.СтрокаСобственник = &СтрокаСобственник
	               |	И АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_СобственникиОбъектовАрендыСпр.ДоляСобственника,
	               |	АР_СобственникиОбъектовАрендыСпр.ДоговорКонтрагента,
	               |	НАЧАЛОПЕРИОДА(АР_СобственникиОбъектовАрендыСпр.Период, МЕСЯЦ),
	               |	КОНЕЦПЕРИОДА(АР_СобственникиОбъектовАрендыСпр.Период, МЕСЯЦ)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	МИНИМУМ(ВТ.Период) КАК Период,
	               |	ВТ.ДоляСобственника КАК ДоляСобственника,
	               |	МИНИМУМ(ВТ.НачалоМесяца) КАК НачалоМесяца,
	               |	МИНИМУМ(ВТ.КонецМесяца) КАК КонецМесяца
	               |ПОМЕСТИТЬ ВТ_
	               |ИЗ
	               |	ТЗ КАК ТЗ
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ КАК ВТ
	               |		ПО ТЗ.НачалоМесяца >= ВТ.НачалоМесяца
	               |			И ТЗ.КонецМесяца <= ВТ.КонецМесяца
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ.ДоговорКонтрагента,
	               |	ВТ.ДоляСобственника
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	СрезПоследних.ДоговорКонтрагента,
	               |	СрезПоследних.Период,
	               |	СрезПоследних.ДоляСобственника,
	               |	NULL,
	               |	NULL
	               |ИЗ
	               |	СрезПоследних КАК СрезПоследних
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	МИНИМУМ(ВТ_.Период) КАК Период,
	               |	ВТ_.ДоляСобственника КАК ДоляСобственника,
	               |	МАКСИМУМ(ВТ_.НачалоМесяца) КАК НачалоМесяца,
	               |	МАКСИМУМ(ВТ_.КонецМесяца) КАК КонецМесяца
	               |ИЗ
	               |	ВТ_ КАК ВТ_
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_.ДоговорКонтрагента,
	               |	ВТ_.ДоляСобственника
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Период";
	
	Запрос.УстановитьПараметр("НачалоПериода",НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Договор);
	Запрос.УстановитьПараметр("СтрокаСобственник","Общедолевая собственность");
	
	тзПериоды1 = Новый ТаблицаЗначений;
	тзПериоды1.Колонки.Добавить("НачалоМесяца",Новый ОписаниеТипов("Дата"));
	тзПериоды1.Колонки.Добавить("КонецМесяца",Новый ОписаниеТипов("Дата"));
	
	НачалоМесяца_ = 0;
	Для Сч = 0 По тзПериоды.Количество()-1 Цикл
		НоваяСтрока = тзПериоды1.Добавить();
		НоваяСтрока.НачалоМесяца = тзПериоды[Сч].НачалоМесяца;
		НоваяСтрока.КонецМесяца = тзПериоды[Сч].КонецМесяца;
		Если НачалоМесяца_ <> 0 и НачалоМесяца_ < тзПериоды[Сч].НачалоМесяца Тогда
			НоваяСтрока = тзПериоды1.Добавить();
			НоваяСтрока.НачалоМесяца = КонецМесяца(НачалоМесяца_)+1;
			НоваяСтрока.КонецМесяца = КонецМесяца(НоваяСтрока.НачалоМесяца);
		КонецЕсли;	
		НачалоМесяца_ = тзПериоды[Сч].НачалоМесяца;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТЗ1",тзПериоды1); 
	//-
	
	Выборка = Запрос.Выполнить().Выбрать();
	тзВыгрузка = Запрос.Выполнить().Выгрузить();
	//
	тзВыгрузка.Колонки.Добавить("КоличествоДнейОплата",Новый ОписаниеТипов("Число"));
	тзВыгрузка.Колонки.Добавить("КоличествоДнейМесяцаОплата",Новый ОписаниеТипов("Число"));
	//
	тзВыгрузка.Колонки.Добавить("Период2",Новый ОписаниеТипов("Дата"));
	тзВыгрузка.ЗагрузитьКолонку(тзВыгрузка.ВыгрузитьКолонку("Период"),"Период2");
	Для Каждого СтрВ Из тзВыгрузка Цикл
		Если СтрВ.НачалоМесяца = NULL Тогда
			//СтрВ.НачалоМесяца = НачалоМесяца(НачалоПериода);
			СтрВ.НачалоМесяца = НачалоМесяца(СтрВ.Период);
		КонецЕсли;
		Если СтрВ.КонецМесяца = NULL Тогда
			//СтрВ.КонецМесяца = КонецМесяца(НачалоПериода);
			СтрВ.КонецМесяца = КонецМесяца(СтрВ.Период);
		КонецЕсли;
		Если СтрВ.Период < СтрВ.НачалоМесяца Тогда
			СтрВ.Период = СтрВ.НачалоМесяца;		
		КонецЕсли;
		СтрВ.КоличествоДнейМесяцаОплата = Число(Лев(КонецМесяца(СтрВ.КонецМесяца),2));
	КонецЦикла;	
	
	Если тзПериоды.Количество() > 0 Тогда
		
		Выгрузка = тзВыгрузка.Скопировать();
		
		Построитель = Новый ПостроительЗапроса;
		Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(тзВыгрузка);

		тОтбор = Построитель.Отбор.Добавить("Период");
		тОтбор.ВидСравнения = ВидСравнения.БольшеИлиРавно;
		тОтбор.Значение = тзПериоды[0].НачалоМесяца; //НачалоПериода;
		тОтбор.Использование = Истина;

		Построитель.Выполнить();
		Выгрузка = Построитель.Результат.Выгрузить();
		
		// + NAI Becar Комментирование Смирнов А.А. от 29.07.2019 10:50
		Если Выгрузка.Количество()>0 Тогда
			Если Выгрузка[0].Период > Выгрузка[0].НачалоМесяца Тогда
				Отбор = Новый Структура;
			    Отбор.Вставить("Период", Выгрузка[0].Период);
			    Строки = тзВыгрузка.НайтиСтроки(Отбор);
				СтрВыгрузка = Выгрузка.Добавить();
				ЗаполнитьЗначенияСвойств(СтрВыгрузка,?(тзВыгрузка.Количество()=1,тзВыгрузка[0], ?(Строки.Количество()=1,тзВыгрузка[0],тзВыгрузка[тзВыгрузка.Индекс(Строки[0])-1])));
				Выгрузка.Сортировать("Период");
				СтрВыгрузка = Выгрузка[0];
				СтрВыгрузка.НачалоМесяца = ?(тзВыгрузка.Количество()=1,тзВыгрузка[0].НачалоМесяца,тзВыгрузка[1].НачалоМесяца);
				СтрВыгрузка.КонецМесяца = ?(тзВыгрузка.Количество()=1,тзВыгрузка[0].КонецМесяца,тзВыгрузка[1].КонецМесяца);
				Выгрузка[0].Период = Выгрузка[1].Период;
				Выгрузка[0].Период2 = Выгрузка[1].Период2;
				Выгрузка[0].КоличествоДнейМесяцаОплата = Выгрузка[1].КоличествоДнейМесяцаОплата;
			КонецЕсли;
		КонецЕсли;
		// - NAI Becar Комментирование Смирнов А.А.. от 29.07.2019 10:50
		
		к=0;
		
		Выгрузка.Колонки.Добавить("Начислено");
		Выгрузка.ЗаполнитьЗначения(Ложь, "Начислено");
		Выгрузка.Колонки.Добавить("КоличествоДней");
		Выгрузка.Колонки.Добавить("КоличествоДнейВМесяце");
			
 		Для Каждого Стр Из Выгрузка Цикл
			
			Если Стр.Период2<КонецДня(ОкончаниеПериода) и (Стр.Период2>НачалоПериода) Тогда 
				Стр.Начислено = Истина; 
			КонецЕсли; 

			Выгрузка[к].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
			Если КонецДня(Стр.Период) = тзВыгрузка[тзВыгрузка.Количество()-1].КонецМесяца Тогда 
				Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
				Прервать; 
			КонецЕсли;
			
			Если КонецДня(Выгрузка[к].Период) = КонецМесяца(Выгрузка[к].Период) Тогда
				Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
			Иначе
				Если (Выгрузка.Количество() = к+1) и ((Выгрузка[к].Период > Выгрузка[к].НачалоМесяца)и(Выгрузка[к].Период)<НачалоМесяца(ОкончаниеПериода)) Тогда
					ДоляСобственника_=Выгрузка[к].ДоляСобственника;
					//Выгрузка[к].ДоляСобственника=тзВыгрузка[0].ДоляСобственника;
					Выгрузка[к].ДоляСобственника=Выгрузка[к-1].ДоляСобственника;
					Выгрузка[к].КоличествоДнейОплата = (КонецДня(Выгрузка[к].Период)+1 - НачалоДня(Выгрузка[к].НачалоМесяца)-86400)/86400;
					Выгрузка[к].КоличествоДней = Выгрузка[к].КоличествоДнейОплата;
					
					НовСтр = Выгрузка.Добавить();
					НовСтр.ДоляСобственника=ДоляСобственника_;
					НовСтр.КоличествоДнейОплата=((КонецДня(Выгрузка[к].КонецМесяца)+1 - НачалоДня(Выгрузка[к].Период-1)) -86400)/86400;
					НовСтр.КоличествоДнейМесяцаОплата=Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					НовСтр.КоличествоДней=((КонецДня(Выгрузка[к].КонецМесяца)+1 - НачалоДня(Выгрузка[к].Период-1)) -86400)/86400;
					НовСтр.КоличествоДнейВМесяце=Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					НовСтр.НачалоМесяца = Выгрузка[к].НачалоМесяца;
					НовСтр.КонецМесяца = Выгрузка[к].КонецМесяца;
					НовСтр.Период = Выгрузка[к].КонецМесяца;
					НовСтр.Период2 = Выгрузка[к].КонецМесяца;
					НовСтр.Начислено = Истина;
					Если (к<>0 и Выгрузка[к-1].Период=Выгрузка[к-1].НачалоМесяца и Выгрузка[к-1].Период=Выгрузка[к-1].НачалоМесяца) Тогда
						Выгрузка.Удалить(Выгрузка[к-1]);
					КонецЕсли;
					
					Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
					Если (Выгрузка[к].Период)<НачалоМесяца(ОкончаниеПериода) Тогда
						Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Выгрузка[к].Период),2)); //Число(Лев(КонецМесяца(ОкончаниеПериода),2));
					КонецЕсли;
				Иначе	
					//Денис++
					Если стр.Период > НачалоПериода Тогда
						Выгрузка[к].КоличествоДней = окр((КонецМесяца(Стр.КонецМесяца) - стр.Период) /60/60/24,0);
						//Выгрузка[к].КоличествоДнейОплата = Выгрузка[к].КоличествоДней;
						Выгрузка[к].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						Если к > 0 Тогда
							Выгрузка[к-1].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2)) - Выгрузка[к].КоличествоДней;// - 1;
							//Выгрузка[к-1].КоличествоДней = Выгрузка[к-1].КоличествоДней - Выгрузка[к].КоличествоДней - 1;
							Выгрузка[к-1].Начислено = Истина;
							//Выгрузка[к-1].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
							//Выгрузка[к-1].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2)) - Выгрузка[к].КоличествоДней;// - 1;
							Выгрузка[к-1].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						КонецЕсли;
					Иначе		
						Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						Выгрузка[к].КоличествоДнейОплата = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
						//Выгрузка[к].КоличествоДнейВМесяце = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
					КонецЕсли;
					//Денис--
					//Выгрузка[к].КоличествоДней = Число(Лев(КонецМесяца(Стр.КонецМесяца),2));
					Если Выгрузка.Количество() = к+1 Тогда
						Выгрузка[к].Начислено = Истина;//Стр.Начислено;
					КонецЕсли;	
				КонецЕсли;	
				
			КонецЕсли;
			
			к=к+1;
		КонецЦикла;
		
		к=0;
		Для Каждого Стр Из Выгрузка Цикл
			Если к<>0 и Выгрузка[к].ДоляСобственника = Выгрузка[к-1].ДоляСобственника Тогда
				Выгрузка[к].КоличествоДнейОплата = Число(Лев(КонецМесяца(Выгрузка[к].Период),2));
				Выгрузка.Удалить(Выгрузка[к-1]);
			КонецЕсли;
		к=к+1;
		КонецЦикла;

	КонецЕсли;	
	
	Возврат Выгрузка;
	
КонецФункции	

