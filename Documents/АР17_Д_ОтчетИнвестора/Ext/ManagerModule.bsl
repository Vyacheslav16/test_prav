Функция ПолучитьДоки(Организация,Период,ДоговорКонтрагента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Хозрасчетный.Регистратор КАК Регистратор,
	               |	СУММА(Хозрасчетный.Сумма) КАК Сумма,
	               |	Хозрасчетный.Период КАК Период
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	               |ГДЕ
	               |	Хозрасчетный.СчетДт = &СчетДт
	               |	И Хозрасчетный.СчетКт = &СчетКт
	               |	И Хозрасчетный.Организация = &Организация
	               |	И Хозрасчетный.Регистратор.ДоговорКонтрагента = &ДоговорКонтрагента
	               |	И Хозрасчетный.Период >= &НачалоПериода
	               |	И Хозрасчетный.Период <= &КонецПериода
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Хозрасчетный.Регистратор,
	               |	Хозрасчетный.Период";
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
	Запрос.УстановитьПараметр("НачалоПериода",НачалоМесяца(Период));
	Запрос.УстановитьПараметр("КонецПериода",КонецМесяца(Период));
	Запрос.УстановитьПараметр("СчетДт",ПланыСчетов.Хозрасчетный.НайтиПоКоду("76.06"));
	Запрос.УстановитьПараметр("СчетКт",ПланыСчетов.Хозрасчетный.НайтиПоКоду("51"));
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции
	
Функция ПолучитьВознагрождениеАгента(Договор,Период)
	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(ОтчетКомитентуОПродажах.СуммаВознаграждения) КАК СуммаВознаграждения,
	               |	ОтчетКомитентуОПродажах.ПроцентКомиссионногоВознаграждения КАК ПроцентКомиссионногоВознаграждения
	               |ИЗ
	               |	Документ.ОтчетКомитентуОПродажах КАК ОтчетКомитентуОПродажах
	               |ГДЕ
	               |	ОтчетКомитентуОПродажах.Дата <= &ДатаК
	               |	И ОтчетКомитентуОПродажах.ДоговорКонтрагента = &Ссылка
	               |	И ОтчетКомитентуОПродажах.Дата >= &ДатаН
	               |	И ОтчетКомитентуОПродажах.ПометкаУдаления = ЛОЖЬ
	               |	И ОтчетКомитентуОПродажах.Проведен = ИСТИНА
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ОтчетКомитентуОПродажах.ПроцентКомиссионногоВознаграждения";
	Запрос.УстановитьПараметр("ДатаН",НачалоМесяца(Период));
	Запрос.УстановитьПараметр("ДатаК",КонецМесяца(Период));
	Запрос.УстановитьПараметр("Ссылка",Договор);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() > 0 Тогда
		Возврат Рез[0];
	Иначе Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ЮнитПрописью(Количество)
	КоличествоП = Прав(Строка(Количество),1);
	Если КоличествоП = "1" Тогда
		Возврат "юнит";
	ИначеЕсли КоличествоП = "2" ИЛИ КоличествоП = "3" ИЛИ КоличествоП = "4" Тогда
		Возврат "юнита";
	Иначе
		Возврат "юнитов";
	КонецЕсли;		
КонецФункции

Функция МесяцСтрокой(Месяц)
	Если Месяц = 1 Тогда
		Возврат "январе ";
	ИначеЕсли Месяц = 2 Тогда
		Возврат "феврале ";
	ИначеЕсли Месяц = 3 Тогда
		Возврат "марте ";
	ИначеЕсли Месяц = 4 Тогда
		Возврат "апреле ";
	ИначеЕсли Месяц = 5 Тогда
		Возврат "мае ";
	ИначеЕсли Месяц = 6 Тогда
		Возврат "июне ";
	ИначеЕсли Месяц = 7 Тогда
		Возврат "июле ";
	ИначеЕсли Месяц = 8 Тогда
		Возврат "августе ";
	ИначеЕсли Месяц = 9 Тогда
		Возврат "сентябре ";
	ИначеЕсли Месяц = 10 Тогда
		Возврат "октябре ";
	ИначеЕсли Месяц = 11 Тогда
		Возврат "ноябре ";
	Иначе
		Возврат "декабре";
	КонецЕсли;		
КонецФункции

Функция МесяцСтрокой2(Месяц)
	Если Месяц = 1 Тогда
		Возврат " месяц";
	ИначеЕсли Месяц = 2 ИЛИ Месяц = 3 ИЛИ Месяц = 4 Тогда
		Возврат " месяца";
	Иначе
		Возврат " месяцев";
	КонецЕсли;		
КонецФункции

