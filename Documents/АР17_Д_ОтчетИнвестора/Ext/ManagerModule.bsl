	ШапкаАкта			 = Макет.ПолучитьОбласть("ШапкаАкта");
	ШапкаАкта.Параметры.Номер 	= Стр.Номер;
	ШапкаАкта.Параметры.Дата = Формат(Стр.Период, "ДФ=dd.MM.yyyy");
