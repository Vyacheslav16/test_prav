Функция СформироватьПечатнуюФормуОтчетаСмайл(МассивСсылок) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	//ТабличныйДокумент.ФоноваяКартинка = БиблиотекаКартинок.ОтчетИнвестора;
	//ТабличныйДокумент.ФоноваяКартинка. = Новый Картинка(БиблиотекаКартинок.ОтчетИнвестора);
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_ЗаявкаНаРасходованиеСредств_ЗаявкаНаОплату";
	
	Если МассивСсылок.Количество() > 0 Тогда
		
		Макет = Документы.АР17_Д_ОтчетИнвестора.ПолучитьМакет("МакетСмайл");
		Шапка			 = Макет.ПолучитьОбласть("Шапка");
		ПервыйДокумент   = Истина;
		Для каждого ВыборкаИзЗапроса ИЗ МассивСсылок Цикл 
			ТекДокумент = ВыборкаИзЗапроса.Ссылка;
			Отбор = Новый Структура;
			Отбор.Вставить("Ссылка", ТекДокумент);
			ОбщП = Строка(ВыборкаИзЗапроса.ПлощадьПоОтчетуАгента);
			//Если ТипЗнч(ВыборкаИзЗапроса.Основание) = Тип("ДокументСсылка.С_ОтчетАгента") Тогда
			//	ОбщП = Строка(ВыборкаИзЗапроса.Основание.ОбъектыПринципала.Итог("Площадь"));
			//КонецЕсли;
			
			Шапка.Рисунки.Номер.Текст = "Договор " + ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента.Номер;
			Шапка.Рисунки.Шапка2.Текст = "S=" + ОбщП + " кв.м";
			Шапка.Рисунки.Шапка3.Текст = "Дата инвестиций: " + Формат(ВыборкаИзЗапроса.ДоговорИнвестора.Дата, "ДЛФ= ДД") + Символы.ПС 
			+ "Текущая стоимость: " + Строка(ВыборкаИзЗапроса.ТекущаяСтоимость) + " ₽" + Символы.ПС
			+ "Ваши инвестиции: " + Строка(ВыборкаИзЗапроса.ДоговорИнвестора.СуммаДоговора) + " ₽" + Символы.ПС
			+ "Капитализация: " + Строка(ВыборкаИзЗапроса.Капитализация) + " ₽";

			Шапка.Рисунки.Доход.Текст = Строка(ВыборкаИзЗапроса.СовокупныйДоход) + " ₽";
			Шапка.Рисунки.ДоходК.Текст = Строка(ВыборкаИзЗапроса.ДоходСКапитализацией) + " ₽";
			Шапка.Рисунки.ДоходП.Текст = Строка(ВыборкаИзЗапроса.СовокупныйДоходДинамика) + "%";
			Шапка.Рисунки.ДоходКП.Текст = Строка(ВыборкаИзЗапроса.ДоходСКапитализациейДинамика) + "%";
			
			ВОФ =(ВыборкаИзЗапроса.ВыручкаПоПомещению+ВыборкаИзЗапроса.ВыручкаПоМОП);
			ВОП =(ВыборкаИзЗапроса.ВыручкаПоПомещениюПлан+ВыборкаИзЗапроса.ВыручкаПоМОППлан);
			
			Шапка.Рисунки.ПосещаемостьПериодПлан.Текст =Формат(ВыборкаИзЗапроса.ПосещаемостьПериодПлан,"ДФ='ММ"".""гггг'"); 
			Шапка.Рисунки.ПосещаемостьПериод.Текст =Формат(ВыборкаИзЗапроса.ПосещаемостьПериод,"ДФ='ММ"".""гггг'"); 
			
			УстановитьФинПокиВМакет(Шапка,"Выручка", Новый Структура("П,Ф,Д",ВОП,ВОФ,РассчитатьПоказательДинамики(ВОФ, ВОП,ВыборкаИзЗапроса)));
			УстановитьФинПокиВМакет(Шапка,"ВыручкаПом", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.ВыручкаПоПомещениюПлан,ВыборкаИзЗапроса.ВыручкаПоПомещению,ВыборкаИзЗапроса.ВыручкаПоПомещениюДинамика));
			УстановитьФинПокиВМакет(Шапка,"ВыручкаМОП", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.ВыручкаПоМОППлан,ВыборкаИзЗапроса.ВыручкаПоМОП,ВыборкаИзЗапроса.ВыручкаПоМОПДинамика));
			УстановитьФинПокиВМакет(Шапка,"РасходыИнв", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.РасходыИнвестораПлан,ВыборкаИзЗапроса.РасходыИнвестора,ВыборкаИзЗапроса.РасходыИнвестораДинамика));
			УстановитьФинПокиВМакет(Шапка,"РасходыУслугиУК", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.РасходыУслугиУКПлан,ВыборкаИзЗапроса.РасходыУслугиУК,ВыборкаИзЗапроса.РасходыУслугиУКДинамика));
			УстановитьФинПокиВМакет(Шапка,"РасходыВозм", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.РасходыВозмещаемыеПлан,ВыборкаИзЗапроса.РасходыВозмещаемые,ВыборкаИзЗапроса.РасходыВозмещаемыеДинамика));
			УстановитьФинПокиВМакет(Шапка,"ЧистыйДоходМ", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.ЧистыйДоходПлан,ВыборкаИзЗапроса.ЧистыйДоход,ВыборкаИзЗапроса.ЧистыйДоходДинамика));
			УстановитьФинПокиВМакет(Шапка,"Посещаемость", Новый Структура("П,Ф,Д",ВыборкаИзЗапроса.ПосещаемостьПлан,ВыборкаИзЗапроса.Посещаемость,ВыборкаИзЗапроса.ПосещаемостьДинамика),Ложь," чел");
			
			Если Шапка.Рисунки.План.Ширина * ВыборкаИзЗапроса.ЧистыйДоходИтогДинамика / 100 > Шапка.Рисунки.Факт.Ширина Тогда
				Шапка.Рисунки.План.Ширина = Шапка.Рисунки.Факт.Ширина * 100 / ВыборкаИзЗапроса.ЧистыйДоходИтогДинамика;
			Иначе
				Шапка.Рисунки.Факт.Ширина = Шапка.Рисунки.План.Ширина * ВыборкаИзЗапроса.ЧистыйДоходИтогДинамика / 100; 
			КонецЕсли;
			
			
			Шапка.Рисунки.Адрес.Текст = Строка(ВыборкаИзЗапроса.ИК.Адрес);
			
			Шапка.Рисунки.ЧДТ.Текст = "Чистый доход нарастающим итогом за " + Месяц(ВыборкаИзЗапроса.Период) + МесяцСтрокой2(Месяц(ВыборкаИзЗапроса.Период));
			
			Шапка.Рисунки.ЧистыйДоход.Текст = Строка(ВыборкаИзЗапроса.ЧистыйДоходИтогПлан) + " ₽";
			Шапка.Рисунки.ЧистыйДоходФ.Текст = Строка(ВыборкаИзЗапроса.ЧистыйДоходИтог) + " ₽";
			Шапка.Рисунки.ФактИтог.Текст = "Факт" + Символы.ПС + Строка(ВыборкаИзЗапроса.ЧистыйДоходИтогДинамика) + "%";
			
			Шапка.Рисунки.Шапка5.Текст = "Доход в " + МесяцСтрокой(Месяц(ВыборкаИзЗапроса.Период)) + СтрЗаменить(Строка(Год(ВыборкаИзЗапроса.Период)),Символы.НПП,"");

			Шапка.Рисунки.КомментУК.Текст = ПолучитьКомментарийУК(ВыборкаИзЗапроса.Ссылка);
			
			ТабличныйДокумент.Вывести(Шапка);
			
		КонецЦикла; 
	КонецЕсли;
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	ТабличныйДокумент.Защита = Истина;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ПолучитьКомментарийУК(Док)
	
	КомСт = "* средняя стоимость номера за выбранный промежуток времени. Рассчитывается делением чистой
	|выручки от продаж номерного фонда (после вычета скидок, косвенных налогов, стоимости
	|завтраков и т.п.) на общее количество проданных за рассматриваемый период номеров.
	|Показатель отображает процент загрузки номеров в гостинице. ";
	Если Не ЗначениеЗаполнено(Док.ДоговорИнвестора) Тогда
		Возврат КомСт;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору.КомментарийДляОтчетаИнвестору КАК КомментарийДляОтчетаИнвестору
	|ИЗ
	|	Документ.С_УстановкаПлановыхПоказателейДляОтчетаИнвестору.ПланПоДоговору КАК С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору
	|ГДЕ
	|	С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору.ЗаключениеАгентскогоДоговора = &ЗаключениеАгентскогоДоговора
	|	И С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору.Ссылка.Дата <= &ДатаН
	|	И С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору.Ссылка.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	С_УстановкаПлановыхПоказателейДляОтчетаИнвесторуПланПоДоговору.Ссылка.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("ДатаН", Док.Период);
	Запрос.УстановитьПараметр("ЗаключениеАгентскогоДоговора", Док.ДоговорИнвестора); 
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.КомментарийДляОтчетаИнвестору;
	Иначе
		Возврат КомСт;
	КонецЕсли;
	
КонецФункции


Функция РассчитатьПоказательДинамики(МетаФакт, МетаПлан,Сс)
	
	Если МетаПлан = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	А = (МетаФакт - МетаПлан) / Макс(МетаПлан,- МетаПлан) * 100;
	Возврат А;

КонецФункции

Процедура УстановитьФинПокиВМакет(Обл,Маска,Стрт,ВыводВалюты=Истина,ЕдИзм="")
	Если ВыводВалюты Тогда
		Обл.Рисунки[(Маска+"П")].Текст = Строка(Стрт.П) + " ₽";
		Обл.Рисунки[(Маска+"Ф")].Текст = Строка(Стрт.Ф) + " ₽";
	Иначе
		Обл.Рисунки[(Маска+"П")].Текст = Строка(Стрт.П)+ЕдИзм;
		Обл.Рисунки[(Маска+"Ф")].Текст = Строка(Стрт.Ф)+ЕдИзм;
	КонецЕсли;
	Если Стрт.Д > 0 Тогда
		Обл.Рисунки[(Маска+"Д")].ЦветТекста = Новый Цвет(118, 215, 58);
		Обл.Рисунки[(Маска+"Д")].Текст = Строка(Формат(Стрт.Д, "ЧДЦ=0")) + "%";
		Обл.Рисунки[(Маска+"Л")].Картинка = БиблиотекаКартинок.СтрелкаПлюс;
	Иначе
		Обл.Рисунки[(Маска+"Д")].ЦветТекста = Новый Цвет(239, 83, 73);
		Обл.Рисунки[(Маска+"Д")].Текст = Строка(Формат(Стрт.Д, "ЧДЦ=0")) + "%";
		Обл.Рисунки[(Маска+"Л")].Картинка = БиблиотекаКартинок.СтрелкаМинус;
	КонецЕсли;

КонецПроцедуры

