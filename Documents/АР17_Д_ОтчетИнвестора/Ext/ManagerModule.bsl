			Шапка.Параметры.Договор			= СокрЛП(Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер) + " от " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy");
			Шапка.Параметры.Объект	 	= Стр.Помещение;
			Шапка.Параметры.ОбщаяПлощадь = Стр.Помещение.ОбщаяПлощадь;
			Шапка.Параметры.СуммаПрописью = ЧислоПрописью(Стр.ДоходЗаОтчетныйПериод, "Л = ru_RU; ДП = Истина", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
			Шапка.Параметры.Дата1 = Формат(Стр.Период, "ДФ=dd.MM.yyyy");

			
			ТабличныйДокумент.Вывести(Шапка); 

		//КонецЕсли;	
	КонецЦикла;
	
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	ТабличныйДокумент.Защита = Истина;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуЗаявкиНаОплату()


Функция СформироватьПечатнуюФормуОтчетаСводный(МассивСсылок) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	//ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_ЗаявкаНаРасходованиеСредств_ЗаявкаНаОплату";
	//Для Каждого Стр из МассивСсылок Цикл
	//	Если Стр.Период <= Дата('20240601') Тогда
	//		ТабличныйДокумент = СформироватьПечатнуюФормуОтчетаВалоНов(Стр);
	//	Иначе
			Стр = МассивСсылок[0];
			Макет = Документы.АР17_Д_ОтчетИнвестора.ПолучитьМакет("Отчет"); 
			
			Шапка			 		= Макет.ПолучитьОбласть("Шапка");
			Шапка.Параметры.Номер 	= Стр.Номер;
			Шапка.Параметры.Дата 	= Формат(Стр.Период, "ДФ=dd.MM.yyyy");
			ТабличныйДокумент.Вывести(Шапка); 

			Шапка2			 				= Макет.ПолучитьОбласть("Шапка2");
			Шапка2.Параметры.Организация 	= Стр.ДоговорИнвестора.Организация.НаименованиеСокращенное;
			ОтветственныеЛица 				= ОтветственныеЛицаБП.ОтветственныеЛица(Стр.ДоговорИнвестора.Организация, Стр.Дата);
			
			Организация_Руководитель 				= ОтветственныеЛица.Руководитель;
			Организация_Руководитель_ФИО_ИменП		= Организация_Руководитель.ФИО;
			Пол = ?(Организация_Руководитель.Пол	= Перечисления.ПолФизическогоЛица.Женский,2,1);
			Организация_Руководитель_ФИО_РодП 		= Организация_Руководитель_ФИО_ИменП;
			Организация_Руководитель_ФИО_РодП		= СклонениеФИО(Организация_Руководитель_ФИО_РодП,2,Пол);
			Шапка2.Параметры.Руководитель 			= ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Организация_Руководитель_ФИО_РодП);
			Шапка2.Параметры.Принципал				= Стр.ДоговорИнвестора.Контрагент.Наименование;
			Шапка2.Параметры.Период					= Формат(Стр.Период, "ДФ='MMM  yyyy'");
			ТабличныйДокумент.Вывести(Шапка2); 
			
			ШапкаТаблицы	= Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабличныйДокумент.Вывести(ШапкаТаблицы);
			Оснощ = 0;
			Итог = 0; 
			ПлощадьПом = 0;
			ДоляВКотле = 0;
			Для Каждого отч Из МассивСсылок Цикл
				СтрокаТаблицы	= Макет.ПолучитьОбласть("СтрокаТаблицы");
				СтрокаТаблицы.Параметры.НомерПИБ 				= отч.Помещение.ПомещениеНомерБТИ;
				СтрокаТаблицы.Параметры.НомерДоговора			= СокрЛП(отч.ДоговорИнвестора.ДоговорКонтрагента.Номер) + " от " + Формат(отч.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy");
				СтрокаТаблицы.Параметры.ПрограммаДоходности		= отч.ДоговорИнвестора.ПрограммаДоходности;
				СтрокаТаблицы.Параметры.ДоходРасходПринципала 	= отч.ЧистыйДоход;
				Если СокрЛП(Стр.ДоговорИнвестора.ПрограммаДоходности) = "ПД Прогрессивная- К" Тогда
					СтрокаТаблицы.Параметры.ПрограммаДоходности		= "ПД Прогрессивная- К (" + СокрЛП(отч.КоличествоВсехКотлов) + " участн. котла)";
				ИначеЕсли Найти(Стр.ДоговорИнвестора.ПрограммаДоходности, "Гарант")>0 Тогда
					СтрокаТаблицы.Параметры.ПрограммаДоходности		= СокрЛП(отч.ДоговорИнвестора.ПрограммаДоходности) + " (Гарантированный доход - " + СТРОКА(отч.ЧистыйДоход) + ")";
					СтрокаТаблицы.Параметры.ДоходРасходПринципала = отч.ЧистыйДоход;
				КонецЕсли;	
				СтрокаТаблицы.Параметры.ПолученныйДоход 		= отч.ВыручкаНомера; /// выручка номера
				СтрокаТаблицы.Параметры.ГостиничныеРасходы 		= отч.РасходыВозмещаемые;//ПолучитьГР(Стр); //Стр.  // реализация на собственника
				СтрокаТаблицы.Параметры.РасходыНаКУ 			= отч.КУ; // из квитанции коммуналка
				СтрокаТаблицы.Параметры.ВозмещеноКУ 			= ?(отч.ДоговорИнвестора.ПрограммаДоходности.Компенсировать,ПолучитьКУ(отч),0);
				СтрокаТаблицы.Параметры.СуммаАренднойСтавки 	= отч.СреднийТариф;
				СтрокаТаблицы.Параметры.ВознаграждениеУК 		= отч.РасходыУслугиУК;
				ТабличныйДокумент.Вывести(СтрокаТаблицы);  
				Если отч.Оснащение > 0 Тогда     
					Оснощ = Оснощ + отч.Оснащение;
				КонецЕсли;
				Итог = Итог + отч.ЧистыйДоход; 
				ПлощадьПом = ПлощадьПом + Стр.Помещение.ОбщаяПлощадь;
				ДоляВКотле = ДоляВКотле + Стр.ДоляПомещения;
			КонецЦикла;
			Итого			= Макет.ПолучитьОбласть("Итого");
			Итого.Параметры.Итого 	= "Итого: " + Строка(?(Итог - Оснощ >0,Итог - Оснощ,0)) + " руб.";
			ТабличныйДокумент.Вывести(Итого);
			
			Если НЕ СокрЛП(стр.Комментарий) = "" Тогда
				Комментарий			= Макет.ПолучитьОбласть("Комментарий");
				Комментарий.Параметры.Комментарий 	=стр.Комментарий;
				ТабличныйДокумент.Вывести(Комментарий);
			КонецЕсли;	
			Подвал			 = Макет.ПолучитьОбласть("Подвал");
			Подвал.Параметры.ЧетвертыйПункт 	= "4. Сумма к перечислению на р/счет Принципала составляет " + ?(Итог - Оснощ >0, Итог - Оснощ, 0) + " (" +
								ЧислоПрописью(?(Итог - Оснощ>0,Итог - Оснощ,0), "Л=ru_RU;ДП=Истина", "рубль,рубля,рублей,м,копейка,копейки,копеек,ж,2") + ")";
			Подвал.Параметры.КолВоУчастников = Стр.КоличествоВсехКотлов;					
			Подвал.Параметры.ПлощадьКотла = ?(Стр.ПлощадьКотла = 0, ПлощадьПом, Стр.ПлощадьКотла);					
			Подвал.Параметры.ПлощадьПомещения = ПлощадьПом;					
			Подвал.Параметры.ДоляВКотле = ДоляВКотле;					
			Если Стр.Оснащение > 0 Тогда     
				Подвал.Параметры.ДоговорО = "";
				Подвал.Параметры.СуммаУО = Оснощ;
			КонецЕсли;	
			ТабличныйДокумент.Вывести(Подвал);
			
			Подписи			 = Макет.ПолучитьОбласть("Подписи");
			Подписи.Параметры.Руководитель 	= ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ОтветственныеЛица.Руководитель); 
			Подписи.Параметры.Принципал		= Стр.ДоговорИнвестора.Контрагент.Наименование;
			ТабличныйДокумент.Вывести(Подписи); 
			
			// акт
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
			ШапкаАкта			 = Макет.ПолучитьОбласть("ШапкаАкта");
			ШапкаАкта.Параметры.Номер 	= Стр.Номер;
			ШапкаАкта.Параметры.Дата = Формат(Стр.Период, "ДФ=dd.MM.yyyy");
			Орг = Стр.ДоговорИнвестора.Организация;
			ТабКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Орг,Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,Стр.Период,Ложь);
			Если ТабКИ.Количество() > 0 Тогда
				Адрес = ТабКИ[0].Представление;
			КонецЕсли;
			ШапкаАкта.Параметры.Агент 	= Орг.НаименованиеСокращенное + ", ИНН " + Орг.ИНН + ", " + Адрес + ", р/с " + Орг.ОсновнойБанковскийСчет
				+ ", в банке " + Орг.ОсновнойБанковскийСчет.Банк.Наименование + ", БИК " + Орг.ОсновнойБанковскийСчет.Банк.Код + ", к/с " + Орг.ОсновнойБанковскийСчет.Банк.КоррСчет;
				
			Кон	= Стр.ДоговорИнвестора.Контрагент;
			ШапкаАкта.Параметры.Принципал = Кон.Наименование + Символы.ПС 
				+ ?(СокрЛП(Кон.ДокументУдостоверяющийЛичность)="Выдан: Дата выдачи: Код подр:","",Кон.ДокументУдостоверяющийЛичность);
				
			ШапкаАкта.Параметры.Услуга1 = "Вознаграждение Агента за оказание услуг по управлению зданием за " + Формат(Стр.Период, "ДФ='MMM  yyyy'") 
				+ " по адресу: " + " в отношении помещения №" + Стр.Помещение.Наименование + " по договору от  " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy") + " № " + Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер; 
			ШапкаАкта.Параметры.Сумма1 = ПолучитьСумму(Стр.Период,Стр.ДоговорИнвестора.ДоговорКонтрагента);
			
			ШапкаАкта.Параметры.Услуга2 = "Вознаграждение Агента за оказание услуг по управлению помещением за " + Формат(Стр.Период, "ДФ='MMM  yyyy'") 
				+ " по адресу: " + " в отношении помещения №" + Стр.Помещение.Наименование + " по договору от  " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy") + " № " + Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер; 
			ШапкаАкта.Параметры.Сумма2 = Стр.РасходыУслугиУК;
			
