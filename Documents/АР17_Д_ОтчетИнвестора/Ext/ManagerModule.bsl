	               |	-КорректировкаДолгаДебиторскаяЗадолженность.СуммаВзаиморасчетов,
	               |	КорректировкаДолгаДебиторскаяЗадолженность.Ссылка
	               |ИЗ
	               |	Документ.КорректировкаДолга.ДебиторскаяЗадолженность КАК КорректировкаДолгаДебиторскаяЗадолженность
	               |ГДЕ
	               |	КорректировкаДолгаДебиторскаяЗадолженность.Ссылка.Дата >= &ДатаН
	               |	И КорректировкаДолгаДебиторскаяЗадолженность.Ссылка.Дата <= &ДатаК
	               |	И КорректировкаДолгаДебиторскаяЗадолженность.Ссылка.Проведен = ИСТИНА
	               |	И КорректировкаДолгаДебиторскаяЗадолженность.Ссылка.Организация = &Организация
	               |	И (КорректировкаДолгаДебиторскаяЗадолженность.ДоговорКонтрагента = &Договор
	               |			ИЛИ КорректировкаДолгаДебиторскаяЗадолженность.ДоговорКонтрагента = &ДоговорТО)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	КорректировкаДолгаКредиторскаяЗадолженность.СуммаВзаиморасчетов,
	               |	КорректировкаДолгаКредиторскаяЗадолженность.Ссылка
	               |ИЗ
	               |	Документ.КорректировкаДолга.КредиторскаяЗадолженность КАК КорректировкаДолгаКредиторскаяЗадолженность
	               |ГДЕ
	               |	КорректировкаДолгаКредиторскаяЗадолженность.Ссылка.Дата >= &ДатаН
	               |	И КорректировкаДолгаКредиторскаяЗадолженность.Ссылка.Дата <= &ДатаК
	               |	И КорректировкаДолгаКредиторскаяЗадолженность.Ссылка.Проведен = ИСТИНА
	               |	И КорректировкаДолгаКредиторскаяЗадолженность.Ссылка.Организация = &Организация
	               |	И (КорректировкаДолгаКредиторскаяЗадолженность.ДоговорКонтрагента = &Договор
	               |			ИЛИ КорректировкаДолгаКредиторскаяЗадолженность.ДоговорКонтрагента = &ДоговорТО)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ.Ссылка КАК Регистратор,
	               |	ТЗ.Ссылка.Дата КАК Период,
	               |	СУММА(ТЗ.Сумма) КАК Сумма
	               |ИЗ
	               |	ТЗ КАК ТЗ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТЗ.Ссылка,
	               |	ТЗ.Ссылка.Дата";
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("ДатаН",НачалоМесяца(Период));
	Запрос.УстановитьПараметр("ДатаК",КонецМесяца(Период));
	Запрос.УстановитьПараметр("Договор",Договор);
	Запрос.УстановитьПараметр("ДоговорТО",ДоговорТО);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() > 0 Тогда
		Возврат Рез;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

