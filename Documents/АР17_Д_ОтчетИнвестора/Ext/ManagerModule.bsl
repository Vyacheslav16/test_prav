	СтрокаТаблицы.Параметры.НомерПИБ 				= Стр.Помещение.ПомещениеНомерБТИ;
	СтрокаТаблицы.Параметры.НомерДоговора			= СокрЛП(Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер) + " от " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy");
	СтрокаТаблицы.Параметры.ПрограммаДоходности		= Стр.ДоговорИнвестора.ПрограммаДоходности;
	СтрокаТаблицы.Параметры.ДоходРасходПринципала 	= Стр.ЧистыйДоход;
	Если СокрЛП(Стр.ДоговорИнвестора.ПрограммаДоходности) = "ПД Прогрессивная- К" Тогда
		СтрокаТаблицы.Параметры.ПрограммаДоходности		= "ПД Прогрессивная- К (" + СокрЛП(Стр.КоличествоВсехКотлов) + " участн. котла)";
	ИначеЕсли Найти(Стр.ДоговорИнвестора.ПрограммаДоходности, "Гарант")>0 Тогда
		//Если Стр.ДоговорИнвестора.Дата < НачалоМесяца(Стр.Период) Тогда
		//	РазницаВДняхПред = (НачалоДня(НачалоМесяца(Стр.Период)-1) - НачалоДня(Стр.ДоговорИнвестора.Дата)) / (60 * 60 * 24) + 1;
		//	КолПред = Стр.ДоговорИнвестора.Гарантированныйдоход * РазницаВДняхПред/День(НачалоМесяца(Стр.Период)-1);
		//	КолТек = Стр.ДоговорИнвестора.Гарантированныйдоход;
		//	КолПредЧД = Стр.ЧистыйДоход * РазницаВДняхПред/День(НачалоМесяца(Стр.Период)-1);
		//	КолТекЧД = Стр.ЧистыйДоход;
		//Иначе
		//	КолПред = 0;
		//	КолПредЧД = 0;
		//	РазницаВДняхТек = (НачалоДня(КонецМесяца(Стр.Период)) - НачалоДня(Стр.ДоговорИнвестора.Дата)) / (60 * 60 * 24) + 1;
		//	КолТек = Стр.ДоговорИнвестора.Гарантированныйдоход * РазницаВДняхТек/День(КонецМесяца(Стр.Период));
		//	РазницаВДняхТек = (НачалоДня(КонецМесяца(Стр.Период)) - НачалоДня(Стр.ДоговорИнвестора.Дата)) / (60 * 60 * 24) + 1;
		//	КолТекЧД = Стр.ЧистыйДоход * РазницаВДняхТек/День(КонецМесяца(Стр.Период));
		//КонецЕсли;
		//ГД = Окр(КолПред + КолТек,2);
		//СтрокаТаблицы.Параметры.ПрограммаДоходности		= СокрЛП(Стр.ДоговорИнвестора.ПрограммаДоходности) + " (Гарантированный доход - " + ГД + ")";
		//
		//ЧД = Окр(КолПредЧД + КолТекЧД,2);
		//Если ГД > 0 Тогда
		//	ЧД = ?(ЧД > ГД,ЧД,ГД);    
		//КонецЕсли;			
		//СтрокаТаблицы.Параметры.ДоходРасходПринципала = ЧД;
		СтрокаТаблицы.Параметры.ПрограммаДоходности		= СокрЛП(Стр.ДоговорИнвестора.ПрограммаДоходности) + " (Гарантированный доход - " + СТРОКА(Стр.ЧистыйДоход) + ")";
		СтрокаТаблицы.Параметры.ДоходРасходПринципала = Стр.ЧистыйДоход;
	КонецЕсли;	
	СтрокаТаблицы.Параметры.ПолученныйДоход 		= Стр.ВыручкаНомера; /// выручка номера
	СтрокаТаблицы.Параметры.ГостиничныеРасходы 		= Стр.РасходыВозмещаемые;//ПолучитьГР(Стр); //Стр.  // реализация на собственника
	//СтрокаТаблицы.Параметры.РасходыНаКУ 			= ПолучитьКУ(Стр); // из квитанции коммуналка
	СтрокаТаблицы.Параметры.РасходыНаКУ 			= Стр.КУ; // из квитанции коммуналка
	СтрокаТаблицы.Параметры.ВозмещеноКУ 			= ?(Стр.ДоговорИнвестора.ПрограммаДоходности.Компенсировать,ПолучитьКУ(Стр),0);
	СтрокаТаблицы.Параметры.СуммаАренднойСтавки 	= Стр.СреднийТариф;
	СтрокаТаблицы.Параметры.ВознаграждениеУК 		= Стр.РасходыУслугиУК;
	//СтрокаТаблицы.Параметры.ДоходРасходПринципала 	= Стр.ЧистыйДоход;
	ТабличныйДокумент.Вывести(СтрокаТаблицы);
	Оснощ = 0;
	Если Стр.Оснащение > 0 Тогда
		Оснащение			= Макет.ПолучитьОбласть("Оснащение");
		Оснащение.Параметры.Оснащение 	= "удержание из ДП в счет погашения задолженности по договору " + Стр.ДоговорОснащения + " -" + Формат(Стр.Оснащение,"ЧДЦ=2");  
