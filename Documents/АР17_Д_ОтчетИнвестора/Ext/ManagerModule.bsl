			Шапка.Рисунки.РИФ.Текст = Строка(ВыборкаИзЗапроса.РасходыИнвестора) + " ₽";
			Если ВыборкаИзЗапроса.РасходыИнвестораДинамика < 0 Тогда
				Шапка.Рисунки.РИД.ЦветТекста = Новый Цвет(118, 215, 58);
				Шапка.Рисунки.РИД.Текст = Строка(Формат(ВыборкаИзЗапроса.РасходыИнвестораДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.РИПЛ.Картинка = БиблиотекаКартинок.СтрелкаПлюс;
			Иначе
				Шапка.Рисунки.РИД.ЦветТекста = Новый Цвет(239, 83, 73);
				Шапка.Рисунки.РИД.Текст = Строка(Формат(ВыборкаИзЗапроса.РасходыИнвестораДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.РИПЛ.Картинка = БиблиотекаКартинок.СтрелкаМинус;
			КонецЕсли;
			//Шапка.Рисунки.РИД.Текст = Строка(ВыборкаИзЗапроса.РасходыИнвестораДинамика) + "%";
			Шапка.Рисунки.ВНП.Текст = Строка(ВыборкаИзЗапроса.ВыручкаНомераПлан) + " ₽";
			Шапка.Рисунки.ВНФ.Текст = Строка(ВыборкаИзЗапроса.ВыручкаНомера) + " ₽";
			Если ВыборкаИзЗапроса.ВыручкаНомераДинамика > 0 Тогда
				Шапка.Рисунки.ВНД.ЦветТекста = Новый Цвет(118, 215, 58);
				Шапка.Рисунки.ВНД.Текст = Строка(Формат(ВыборкаИзЗапроса.ВыручкаНомераДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.ВНПЛ.Картинка = БиблиотекаКартинок.СтрелкаПлюс;
			Иначе
				Шапка.Рисунки.ВНД.ЦветТекста = Новый Цвет(239, 83, 73);
				Шапка.Рисунки.ВНД.Текст = Строка(Формат(ВыборкаИзЗапроса.ВыручкаНомераДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.ВНПЛ.Картинка = БиблиотекаКартинок.СтрелкаМинус;
			КонецЕсли;
			//Шапка.Рисунки.ВНД.Текст = Строка(ВыборкаИзЗапроса.ВыручкаНомераДинамика) + "%";
			Шапка.Рисунки.ДДП.Текст = Строка(ВыборкаИзЗапроса.ДоляДоходаВВыручкеПлан) + "%";
			Шапка.Рисунки.ДДФ.Текст = Строка(ВыборкаИзЗапроса.ДоляДоходаВВыручке) + "%";
			Если ВыборкаИзЗапроса.ДоляДоходаВВыручкеДинамика > 0 Тогда
				Шапка.Рисунки.ДДД.ЦветТекста = Новый Цвет(118, 215, 58);
				Шапка.Рисунки.ДДД.Текст = Строка(Формат(ВыборкаИзЗапроса.ДоляДоходаВВыручкеДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.ДДПЛ.Картинка = БиблиотекаКартинок.СтрелкаПлюс;
			Иначе
				Шапка.Рисунки.ДДД.ЦветТекста = Новый Цвет(239, 83, 73);
				Шапка.Рисунки.ДДД.Текст = Строка(Формат(ВыборкаИзЗапроса.ДоляДоходаВВыручкеДинамика, "ЧДЦ=0")) + "%";
				Шапка.Рисунки.ДДПЛ.Картинка = БиблиотекаКартинок.СтрелкаМинус;
			КонецЕсли;
			//Шапка.Рисунки.ДДД.Текст = Строка(ВыборкаИзЗапроса.ДоляДоходаВВыручкеДинамика) + "%";
			Шапка.Рисунки.Шапка5.Текст = "Доход в " + МесяцСтрокой(Месяц(ВыборкаИзЗапроса.Период)) + СтрЗаменить(Строка(Год(ВыборкаИзЗапроса.Период)),Символы.НПП,"");
			Шапка.Рисунки.ЧДТ.Текст = "Чистый доход нарастающим итогом за " + Месяц(ВыборкаИзЗапроса.Период) + МесяцСтрокой2(Месяц(ВыборкаИзЗапроса.Период));
			ПрисоединенныйФайл = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаИзЗапроса.ИК, "ФайлЛоготип");
			Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
				ДанныеКартинки = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл);
				ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеКартинки.СсылкаНаДвоичныеДанныеФайла);
				Шапка.Рисунки.Лого.Картинка = Новый Картинка(ДвоичныеДанныеКартинки); 
			КонецЕсли;

			ТабличныйДокумент.Вывести(Шапка);
		КонецЦикла; 
	КонецЕсли;
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	ТабличныйДокумент.Защита = Истина;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуЗаявкиНаОплату()

Функция СформироватьПечатнуюФормуОтчетаА(МассивСсылок) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_ЗаявкаНаРасходованиеСредств_ЗаявкаНаОплату";
	
	Если МассивСсылок.Количество() > 0 Тогда
		
		Макет = Документы.АР17_Д_ОтчетИнвестора.ПолучитьМакет("отчетБ");
		ПервыйДокумент   = Истина;
		Для каждого ВыборкаИзЗапроса ИЗ МассивСсылок Цикл 
			Шапка = Макет.ПолучитьОбласть("Шапка");
			ТекДокумент = ВыборкаИзЗапроса.Ссылка;
			Отбор = Новый Структура;
			Отбор.Вставить("Ссылка", ТекДокумент); 
			Руководители = ОтветственныеЛицаБП.ОтветственныеЛица(ВыборкаИзЗапроса.ДоговорИнвестора.Организация, ВыборкаИзЗапроса.Период);
			Руководитель = Руководители.РуководительПредставление;
			//Если Руководители.Руководитель.Пол = Перечисления.ПолФизическогоЛица.Мужской Тогда
			//	Пол = 1;
			//Иначе
			//	Пол = 2;
			//КонецЕсли;
			Шапка.Параметры.Приложение = "Приложение к Агентскому Договору № " + СокрЛП(ВыборкаИзЗапроса.ДоговорИнвестора.Номер) + " от " + Формат(ВыборкаИзЗапроса.ДоговорИнвестора.Дата,"ДЛФ=Д");
			Шапка.Параметры.Агент = "Агент: """ + ВыборкаИзЗапроса.ДоговорИнвестора.Организация + """ в лице " + СклонениеПредставленийОбъектов.ПросклонятьФИО(Строка(Руководители.РуководительДолжностьПредставление), 2,,1) + " " + СклонениеПредставленийОбъектов.ПросклонятьФИО(Строка(Руководители.Руководитель), 2,,1);
			Шапка.Параметры.Принципал = "Принципал: " + ВыборкаИзЗапроса.ДоговорИнвестора.Контрагент;
			Шапка.Параметры.ОбъектА = "- размещение арендаторов объекта недвижимости - нежилого помещения " + ВыборкаИзЗапроса.Помещение.Родитель + " (далее ""Объект""), находящегося по адресу: " + ВыборкаИзЗапроса.ИК.Адрес;
			Шапка.Параметры.ФинансовыйП = "Финансовые показатели за период с " + Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДЛФ=Д") + " по " + Формат(КонецМесяца(ВыборкаИзЗапроса.Период),"ДЛФ=Д");
			ПрисоединенныйФайл = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаИзЗапроса.ИК, "ФайлЛоготип");
			Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
				ДанныеКартинки = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл);
				ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеКартинки.СсылкаНаДвоичныеДанныеФайла);
				Шапка.Рисунки.Лого.Картинка = Новый Картинка(ДвоичныеДанныеКартинки); 
			КонецЕсли;
			ТабличныйДокумент.Вывести(Шапка);
			Шапка = Макет.ПолучитьОбласть("Строка1");
			Шапка.Параметры.Помещение = ВыборкаИзЗапроса.Помещение;
			Шапка.Параметры.Комната = ВыборкаИзЗапроса.Помещение.Родитель;
			Шапка.Параметры.СрАрСтавка = ВыборкаИзЗапроса.Аренда;
			Шапка.Параметры.КолНочей = Сред(ВыборкаИзЗапроса.Загрузка,Найти(ВыборкаИзЗапроса.Загрузка,"/")+1,(Найти(ВыборкаИзЗапроса.Загрузка,"дн")-1-Найти(ВыборкаИзЗапроса.Загрузка,"/")));
			Шапка.Параметры.Всего = ВыборкаИзЗапроса.ВыручкаНомера;
			ТабличныйДокумент.Вывести(Шапка);
			Шапка = Макет.ПолучитьОбласть("Шапка2");
			Пять = 0;
			ВознАгента = ПолучитьВознагрождениеАгента(ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента,ВыборкаИзЗапроса.Период);
			Если Не ВознАгента = Неопределено Тогда
				Шапка.Параметры.Процент = ВознАгента.ПроцентКомиссионногоВознаграждения;
				Шапка.Параметры.Вознагрождение = ВознАгента.СуммаВознаграждения;
				Пять = ВыборкаИзЗапроса.ВыручкаНомера - ВознАгента.СуммаВознаграждения;
				Шапка.Параметры.ВознагрождениеИтог = Пять;
			Иначе	
				Шапка.Параметры.Процент = 0;
				Шапка.Параметры.Вознагрождение = 0;
				Пять = ВыборкаИзЗапроса.ВыручкаНомера;
				Шапка.Параметры.ВознагрождениеИтог = Пять;
			КонецЕсли;
			Шапка.Параметры.Организация = ВыборкаИзЗапроса.ДоговорИнвестора.Организация;
			Шапка.Параметры.Принципал = ВыборкаИзЗапроса.ДоговорИнвестора.Контрагент;
			Шапка.Параметры.СверкаТекст = Строка(ВыборкаИзЗапроса.ДоговорИнвестора.Организация) 
					+ ", именуемое в дальнейшем ""Сторона 1"" с одной стороны и " 
					+ ВыборкаИзЗапроса.ДоговорИнвестора.Контрагент 
					+ " именуемое в дальнейшем ""Сторона 2"" с другой стороны, составили настоящий акт взаимных расчетов в том, что состояние взаимных расчетов по данным учета следующее:";							
			Шапка.Параметры.НачалоМесяца = Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДЛФ=Д");
			Шапка.Параметры.Месяц = Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДФ='ММММ yyyy'");
			//Шапка.Параметры.КолНочей = ВыборкаИзЗапроса.Загрузка;
			//Шапка.Параметры.Всего = ВыборкаИзЗапроса.ВыручкаНомера;
			НачальнаяЗадолженность = ПолучитьНачальнуюЗадолженность(ВыборкаИзЗапроса.ДоговорИнвестора.Организация,ВыборкаИзЗапроса.Период,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорТО);
			ИтогД = 0;
			ИтогК = 0;
			ОборотД1 = 0;
			ОборотК1 = 0;
			Если НачальнаяЗадолженность[0].СуммаОстаток > 0 Тогда
				Шапка.Параметры.Сторона2Д = НачальнаяЗадолженность[0].СуммаОстаток;
				ИтогД = ИтогД + НачальнаяЗадолженность[0].СуммаОстаток; 
			Иначе
				Шапка.Параметры.Сторона1К = -НачальнаяЗадолженность[0].СуммаОстаток;
				ИтогК = ИтогК + -НачальнаяЗадолженность[0].СуммаОстаток;
			КонецЕсли;	
			Шапка.Параметры.ДоходПринцПоАгДогК = Пять; 
			ОборотД1 = ПолучитьКвит(ВыборкаИзЗапроса.ДоговорИнвестора.Организация,ВыборкаИзЗапроса.Период,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорТО);
			Шапка.Параметры.КвитанцияД = ОборотД1;
			ТабличныйДокумент.Вывести(Шапка);
			
			
			МЗ = 0;
			Шапка = Макет.ПолучитьОбласть("Шапка3");
			Шапка.Параметры.ИтогОборотД = ОборотД1;
			Шапка.Параметры.ИтогОборотК = Пять;
			КонечнаяЗадолженность = ПолучитьКонечнуюЗадолженность(ВыборкаИзЗапроса.ДоговорИнвестора.Организация,ВыборкаИзЗапроса.Период,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорТО);
			МЗ = ОборотД1 - Пять;
			Если ОборотД1 - Пять > 0 Тогда
				Шапка.Параметры.СальдоЗаД = ОборотД1 - Пять;
			Иначе
				Шапка.Параметры.СальдоЗаК = Пять - ОборотД1;
			КонецЕсли;	
			ИтогД = ИтогД + ОборотД1; 
			ИтогК = ИтогК + Пять;
			Шапка.Параметры.СальдоЗа = "Сальдо за " + Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДФ='ММММ yyyy'");
			ТабличныйДокумент.Вывести(Шапка);
			
			
			Шапка = Макет.ПолучитьОбласть("Доки");
			ОборотД = 0;
			ОборотК = 0;
			Доки = ПолучитьДоки(ВыборкаИзЗапроса.ДоговорИнвестора.Организация,ВыборкаИзЗапроса.Период,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента);
			Для каждого Стр Из Доки Цикл
				Шапка.Параметры.Дата = Формат(Стр.Период,"ДЛФ=Д");
				Шапка.Параметры.Документ = Сред(Стр.Регистратор,0,Найти(Стр.Регистратор," от")-1);
				Если Стр.Сумма > 0 Тогда
					Шапка.Параметры.ДокументД = Стр.Сумма;
					ОборотД = ОборотД + Стр.Сумма;
				Иначе
					Шапка.Параметры.ДокументК = - Стр.Сумма;
					ОборотК = ОборотК - Стр.Сумма;
				КонецЕсли;
				ТабличныйДокумент.Вывести(Шапка);
			КонецЦикла;
			
			Доки = ПолучитьКорректировки(ВыборкаИзЗапроса.ДоговорИнвестора.Организация,ВыборкаИзЗапроса.Период,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорКонтрагента,ВыборкаИзЗапроса.ДоговорИнвестора.ДоговорТО);
			Если НЕ Доки = неопределено Тогда
				Шапка = Макет.ПолучитьОбласть("Корректировки");
				Для каждого Стр Из Доки Цикл
					Если НЕ Стр.Сумма = 0 Тогда
						Шапка.Параметры.Дата = Формат(Стр.Период,"ДЛФ=Д");
						Шапка.Параметры.Документ = Сред(Стр.Регистратор,0,Найти(Стр.Регистратор," от")-1);
						Шапка.Параметры.ДокументД = "";
						Шапка.Параметры.ДокументК = "";
						Если Стр.Сумма > 0 Тогда
							Шапка.Параметры.ДокументД = Стр.Сумма;
							ОборотД = ОборотД + Стр.Сумма;
						Иначе
							Шапка.Параметры.ДокументК = - Стр.Сумма;
							ОборотК = ОборотК - Стр.Сумма;
						КонецЕсли;
						ТабличныйДокумент.Вывести(Шапка);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Шапка = Макет.ПолучитьОбласть("Подвал");
			Шапка.Параметры.ИтогОборотДК = ИтогД + ОборотД;
			Шапка.Параметры.ИтогОборотКК = ИтогК + ОборотК;
			
			Шапка.Параметры.СальдоКонечное = "Сальдо конечное нарастающим итогом на " + Формат(КонецМесяца(ВыборкаИзЗапроса.Период),"ДЛФ=Д");
			Если КонечнаяЗадолженность[0].СуммаОстаток > 0 Тогда
				Шапка.Параметры.СальдоКонечноеД = КонечнаяЗадолженность[0].СуммаОстаток;
			Иначе
				Шапка.Параметры.СальдоКонечноеК = -КонечнаяЗадолженность[0].СуммаОстаток;
			КонецЕсли;
			
			Если МЗ < 0 Тогда
				Шапка.Параметры.НаОсновании = "На основании ст.407 и ст. 410 ГК РФ Стороны пришли к соглашению о зачете встречных однородных требований. Итого по данным учета "
						+ ВыборкаИзЗапроса.ДоговорИнвестора.Организация + " задолженность за " + Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДФ='ММММ yyyy'") + " в пользу "
						+ ВыборкаИзЗапроса.ДоговорИнвестора.Контрагент + " составляет: " + Строка(-МЗ) + " руб. (" + УчетДенежныхСредствБП.ФорматироватьСуммуПрописьюПлатежногоДокумента(
		                -МЗ, Справочники.Валюты.НайтиПоКоду("643")) + ")";
			Иначе
				Шапка.Параметры.НаОсновании = "На основании ст.407 и ст. 410 ГК РФ Стороны пришли к соглашению о зачете встречных однородных требований. Итого по данным учета "
						+ ВыборкаИзЗапроса.ДоговорИнвестора.Организация + " задолженность за " + Формат(НачалоМесяца(ВыборкаИзЗапроса.Период),"ДФ='ММММ yyyy'") + " в пользу "
