			Подвал.Параметры.ПлощадьКотла = ?(Стр.ПлощадьКотла = 0, Стр.Помещение.ОбщаяПлощадь, Стр.ПлощадьКотла);					
			Подвал.Параметры.ПлощадьПомещения = Стр.Помещение.ОбщаяПлощадь;					
			Подвал.Параметры.ДоляВКотле = Стр.ДоляПомещения;					
			Если Стр.Оснащение > 0 Тогда     
				Подвал.Параметры.ДоговорО = Стр.ДоговорОснащения;
				Подвал.Параметры.СуммаУО = Стр.Оснащение;
				//Оснащение			= Макет.ПолучитьОбласть("Оснащение");
				//Оснащение.Параметры.Оснащение 	= "удержание из ДП в счет погашения задолженности по договору " + Стр.ДоговорОснащения + " -" + Формат(Стр.Оснащение,"ЧДЦ=2");  
				//Оснощ = Стр.Оснащение;
				//ТабличныйДокумент.Вывести(Оснащение);   
			КонецЕсли;	
			ТабличныйДокумент.Вывести(Подвал);
			
			Подписи			 = Макет.ПолучитьОбласть("Подписи");
			Подписи.Параметры.Руководитель 	= ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ОтветственныеЛица.Руководитель); 
			Подписи.Параметры.Принципал		= Стр.ДоговорИнвестора.Контрагент.Наименование;
			ТабличныйДокумент.Вывести(Подписи); 
			
			// акт
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
			ШапкаАкта			 = Макет.ПолучитьОбласть("ШапкаАкта");
			ШапкаАкта.Параметры.Номер 	= Стр.Номер;
			ШапкаАкта.Параметры.Дата = Формат(Стр.Период, "ДФ=dd.MM.yyyy");
			Орг = Стр.ДоговорИнвестора.Организация;
			ТабКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Орг,Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,Стр.Период,Ложь);
			Если ТабКИ.Количество() > 0 Тогда
				Адрес = ТабКИ[0].Представление;
			КонецЕсли;
			ШапкаАкта.Параметры.Агент 	= Орг.НаименованиеСокращенное + ", ИНН " + Орг.ИНН + ", " + Адрес + ", р/с " + Орг.ОсновнойБанковскийСчет
				+ ", в банке " + Орг.ОсновнойБанковскийСчет.Банк.Наименование + ", БИК " + Орг.ОсновнойБанковскийСчет.Банк.Код + ", к/с " + Орг.ОсновнойБанковскийСчет.Банк.КоррСчет;
				
			Кон	= Стр.ДоговорИнвестора.Контрагент;
			ШапкаАкта.Параметры.Принципал = Кон.Наименование + Символы.ПС 
				+ ?(СокрЛП(Кон.ДокументУдостоверяющийЛичность)="Выдан: Дата выдачи: Код подр:","",Кон.ДокументУдостоверяющийЛичность);
				
			ШапкаАкта.Параметры.Услуга1 = "Вознаграждение Агента за оказание услуг по управлению зданием за " + Формат(Стр.Период, "ДФ='MMM  yyyy'") 
				+ " по адресу: " + " в отношении помещения №" + Стр.Помещение.Наименование + " по договору от  " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy") + " № " + Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер; 
			ШапкаАкта.Параметры.Сумма1 = ПолучитьСумму(Стр.Период,Стр.ДоговорИнвестора.ДоговорКонтрагента);
			
			ШапкаАкта.Параметры.Услуга2 = "Вознаграждение Агента за оказание услуг по управлению помещением за " + Формат(Стр.Период, "ДФ='MMM  yyyy'") 
				+ " по адресу: " + " в отношении помещения №" + Стр.Помещение.Наименование + " по договору от  " + Формат(Стр.ДоговорИнвестора.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy") + " № " + Стр.ДоговорИнвестора.ДоговорКонтрагента.Номер; 
			ШапкаАкта.Параметры.Сумма2 = Стр.РасходыУслугиУК;
			
			ШапкаАкта.Параметры.Итого = ШапкаАкта.Параметры.Сумма1 + ШапкаАкта.Параметры.Сумма2;
			ШапкаАкта.Параметры.ИтогоПрописью = ЧислоПрописью(ШапкаАкта.Параметры.Итого, "Л=ru_RU", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
			ТабличныйДокумент.Вывести(ШапкаАкта);
		//КонецЕсли;	
	КонецЦикла;
	
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	ТабличныйДокумент.Защита = Истина;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуЗаявкиНаОплату()

Функция СформироватьПечатнуюФормуОтчета3(МассивСсылок) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	//ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_ЗаявкаНаРасходованиеСредств_ЗаявкаНаОплату";
	Для Каждого Стр из МассивСсылок Цикл
		//Если Стр.Период <= Дата('20240601') Тогда
