Функция СформироватьПечатнуюФормуОтчетаВалоНов(Стр) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = Документы.АР17_Д_ОтчетИнвестора.ПолучитьМакет("ОтчетВалоНовый"); 
	
	Шапка			 		= Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.Номер 	= Стр.Номер;
	Шапка.Параметры.Дата 	= Формат(Стр.Период, "ДФ=dd.MM.yyyy");
	ТабличныйДокумент.Вывести(Шапка); 

	Шапка2			 				= Макет.ПолучитьОбласть("Шапка2");
	Шапка2.Параметры.Организация 	= Стр.ДоговорИнвестора.Организация.НаименованиеСокращенное;
	ОтветственныеЛица 				= ОтветственныеЛицаБП.ОтветственныеЛица(Стр.ДоговорИнвестора.Организация, Стр.Дата);
	
	Организация_Руководитель 				= ОтветственныеЛица.Руководитель;
	Организация_Руководитель_ФИО_ИменП		= Организация_Руководитель.ФИО;
	Пол = ?(Организация_Руководитель.Пол	= Перечисления.ПолФизическогоЛица.Женский,2,1);
	Организация_Руководитель_ФИО_РодП 		= Организация_Руководитель_ФИО_ИменП;
	Организация_Руководитель_ФИО_РодП		= СклонениеФИО(Организация_Руководитель_ФИО_РодП,2,Пол);
	Шапка2.Параметры.Руководитель 			= ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Организация_Руководитель_ФИО_РодП);
	Шапка2.Параметры.Принципал				= Стр.ДоговорИнвестора.Контрагент.Наименование;
	Шапка2.Параметры.Период					= Формат(Стр.Период, "ДФ='MMM  yyyy'");
	ТабличныйДокумент.Вывести(Шапка2); 
	
	ШапкаТаблицы	= Макет.ПолучитьОбласть("ШапкаТаблицы");
	ТабличныйДокумент.Вывести(ШапкаТаблицы);
	
