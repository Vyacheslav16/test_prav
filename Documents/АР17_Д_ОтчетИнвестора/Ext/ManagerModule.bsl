Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм,ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Отчет") Тогда
		// Формируем табличный документ и добавляем его в коллекцию печатных форм.
	
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,
		"Отчет",
		"Отчет",
		СформироватьПечатнуюФормуОтчета2(МассивОбъектов),
		,
		"Документ.АР17_Д_ОтчетИнвестора.Отчет");
    КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ОтчетИнвестора") Тогда
		// Формируем табличный документ и добавляем его в коллекцию печатных форм.
	
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,
		"ОтчетИнвестора",
		"ОтчетИнвестора",
		СформироватьПечатнуюФормуОтчета3(МассивОбъектов),
		,
		"Документ.АР17_Д_ОтчетИнвестора.ОтчетИнвестора");
    КонецЕсли;
	
КонецПроцедуры // Печать()

Функция ПолучитьКУ(Об)
	Запрос = Новый Запрос;  
	Если Об.ДоговорИнвестора.ПрограммаДоходности.ЭтоКотел Тогда
 		Запрос.Текст = "ВЫБРАТЬ
 		               |	АР17_ЗаключениеАгентскогоДоговора.ПрограммаДоходности КАК ПрограммаДоходности
 		               |ПОМЕСТИТЬ вт
 		               |ИЗ
 		               |	Документ.АР17_ЗаключениеАгентскогоДоговора КАК АР17_ЗаключениеАгентскогоДоговора
 		               |ГДЕ
 		               |	АР17_ЗаключениеАгентскогоДоговора.ДоговорКонтрагента = &ДоговорКонтрагента
 		               |;
 		               |
 		               |////////////////////////////////////////////////////////////////////////////////
 		               |ВЫБРАТЬ
 		               |	АР17_ЗаключениеАгентскогоДоговора.ДоговорКонтрагента КАК ДоговорКонтрагента
 		               |ПОМЕСТИТЬ Договора
 		               |ИЗ
 		               |	вт КАК вт
 		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора КАК АР17_ЗаключениеАгентскогоДоговора
 		               |		ПО вт.ПрограммаДоходности = АР17_ЗаключениеАгентскогоДоговора.ПрограммаДоходности
 		               |;
 		               |
 		               |////////////////////////////////////////////////////////////////////////////////
 		               |ВЫБРАТЬ
 		               |	СУММА(ПР_Квитанция.КоммунальныеУслуги1 + ПР_Квитанция.ТехническоеОбслуживание + ПР_Квитанция.ТелекоммуникационныеУслуги1 + ПР_Квитанция.ДополнительныеУслуги1) КАК Всего
 		               |ИЗ
 		               |	Документ.ПР_Квитанция КАК ПР_Квитанция
 		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Договора КАК Договора
 		               |		ПО ПР_Квитанция.ДоговорКонтрагента = Договора.ДоговорКонтрагента
 		               |ГДЕ
 		               |	ПР_Квитанция.ДатаКон >= &ДатаНач
 		               |	И ПР_Квитанция.ДатаНач <= &ДатаКон
 		               |	И ПР_Квитанция.Проведен = ИСТИНА";

	Иначе
		Запрос.Текст = "ВЫБРАТЬ
		               |	ПР_Квитанция.КоммунальныеУслуги1 + ПР_Квитанция.ТехническоеОбслуживание + ПР_Квитанция.ТелекоммуникационныеУслуги1 + ПР_Квитанция.ДополнительныеУслуги1 КАК Всего
		               |ИЗ
		               |	Документ.ПР_Квитанция КАК ПР_Квитанция
		               |ГДЕ
		               |	ПР_Квитанция.ДатаКон >= &ДатаНач
		               |	И ПР_Квитанция.ДатаНач <= &ДатаКон
		               |	И ПР_Квитанция.ДоговорКонтрагента = &ДоговорКонтрагента
		               |	И ПР_Квитанция.Проведен = ИСТИНА";
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаНач",НачалоМесяца(Об.Период));
	Запрос.УстановитьПараметр("ДатаКон",КонецМесяца(Об.Период));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Об.ДоговорИнвестора.ДоговорКонтрагента);
	
	//Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Всего;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции

Функция ПолучитьГР(Об)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(РеализацияТоваровУслугУслуги.Сумма) КАК Сумма
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
	               |ГДЕ
	               |	РеализацияТоваровУслугУслуги.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
	               |	И РеализацияТоваровУслугУслуги.Ссылка.Дата >= &ДатаНач
	               |	И РеализацияТоваровУслугУслуги.Ссылка.Дата <= &ДатаКон";
	
	Запрос.УстановитьПараметр("ДатаНач",НачалоМесяца(Об.Дата));
	Запрос.УстановитьПараметр("ДатаКон",КонецМесяца(Об.Дата));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Об.ДоговорИнвестора.ДоговорКонтрагента);
	
	//Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Сумма;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции	

Функция СклонениеФИО(ФИО, падеж, пол) 
	
	РезультатСклонения = "";
	//УниверсальныеМеханизмы.Просклонять(глЗначениеПеременной("глКомпонентаСклоненияФИО"), ФИО, Падеж,Пол, РезультатСклонения);
	Если ФизическиеЛицаЗарплатаКадры.Просклонять(ФИО, Падеж, РезультатСклонения, Пол) Тогда
		ФИО = РезультатСклонения;
	КонецЕсли;

	Возврат РезультатСклонения;
	
КонецФункции

