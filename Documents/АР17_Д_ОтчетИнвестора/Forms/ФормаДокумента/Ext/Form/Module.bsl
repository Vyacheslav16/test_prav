&НаСервере
Процедура ЗаполнитьОтОтчетаСобственникуПоКотлуНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Основание) Тогда
		Если ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.С_ОтчетСобственникуПоКотлу") Тогда
			ДокОб = РеквизитФормыВЗначение("Объект");
			ДокОб.ЗаполнитьОтОтчетаСобственникуПоКотлу(Объект.Основание);
			ЗначениеВРеквизитФормы(ДокОб, "Объект");
		ИначеЕсли ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.С_ОтчетАгента") Тогда
			ДокОб = РеквизитФормыВЗначение("Объект");
			ДокОб.ЗаполнитьОтОтчетаАгента(Объект.Основание);
			ЗначениеВРеквизитФормы(ДокОб, "Объект");
		КонецЕсли;
	Иначе
		Сообщить("Основание не заполнено или имеет неверный тип!");
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОтОтчетаСобственникуПоКотлу(Команда)
	ЗаполнитьОтОтчетаСобственникуПоКотлуНаСервере();
КонецПроцедуры
