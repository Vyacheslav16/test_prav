&НаСервере
Функция ДанныеЗапроса(Ошибки, ТекстЗапроса, HTTPСоединение)
	
	Запрос = Новый HTTPЗапрос(ТекстЗапроса);
	Ответ = HTTPСоединение.Получить(Запрос);
	ЛинкПроект = ""; Следующий = Ложь;
	Если Ответ.КодСостояния = 200 Тогда
		
		ОтветСтрокой = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		Данные = Новый ЧтениеJSON;
		Данные.УстановитьСтроку(ОтветСтрокой);
		
		мЧтение = ПрочитатьJSON(Данные, Истина);
		мРезультат = мЧтение["value"];
		
		Если мРезультат <> Неопределено Тогда
			
			Возврат мРезультат;
			
		Иначе
			
			Ошибки.Добавить("Ошибка анализа результата запроса");
	
			Возврат Новый Соответствие;
			
		КонецЕсли;
			
	Иначе
		
		Ошибки.Добавить("Ошибка выполнения запроса: " + Ответ.КодСостояния);
		
		Возврат Новый Соответствие;
		
	КонецЕсли;
	
КонецФункции

