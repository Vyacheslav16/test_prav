&НаКлиенте
Процедура СоставОбъектАрендыПриИзменении(Элемент)
	
	ТекСтр = Элементы.Состав.ТекущиеДанные;
	ТекСтр.Площадь = ПолучитьПлощадь(ТекСтр.ОбъектАренды);
	
КонецПроцедуры

&НаСервере
Функция ПоискИКПоДоговору()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ЗаключениеДоговораАренды.ИК
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента
		|	И АР17_ЗаключениеДоговораАренды.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Объект.ДоговорКонтрагента);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.ИК;
	КонецЕсли; 

КонецФункции // ПоискИКПоДоговору()

&НаКлиенте
Процедура СоставОбъектАрендыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
		ИКДоговора = ПоискИКПоДоговору();
		Если ИКДоговора <> Неопределено Тогда
			СтандартнаяОбработка = Ложь;
			ПараметрыОбъекты = Новый Структура("ИК",ИКДоговора);
			ОткрытьФорму("Справочник.АР_ОбъектыАренды.ФормаВыбора", ПараметрыОбъекты, Элемент);
		КонецЕсли;
	КонецЕсли; 

КонецПроцедуры
// - NAI Becar Конюшок С.Н. 
 

