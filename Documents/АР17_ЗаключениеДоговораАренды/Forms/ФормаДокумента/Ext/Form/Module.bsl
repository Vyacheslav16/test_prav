Функция ПроверитьДоговор(ТекущийОбъект)
	
	Если ТекущийОбъект.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
		Возврат Истина;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАренды.Ссылка,
	               |	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента
	               |	И АР_ЗаключениеДоговораАренды.Ссылка <> &Ссылка";
				   
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ТекущийОбъект.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Ссылка",ТекущийОбъект.Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Договор уже используется в " + Выборка.Ссылка.Номер + " заключении договора аренды";
		Сообщение.Сообщить();
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;	
КонецФункции

