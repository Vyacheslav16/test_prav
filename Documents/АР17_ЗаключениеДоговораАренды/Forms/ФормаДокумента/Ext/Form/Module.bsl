	|			КОГДА ТИПЗНАЧЕНИЯ(АР_АктДоступаСостав.Ссылка.ДокументОснование) = ТИП(Документ.АР17_ДополнительноеСоглашение)
	|				ТОГДА АР_АктДоступаСостав.Ссылка.ДокументОснование.ДокументОснование = &ЗДА
	|			КОГДА ТИПЗНАЧЕНИЯ(АР_АктДоступаСостав.Ссылка.ДокументОснование) = ТИП(Документ.АР_АктДоступа)
	|				ТОГДА ВЫБОР
	|						КОГДА ТИПЗНАЧЕНИЯ(АР_АктДоступаСостав.Ссылка.ДокументОснование.ДокументОснование) = ТИП(Документ.АР17_ЗаключениеДоговораАренды)
	|							ТОГДА АР_АктДоступаСостав.Ссылка.ДокументОснование.ДокументОснование = &ЗДА
	|						КОГДА ТИПЗНАЧЕНИЯ(АР_АктДоступаСостав.Ссылка.ДокументОснование.ДокументОснование) = ТИП(Документ.АР17_ДополнительноеСоглашение)
	|							ТОГДА АР_АктДоступаСостав.Ссылка.ДокументОснование.ДокументОснование.ДокументОснование = &ЗДА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И НЕ АР_АктДоступаСостав.Ссылка.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	АР_АктДоступаСостав.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Ссылка,
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.Площадь, 0))
	|ИЗ
	|	(ВЫБРАТЬ
	|		АР_АктПриемаПередачиПомещенияВАренду.Ссылка КАК Ссылка,
	|		ВложенныйЗапрос.Площадь КАК Площадь
	|	ИЗ
	|		Документ.АР_АктПриемаПередачиПомещенияВАренду КАК АР_АктПриемаПередачиПомещенияВАренду
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				АР_АктПриемаПередачиПомещенияВАрендуСостав.Ссылка КАК Ссылка,
	|				АР_АктПриемаПередачиПомещенияВАрендуСостав.ОбъектАренды КАК ОбъектАренды,
	|				СУММА(АР_АктПриемаПередачиПомещенияВАрендуСостав.Площадь) КАК Площадь
	|			ИЗ
	|				Документ.АР_АктПриемаПередачиПомещенияВАренду.Состав КАК АР_АктПриемаПередачиПомещенияВАрендуСостав
	|			ГДЕ
	|				АР_АктПриемаПередачиПомещенияВАрендуСостав.Ссылка.ПометкаУдаления = ЛОЖЬ
	|			
	|			СГРУППИРОВАТЬ ПО
	|				АР_АктПриемаПередачиПомещенияВАрендуСостав.Ссылка,
	|				АР_АктПриемаПередачиПомещенияВАрендуСостав.ОбъектАренды) КАК ВложенныйЗапрос
	|			ПО АР_АктПриемаПередачиПомещенияВАренду.Ссылка = ВложенныйЗапрос.Ссылка
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА ТИПЗНАЧЕНИЯ(АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование) = ТИП(Документ.АР17_ЗаключениеДоговораАренды)
	|					ТОГДА АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование = &ЗДА
	|				КОГДА ТИПЗНАЧЕНИЯ(АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование) = ТИП(Документ.АР17_ДополнительноеСоглашение)
	|					ТОГДА АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование.ДокументОснование = &ЗДА
	|				КОГДА ТИПЗНАЧЕНИЯ(АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование) = ТИП(Документ.АР_АктДоступа)
	|					ТОГДА ВЫБОР
	|							КОГДА ТИПЗНАЧЕНИЯ(АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование.ДокументОснование) = ТИП(Документ.АР17_ЗаключениеДоговораАренды)
	|								ТОГДА АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование.ДокументОснование = &ЗДА
	|							КОГДА ТИПЗНАЧЕНИЯ(АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование.ДокументОснование) = ТИП(Документ.АР17_ДополнительноеСоглашение)
	|								ТОГДА АР_АктПриемаПередачиПомещенияВАренду.Ссылка.ДокументОснование.ДокументОснование.ДокументОснование = &ЗДА
	|							ИНАЧЕ ЛОЖЬ
	|						КОНЕЦ
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ
	|		И АР_АктПриемаПередачиПомещенияВАренду.ПометкаУдаления = ЛОЖЬ) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Ссылка";
	
	
	//Запрос.УстановитьПараметр("Договор", Объект.Ссылка);	
	Запрос.УстановитьПараметр("ЗДА", Объект.Ссылка);	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выгрузка.Свернуть("Ссылка,Площадь");
	Выборка = Запрос.Выполнить().Выбрать();
	
	//Пока Выборка.Следующий() Цикл
	Для Каждого СтрВыгрузка из Выгрузка Цикл
		Стр = Объект.АктыПриемаПередачи.Добавить();
		Стр.Документ = СтрВыгрузка.Ссылка;
		Стр.Площадь = СтрВыгрузка.Площадь;
	КонецЦикла;		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСчета()
	
	Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
                   |	АР_СчетНаАренду.Ссылка
                   |ИЗ
                   |	Документ.АР17_СчетНаАренду КАК АР_СчетНаАренду
                   |ГДЕ
                   |	АР_СчетНаАренду.ДоговорКонтрагента = &ДоговорКонтрагента
                   |	И АР_СчетНаАренду.Проведен = ИСТИНА
                   |	И АР_СчетНаАренду.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита)
                   |
                   |УПОРЯДОЧИТЬ ПО
                   |	АР_СчетНаАренду.Дата";
				   
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Объект.ДоговорКонтрагента);	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Стр = Объект.Счета.Добавить();
		Стр.Документ = Выборка.Ссылка;
	КонецЦикла;
	
КонецПроцедуры

