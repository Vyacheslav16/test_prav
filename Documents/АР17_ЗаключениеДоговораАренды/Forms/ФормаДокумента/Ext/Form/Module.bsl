Функция ЗаполнитьДокументНаСервере(ДанныеФормы);

	Док = ДанныеФормыВЗначение(ДанныеФормы, Тип("ДокументОбъект.АР_АктПриемаПередачиПомещенияВАренду")); // Получаем объект из данных формы ИЛИ

	Док = Документы.АР_АктПриемаПередачиПомещенияВАренду.СоздатьДокумент();

	// Заполняем реквизиты объекта или другие действия ********
	Док.Организация = ДанныеФормы.Организация;
	Док.Контрагент = ДанныеФормы.Контрагент;
	Док.ДоговорКонтрагента = ДанныеФормы.ДоговорКонтрагента;


ЗначениеВДанныеФормы(Док,ДанныеФормы); // Кладем обратно в объект формы уже созданный документ

