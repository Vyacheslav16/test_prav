 &НаСервере
Процедура ЗаполнитьДопСоглашения()
	
	Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
                   |	АР_ДополнительноеСоглашение.Ссылка КАК Ссылка,
                   |	АР_ДополнительноеСоглашение.ТекстПисьма КАК Текст,
                   |	АР_ДополнительноеСоглашение.Содержание КАК Содержание
                   |ИЗ
                   |	Документ.АР17_ДополнительноеСоглашение КАК АР_ДополнительноеСоглашение
                   |ГДЕ
                   |	АР_ДополнительноеСоглашение.ДокументОснование = &ДокументОснование
                   |	И АР_ДополнительноеСоглашение.Проведен = ИСТИНА
                   |
                   |ОБЪЕДИНИТЬ ВСЕ
                   |
                   |ВЫБРАТЬ
                   |	АР_РасторжениеДоговораАренды.Ссылка,
                   |	NULL,
                   |	NULL
                   |ИЗ
                   |	Документ.АР17_РасторжениеДоговораАренды КАК АР_РасторжениеДоговораАренды
                   |ГДЕ
                   |	АР_РасторжениеДоговораАренды.ДокументОснование = &ДокументОснование
                   |	И АР_РасторжениеДоговораАренды.Проведен = ИСТИНА
                   |
                   |ОБЪЕДИНИТЬ ВСЕ
                   |
                   |ВЫБРАТЬ
                   |	АР17_ИнформационныйДокумент.Ссылка,
                   |	АР17_ИнформационныйДокумент.Текст,
                   |	NULL
                   |ИЗ
                   |	Документ.АР17_ИнформационныйДокумент КАК АР17_ИнформационныйДокумент
                   |ГДЕ
                   |	АР17_ИнформационныйДокумент.ДокументОснование = &ДокументОснование
                   |	И АР17_ИнформационныйДокумент.ПометкаУдаления = ЛОЖЬ";
				   
				   
	Запрос.УстановитьПараметр("ДокументОснование", Объект.Ссылка);	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Стр = Объект.ДополнительныеСоглашения.Добавить();
		Если ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда
			Стр.ВидОперации = Выборка.Ссылка.ВидОперации;
		ИначеЕсли ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.АР_АктДоступа") Тогда
			Стр.ВидОперации = "Акт доступа";
		ИначеЕсли ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.АР17_ИнформационныйДокумент") Тогда
			//Стр.ВидОперации = "Информационный документ";
			Стр.ВидОперации = Выборка.Ссылка.Наименование;
			Стр.Номер = Выборка.Ссылка.Номер;
		Иначе	
			Стр.ВидОперации = "Расторжение договора аренды";
		КонецЕсли;
		Номер = Выборка.Ссылка.Номер;
		Пока Лев(Номер,1)="0" Цикл
		 	Номер = Прав(Номер,СтрДлина(Номер)-1);
		КонецЦикла;
		Если ТипЗнч(Выборка.Ссылка) <> Тип("ДокументСсылка.АР17_ИнформационныйДокумент") Тогда
			Стр.Номер = Номер;
		КонецЕсли;	
		Стр.Документ = Выборка.Ссылка;
		Стр.Содержание = Выборка.Содержание;
		Стр.Текст = Выборка.Текст;
	КонецЦикла;
	//ЭтотОбъект.Записать();
	
КонецПроцедуры


&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.ГруппаОсновная Тогда
		//Объект.ДополнительныеСоглашения.Очистить();
		//ЗаполнитьДопСоглашения();
	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаПостояннаяЧастьАренднойПлаты Тогда
		ТекущиеДанные = Элементы.ПостояннаяЧастьАренднойПлаты.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			СформироватьНадписьГрафикаСтавок(Неопределено);
		Иначе
			СформироватьНадписьГрафикаСтавок(ТекущиеДанные.Ставка);
		КонецЕсли;
	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаПеременнаяЧастьАренднойПлаты Тогда
		ТекущиеДанные = Элементы.ПеременнаяЧастьАренднойПлаты.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			СформироватьНадписьГрафикаСтавок(Неопределено);
		Иначе
			СформироватьНадписьГрафикаСтавок(ТекущиеДанные.Ставка);
		КонецЕсли;
	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаАктыПриемаПередачи Тогда
		Объект.АктыПриемаПередачи.Очистить();
		ЗаполнитьАкты();
		Объект.ДополнительныеСоглашения.Очистить();
		ЗаполнитьДопСоглашения();
	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаДокументы Тогда
		Объект.Счета.Очистить();
		ЗаполнитьСчета();
		Объект.Реализации.Очистить();
		ЗаполнитьРеализации();
	//ИначеЕсли ТекущаяСтраница = Элементы.ГруппаНачисления Тогда
	//	Объект.Начисления.Очистить();
	//	ЗаполнитьНачисления();
	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаДепозит Тогда
		ТекущиеСчетаНаДепозит.Очистить();
		ЗаполнитьСчетаНаДепозит();
	Иначе
		СформироватьНадписьГрафикаСтавок(Неопределено);
	КонецЕсли;

	УстановитьВидимость();
	
КонецПроцедуры

