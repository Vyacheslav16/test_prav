	//КонецЕсли;

	//
	
	
	Если  НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если Вопрос("Перед добавлением необходимо записать договор! Записать?", РежимДиалогаВопрос.ДаНет,25,КодВозвратаДиалога.Нет)=КодВозвратаДиалога.Да Тогда
