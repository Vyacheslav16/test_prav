&НаКлиенте
Процедура ДоговорУслугПриИзменении(Элемент)
	
	Если Объект.ДоговорУслуг Тогда
		
		Если Объект.ОбъектыАренды.Количество() > 0 Тогда
			
			Режим = РежимДиалогаВопрос.ДаНет;
			Ответ = Вопрос("Внимание! Для договоров услуг не указываются объекты аренды! Очистить список объектов аренды текущего договора?",Режим);
			Если Ответ = КодВозвратаДиалога.Нет Тогда
				Объект.ДоговорУслуг = Не Объект.ДоговорУслуг;
				Возврат;
			Иначе
				Объект.ОбъектыАренды.Очистить();
			КонецЕсли;
			
		КонецЕсли; 
		
		Если Объект.КоммунальныеУслуги.Количество() > 0 Тогда
			
			Режим = РежимДиалогаВопрос.ДаНет;
			Ответ = Вопрос("Внимание! Для договоров услуг не предусмотрен учет коммунальных услуг! Очистить список коммунальных услуг текущего договора?",Режим);
			Если Ответ = КодВозвратаДиалога.Нет Тогда
				Объект.ДоговорУслуг = Не Объект.ДоговорУслуг;
				Возврат;
			Иначе
				Объект.ОбъектыАренды.Очистить();
			КонецЕсли;
			
		КонецЕсли; 
		
	КонецЕсли;
	
	ИзменениеФормыДляДоговораУслуг(Объект.ДоговорУслуг);

КонецПроцедуры

