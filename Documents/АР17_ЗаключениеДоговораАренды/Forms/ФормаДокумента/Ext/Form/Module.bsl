Функция ПолучитьКопию(СсылкаНаЭлемент)
	Наименование = СсылкаНаЭлемент.Наименование;
	//Если Справочники.Номенклатура.НайтиПоНаименованию(Наименование) Тогда
		Наименование = ПолучитьНаименование(Наименование);
	//КонецЕсли;	
		
	Копия = Справочники.Номенклатура.СоздатьЭлемент();
	//Копия.Наименование = СсылкаНаЭлемент.Наименование + " 1";
	Копия.Наименование = Наименование;
	
	Копия.НаименованиеПолное = СсылкаНаЭлемент.НаименованиеПолное;
	Копия.Родитель = ПолучитьРодителя();
	//
	Копия.ЕдиницаИзмерения = СсылкаНаЭлемент.ЕдиницаИзмерения;
	//Копия.СтавкаНДС = СсылкаНаЭлемент.СтавкаНДС;
	Копия.ВидСтавкиНДС = СсылкаНаЭлемент.ВидСтавкиНДС;
	Копия.Услуга = СсылкаНаЭлемент.Услуга;
	Копия.АР_ПостояннаяЧастьОплаты = СсылкаНаЭлемент.АР_ПостояннаяЧастьОплаты;
	Копия.АР_Внешняя = СсылкаНаЭлемент.АР_Внешняя;
	Копия.АР_ТелефонИнтернет = СсылкаНаЭлемент.АР_ТелефонИнтернет;
	Копия.АР_ОплачиваетсяАвансом = СсылкаНаЭлемент.АР_ОплачиваетсяАвансом;
	Копия.АР_АгентскаяСхема = СсылкаНаЭлемент.АР_АгентскаяСхема;
	//
	Копия.Записать();
	
	Возврат Копия;
	
КонецФункции	

Функция ПолучитьНаименование(Наименование)
	
	Наименование = СокрЛП(Наименование);
	
	Если Справочники.Номенклатура.НайтиПоНаименованию(Наименование) <> Справочники.Номенклатура.ПустаяСсылка() Тогда
		
		Если Найти("0123456789", Прав(СокрЛП(Наименование),1)) > 0 Тогда
			ЧиселСправа = ЧиселСправа(СокрЛП(Наименование),1);
			Ч = Число(Прав(СокрЛП(Наименование),ЧиселСправа))+1;
			//Наименование = Прав(СокрЛП(Наименование),ЧиселСправа) + Ч;
			Наименование = Лев(Наименование,СтрДлина(Наименование)-ЧиселСправа) + Ч;
			//Сред(Наименование,СтрДлина(Наименование)-Сч-1,СтрДлина(Наименование)-Сч)
		Иначе
			Наименование = Наименование+"1";
			Наименование = ПолучитьНаименование(Наименование);
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат Наименование;
	
КонецФункции	

Функция ЧиселСправа(Наим, Сч)
	//Для Сч по 10 Цикл
		//Если Найти("0123456789", Прав(СокрЛП(Наим),Сч)) > 0 Тогда
		Если Найти("0123456789", Сред(Наим,СтрДлина(Наим)-Сч-1,СтрДлина(Наим)-Сч)) > 0 Тогда
			Сч = Сч + 1;
			ЧиселСправа(Наим,Сч);
		Иначе	
			Сч =1;			
		КонецЕсли;	
	//КонецЦикла;		
	Возврат Сч;		
	
