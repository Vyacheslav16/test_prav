Процедура ПересчитатьСуммуЗалога()
	
	Объект.СуммаЗалога = 0;
	
	Для каждого Стр Из Объект.ПостояннаяЧастьАренднойПлаты Цикл
		
		Если Стр.Депозит Тогда
			Если Стр.СпособНачисления = Справочники.АР_СпособыНачисленияАренднойПлаты.В_руб_за_м2_год Тогда
				Сумма = Стр.Сумма/12;
			ИначеЕсли Стр.СпособНачисления = Справочники.АР_СпособыНачисленияАренднойПлаты.КоличестваКалендарныхДней Тогда
				КоличествоДней = (Окр((Стр.ДатаОкончанияСрокаАренды - Стр.ДатаНачалаСрокаАренды)))/86400; 
				Сумма = Стр.Сумма/КоличествоДней*28.3;	
			Иначе	 
				Сумма = Стр.Сумма;
			КонецЕсли; 
			Объект.СуммаЗалога = Объект.СуммаЗалога + Сумма;
		КонецЕсли;
		
	КонецЦикла; 
	
	Для каждого Стр Из Объект.ПеременнаяЧастьАренднойПлаты Цикл
		
