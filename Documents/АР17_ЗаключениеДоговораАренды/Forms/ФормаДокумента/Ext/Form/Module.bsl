Процедура Таблица1Выбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка=Ложь;
    ссылкаНаДокумент = Элемент.ТекущиеДанные.Документ;
	
	Если ТипЗнч(ссылкаНаДокумент) = Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда
		Пар = Новый Структура("Ключ",ссылкаНаДокумент); 
		форма = ПолучитьФорму("Документ.АР17_ДополнительноеСоглашение.Форма.ФормаДокумента",пар);
		//форма=  ссылкаНаДокумент.ПолучитьФорму("ФормаДокумента");
	    форма.Открыть();
	ИначеЕсли ТипЗнч(ссылкаНаДокумент) = Тип("ДокументСсылка.АР17_РасторжениеДоговораАренды") Тогда
		Пар = Новый Структура("Ключ",ссылкаНаДокумент); 
		форма = ПолучитьФорму("Документ.АР17_РасторжениеДоговораАренды.Форма.ФормаДокумента",пар);
		//форма=  ссылкаНаДокумент.ПолучитьФорму("ФормаДокумента");
	    форма.Открыть();
	ИначеЕсли ТипЗнч(ссылкаНаДокумент) = Тип("ДокументСсылка.АР_АктДоступа") Тогда
		Пар = Новый Структура("Ключ",ссылкаНаДокумент); 
		форма = ПолучитьФорму("Документ.АР_АктДоступа.Форма.ФормаДокумента",пар);
		//форма=  ссылкаНаДокумент.ПолучитьФорму("ФормаДокумента");
