Процедура ЗаполнитьДепозит()
	
	Если Не ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	//ЭтотОбъект.Депозит.Очистить();
	Объект.ДепозитСодержаниеИК.Очистить();
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_УстановкаПараметровИКНоменклатура.Номенклатура КАК Услуга,
	               |	АР_УстановкаПараметровИКНоменклатура.Содержание,
	               |	АР_УстановкаПараметровИКНоменклатура.ВидДоговора,
	               |	АР_УстановкаПараметровИКНоменклатура.ГруппаУслуг
	               |ИЗ
	               |	Документ.АР17_УстановкаПараметровИК.Номенклатура КАК АР_УстановкаПараметровИКНоменклатура
	               |ГДЕ
	               |	АР_УстановкаПараметровИКНоменклатура.ГруппаУслуг = &ГруппаУслуг
	               |	И АР_УстановкаПараметровИКНоменклатура.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка",Объект.ДокументОснование);
	Запрос.УстановитьПараметр("ГруппаУслуг",Справочники.АР_ГруппыУслуг.ОбеспечительныйПлатеж);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		//НоваяСтрока = ЭтотОбъект.Депозит.Добавить();
		//ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);
		НоваяСтрокаИК = Объект.ДепозитСодержаниеИК.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаИК,Выборка);
		НоваяСтрокаИК.СуммаДепозита = Объект.СуммаЗалога;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПостояннаяЧастьАренднойПлатыБРРПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ПостояннаяЧастьАренднойПлаты.ТекущиеДанные;
	// + NAI Becar Комментирование Смирнов А.А. от 28.10.2020 11:45
	Годы = Год(ТекущиеДанные.ДатаОкончанияСрокаАренды) - Год(ТекущиеДанные.ДатаНачалаСрокаАренды); 
	Месяцы = Месяц(ТекущиеДанные.ДатаОкончанияСрокаАренды) - Месяц(ТекущиеДанные.ДатаНачалаСрокаАренды); 
	Разность = месяцы + годы * 12;
	
	Если Разность > 12 Тогда
		Сообщить("Зполнять БРР можно только в договоре с периодом на год!");
		ТекущиеДанные.БРР = Неопределено;
		Возврат;
	КонецЕсли;
	// - NAI Becar Комментирование Смирнов А.А. от 28.10.2020 11:45
	ТекущиеДанные.ЦФО = ПолучитьЦФО(ТекущиеДанные.БРР);
	ТекущиеДанные.Проект = ПолучитьПроект(ТекущиеДанные.БРР);
КонецПроцедуры

