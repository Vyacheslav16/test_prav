Функция РедактироватьОбъект()
	Если ПользователиИнформационнойБазы.ТекущийПользователь().Роли.Содержит(Метаданные.Роли.АР_Руководитель) Или 
	ПользователиИнформационнойБазы.ТекущийПользователь().Роли.Содержит(Метаданные.Роли.ПолныеПрава)	Тогда
		Возврат Истина;
	Иначе	
		Возврат Объект.ДокументОснование.ПолучитьОбъект().РедактироватьОбъект;
	КонецЕсли;	
КонецФункции

Функция РедактироватьСобственник()
	Если ПользователиИнформационнойБазы.ТекущийПользователь().Роли.Содержит(Метаданные.Роли.АР_Руководитель) Или 
	ПользователиИнформационнойБазы.ТекущийПользователь().Роли.Содержит(Метаданные.Роли.ПолныеПрава)	Тогда
		Возврат Истина;
	Иначе	
		Если Объект.ДокументОснование.ПолучитьОбъект().РедактироватьСобственник = Объект.Контрагент Тогда
			Возврат Истина;//Объект.ДокументОснование.ПолучитьОбъект().РедактироватьОбъект;	
		Иначе 
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;	
КонецФункции

