	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Предупреждение("Заполните организацию!",3);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	Если (Объект.Организация <> ОрганизацияСтар) И (ОрганизацияСтар <> ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка")) Тогда
		Предупреждение("Изменена организация!"+Символы.ПС+"Необходимо записать договор!", 3);
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Предупреждение("Заполните контрагента!",3);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	Если КонтрагентСтар <> ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка") И Объект.Контрагент <> КонтрагентСтар Тогда
