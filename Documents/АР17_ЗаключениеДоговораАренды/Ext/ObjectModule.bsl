Процедура УстановитьНомерДокументаДоговора()

	Номер1 = ДокументОснование.ПрефиксДоговора;
	Если Найти(Номер1, "[Организация]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Организация]", СокрЛП(ДокументОснование.Арендодатель.Префикс));
	КонецЕсли;
	Если Найти(Номер1, "[Имущественный комплекс]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Имущественный комплекс]", СокрЛП(ДокументОснование.ПрефиксИК));
	КонецЕсли;
	Если Найти(Номер1, "[Вид договора]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Вид договора]", ВидДоговора.Преффикс); // + NAI Becar Конюшок С.Н. от 29.12.2016 15:49 
	КонецЕсли;
	Если Найти(Номер1, "[Месяц договора]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Месяц договора]", Формат(ТекущаяДата(),"ДФ=MM"));
	КонецЕсли;
	Если Найти(Номер1, "[Год договора]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Год договора]", Формат(ТекущаяДата(),"ДФ=гг"));
	КонецЕсли;
	Если Найти(Номер1, "[Дата договора]") > 0 Тогда
		Номер1 = СтрЗаменить(Номер1, "[Дата договора]", Формат(ТекущаяДата(),"ДФ=дд"));
	КонецЕсли;
	Если Найти(Номер1, "[Номер по порядку]") > 0 Тогда
		ЧислоСимволов = Найти(Номер1, "[Номер по порядку]");
		СледующийНомер = НайтиСледующийНомер(Лев(Номер1,ЧислоСимволов-1),ДокументОснование.ИКСсылка);
		Номер1 = СтрЗаменить(Номер1, "[Номер по порядку]", СледующийНомер);
	КонецЕсли;
	// + NAI Becar Комментирование Смирнов А.А. от 18.10.2016 13:45
	
	// - NAI Becar Комментирование Смирнов А.А.
	ЭтотОбъект.Номер = Номер1;

КонецПроцедуры
 

Процедура ЗаполнитьДокументПоОснованию()
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АР17_УстановкаПараметровИК") Тогда
		// + NAI Becar Матюхин Н.О. от 05.10.2016 13:12 по заявке № 113216
		//ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,"Дата,Номер,ПометкаУдаления,Проведен");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект,ДокументОснование,,"БанковскийСчет,Дата,Номер,ПометкаУдаления,Проведен,Ответственный");
		// + NAI Becar Матюхин Н.О. от 05.10.2016 13:12 по заявке № 113216
		ЭтотОбъект.ИК = ДокументОснование.ИКСсылка;
		ЭтотОбъект.Организация = ДокументОснование.Арендодатель;
		ЗаполнитьБанковскийСчетПоИКМодуль();
		// - NAI Becar Матюхин Н.О.
		Для Каждого СтрОснование из ДокументОснование.Пени Цикл
			Стр = ЭтотОбъект.Пени.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,СтрОснование);
		КонецЦикла;	
		ЭтотОбъект.Собственник = ДокументОснование.ИКСобственник;
		//ЭтотОбъект.ДоговорКонтрагента = ДокументОснование.ИКДоговор;
		Если ДокументОснование.Контрагенты.Количество()>0 Тогда
			ЭтотОбъект.Собственник = ДокументОснование.Контрагенты[0].Контрагент;
			ЭтотОбъект.ДоговорСобственника = ДокументОснование.Контрагенты[0].Договор;
		КонецЕсли;	
		
		// + NAI Becar Конюшок С.Н. от 29.12.2016 17:33 
		УстановитьНомерДокументаДоговора();
		// - NAI Becar Конюшок С.Н. 		
		
		// + NAI Becar Матюхин Н.О. от 09.11.2016 14:17 по заявке № 116341
		ЗаполнитьДепозит();
		// - NAI Becar Матюхин Н.О.
		
		//-содержание услуги
		Для Каждого Стр из ДокументОснование.Номенклатура Цикл
			Если Стр.ГруппаУслуг = Справочники.АР_ГруппыУслуг.ОбеспечительныйПлатеж Тогда Продолжить; КонецЕсли;
			Если Стр.Номенклатура.АР_ПостояннаяЧастьОплаты Тогда
				НоваяСтрока = ЭтотОбъект.ПостояннаяЧастьАренднойПлаты.Добавить();
				НоваяСтрока.Услуга = Стр.Номенклатура;
				НоваяСтрока.Содержание = Стр.Содержание;
				НоваяСтрока.ГруппаУслуг = Стр.ГруппаУслуг;
				НоваяСтрока.НоменклатурнаяГруппа = ДокументОснование.НоменклатурнаяГруппа;
			Иначе
				НоваяСтрока = ЭтотОбъект.ПеременнаяЧастьАренднойПлаты.Добавить();
				НоваяСтрока.Услуга = Стр.Номенклатура;
				НоваяСтрока.Содержание = Стр.Содержание;
				НоваяСтрока.ГруппаУслуг = Стр.ГруппаУслуг;
				НоваяСтрока.НоменклатурнаяГруппа = ДокументОснование.НоменклатурнаяГруппа;
			КонецЕсли;	
		КонецЦикла;
		
		//-сроки оплаты
		ЭтотОбъект.УсловияДоговора.Очистить();
		Для Каждого Стр из ДокументОснование.СрокиОплаты Цикл
			НоваяСтрока = ЭтотОбъект.УсловияДоговора.Добавить();
			НоваяСтрока.Наименование = Стр.Наименование;
			НоваяСтрока.Функция = Стр.Функция;
			НоваяСтрока.Значение = Стр.Значение;
		КонецЦикла;	
		
	КонецЕсли;
	
