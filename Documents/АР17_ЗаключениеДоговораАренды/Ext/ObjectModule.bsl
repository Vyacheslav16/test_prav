Процедура ОтсеитьДатыпрошлогоПоРеализации(ДанныеПоМесяцам)

	ДанныеПоМесяцам.Сортировать("ПериодАренды");
	ТребуемыйПериод = Неопределено;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ХозрасчетныйОбороты.Период КАК Период
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(, , Запись, , , , КорСчет.Код <> ""51"", ) КАК ХозрасчетныйОбороты
	|ГДЕ
	|	ХозрасчетныйОбороты.Субконто2 = &Субконто2
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ";
	Запрос.УстановитьПараметр("Субконто2",ДоговорКонтрагента);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		
		ТребуемыйПериод = КонецМесяца(Выборка.Период);
		
	КонецЕсли;
	
	КолвоСтрок = ДанныепоМесяцам.Количество();
	ИндПовторений = 0;
	
	ПроверяемСтроки = КолвоСтрок > 0;
	
	Пока ПроверяемСтроки И ЗначениеЗаполнено(ТребуемыйПериод) Цикл
		
		ТекСтрока = ДанныеПоМесяцам[0];
		
		Если ТекСтрока.ПериодАренды > ТребуемыйПериод Тогда
		    Прервать;
		Иначе	
		    ДанныеПоМесяцам.Удалить(ТекСтрока);
		КонецЕсли;
		
		ИндПовторений = ИндПовторений + 1;
		
		Если ИндПовторений > КолвоСтрок ИЛИ ДанныепоМесяцам.Количество() = 0 Тогда
			ПроверяемСтроки = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	

КонецПроцедуры
