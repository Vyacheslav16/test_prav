Функция ПолучитьСодержание(Сод)
	Содержание = Сод;
	Если Найти(Содержание, "[наименование ИК]") > 0 Тогда
		Содержание = СтрЗаменить(Содержание, "[наименование ИК]", ЭтотОбъект.ИК.Наименование);
	КонецЕсли;
	Если Найти(Содержание, "[адрес место нахождения]") > 0 Тогда
		Содержание = СтрЗаменить(Содержание, "[адрес место нахождения]", ПолучитьАдрес());
	КонецЕсли;
	Если Найти(Содержание, "[номер договора]") > 0 Тогда
		Содержание = СтрЗаменить(Содержание, "[номер договора]", ЭтотОбъект.Номер);
	КонецЕсли;
	Если Найти(Содержание, "[дата договора]") > 0 Тогда
		Содержание = СтрЗаменить(Содержание, "[дата договора]", формат(ЭтотОбъект.Дата,"ДЛФ=Д"));
	КонецЕсли;
	Если Найти(Содержание, "[период]") > 0 Тогда
		//Содержание = СтрЗаменить(Содержание, "[период]", ЭтотОбъект.Дата);
	КонецЕсли;
	
	Возврат Содержание;
	
КонецФункции

Функция ПолучитьАдрес()
	Адрес = "";
	Если ЭтотОбъект.ОбъектыАренды.Количество() <> 0 Тогда
		ОбъектАренды = ЭтотОбъект.ОбъектыАренды[0].ОбъектАренды;
		Адрес = ОбъектАренды.Родитель.Родитель.Родитель.Адрес;
	КонецЕсли;
	Возврат Адрес;
КонецФункции	

