Процедура ЗаполнитьБанковскийСчетПоИКМодуль() Экспорт
	
	Если ЗначениеЗаполнено(ВидДоговора) И ЗначениеЗаполнено(ДокументОснование) Тогда
		
		Запрос = Новый Запрос();
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР_УстановкаПараметровИКДоговора.РасчетныйСчет КАК РасчетныйСчет
		               |ИЗ
		               |	Документ.АР17_УстановкаПараметровИК.Договора КАК АР_УстановкаПараметровИКДоговора
		               |ГДЕ
		               |	АР_УстановкаПараметровИКДоговора.Ссылка = &Ссылка
		               |	И АР_УстановкаПараметровИКДоговора.ВидДоговора = &ВидДоговора
		               |	И НЕ АР_УстановкаПараметровИКДоговора.РасчетныйСчет В (&Неопределено)
		               |	И АР_УстановкаПараметровИКДоговора.РасчетныйСчет.Владелец = &Владелец";
		
		
		СписокСчетов = Новый СписокЗначений;
		СписокСчетов.Добавить(Неопределено);
		СписокСчетов.Добавить(Справочники.БанковскиеСчета.ПустаяСсылка());
		
		Запрос.УстановитьПараметр("Неопределено",СписокСчетов);
		Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
		Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
		Запрос.УстановитьПараметр("Владелец", Организация);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			НайденныСчет = Выборка.РасчетныйСчет;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НайденныСчет) Тогда
		ЭтотОбъект.БанковскийСчет = НайденныСчет;
	//Иначе
	//	ЭтотОбъект.БанковскийСчет = ДокументОснование.БанковскийСчет;
	КонецЕсли;
	
КонецПроцедуры
