Функция ПолучитьДокументПроведенияАренды()
	
	ТекДоговор = ЭтотОбъект.Ссылка;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	АР17_ПроведениеДоговораАренды.Ссылка
	|ИЗ
	|	Документ.АР17_ПроведениеДоговораАренды КАК АР17_ПроведениеДоговораАренды
	|ГДЕ
	|	АР17_ПроведениеДоговораАренды.Документоснование = &Документоснование";
	
	Запрос.УстановитьПараметр("Документоснование",ТекДоговор);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе		
		ДокПроведение = Документы.АР17_ПроведениеДоговораАренды.СоздатьДокумент();
		ДокПроведение.Документоснование = ТекДоговор;
		ДокПроведение.Дата = ТекущаяДата();
		ДокПроведение.Заполнить(ТекДоговор);
		ДокПроведение.Записать();
		Возврат ДокПроведение.Ссылка;
	КонецЕсли;
	
	
