Процедура ЗаполнитьДепозит()
	
	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.Депозит.Очистить();
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_УстановкаПараметровИКНоменклатура.Номенклатура КАК Услуга,
	               |	АР_УстановкаПараметровИКНоменклатура.Содержание,
	               |	АР_УстановкаПараметровИКНоменклатура.ВидДоговора,
	               |	АР_УстановкаПараметровИКНоменклатура.ГруппаУслуг
	               |ИЗ
	               |	Документ.АР17_УстановкаПараметровИК.Номенклатура КАК АР_УстановкаПараметровИКНоменклатура
	               |ГДЕ
	               |	АР_УстановкаПараметровИКНоменклатура.ГруппаУслуг = &ГруппаУслуг
	               |	И АР_УстановкаПараметровИКНоменклатура.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка",ДокументОснование);
	Запрос.УстановитьПараметр("ГруппаУслуг",Справочники.АР_ГруппыУслуг.ОбеспечительныйПлатеж);
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ЭтотОбъект.Депозит.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);
		//НоваяСтрокаИК = ЭтотОбъект.ДепозитСодержаниеИК.Добавить();
		//ЗаполнитьЗначенияСвойств(НоваяСтрокаИК,Выборка);
	КонецЦикла;

