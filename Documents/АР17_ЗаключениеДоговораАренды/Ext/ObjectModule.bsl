Функция НайтиСледующийНомер(Префикс, ИК)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАренды.Ссылка,
	               |	ПОДСТРОКА(АР_ЗаключениеДоговораАренды.Номер, &ЧислоСимволов+1, 4) КАК Номер
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	ПОДСТРОКА(АР_ЗаключениеДоговораАренды.Номер, 1, &ЧислоСимволов) = &Префикс
				   |	И АР_ЗаключениеДоговораАренды.ИК = &ИК
				   //|	И ГОД(АР_ЗаключениеДоговораАренды.Дата) = &год
				   |	И АР_ЗаключениеДоговораАренды.Номер ПОДОБНО &Символ
	               |
				   |УПОРЯДОЧИТЬ ПО
				   |	АР_ЗаключениеДоговораАренды.Номер УБЫВ"
				   ;
				   
	ЧислоСимволов = СтрДлина(Префикс);
	Запрос.УстановитьПараметр("ЧислоСимволов",ЧислоСимволов); 
	Запрос.УстановитьПараметр("Префикс",Префикс); 
	Запрос.УстановитьПараметр("ИК",ИК);
	//Запрос.УстановитьПараметр("месяц",месяц(Источник.Дата));
	//Запрос.УстановитьПараметр("год",Год(Источник.Дата));
	Запрос.УстановитьПараметр("Символ","%/%");
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка.Сортировать("Номер Убыв");
	
	Сч = 0;
	Пока Сч < Выгрузка.Количество()-1 Цикл
		Если ЕстьКириллица(Выгрузка[Сч].Номер) Тогда 
			Выгрузка.Удалить(0);
		Иначе
			Сч = Сч+1;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Стр Из Выгрузка Цикл
		Ном = Лев(Стр.Номер,Найти(Стр.Номер,"/")-1);
		Пока СтрДлина(СокрЛП(Ном)) <4 Цикл
			Ном = "0" + СокрЛП(Ном);
		КонецЦикла;
		Стр.Номер = Ном;
	КонецЦикла;	
	
	Выгрузка.Сортировать("Номер Убыв");
	
	Если Выборка.Следующий() Тогда
		//Возврат Число(СокрЛП(Выгрузка[0].Номер)) + 1;
		Номер = ТолькоЦифрыИзСтроки(Выгрузка[0].Номер);
		Возврат Число(СокрЛП(Номер)) + 1;
	Иначе 
		Возврат "1";
	КонецЕсли;	
	
КонецФункции

Функция ЕстьКириллица(ИсходнаяСтрока) Экспорт 
	ЕстьКириллица=ложь; 
	ИсходнаяСтрока=СокрЛП(ИсходнаяСтрока); 
	Если СтрДлина(ИсходнаяСтрока)>0 Тогда 
	Для Сч=1 по СтрДлина(ИсходнаяСтрока) Цикл 
	Символ = НРег(Сред(ИсходнаяСтрока, Сч, 1)); 
	Если Найти("абвгдеёжзийклмнопрстуфхцчшщъыьэюя", Символ) Тогда 
	ЕстьКириллица=истина; 
	КонецЕсли; 
	КонецЦикла; 
	КонецЕсли; 

	Возврат ЕстьКириллица; 
КонецФункции

Функция ТолькоЦифрыИзСтроки(Знач СтрокаПроверки, УчитыватьЛидирующиеНули = Истина, УчитыватьПробелы = Истина) Экспорт 
    
    Если ТипЗнч(СтрокаПроверки) <> Тип("Строка") Тогда
        Возврат 0;
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(СтрокаПроверки) Тогда
        Возврат 0;
    КонецЕсли; 
    
    Если НЕ УчитыватьПробелы Тогда
        СтрокаПроверки = СтрЗаменить(СтрокаПроверки, " ", "");
    КонецЕсли;
    
    Стр = "";
    Для а = 1 По СтрДлина(СтрокаПроверки) Цикл
        КодСимвола = КодСимвола(Сред(СтрокаПроверки, а, 1));
        Цифра = Сред(СтрокаПроверки, а, 1);
        Если (КодСимвола >= 48 И КодСимвола <= 57) Тогда
            Стр = Стр + Цифра;
		Иначе
			Продолжить; // + NAI Becar Комментирование Смирнов А.А. от 28.03.2017 10:26
			//Прервать; //КСН 16032017 нужно, чтобы из строки вида 1/16 вернулось только 1, а не 116
        КонецЕсли; 
    КонецЦикла; 

    Если НЕ УчитыватьЛидирующиеНули Тогда
        Стр = Число(Стр);
    КонецЕсли;
    
    Возврат Стр;
    
КонецФункции

