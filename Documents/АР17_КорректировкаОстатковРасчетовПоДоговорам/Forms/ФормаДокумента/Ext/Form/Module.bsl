&НаСервере
Процедура ЗаполнитьДоговорыПоИКНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР17_ЗаключениеДоговораАренды.Ссылка Как ДоговорАренды
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАренды.Проведен
	|	И АР17_ЗаключениеДоговораАренды.ИК = &ИК";
	
	Запрос.УстановитьПараметр("ИК", Объект.ИК);
	
	РЗ = Запрос.Выполнить().Выгрузить();
	
	Объект.ВводОстатков.Загрузить(РЗ);
	
	ОбновитьОстаткиПоДаннымУчетаНаСервере();
	
КонецПроцедуры

