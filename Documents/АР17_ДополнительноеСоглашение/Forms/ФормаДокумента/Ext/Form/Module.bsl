// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИспользоватьГрафикСтавок = ПолучитьФункциональнуюОпцию("АР_ИспользоватьГрафикИзмененияСтавокВДоговорахАренды");
	Если ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
		ОчиститьГрафикиСтавки(Ложь);
	КонецЕсли;
	//ЗаполнитьСуммыПостояннойЧасти();
	
	//+са
	Если ЗначениеЗаполнено(Параметры.ЗначенияЗаполнения) Тогда
		ЭтаФорма.Заголовок = Параметры.ЗначенияЗаполнения.ВидОперации;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда //ЭтоНовый
		Объект.Статус = Перечисления.АР_СтатусДоговора.Проект;
	КонецЕсли;
	//-са
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЭтаФорма.Заголовок = Объект.ВидОперации; //-са
	//Элементы.Содержание.Видимость = ?(СокрЛП(Объект.ВидОперации) = "Письмо", Истина, Ложь);
	ПриОткрытииНаСервере();

	УстановитьВидимость();
	
	Если СокрЛП(Объект.ВидОперации) = "Письмо" Тогда
		Элементы.ГруппаУсловияДоговора.Видимость = Ложь;
		Элементы.ГруппаПриложения.Видимость = Ложь;
		Элементы.ГруппаФактическоеИсполнениеДоговора.Видимость = Ложь;
	КонецЕсли;	
	
КонецПроцедуры
// + Рогачев  Андрей от 14.06.2016  № 103091

&НаСервере
Процедура ПриОткрытииНаСервере()
	//Вставить содержимое обработчика
