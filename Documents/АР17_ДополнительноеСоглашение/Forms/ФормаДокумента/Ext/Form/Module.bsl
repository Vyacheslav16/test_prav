	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеременнаяЧастьАренднойПлатыСтавкаОткрытие(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПеременнаяЧастьАренднойПлаты.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.Ставка) Тогда
		
		Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			Предупреждение("График ставок можно создать только после записи документа!");
			Возврат;
		КонецЕсли;
		
		СтандартнаяОбработка = Ложь;
		Отказ = Ложь;
		Если Не ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
			ТекстСообщения = "Необходимо выбрать договор арендатора";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "ДоговорКонтрагента", "Объект", Отказ);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекущиеДанные.Услуга) Тогда
			ТекстСообщения = "Необходимо выбрать услугу в текущей строке";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "ПеременнаяЧастьАренднойПлаты[" + Строка(ТекущиеДанные.НомерСтроки - 1) + "].Услуга", "Объект", Отказ);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекущиеДанные.ОбъектАренды) Тогда
			ТекстСообщения = "Необходимо выбрать объект аренды в текущей строке";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "ПеременнаяЧастьАренднойПлаты[" + Строка(ТекущиеДанные.НомерСтроки - 1) + "].ОбъектАренды", "Объект", Отказ);
		КонецЕсли;
		
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("ЭтоПостояннаяЧасть", Ложь);
		ПараметрыФормы.Вставить("ДокументВладелец", Объект.Ссылка);

		ФормаГрафика = ПолучитьФорму("Справочник.АР_ГрафикиИзмененияСтавокНаУслуги.ФормаОбъекта", ПараметрыФормы, Элемент);
		ФормаГрафика.Объект.Владелец = Объект.ДоговорКонтрагента;
		ФормаГрафика.Объект.Документ = Объект.Ссылка;
		ФормаГрафика.Объект.Наименование = "График изменения ставок по услуге """ + ТекущиеДанные.Услуга + """ и объекту """ + ТекущиеДанные.ОбъектАренды + """";
		ФормаГрафика.ЗакрыватьПриВыборе = Ложь;
		ФормаГрафика.Открыть();
		
	Иначе
		
		СтандартнаяОбработка = Ложь;
		Если ТипЗнч(ТекущиеДанные.Ставка) = Тип("СправочникСсылка.АР_ГрафикиИзмененияСтавокНаУслуги") Тогда
			ПараметрыФормы = Новый Структура();
			ПараметрыФормы.Вставить("ЭтоПостояннаяЧасть", Ложь);
			ПараметрыФормы.Вставить("ДокументВладелец", Объект.Ссылка);
			ПараметрыФормы.Вставить("Ключ", ТекущиеДанные.Ставка);
			
			ФормаГрафика = ПолучитьФорму("Справочник.АР_ГрафикиИзмененияСтавокНаУслуги.ФормаОбъекта", ПараметрыФормы);
			ФормаГрафика.Открыть();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеременнаяЧастьАренднойПлатыСтавкаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПеременнаяЧастьАренднойПлаты.ТекущиеДанные;
	Если ТипЗнч(ТекущиеДанные.Ставка) = Тип("СправочникСсылка.АР_ГрафикиИзмененияСтавокНаУслуги") Тогда
		СтандартнаяОбработка = Ложь;
		Если Не ЗначениеЗаполнено(ТекущиеДанные.Ставка) Тогда
			ТекущиеДанные.Ставка = ВыбранноеЗначение;
			ЗаполнитьСуммыПостояннойЧасти();
		КонецЕсли;
