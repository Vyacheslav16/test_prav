		ТекущиеДанные.Ставка = 0;
		ОбновитьСтавку(ТекущиеДанные);
	КонецЕсли;
	
	СформироватьНадписьГрафикаСтавок(ТекущиеДанные.Ставка);
	
КонецПроцедуры

