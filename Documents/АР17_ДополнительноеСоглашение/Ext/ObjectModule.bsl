Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Если ДанныеЗаполнения <> Неопределено И ТипДанныхЗаполнения <> Тип("Структура")
		И Метаданные().ВводитсяНаОсновании.Содержит(ДанныеЗаполнения.Метаданные()) Тогда
		ДокументОснование = ДанныеЗаполнения;
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокументОснование,, "Дата, Номер, Проведен, ПометкаУдаления, Передан, Возвращен");
		ЭтотОбъект.ДокументОснование = ДанныеЗаполнения;
		ЭтотОбъект.ОбъектыАренды.Загрузить(ДанныеЗаполнения.ОбъектыАренды.Выгрузить());
		Если ЗначениеЗаполнено(ДатаОкончанияДоговора) или ДокументОснование.Автопролонгация Тогда
			ЗаполнитьТабличныеЧасти();
		КонецЕсли;
	КонецЕсли;

	ЗаполнениеДокументов.Заполнить(ЭтотОбъект, ДанныеЗаполнения);

КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)

	Дата = НачалоДня(ТекущаяДатаСеанса());
	Ответственный = Пользователи.ТекущийПользователь();

