&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ЗаписьСобственника" Тогда
		УстановитьСобственника();

		Объект.ИКСобственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(Объект.ИКСсылка).Контрагент;
		//
		Для каждого СтрокаЗдания из Объект.Здания Цикл
			СтрокаЗдания.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(СтрокаЗдания.ЗданияСсылка).Контрагент;
		КонецЦикла;
		//
		Для каждого СтрокаЭтажи из Объект.Этажи Цикл
			СтрокаЭтажи.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(СтрокаЭтажи.ЭтажиСсылка).Контрагент;	
		КонецЦикла;
		//
		Для каждого СтрокаОфисы из Объект.Офисы Цикл
			СтрокаОфисы.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(СтрокаОфисы.ОфисыСсылка).Контрагент;	
		КонецЦикла;
		//
		Для каждого СтрокаПомещения из Объект.Помещения Цикл
			СтрокаОфисы.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(СтрокаПомещения.ПомещенияСсылка).Контрагент;	
		КонецЦикла;
// + Рогачев  Андрей от 13.10.2016  № 113703
		ЭтаФорма.Прочитать();
		ОбновитьОтображениеДанных();
	КонецЕсли;
	Если ИмяСобытия = "ПослеЗаписиЗдания" Тогда
		ЭтаФорма.Прочитать();
		Объект.Здания.Очистить();
		ЗаполнитьЗдания();
		// + NAI Becar Конюшок С.Н. от 20.10.2016 17:36 
		Объект.ЗемельныеУчастки.Очистить();
		ЗаполнениеПараметровЗУ();
		// - NAI Becar Конюшок С.Н. 
		Записать();
		ЭтаФорма.Прочитать();
		ОбновитьОтображениеДанных();
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьСобственника()
	НоваяЗапись = РегистрыСведений.АР_СобственникиОбъектовАренды.СоздатьМенеджерЗаписи();
	НоваяЗапись.Период = Объект.Дата;//ТекущаяДата();
	НоваяЗапись.ОбъектАренды = Объект.ИКСсылка;
	НоваяЗапись.Контрагент = Объект.ИКСобственник;
	НоваяЗапись.ДоговорКонтрагента = Объект.ИКДоговор;
	НоваяЗапись.Записать();
КонецПроцедуры	
	

