&НаКлиенте
Процедура ЗаполнитьСЛиста(Команда)
	
		Отказ = Ложь;
		Если Книга = Неопределено Тогда
			ОткрытьКнигу(Отказ);
			Возврат;
		КонецЕсли;
		
		Этажей = 0;
		Для Лист = 1 по Книга.Sheets.Count Цикл
			План = Книга.Sheets(Лист);
			
			Если СокрЛП(Нрег(План.Name)) = "реквизиты" Тогда Продолжить; КонецЕсли;
			Этажей = Этажей + 1;
			
			НайденныйОбъект = НайтиОбъект(План.Name,"Этаж",Элементы.Здания.ТекущиеДанные.ЗданияСсылка);
			Если СокрЛП(НайденныйОбъект) = "" Тогда
				СохранитьОбъект(План.Name,"Этаж",Элементы.Здания.ТекущиеДанные.ЗданияСсылка,Элементы.Здания.ТекущиеДанные.РасположениеНаПлане);
			КонецЕсли;	
			
			СписокОбъектов = Новый СписокЗначений;
			СписокТекстбоксов = Новый СписокЗначений;
			Для Ном = 1 по План.Shapes().Count() Цикл
				Если План.Shapes(Ном).Type() = 17 Тогда
					СписокТекстбоксов.Добавить(План.Shapes(Ном).Name);
				ИначеЕсли (План.Shapes(Ном).Type() = 5) ИЛИ (План.Shapes(Ном).Type() = 1 И (План.Shapes(Ном).AutoShapeType < 105 
						ИЛИ План.Shapes(Ном).AutoShapeType > 108)) Тогда
					СписокОбъектов.Добавить(План.Shapes(Ном).Name);
				КонецЕсли;
			КонецЦикла;

			Для Каждого Элемент Из СписокОбъектов Цикл
				КомОбъект = План.Shapes(Элемент.Значение);
				// Ищем текстбокс для объекта
				ОбъектТекст = Неопределено;
				Для Каждого ЭлементТекст Из СписокТекстбоксов Цикл
					ОбъектТекст = План.Shapes(ЭлементТекст.Значение); 
					Если КомОбъект.Left <= ОбъектТекст.Left И КомОбъект.Top <= ОбъектТекст.Top
						И КомОбъект.Left + КомОбъект.Width >= ОбъектТекст.Left + ОбъектТекст.Width И КомОбъект.Top + КомОбъект.Height >= ОбъектТекст.Top + ОбъектТекст.Height Тогда // Нашли текстбокс
						Прервать;
					Иначе
						ОбъектТекст = Неопределено;
					КонецЕсли;
				КонецЦикла;
				
				ИмяОбласти = ?(ОбъектТекст = Неопределено, "", ОбъектТекст.Name);
				
				Родитель = НайтиОбъект(План.Name,"Этаж",Элементы.Здания.ТекущиеДанные.ЗданияСсылка);
				НайденныйОбъект = НайтиОбъект(КомОбъект.Name,"Офис",Родитель);
				Если СокрЛП(НайденныйОбъект) = "" Тогда
					СохранитьОбъект(КомОбъект.Name, "Офис", Родитель,Элементы.Здания.ТекущиеДанные.РасположениеНаПлане);
				КОнецЕсли;	
				РодительПомещения = НайтиОбъект(КомОбъект.Name,"Офис",Родитель);
				НайденныйОбъект = НайтиОбъект(КомОбъект.Name,"Помещение",РодительПомещения);
				Если СокрЛП(НайденныйОбъект) = "" Тогда
					СохранитьОбъект(КомОбъект.Name, "Помещение", РодительПомещения, Элементы.Здания.ТекущиеДанные.РасположениеНаПлане);
				КонецЕсли;	
				//
				//СохранитьПланировку(План.Name,"Этаж",План.Name);
				СохранитьПланировку(СокрЛП(Элементы.Здания.ТекущиеДанные.ЗданияСсылка) + "/" + СокрЛП(План.Name) + "/" + СокрЛП(КомОбъект.Name), "Помещение", План.Name, КомОбъект.Name, Элементы.Здания.ТекущиеДанные.РасположениеНаПлане, Элементы.Здания.ТекущиеДанные.ЗданияСсылка);
				
			КонецЦикла;
			
		КонецЦикла;	
		
		Книга.Close(Ложь);
		Книга = Неопределено;	
		//ЭтаФорма.Закрыть();

		СохранитьЭтажность(Элементы.Здания.ТекущиеДанные.ЗданияСсылка, Этажей);
		
КонецПроцедуры

