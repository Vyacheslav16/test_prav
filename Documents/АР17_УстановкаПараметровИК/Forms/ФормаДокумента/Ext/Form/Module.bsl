&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда
		Элементы.ГруппаНаименование.ТекущаяСтраница = Элементы.ГруппаНаименование1;
	Иначе
		Элементы.ГруппаНаименование.ТекущаяСтраница = Элементы.ГруппаНаименование2;
	КонецЕсли;
	
	//+са
	Номер = Объект.ПрефиксДоговора; 
	
	Номер = СтрЗаменить(Номер, "[Номер по порядку]", "1");
	Если ЗначениеЗаполнено(Объект.Арендодатель) Тогда
		//ПрефиксОрганизации = ПолучитьПрефиксОрганизации(Объект.Арендодатель);
		Номер = СтрЗаменить(Номер, "[Организация]", Объект.Арендодатель.ПолучитьОбъект().Префикс);
	КонецЕсли;	
	Номер = СтрЗаменить(Номер, "[Имущественный комплекс]", СокрЛП(Объект.ПрефиксИК));	
	Номер = СтрЗаменить(Номер, "[Вид договора]", "ВД");
	Номер = СтрЗаменить(Номер, "[Месяц договора]", Формат(ТекущаяДата(),"ДФ=MM"));	
	Номер = СтрЗаменить(Номер, "[Год договора]", Формат(ТекущаяДата(),"ДФ=гг"));	
	Номер = СтрЗаменить(Номер, "[Дата договора]", Формат(ТекущаяДата(),"ДФ=гг"));
	
	Форма.Образец = Номер;
	//-са
	
КонецПроцедуры


&НаКлиенте
Процедура Согласовать(Команда)
	Объект.Согласован = Истина;
	Если Не ОтправитьПисьмо() Тогда
		Предупреждение("ОшибкаОтправки");
	Иначе
		//Предупреждение("Письмо отправлено");
		Элементы.Согласовать.Доступность = Ложь;
	КонецЕсли;
