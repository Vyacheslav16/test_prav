&НаКлиенте
Процедура СогласованПриИзменении(Элемент)
	Если Объект.Согласован Тогда
		УстановитьПризнакСогласован(Истина);
	Иначе
		УстановитьПризнакСогласован(Ложь);
	КонецЕсли;		
КонецПроцедуры

Процедура УстановитьПризнакСогласован(Состояние)
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР_ОбъектыАренды.Ссылка
		               |ИЗ
		               |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		               |ГДЕ
		               |	АР_ОбъектыАренды.Ссылка В ИЕРАРХИИ(&Ссылка)";
					   
		Запрос.УстановитьПараметр("Ссылка", Объект.ИКСсылка);
		Выгрузка = Запрос.Выполнить().Выгрузить();
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ОбъектАренды = Выборка.Ссылка.ПолучитьОбъект();
			ОбъектАренды.ПризнакСогласован = Состояние;
			ОбъектАренды.Записать();
		КонецЦикла;	
	КонецПроцедуры
	
	&НаСервереБезКонтекста
	//Процедура ДоговорыГруппаНачалоВыбора1(Элемент, ДанныеВыбора, СтандартнаяОбработка)
Функция ПолучитьДоговорыНаСервере()
		ТабНоменклатуры=Новый СписокЗначений;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ТабНоменклатуры = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
		
		Возврат ТабНоменклатуры;
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
КонецФункции

