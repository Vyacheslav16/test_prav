&НаСервере
Процедура ПолучитьПлощадьИК()
	
	Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
                   |	АР_ОбъектыАренды.Ссылка,
                   |	АР_ОбъектыАренды.ЗначениеХарактеристики,
                   |	АР_ОбъектыАренды.МОП,
                   |	АР_ОбъектыАренды.АП,
                   |	АР_ОбъектыАренды.ТП,
                   |	АР_ОбъектыАренды.ВП
                   |ИЗ
                   |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
                   |ГДЕ
                   |	АР_ОбъектыАренды.Родитель = &Родитель
                   |	И АР_ОбъектыАренды.ТипОбъекта = &ТипОбъекта
				   //|	И АР_ОбъектыАренды.АР_Москва = &АР_Москва
				   //|	И АР_ОбъектыАренды.АР_СанктПетербург = &АР_СанктПетербург
				   |";
				   
	Запрос.УстановитьПараметр("Родитель", Объект.ИКСсылка);
	Запрос.УстановитьПараметр("ТипОбъекта", Справочники.АР_ТипыОбъектовАренды.Здание);
	//Запрос.УстановитьПараметр("АР_Москва",Объект.ИКСсылка.АР_Москва);
	//Запрос.УстановитьПараметр("АР_СанктПетербург",Объект.ИКСсылка.АР_СанктПетербург);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ОбщаяПлощадь = 0;
	ПлощадьМОП = 0;
	ПлощадьВП = 0;
	ПлощадьТП = 0;
	ПлощадьАП = 0;
	Пока Выборка.Следующий() Цикл
		ОбщаяПлощадь = ОбщаяПлощадь + Выборка.ЗначениеХарактеристики;
		ПлощадьМОП = ПлощадьМОП + Выборка.МОП;
		ПлощадьВП = ПлощадьВП + Выборка.ВП;
		ПлощадьТП = ПлощадьТП + Выборка.ТП;
		ПлощадьАП = ПлощадьАП + Выборка.АП;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Объект.ИКСсылка) Тогда // Не ЭтоНовый
		ОбОбъект = Объект.ИКСсылка.ПолучитьОбъект();
		ОбОбъект.ЗначениеХарактеристики = ОбщаяПлощадь;
		ОбОбъект.МОП = ПлощадьВП;
		ОбОбъект.ВП = ПлощадьВП;
		ОбОбъект.ТП = ПлощадьТП;
		ОбОбъект.АП = ПлощадьАП;
		ОбОбъект.Записать();
		ДокОбъект = Объект.Ссылка.ПолучитьОбъект();
		ДокОбъект.ИКОбщаяПлощадь = ОбщаяПлощадь;
		ДокОбъект.Записать();
	КонецЕсли;	
	
КонецПроцедуры


&НаСервере
Функция НайтиОбъект(Наименование,ТипОбъекта,Родитель)
	
	НайденныйОбъект = Справочники.АР_ОбъектыАренды.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	АР_ОбъектыАренды.Ссылка
	                |ИЗ
	                |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	                |ГДЕ
	                |	АР_ОбъектыАренды.Наименование = &Наименование
	                |	И АР_ОбъектыАренды.ТипОбъекта = &ТипОбъекта
	                |	И АР_ОбъектыАренды.Родитель = &Родитель
					//|	И АР_ОбъектыАренды.АР_Москва = &АР_Москва
					//|	И АР_ОбъектыАренды.АР_СанктПетербург = &АР_СанктПетербург
					|";
					
	Запрос.УстановитьПараметр("Наименование",Наименование);
	Запрос.УстановитьПараметр("ТипОбъекта",Справочники.АР_ТипыОбъектовАренды.НайтиПоНаименованию(ТипОбъекта));
	Запрос.УстановитьПараметр("Родитель",Родитель);
	//Запрос.УстановитьПараметр("АР_Москва",Родитель.АР_Москва);
	//Запрос.УстановитьПараметр("АР_СанктПетербург",Родитель.АР_СанктПетербург);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НайденныйОбъект = Выборка.Ссылка;
	КонецЦикла;
	
	Возврат НайденныйОбъект;
	
	
КонецФункции	


