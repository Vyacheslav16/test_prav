Процедура НесколькоКонтрагентов()
	Если Объект.НесколькоКонтрагентов = Истина Тогда
		Элементы.ГруппаКонтрагентДоговор1.Видимость = Ложь;
		Элементы.ГруппаКонтрагентДоговор2.Видимость = Истина;
		
		Если Объект.ИКСсылка <> Справочники.АР_ОбъектыАренды.ПустаяСсылка() Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	АР_ОбъектыАренды.Ссылка,
			               |	АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент
			               |ИЗ
			               |	РегистрСведений.АР_СобственникиОбъектовАренды.СрезПоследних КАК АР_СобственникиОбъектовАрендыСрезПоследних
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
			               |		ПО АР_СобственникиОбъектовАрендыСрезПоследних.ОбъектАренды = АР_ОбъектыАренды.Ссылка
			               |ГДЕ
			               |	АР_ОбъектыАренды.Ссылка В ИЕРАРХИИ(&ИК)
			               |	И АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент <> ЗНАЧЕНИЕ(Справочник.АР_Контрагенты.ПустаяСсылка)
			               |	И АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент.Наименование <> """"";
						   
			Запрос.УстановитьПараметр("ИК",Объект.ИКСсылка);
			Результат = Запрос.Выполнить().Выгрузить();
			Результат.Свернуть("Контрагент");
			// + Рогачев  Андрей от 20.07.2016  № 106552
			//Объект.Контрагенты.Загрузить(Результат);
		КонецЕсли;	
	Иначе
		Элементы.ГруппаКонтрагентДоговор1.Видимость = Истина;
		Элементы.ГруппаКонтрагентДоговор2.Видимость = Ложь;
	КонецЕсли;	

