Функция НайтиПолучателей()
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПользователиКонтактнаяИнформация.Ссылка,
	               |	ПользователиКонтактнаяИнформация.АдресЭП
	               |ИЗ
	               |	Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация";
				   
				   
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("АдресЭП", Новый ОписаниеТипов("Строка"));
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если НЕ Выборка.Следующий() Тогда
		Возврат Неопределено;
	КонецЕсли;
	//Пока Выборка.Следующий() Цикл        
	Для Каждого Пользователь из Выгрузка Цикл
        ПользовательИмя = Пользователь.Ссылка.Наименование;                
        ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ПользовательИмя);
		
		//Пользователь.Ссылка.Роли.Содержит(Метаданные.Роли["АР_Руководитель"])
		
		Если ПользовательИБ <> Неопределено Тогда
			Если ПользовательИБ.Роли.Содержит(Метаданные.Роли["АР_Руководитель"]) Тогда
				Стр = Результат.Добавить();
				Стр.АдресЭП = Пользователь.АдресЭП;
			КонецЕсли; 
		КонецЕсли;	
    КонецЦикла;        
	
	УстановитьПривилегированныйРежим(Ложь);
	
	//Результат = Запрос.Выполнить().Выгрузить();
	Возврат Результат;
				   
КонецФункции	

