&НаКлиенте
Процедура ОткрытьКнигу(Отказ)
	
	Если Элементы.Здания.ТекущиеДанные = Неопределено Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Добавьте здание";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	Иначе	
		ПолноеИмяФайла = НайтиПланировку(Элементы.Здания.ТекущиеДанные.РасположениеНаПлане);
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(ПолноеИмяФайла) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Файл = Новый Файл(ПолноеИмяФайла);
	Если Не Файл.Существует() Тогда
		Сообщить("Файл """ + СокрЛП(ПолноеИмяФайла) + """ не существует!", СтатусСообщения.Важное);
		Отказ = Истина;
	Иначе
		Книга = Excell.Workbooks.Open(ПолноеИмяФайла,, Истина);
	КонецЕсли;
		
КонецПроцедуры

