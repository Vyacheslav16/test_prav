&НаСервере
Функция ПолучитьСобственника(ОбъектАренды, Дата = '00010101')
	
СтруктураДанных = Новый Структура("Контрагент, АгентскаяСхема, ДоговорКонтрагента, Период");
	СтруктураДанных.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
	СтруктураДанных.АгентскаяСхема = Ложь;
	СтруктураДанных.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(ОбъектАренды) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", ОбъектАренды);
		Запрос.УстановитьПараметр("Период", Дата);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	1 КАК Порядок,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.АгентскаяСхема КАК АгентскаяСхема,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.Период КАК Период
		|ИЗ
		|	РегистрСведений.АР_СобственникиОбъектовАренды.СрезПоследних(&Период, ОбъектАренды = &Ссылка) КАК АР_СобственникиОбъектовАрендыСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.АгентскаяСхема,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.ДоговорКонтрагента,
		|	АР_СобственникиОбъектовАрендыСрезПоследних.Период
		|ИЗ
		|	РегистрСведений.АР_СобственникиОбъектовАренды.СрезПоследних(&Период, ОбъектАренды = ЗНАЧЕНИЕ(Справочник.АР_ОбъектыАренды.ПустаяСсылка)) КАК АР_СобственникиОбъектовАрендыСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок";
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
// + Рогачев  Андрей от 20.07.2016  № 106552
			//ЗаполнитьЗначенияСвойств(СтруктураДанных, Выборка);
		КонецЕсли; 
	КонецЕсли;
	
	Возврат СтруктураДанных;
	
КонецФункции

&НаСервере
Процедура ЗаписатьСобственника(Ссылка)
	
	Если СокрЛП(Объект.ИКСобственник) <> "" Тогда
		НаборЗаписейРегистра = РегистрыСведений.АР_СобственникиОбъектовАренды.СоздатьНаборЗаписей();
		ЗаписьРегистра = НаборЗаписейРегистра.Добавить();
		СтруктураДанных = ПолучитьСобственника(Объект.ИКСсылка);

// + Рогачев  Андрей от 25.07.2016  № 106552
		//ЗаписьРегистра.Период = СтруктураДанных.Период;
		ЗаписьРегистра.Период = ?(СтруктураДанных.Период=Неопределено,Объект.Дата,СтруктураДанных.Период);
		ЗаписьРегистра.ОбъектАренды = Ссылка;
		ЗаписьРегистра.Контрагент = СтруктураДанных.Контрагент;
		ЗаписьРегистра.ДоговорКонтрагента = СтруктураДанных.ДоговорКонтрагента;
		ЗаписьРегистра.АгентскаяСхема = СтруктураДанных.АгентскаяСхема;
		НаборЗаписейРегистра.Записать();
	КонецЕсли;	
	
КонецПроцедуры	

