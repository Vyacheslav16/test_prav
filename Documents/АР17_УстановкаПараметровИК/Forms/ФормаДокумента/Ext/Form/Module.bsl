&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьПривилегированныйРежим(Истина);
	ТекушийПользователь = ПолучитьТекущегоПользователя();
	
    //ПользовательИмя = Выборка.Ссылка.Наименование;                
	//ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ТекушийПользователь.Наименование);

	ПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();
	
	Если ПользовательИБ <> Неопределено Тогда
		Если НЕ ПользовательИБ.Роли.Содержит(Метаданные.Роли["АР_Руководитель"])
			и НЕ ПользовательИБ.Роли.Содержит(Метаданные.Роли["ПолныеПрава"])
			Тогда
			//Элементы.Согласован.Доступность = Ложь;
			//Элементы.Согласовать.Доступность = Ложь;
			Если Объект.Согласован Тогда
				ЭтаФорма.ТолькоПросмотр = Истина;
			КонецЕсли;			
		КонецЕсли; 
	КонецЕсли;	
	УстановитьПривилегированныйРежим(Ложь);
	
	//Если Не ТекушийПользователь.АР_Руководитель Тогда
	//	Элементы.Согласован.Доступность = Ложь;
	//КонецЕсли;
	НесколькоКонтрагентов();
	КоэффициентАрендопригодности = 0;
	Для Каждого стр из Объект.Здания Цикл
		КоэффициентАрендопригодности = Стр.КоэффициентАП;
	КонецЦикла;	
	Объект.КоэффициентАрендопригодности = КоэффициентАрендопригодности;

	УправлениеФормой(ЭтаФорма);
	// + Рогачев  Андрей от 09.08.2016  № 104498
	Если ЗначениеЗаполнено(Объект.Ссылка) = Ложь Тогда //ЭтоНовый
		Объект.ИКНаименование="";
	КонецЕсли;
	// + Рогачев  Андрей от 02.12.2016  № 118456
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Ответственный =ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьТекущегоПользователя()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Пользователи.Ссылка
	               |ИЗ
	               |	Справочник.Пользователи КАК Пользователи
	               |ГДЕ
	               |	Пользователи.Ссылка.Наименование = &Ссылка
	               |	И Пользователи.ПометкаУдаления = ЛОЖЬ";
				   
	ТекушийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
	Запрос.УстановитьПараметр("Ссылка",СокрЛП(ТекушийПользователь.ПолноеИмя));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если НЕ Выборка.Следующий() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Выборка.Ссылка;
	КонецЕсли;

КонецФункции	

&НаКлиенте
Процедура ДобавитьКонтрагента(Команда)
	
	П = Новый Структура;
	П.Вставить("Объект", Объект);
	Форма = ПолучитьФорму("Справочник.АР_Контрагенты.Форма.ФормаЭлемента",П,ЭтаФорма);
	Рез = Форма.ОткрытьМодально();
	Объект.ИКСобственник = Форма.Параметры.Ключ;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДоговор(Команда)
	Если ЗначениеЗаполнено(Объект.ИКСобственник) Тогда
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Владелец", Объект.ИКСобственник);
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ключ", Объект.ИКДоговор);
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ФормаДоговора = ПолучитьФорму("Справочник.АР_ДоговорыКонтрагентов.ФормаОбъекта",ПараметрыФормы,ЭтаФорма); //.Форма.ФормаЭлемента",П,ЭтаФорма);
		Рез = ФормаДоговора.ОткрытьМодально();
		Объект.ИКДоговор = ФормаДоговора.Параметры.Ключ;
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заполните собственника";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьДепозит(Команда)
	Если Не ЗначениеЗаполнено(Объект.ВалютаДепозита) Тогда
		ТекстСообщения = ОбщегоНазначенияБПКлиентСервер.ПолучитьТекстСообщения(,, НСтр("ru = 'Валюта депозита'"),,, ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "ВалютаДепозита", "Объект", );
		Возврат;
	КонецЕсли;
	
	Если ЗаписатьДокумент("рассчитать размер депозита") Тогда 
		СуммаЗалога = АР_ОбщиеПроцедуры.РассчитатьЗалог(Объект.Ссылка, Объект.ВалютаДепозита, Объект.СпособРасчетаЗалога, "Депозит");
		Если ЗначениеЗаполнено(СуммаЗалога) Тогда
			Объект.СуммаЗалога = СуммаЗалога;
			Модифицированность = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ПостояннаяЧастьАренднойПлаты.Количество()<>0 тогда 
		Если Не ЗначениеЗаполнено(Объект.СтавкаНДСЗалога) И ЗначениеЗаполнено(Объект.ПостояннаяЧастьАренднойПлаты[0].Услуга) тогда
			Объект.СтавкаНДСЗалога = ОбщегоНазначенияБПВызовСервера.ЗначениеРеквизитаОбъекта(Объект.ПостояннаяЧастьАренднойПлаты[0].Услуга, "СтавкаНДС");
			Модифицированность = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ЗаписатьДокумент(Действие)
	
   Если Модифицированность ИЛИ Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если Вопрос("Автоматически " + Действие + " можно только после записи документа. Записать?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Возврат Записать();
		
	КонецЕсли;
	
	Возврат Истина;
 	
КонецФункции


