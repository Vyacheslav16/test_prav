			  //Рез = ФормаОбъекта.ОткрытьМодально();
			//ФормаОбъекта.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			//ОткрытьФорму("Справочник.АР_ОбъектыАренды.ФормаОбъекта",П,ЭтаФорма);
			ФормаОбъекта.Открыть();
