&НаКлиенте
Процедура СобственникиДоговорНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	МассивПараметров = Новый Массив;
	Если ЗначениеЗаполнено(Элементы.Собственники.ТекущиеДанные.Контрагент) Тогда
	    НовыйПараметр = Новый ПараметрВыбора("Отбор.Владелец", Элементы.Собственники.ТекущиеДанные.Контрагент);
	    МассивПараметров.Добавить(НовыйПараметр);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Арендодатель) Тогда
	    НовыйПараметр = Новый ПараметрВыбора("Отбор.Организация", Объект.Арендодатель);
	    МассивПараметров.Добавить(НовыйПараметр);
	КонецЕсли;
	
    НовыйПараметр = Новый ПараметрВыбора("Отбор.ВидДоговора", ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомитентом"));
    МассивПараметров.Добавить(НовыйПараметр);
	
	Элементы.СобственникиДоговор.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);

КонецПроцедуры


 


