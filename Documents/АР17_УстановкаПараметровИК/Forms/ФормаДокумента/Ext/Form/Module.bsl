&НаСервере
Процедура ЗаполнениеПараметровЗУ()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_ОбъектыАренды.Ссылка КАК ЗемельныйУчасток,
	|	АР_ОбъектыАренды.ЗначениеХарактеристики КАК ОбщаяПлощадь,
	|	АР_ОбъектыАренды.ЕдиницаИзмерения КАК ЕдиницыИзмерения,
	|	АР_ОбъектыАренды.ИспользованиеЗУ КАК Использование,
	|	АР_ОбъектыАренды.НазначениеЗУ КАК Назначение,
	|	АР_ОбъектыАренды.СтатусЗУ КАК Статус,
	|	АР_ОбъектыАренды.РасположениеНаПлане
	|ИЗ
	|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	|ГДЕ
	|	АР_ОбъектыАренды.ТипОбъекта = &ЗУ
	|	И АР_ОбъектыАренды.Родитель = &ИК
	|	И АР_ОбъектыАренды.ПометкаУдаления = ЛОЖЬ";
	
	
	Запрос.УстановитьПараметр("ЗУ", Справочники.АР_ТипыОбъектовАренды.ЗемельныйУчасток);
	Запрос.УстановитьПараметр("ИК", Объект.ИКСсылка);
	
	РЗ = Запрос.Выполнить().Выгрузить();
	Объект.ЗемельныеУчастки.Загрузить(РЗ);  
КонецПроцедуры

