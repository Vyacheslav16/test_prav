		// - NAI Becar Конюшок С.Н. 	
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ПолучитьСправочник(Родитель)
	
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	АР_ОбъектыАренды.Ссылка,
	                |	АР_ОбъектыАренды.Наименование КАК Наименование,
	                |	АР_ОбъектыАренды.ЗначениеХарактеристики,
	                |	АР_ОбъектыАренды.ЕдиницаИзмерения,
	                |	АР_ОбъектыАренды.РасположениеНаПлане,
	                |	АР_ОбъектыАренды.Назначение,
	                |	АР_ОбъектыАренды.ОписаниеОбъектаАренды
	                |ИЗ
	                |	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	                |ГДЕ
	                |	АР_ОбъектыАренды.Родитель = &Родитель
	                |	И АР_ОбъектыАренды.ПометкаУдаления = ЛОЖЬ
	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	Наименование";
					
	Запрос.УстановитьПараметр("Родитель",Родитель);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	
	МассивЗнч = Новый Массив;
 
	Для Каждого СтрТЗ ИЗ Выгрузка Цикл 

		СтруктураВМассив = Новый Структура;
		СтруктураВМассив.Вставить("Наименование" , СтрТЗ.Наименование);
		СтруктураВМассив.Вставить("ЗначениеХарактеристики" , СтрТЗ.ЗначениеХарактеристики);
		СтруктураВМассив.Вставить("ЕдиницаИзмерения" , СтрТЗ.ЕдиницаИзмерения);
		СтруктураВМассив.Вставить("РасположениеНаПлане" , СтрТЗ.РасположениеНаПлане);
		СтруктураВМассив.Вставить("Ссылка" , СтрТЗ.Ссылка);
		СтруктураВМассив.Вставить("Назначение" , СтрТЗ.Назначение);
		СтруктураВМассив.Вставить("Примечание" , СтрТЗ.ОписаниеОбъектаАренды);

		МассивЗнч.Добавить(СтруктураВМассив);

	КонецЦикла; 
	
	Возврат МассивЗнч;
	
КонецФункции	

