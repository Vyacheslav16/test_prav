			Стр.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(Стр.ОфисыСсылка).Контрагент;
		КонецЦикла;	
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПомещения Тогда
		Объект.Помещения.Очистить();
		Если Элементы.Офисы.ТекущиеДанные = Неопределено Тогда
			Сообщить("Не выбран офис!");
			Возврат;
		КонецЕсли;	
		ТЗ = ПолучитьСправочник(Элементы.Офисы.ТекущиеДанные.ОфисыСсылка);
		Если ТЗ.Количество() = 0 Тогда
			Родитель = Элементы.Офисы.ТекущиеДанные.ОфисыСсылка;
			Сообщение = Новый СообщениеПользователю();
			СохранитьОбъект("Помещение 1","Помещение",Родитель,);
			Сообщение.Текст = "Создан помещение 1";
			Сообщение.Сообщить();
		КонецЕсли;
		ТЗ = ПолучитьСправочник(Элементы.Офисы.ТекущиеДанные.ОфисыСсылка);
		//ТЗ.Сортировать("Наименование+");
		//ТЗ = Новый ТаблицаЗначений;
		//ТЗ1.Выгрузить(ТЗ);
		Для каждого СтрокаТаб из ТЗ Цикл
			Стр = Объект.Помещения.Добавить();
			Стр.Наименование = СтрокаТаб.Ссылка;
			Стр.ОбщаяПлощадь = СтрокаТаб.ЗначениеХарактеристики;
			Стр.ЕдиницаИзмерения = СтрокаТаб.ЕдиницаИзмерения;
			Стр.ПомещенияСсылка = СтрокаТаб.Ссылка;
			Стр.РасположениеНаПлане = ПолучитьРасположениеНаПлане(СокрЛП(Элементы.Здания.ТекущиеДанные.ЗданияСсылка) + "/" + СокрЛП(Элементы.Этажи.ТекущиеДанные.ЭтажиСсылка) + "/" + Стр.Наименование);//СтрокаТаб.РасположениеНаПлане;
			Стр.Собственник = АР_ОбщиеПроцедуры.ПолучитьСобственника(Стр.ПомещенияСсылка).Контрагент;
			Стр.Договор = АР_ОбщиеПроцедуры.ПолучитьСобственника(Стр.ПомещенияСсылка).ДоговорКонтрагента;
			Стр.Назначение = СтрокаТаб.Назначение;
			Стр.Примечание = СтрокаТаб.Примечание;
		КонецЦикла;
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНоменклатура Тогда
		// + NAI Becar Конюшок С.Н. от 20.10.2016 16:35 	
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ЗемельныйУчасток Тогда
