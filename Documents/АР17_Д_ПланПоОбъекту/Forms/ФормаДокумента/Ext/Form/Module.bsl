	ЗаполнитьСтроку();
КонецПроцедуры

&НаКлиенте
Процедура ТЧПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ТекущиеДанные = Элементы.ТЧ.ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда
		Если ТекущиеДанные.НомерСтроки > 0 Тогда
			Строка = Объект.ТЧ.Добавить();       
			Строка.Месяц = ДобавитьМесяц(Объект.ТЧ[Объект.ТЧ.Количество()-2].Месяц,1);
			Строка.КоличествоДней = Лев(КонецМесяца(Строка.Месяц),2);
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

