&НаСервере
Процедура ПодготовитьФормуНаСервере()

	ОбщегоНазначенияБПКлиентСервер.УстановитьПараметрыФункциональныхОпцийФормыДокумента(ЭтаФорма);
	
	ВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	ВыписыватьСчетФактуру = Истина;
	//СчетФактура = УчетНДСПереопределяемый.НайтиПодчиненныйСчетФактуруВыданныйНаРеализацию(Объект.Ссылка);
	СчетФактура = НайтиПодчиненныйСчетФактуруВыданныйНаРеализацию(Объект.Ссылка);
		
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
	ПоказыватьВДокументахСчетаУчета	= Истина;
	
	УстановитьПараметрыВыбора(ЭтаФорма);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", КонецДня(Объект.Дата));
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АР_СобственникиОбъектовАрендыСрезПоследних.ОбъектАренды,
	|	АР_СобственникиОбъектовАрендыСрезПоследних.Контрагент
	|ИЗ
	|	РегистрСведений.АР_СобственникиОбъектовАренды.СрезПоследних(&Период, ) КАК АР_СобственникиОбъектовАрендыСрезПоследних
	|ГДЕ
	|	АР_СобственникиОбъектовАрендыСрезПоследних.АгентскаяСхема";
	Выборка = Запрос.Выполнить().Выбрать();
	ВидимостьАгентскойСхемы =  Выборка.Следующий();
	// + NAI Becar Комментирование Смирнов А.А. от 13.09.2016 11:36
	// сделали для агентской схемы 
	ВидимостьАгентскойСхемы = Истина;
	// - NAI Becar Комментирование Смирнов А.А.	
	
	ЭтаФорма.ТребуетсяСчетФактура = ЗначениеЗаполнено(Объект.ДоговорКонтрагента);
	ЗаполнитьТекстПроСчетФактуру(ЭтаФорма);
	
	ВыборПериодаКлиентСервер.ЗаполнитьСписокВыбораВидПериода(
		ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День"),
		Элементы.ВидПериода.СписокВыбора, Объект.ВидПериода);
		
	УправлениеФормой(ЭтаФорма);
	
	Если НЕ Объект.ВалютаДокумента = ВалютаРегламентированногоУчета И Элементы.ФормаПечать.ПодчиненныеЭлементы.Количество() > 0 Тогда
		Элементы.ФормаПечать.ПодчиненныеЭлементы.ФормаДокументАР17_НачислениеАренднойПлатыПечатьАктРуб.Заголовок = 
								Метаданные.Документы.АР17_НачислениеАренднойПлаты.Команды.ПечатьАктРуб.Синоним + " (руб.)";
		Элементы.ФормаПечать.ПодчиненныеЭлементы.ФормаДокументАР17_НачислениеАренднойПлатыПечатьАктСводныйРуб.Заголовок = 
								Метаданные.Документы.АР17_НачислениеАренднойПлаты.Команды.ПечатьАктСводныйРуб.Синоним + " (руб.)";
	КонецЕсли;
							
	ВидимостьСобственника(); //-са
	
	УстановитьСостояниеДокумента();
	
