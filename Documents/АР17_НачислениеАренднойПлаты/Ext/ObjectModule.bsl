Процедура УстановитьНомерДокумента() Экспорт

	Если (ЭтотОбъект.Организация.Код = "000000143") или (ЭтотОбъект.Организация.Код = "000010189") 
		Тогда
		//ЭтотОбъект.УстановитьНовыйНомер(ЭтотОбъект.Организация.Префикс);
		НовыйНомер = Лев(ЭтотОбъект.Номер,6) + Сред(ЭтотОбъект.Номер,10,12) 
		+ "/" + Формат(ЭтотОбъект.Дата, "ДФ=ММ");
		Сообщить(НовыйНомер);
		ЭтотОбъект.Номер = НовыйНомер;
		
		// + NAI Becar Гайфетдинов Р.И. от 10.09.2015 17:03
		Если ЭтотОбъект.Организация.Код = "000000143" Тогда 
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	АР_НачислениеАренднойПлаты.Номер КАК Номер
			|ИЗ
			|	Документ.АР17_НачислениеАренднойПлаты КАК АР_НачислениеАренднойПлаты
			|ГДЕ
			|	АР_НачислениеАренднойПлаты.Организация.Код = &Код
			|	И АР_НачислениеАренднойПлаты.Дата МЕЖДУ &Дата1 И &Дата2
			|	И АР_НачислениеАренднойПлаты.Номер < &Номер
			|
			|УПОРЯДОЧИТЬ ПО
			|	Номер УБЫВ");
			Запрос.УстановитьПараметр("Код", "000000143");
			Запрос.УстановитьПараметр("Дата1", '20150801');
			Запрос.УстановитьПараметр("Дата2", '20150901');
			Запрос.УстановитьПараметр("Номер", "УК00-550/08");
			
			Выборка = Запрос.Выполнить().Выбрать();
			Выборка.Следующий();
			
			Номер = Выборка.Номер;
			Номер = Сред(Номер, 6);
			Номер = Лев(Номер, 3);
			Номер = Строка(Число(Номер) + 1);
			
			Пока СтрДлина(Номер) < 3 Цикл
				Номер = "0" + Номер;
			КонецЦикла; 
			
			НовыйНомер = "УК00-" + Номер + "/" + Формат(ЭтотОбъект.Дата, "ДФ=ММ");
			
		КонецЕсли;
		// - NAI Becar Гайфетдинов Р.И.
		
	Иначе
		ЭтотОбъект.УстановитьНовыйНомер(ЭтотОбъект.Организация.Префикс);
	КонецЕсли;
	
