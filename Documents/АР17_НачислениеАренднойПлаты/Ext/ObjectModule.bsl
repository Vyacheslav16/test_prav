Процедура УбратьСогласование()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РеализацияТоваровУслугУслуги.Ссылка КАК Ссылка,
	               |	РеализацияТоваровУслугУслуги.бит_Аналитика_5 КАК бит_Аналитика_5,
	               |	РеализацияТоваровУслугУслуги.Ссылка.СчетНаОплатуПокупателю КАК СчетНаОплатуПокупателю,
	               |	бит_УстановленныеВизы.Виза КАК Виза,
	               |	бит_УстановленныеВизы.Решение КАК Решение
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	               |		ПО РеализацияТоваровУслугУслуги.бит_Аналитика_5 = бит_УстановленныеВизы.Объект
	               |ГДЕ
				   //|	НЕ РеализацияТоваровУслугУслуги.бит_Аналитика_5 = &бит_Аналитика_5
	               |	РеализацияТоваровУслугУслуги.Ссылка.Проведен = ИСТИНА
	               |	И бит_УстановленныеВизы.Виза = &Виза
	               |	И РеализацияТоваровУслугУслуги.Ссылка.СчетНаОплатуПокупателю = &СчетНаОплатуПокупателю
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	РеализацияТоваровУслугАгентскиеУслуги.Ссылка,
	               |	РеализацияТоваровУслугАгентскиеУслуги.бит_Аналитика_5,
	               |	РеализацияТоваровУслугАгентскиеУслуги.Ссылка.СчетНаОплатуПокупателю,
	               |	бит_УстановленныеВизы.Виза,
	               |	бит_УстановленныеВизы.Решение
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК РеализацияТоваровУслугАгентскиеУслуги
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	               |		ПО РеализацияТоваровУслугАгентскиеУслуги.бит_Аналитика_5 = бит_УстановленныеВизы.Объект
	               |ГДЕ
				   //|	НЕ РеализацияТоваровУслугАгентскиеУслуги.бит_Аналитика_5 = &бит_Аналитика_5
	               |	РеализацияТоваровУслугАгентскиеУслуги.Ссылка.Проведен = ИСТИНА
	               |	И бит_УстановленныеВизы.Виза = &Виза
	               |	И РеализацияТоваровУслугАгентскиеУслуги.Ссылка.СчетНаОплатуПокупателю = &СчетНаОплатуПокупателю";
	
	Запрос.УстановитьПараметр("СчетНаОплатуПокупателю",ЭтотОбъект.Ссылка);
	Запрос.УстановитьПараметр("Виза", Справочники.бит_Визы.НайтиПоКоду("00-000317"));
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		НаборВизированияОбъекта = РегистрыСведений.бит_УстановленныеВизы.СоздатьНаборЗаписей();
		НаборВизированияОбъекта.Отбор.Объект.Установить(Выборка.бит_Аналитика_5);
		НаборВизированияОбъекта.Отбор.Виза.Установить(Справочники.бит_Визы.НайтиПоКоду("00-000317"));
		НаборВизированияОбъекта.Прочитать();
		Для Каждого Запись Из НаборВизированияОбъекта Цикл
			Запись.Решение = Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка();
			Запись.ДатаУстановки = Дата(1,1,1);
			Запись.Пользователь = Справочники.Пользователи.ПустаяСсылка();
		КонецЦикла;	
		НаборВизированияОбъекта.Записать();
	КонецЕсли;	
	
КонецПроцедуры	

//Денис++
Процедура ЗаполнитьРегистрРеализаций(Начисление,Реал,СФ)
	НачислениеА = Начисление.ПолучитьОбъект();
	РА = РегистрыСведений.Д_РеализацииАренды.СоздатьНаборЗаписей();
	РА.Отбор.Реализация.Установить(Реал.Ссылка);
	РА.Очистить();
	РА.Записать();
	Для каждого стр из НачислениеА.Состав Цикл
		Запись = РегистрыСведений.Д_РеализацииАренды.СоздатьМенеджерЗаписи();
		Запись.Организация = НачислениеА.Организация;
		Запись.ИК = ПолучитьИК(НачислениеА.ДоговорКонтрагента);
		Запись.Реализация = Реал.Ссылка;
		Запись.Контрагент = НачислениеА.Контрагент;
		Запись.ДоговорКонтрагента = НачислениеА.ДоговорКонтрагента;
		Если Не СФ = Неопределено Тогда
			Запись.СФ = СФ.Ссылка;
		КонецЕсли;
		Запись.Помещение = ПолучитьПомещение(НачислениеА.ДоговорКонтрагента,стр.Номенклатура,стр.НомерСтрокиТЧ);
		Запись.ДатаНачала = ПолучитьДатаНачала(НачислениеА.НачалоПериода,НачислениеА.ДоговорКонтрагента,стр.Номенклатура,стр.НомерСтрокиТЧ);
		Запись.ДатаОкончания = ПолучитьДатаОкончания(НачислениеА.ОкончаниеПериода,НачислениеА.ДоговорКонтрагента,стр.Номенклатура,стр.НомерСтрокиТЧ);
		Запись.Сумма = стр.Сумма; 
		Запись.НДС = стр.СуммаНДС;
		Запись.Услуга = стр.Номенклатура;
		Запись.ИД = новый УникальныйИдентификатор;
		Запись.Записать(Ложь);
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьИК(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ
	                |	АР17_ЗаключениеДоговораАренды.ИК КАК ИК
	                |ИЗ
	                |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	                |ГДЕ
	                |	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() > 0 Тогда
		Возврат Рез[0].ИК;
	Иначе
		Возврат Справочники.АР_ОбъектыАренды.ПустаяСсылка();
	КонецЕсли;
КонецФункции
	
Функция ПолучитьПомещение(ДоговорКонтрагента,Номенклатура,НомерСтрокиТЧ)
	Запрос = Новый Запрос;
	Если Номенклатура.АР_ПостояннаяЧастьОплаты Тогда
		Запрос.Текст =  "ВЫБРАТЬ
		                |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
		                |	СУММА(1) КАК Количество
		                |ПОМЕСТИТЬ ВТ
		                |ИЗ
		                |	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
		                |ГДЕ
		                |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		                |
		                |СГРУППИРОВАТЬ ПО
		                |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды
		                |;
		                |
		                |////////////////////////////////////////////////////////////////////////////////
		                |ВЫБРАТЬ
		                |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ОбъектАренды КАК ОбъектАренды,
		                |	ВТ.ОбъектАренды КАК ОбъектАрендыДоговор
		                |ИЗ
		                |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты,
		                |	ВТ КАК ВТ
		                |ГДЕ
		                |	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.НомерСтроки = &НомерСтроки
		                |	И АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		                |	И ВТ.Количество = 1";
		Запрос.УстановитьПараметр("НомерСтроки", НомерСтрокиТЧ);
		Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
		Рез = Запрос.Выполнить().Выгрузить();
		Если Рез.Количество() > 0 Тогда
			Если Рез[0].ОбъектАренды = Справочники.АР_ОбъектыАренды.ПустаяСсылка() Тогда
				Если Не Рез[0].ОбъектАрендыДоговор = Неопределено Тогда
					Возврат Рез[0].ОбъектАрендыДоговор;
				Иначе
					Возврат Справочники.АР_ОбъектыАренды.ПустаяСсылка();
				КонецЕсли;
			Иначе
				Возврат Рез[0].ОбъектАренды;
			КонецЕсли;
		Иначе
			Возврат Справочники.АР_ОбъектыАренды.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли  Номенклатура.АР_КоммунальныеУслуги Тогда
	Иначе
		Запрос.Текст =  "ВЫБРАТЬ
		                |	АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.ОбъектАренды КАК ОбъектАренды
		                |ИЗ
		                |	Документ.АР17_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты
		                |ГДЕ
		                |	АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.НомерСтроки = &НомерСтроки
		                |	И АР17_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента";
		Запрос.УстановитьПараметр("НомерСтроки", НомерСтрокиТЧ);
		Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
		Рез = Запрос.Выполнить().Выгрузить();
		Если Рез.Количество() > 0 Тогда
			Возврат Рез[0].ОбъектАренды;
		Иначе
			Возврат Справочники.АР_ОбъектыАренды.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
КонецФункции

