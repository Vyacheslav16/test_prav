#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда


////////////////////////////////////////////////////////////////////////////////
// Проведение

// подготавливаем параметры проведения
Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт

	ПараметрыПроведения = Новый Структура;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.ДоговорКонтрагента.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	Реквизиты.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
	|	Реквизиты.Ссылка,
	|	Реквизиты.СуммаВключаетНДС,
	|	Реквизиты.ДоговорКонтрагента,
	|	Реквизиты.КурсВзаиморасчетов,
	|	Реквизиты.КратностьВзаиморасчетов,
	|	Реквизиты.ДоговорКонтрагента.УчетАгентскогоНДС КАК УчетАгентскогоНДС,
	|	Реквизиты.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоПериодам КАК ВестиВзаиморасчетыПоПериодам,
	|	Реквизиты.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоОбъектам КАК ВестиВзаиморасчетыПоОбъектам,
	|	Реквизиты.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоСчетамПост КАК ВестиВзаиморасчетыПоСчетамПост,
	|	Реквизиты.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоСчетамПерем КАК ВестиВзаиморасчетыПоСчетамПерем,
	|	Реквизиты.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоУслугам КАК ВестиВзаиморасчетыПоУслугам,
	|	Реквизиты.НачалоПериода
	|ИЗ
	|	Документ.АР17_НачислениеАренднойПлаты КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Реквизиты = Новый Структура("ВалютаРеглУчета,ВалютаДокумента,ВалютаВзаиморасчетов,ДоговорКонтрагента,ВидДоговора,Ссылка,СуммаВключаетНДС,ДокументРасчетов,
		|КурсВзаиморасчетов,КратностьВзаиморасчетов,КурсДокумента,КратностьДокумента,РасчетыВУсловныхЕдиницах,ОрганизацияПрименяетУСН,НачислятьНДСПоОтгрузке,
		|НачалоПериода,ВестиВзаиморасчетыПоПериодам,ВестиВзаиморасчетыПоОбъектам,ВестиВзаиморасчетыПоСчетамПост,ВестиВзаиморасчетыПоСчетамПерем,ВестиВзаиморасчетыПоУслугам, УчетАгентскогоНДС");
	
	ЗаполнитьЗначенияСвойств(Реквизиты, Выборка);

	Если НЕ УчетнаяПолитика.Существует(Выборка.Организация, Выборка.Период, Истина, ДокументСсылка) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;
	
	Реквизиты.ОрганизацияПрименяетУСН = УчетнаяПолитика.СистемаНалогообложения(Выборка.Организация, Выборка.Период) = Перечисления.СистемыНалогообложения.Упрощенная;
	Реквизиты.НачислятьНДСПоОтгрузке = УчетнаяПолитика.НачислятьНДСПоОтгрузке(Выборка.Организация, Выборка.Период);
	
	// Коэффициенты пересчета сумм
	// - из валюты документа в валюту взаиморасчетов 
	// - из валюты взаиморасчетов в рубли
	Реквизиты.ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	Если Выборка.ВалютаВзаиморасчетов = Реквизиты.ВалютаРеглУчета Тогда
		КоэффициентРуб = 1;
	Иначе
		Реквизиты.КурсДокумента = Реквизиты.КурсВзаиморасчетов;
		Реквизиты.КратностьДокумента = Реквизиты.КратностьВзаиморасчетов;
		КоэффициентРуб = Реквизиты.КурсВзаиморасчетов / Реквизиты.КратностьВзаиморасчетов;
	КонецЕсли;
	Если Выборка.ВалютаВзаиморасчетов = Выборка.ВалютаДокумента Тогда
		Реквизиты.КурсВзаиморасчетов = 1;
		Реквизиты.КратностьВзаиморасчетов = 1;
		КоэффициентВзаиморасчетов = 1;
	Иначе
		Реквизиты.КурсВзаиморасчетов = Реквизиты.КурсВзаиморасчетов; 
		Реквизиты.КратностьВзаиморасчетов = Реквизиты.КратностьВзаиморасчетов;
		КоэффициентВзаиморасчетов = (Реквизиты.КурсВзаиморасчетов / Реквизиты.КратностьВзаиморасчетов) / КоэффициентРуб;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("КоэффициентВзаиморасчетов", КоэффициентВзаиморасчетов);
	Запрос.УстановитьПараметр("КоэффициентРуб",            КоэффициентРуб);
	Запрос.УстановитьПараметр("ВалютаРеглУчета",           Реквизиты.ВалютаРеглУчета);
	Запрос.УстановитьПараметр("ОрганизацияПрименяетУСН",   УчетнаяПолитика.ПрименяетсяУСН(Выборка.Организация, Выборка.Период));
	Запрос.УстановитьПараметр("ОрганизацияПрименяетУСНПатент",   УчетнаяПолитика.ПрименяетсяУСНПатент(Выборка.Организация, Выборка.Период));
	Запрос.УстановитьПараметр("Субсчета91",                БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПрочиеРасходы));
	Запрос.УстановитьПараметр("Дата", Выборка.Период);
	Запрос.УстановитьПараметр("НачалоПериода", АР_ОбщиеПроцедуры.ОпределитьНачалоПериодаОплатыПоДоговору(Реквизиты.НачалоПериода, Реквизиты.ДоговорКонтрагента));
		
	ПодготовитьТаблицыДокументаДляЦелейПриобретенияРеализации(Запрос, Реквизиты);
	
	НомераТаблиц = Новый Структура;
	
	Запрос.Текст = ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)
		+ ТекстЗапросаТаблицыДокумента(НомераТаблиц)
		+ ТекстЗапросаЗачетАвансов(НомераТаблиц)
		+ ТекстЗапросаРеализация(НомераТаблиц)
		+ ТекстЗапросаЗачетАвансовКомитентов(НомераТаблиц)
		+ ТекстЗапросаРеализацияУслуг(НомераТаблиц)
		+ ТекстЗапросаПродажиПоАренде(НомераТаблиц);
		
	Результат = Запрос.ВыполнитьПакет();
	
	Для Каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	Возврат ПараметрыПроведения;
	
КонецФункции 

Процедура ПодготовитьТаблицыДокументаДляЦелейПриобретенияРеализации(Запрос, Реквизиты)
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаУслуги.Ссылка КАК Ссылка,
	|	ТаблицаУслуги.НомерСтроки КАК НомерСтроки,
	|	ТаблицаУслуги.Номенклатура КАК Номенклатура,
	|	ТаблицаУслуги.Количество КАК Количество,
	|	ТаблицаУслуги.Содержание КАК Содержание,
	|	ТаблицаУслуги.Сумма КАК Сумма,
	|	ТаблицаУслуги.СуммаНДС КАК НДС,
	|	ТаблицаУслуги.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаУслуги.СчетУчетаНДСПоРеализации КАК СчетУчетаНДСПоРеализации,
	|	ТаблицаУслуги.СчетДоходов КАК СчетДоходов,
	|	ВЫБОР
	|		КОГДА ТаблицаУслуги.СчетДоходов = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ВыручкаЕНВД)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ДоходЕНВД,
	|	ТаблицаУслуги.СчетРасходов КАК СчетРасходов,
	|	ТаблицаУслуги.Субконто КАК Субконто,
	|	ТаблицаУслуги.ОбъектАренды КАК ОбъектАренды,
	|	ТаблицаУслуги.Номенклатура КАК УслугаАренды,
	|	ТаблицаУслуги.СчетНаАренду КАК СчетНаАренду,
	|	ТаблицаУслуги.ПериодАренды КАК ПериодАренды,
	|	ЛОЖЬ КАК УслугиЗаРубежом
	|ИЗ
	|	Документ.АР17_НачислениеАренднойПлаты.Состав КАК ТаблицаУслуги
	|ГДЕ
	|	ТаблицаУслуги.Ссылка = &Ссылка
	|	И ТаблицаУслуги.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаАгентскиеУслуги.Ссылка КАК Ссылка,
	|	ТаблицаАгентскиеУслуги.НомерСтроки КАК НомерСтроки,
	|	ТаблицаАгентскиеУслуги.Номенклатура КАК Номенклатура,
	|	ТаблицаАгентскиеУслуги.Количество КАК Количество,
	|	ТаблицаАгентскиеУслуги.Сумма КАК Сумма,
	|	ТаблицаАгентскиеУслуги.СуммаНДС КАК НДС,
	|	ТаблицаАгентскиеУслуги.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаАгентскиеУслуги.Контрагент КАК Контрагент,
	|	ТаблицаАгентскиеУслуги.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ТаблицаАгентскиеУслуги.ДоговорКонтрагента.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ТаблицаАгентскиеУслуги.СчетРасчетов КАК СчетРасчетов,
	|	ТаблицаАгентскиеУслуги.ОбъектАренды КАК ОбъектАренды,
	|	ТаблицаАгентскиеУслуги.Номенклатура КАК УслугаАренды,
	|	ТаблицаАгентскиеУслуги.СчетНаАренду КАК СчетНаАренду,
	|	ТаблицаАгентскиеУслуги.ПериодАренды КАК ПериодАренды
	|ИЗ
	|	Документ.АР17_НачислениеАренднойПлаты.Состав КАК ТаблицаАгентскиеУслуги
	|ГДЕ
	|	ТаблицаАгентскиеУслуги.Ссылка = &Ссылка
	|	И ТаблицаАгентскиеУслуги.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаУслуги			= РезультатЗапроса[0].Выгрузить();
	ТаблицаАгентскиеУслуги	= РезультатЗапроса[1].Выгрузить();
		
	УчетВзаиморасчетов.ПодготовкаТаблицыЗначенийДляЦелейПриобретенияИРеализации(ТаблицаУслуги, Реквизиты);
	УчетВзаиморасчетов.ПодготовкаТаблицыЗначенийДляЦелейПриобретенияИРеализации(ТаблицаАгентскиеУслуги, Реквизиты);
	
	// Подготовим таблицы по арендной аналитике в зависимости от настроек договора
	ПодготовитьТаблицуДокументаДляВзаиморасчетовПоАренде(ТаблицаУслуги, Реквизиты);
	ПодготовитьТаблицуДокументаДляВзаиморасчетовПоАренде(ТаблицаАгентскиеУслуги, Реквизиты);
	
	Запрос.УстановитьПараметр("ТаблицаУслуги", 			ТаблицаУслуги);
	Запрос.УстановитьПараметр("ТаблицаАгентскиеУслуги",	ТаблицаАгентскиеУслуги);

КонецПроцедуры

Процедура ПодготовитьТаблицуДокументаДляВзаиморасчетовПоАренде(Таблица, Реквизиты)
	
	НачалоПериода = АР_ОбщиеПроцедуры.ОпределитьНачалоПериодаОплатыПоДоговору(Реквизиты.НачалоПериода, Реквизиты.ДоговорКонтрагента);
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ПериодАренды) Тогда
			СтрокаТаблицы.ПериодАренды = НачалоПериода;
		КонецЕсли;
		Если НЕ Реквизиты.ВестиВзаиморасчетыПоОбъектам Тогда
			СтрокаТаблицы.ОбъектАренды = Справочники.АР_ОбъектыАренды.ПустаяСсылка();
		КонецЕсли;
		Если НЕ Реквизиты.ВестиВзаиморасчетыПоУслугам Тогда
			СтрокаТаблицы.УслугаАренды = Справочники.Номенклатура.ПустаяСсылка();
		КонецЕсли;
		Если Не Реквизиты.ВестиВзаиморасчетыПоПериодам Тогда
			СтрокаТаблицы.ПериодАренды = '00010101';
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаТаблицы.УслугаАренды) Тогда
			Если (СтрокаТаблицы.УслугаАренды.АР_ПостояннаяЧастьОплаты И Не Реквизиты.ВестиВзаиморасчетыПоСчетамПост) 
				ИЛИ (НЕ СтрокаТаблицы.УслугаАренды.АР_ПостояннаяЧастьОплаты И Не Реквизиты.ВестиВзаиморасчетыПоСчетамПерем) Тогда
				СтрокаТаблицы.СчетНаАренду = Документы.АР17_СчетНаАренду.ПустаяСсылка();
			КонецЕсли;
		Иначе
			Если (Не Реквизиты.ВестиВзаиморасчетыПоСчетамПост И Не Реквизиты.ВестиВзаиморасчетыПоСчетамПерем) Тогда
				СтрокаТаблицы.СчетНаАренду = Документы.АР17_СчетНаАренду.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Функция ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)

	НомераТаблиц.Вставить("ВременнаяТаблицаУслуги"              , НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВременнаяТаблицаАгентскиеУслуги"     , НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаУслуги.Ссылка,
	|	ТаблицаУслуги.Ссылка КАК ДокументРасчетов,
	|	ТаблицаУслуги.НомерСтроки,
	|	ТаблицаУслуги.Номенклатура,
	|	ТаблицаУслуги.Содержание,
	|	ТаблицаУслуги.Количество,
	|	ТаблицаУслуги.Сумма КАК СуммаРуб,
	|	ТаблицаУслуги.Сумма КАК СуммаБУ,
	|	ТаблицаУслуги.Сумма КАК СуммаНУ,
	|	ТаблицаУслуги.НДС КАК СуммаНДСРуб,
	|	ТаблицаУслуги.НДСВал КАК СуммаНДСВзаиморасчетов,
	|	ТаблицаУслуги.СуммаВал КАК СуммаВзаиморасчетов,
	|	ТаблицаУслуги.СтавкаНДС,
	|	ТаблицаУслуги.СчетРасходов,
	|	ТаблицаУслуги.СчетДоходов,
	|	ТаблицаУслуги.Субконто,
	|	ТаблицаУслуги.ДоходЕНВД,
	|	ТаблицаУслуги.СчетУчетаНДСПоРеализации,
	|	ТаблицаУслуги.ОбъектАренды,
	|	ТаблицаУслуги.УслугаАренды,
	|	ТаблицаУслуги.СчетНаАренду,
	|	ТаблицаУслуги.ПериодАренды,
	|	ТаблицаУслуги.УслугиЗаРубежом
	|ПОМЕСТИТЬ ТаблицаУслуги
	|ИЗ
	|	&ТаблицаУслуги КАК ТаблицаУслуги
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаАгентскиеУслуги.Ссылка,
	|	ТаблицаАгентскиеУслуги.Ссылка КАК ДокументРасчетов,
	|	ТаблицаАгентскиеУслуги.НомерСтроки,
	|	ТаблицаАгентскиеУслуги.Номенклатура,
	|	ТаблицаАгентскиеУслуги.Количество,
	|	ТаблицаАгентскиеУслуги.Сумма КАК СуммаРуб,
	|	ТаблицаАгентскиеУслуги.Сумма КАК СуммаБУ,
	|	ТаблицаАгентскиеУслуги.Сумма КАК СуммаНУ,
	|	ТаблицаАгентскиеУслуги.НДС КАК СуммаНДСРуб,
	|	ТаблицаАгентскиеУслуги.СуммаВал КАК СуммаВзаиморасчетов,
	|	ТаблицаАгентскиеУслуги.НДСВал КАК СуммаНДСВзаиморасчетов,
	|	ТаблицаАгентскиеУслуги.СтавкаНДС,
	|	ТаблицаАгентскиеУслуги.ВалютаВзаиморасчетов,
	|	ТаблицаАгентскиеУслуги.Контрагент,
	|	ТаблицаАгентскиеУслуги.ДоговорКонтрагента,
