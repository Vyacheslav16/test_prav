// Печать

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Акт") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "Акт", "Акт сдачи-премки услуг", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктРуб") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктРуб", "Акт сдачи-премки услуг (руб.)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Ложь, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктСводный") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктСводный", "Акт сдачи-приемки услуг (сводный по услугам)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктСводныйРуб") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктСводныйРуб", "Акт сдачи-приемки услуг (сводный по услугам) (руб.)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Истина, Истина));
	КонецЕсли;
	//+са
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктШК") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктШК", "Акт сдачи-приемки услуг (штрих-код)", ПечатьАктаШК(МассивОбъектов, ОбъектыПечати, Истина));
	КонецЕсли;
	//-са
	// + NAI Becar Конюшок С.Н. от 06.02.2017 10:49 	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктШКБезЕдИзм") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктШКБезЕдИзм", "Акт сдачи-приемки услуг (штрих-код) без единиц измерения", ПечатьАктаШК(МассивОбъектов, ОбъектыПечати, Истина,,Истина));
	КонецЕсли;
	// - NAI Becar Конюшок С.Н. 

	
КонецПроцедуры

// Формирует и возвращает текст запроса для выборки данных,
// необходимых для формирования печатной формы
Функция ПолучитьТекстЗапросаДляФормированияПечатнойФормыАкта()
		
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НачислениеАренды.Ссылка КАК Ссылка,
	|	НачислениеАренды.Ссылка.Номер КАК Номер,
	|	НачислениеАренды.Ссылка.Дата КАК Дата,
	|	НачислениеАренды.Ссылка.ДоговорКонтрагента,
	|	НачислениеАренды.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
	|	НачислениеАренды.Ссылка.Контрагент КАК Получатель,
	|	НачислениеАренды.Ссылка.Организация КАК Поставщик,
	|	НачислениеАренды.Ссылка.Организация,
	|	НачислениеАренды.Ссылка.СуммаДокумента КАК СуммаДокумента,
	|	НачислениеАренды.Ссылка.ВалютаДокумента,
	|	НачислениеАренды.Ссылка.СуммаВключаетНДС,
	|	НачислениеАренды.Ссылка.Проведен,
	|	НачислениеАренды.Ссылка.НачалоПериода КАК НачалоПериода,
	|	НачислениеАренды.Ссылка.ОкончаниеПериода КАК ОкончаниеПериода,
	|	НачислениеАренды.Номенклатура КАК Товар,
	|	СУММА(НачислениеАренды.Количество) КАК Количество,
	|	ВЫБОР
	|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
	|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
	|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
	|	КОНЕЦ КАК ЕдиницаИзмерения,
	|	СУММА(НачислениеАренды.Цена) КАК Цена,
	|	СУММА(НачислениеАренды.Сумма) КАК Сумма,
	|	НачислениеАренды.СтавкаНДС,
	|	СУММА(НачислениеАренды.СуммаНДС) КАК СуммаНДС,
	|	ВЫРАЗИТЬ(НачислениеАренды.Содержание КАК СТРОКА(1000)) КАК Содержание,
	|	НачислениеАренды.Ссылка.КурсВзаиморасчетов,
	|	НачислениеАренды.Ссылка.КратностьВзаиморасчетов,
	|	НачислениеАренды.Ссылка.Руководитель,
	|	НачислениеАренды.Ссылка.ЗаРуководителяПоПриказу,
	|	МАКСИМУМ(НачислениеАренды.ОбъектАренды) КАК ОбъектАренды,
	|	АР_ШтрихКоды.ШтрихКод
	|ИЗ
	|	Документ.АР17_НачислениеАренднойПлаты.Состав КАК НачислениеАренды
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АР_ШтрихКоды КАК АР_ШтрихКоды
	|		ПО НачислениеАренды.Ссылка = АР_ШтрихКоды.СсылкаНаОбъект
	|ГДЕ
	|	НачислениеАренды.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачислениеАренды.Ссылка.Номер,
	|	НачислениеАренды.Ссылка.Дата,
	|	НачислениеАренды.Ссылка.ДоговорКонтрагента,
	|	НачислениеАренды.Ссылка.Контрагент,
	|	НачислениеАренды.Ссылка.Организация,
	|	НачислениеАренды.Ссылка.ВалютаДокумента,
	|	НачислениеАренды.Ссылка.СуммаВключаетНДС,
	|	НачислениеАренды.Ссылка.НачалоПериода,
	|	НачислениеАренды.Ссылка.ОкончаниеПериода,
	|	НачислениеАренды.Номенклатура,
	|	ВЫБОР
	|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
	|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
	|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	НачислениеАренды.СтавкаНДС,
	|	НачислениеАренды.Ссылка.СуммаДокумента,
	|	НачислениеАренды.Ссылка,
	|	НачислениеАренды.Ссылка.КурсВзаиморасчетов,
	|	НачислениеАренды.Ссылка.КратностьВзаиморасчетов,
	|	ВЫРАЗИТЬ(НачислениеАренды.Содержание КАК СТРОКА(1000)),
	|	НачислениеАренды.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах,
	|	НачислениеАренды.Ссылка.Проведен,
	|	НачислениеАренды.Ссылка.Руководитель,
	|	НачислениеАренды.Ссылка.ЗаРуководителяПоПриказу,
	|	АР_ШтрихКоды.ШтрихКод,
	|	НачислениеАренды.Ссылка.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка";
	
	Возврат ТекстЗапроса;

КонецФункции

