	|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
	|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	НачислениеАренды.ДатаНачалаАренды,
	|	НачислениеАренды.Цена,
	|	НачислениеАренды.Ссылка.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка";
	
	Если БезЕдИзм Тогда       
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "СУММА(НачислениеАренды.Количество) КАК Количество,", ""); 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НачислениеАренды.Цена КАК Цена", "СУММА(НачислениеАренды.Сумма + НачислениеАренды.СуммаНДС) КАК Цена");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НачислениеАренды.ДатаНачалаАренды,", ""); 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НачислениеАренды.Цена,", ""); 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|	КОНЕЦ,", ""); 
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|	КОНЕЦ КАК ЕдиницаИзмерения,", ""); 

	// Клес +
	Иначе
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|	КОНЕЦ,", 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		КОГДА НЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ ""усл.""
		|	КОНЕЦ,"); 
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		ИНАЧЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|	КОНЕЦ КАК ЕдиницаИзмерения,", 
		"ВЫБОР
		|		КОГДА НЕ НачислениеАренды.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.ЕдиницаИзмерения
		|		КОГДА НЕ НачислениеАренды.Номенклатура.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА НачислениеАренды.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ ""усл.""
		|	КОНЕЦ КАК ЕдиницаИзмерения,");
		
	// Клес -
		
	КонецЕсли; 
	
	Возврат ТекстЗапроса;

КонецФункции

// Функция формирует табличный документ с печатной формой акта сдачи-приемки услуг
//
// Возвращаемое значение:
//  Табличный документ - сформированная печатная форма
//
Функция ПечатьАкта(МассивОбъектов, ОбъектыПечати, Сводный, СуммыВРублях = Ложь) Экспорт
	
	ВалютаРегламентированногоУчета   = Константы.ВалютаРегламентированногоУчета.Получить();

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_НачислениеАренднойПлаты_Акт";
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Если Сводный Тогда
		Запрос.Текст = ПолучитьТекстЗапросаДляФормированияПечатнойФормыАктаСводный();
	Иначе 
		Запрос.Текст = ПолучитьТекстЗапросаДляФормированияПечатнойФормыАкта();
	КонецЕсли;
	
	Шапка = Запрос.Выполнить().Выбрать(); 
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_ВзаиморасчетыПоАрендеОбороты.Регистратор КАК Регистратор,
	|	АР_ВзаиморасчетыПоАрендеОбороты.УслугаАренды КАК Номенклатура,
	|	АР_ВзаиморасчетыПоАрендеОбороты.СуммаПриход КАК Сумма
	|ИЗ
	|	РегистрНакопления.АР_ВзаиморасчетыПоАренде.Обороты(, , Регистратор, ) КАК АР_ВзаиморасчетыПоАрендеОбороты
	|ГДЕ
	|	АР_ВзаиморасчетыПоАрендеОбороты.Регистратор В (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор";
	
	ТаблицаСуммВзаиморасчетов = Запрос.Выполнить().Выгрузить();
    
	ПервыйДокумент = Истина;
	
	Пока Шапка.СледующийПоЗначениюПоля("Ссылка") Цикл
		
		ВалютаПечати = ?(СуммыВРублях, ВалютаРегламентированногоУчета, Шапка.ВалютаДокумента);
		
		Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР17_НачислениеАренднойПлаты.Акт");

		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

		ТаблицаУслуги = Новый ТаблицаЗначений;
		ТаблицаУслуги.Колонки.Добавить("Номенклатура");
		ТаблицаУслуги.Колонки.Добавить("Содержание");
		ТаблицаУслуги.Колонки.Добавить("Товар");
		ТаблицаУслуги.Колонки.Добавить("Количество");
		ТаблицаУслуги.Колонки.Добавить("ЕдиницаИзмерения");
		ТаблицаУслуги.Колонки.Добавить("Цена");
		ТаблицаУслуги.Колонки.Добавить("Сумма");
		ТаблицаУслуги.Колонки.Добавить("СтавкаНДС");
		ТаблицаУслуги.Колонки.Добавить("СуммаНДС");
		ТаблицаУслуги.Колонки.Добавить("НомерСтроки");
        	
		Пока Шапка.Следующий() Цикл
			
			СтрокаТовар = ТаблицаУслуги.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТовар, Шапка);
					
		КонецЦикла;	
		
		ТаблицаУслугиНовая = ТаблицаУслуги.СкопироватьКолонки();
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Регистратор", Шапка.Ссылка);
		
		ТаблицаСуммВзаиморасчетовПоРегистратору = ТаблицаСуммВзаиморасчетов.Скопировать(СтруктураПоиска);
		
		
		Если СуммыВРублях И (Шапка.Проведен 
			И (Шапка.РасчетыВУсловныхЕдиницах
			ИЛИ (Шапка.ВалютаДокумента <> ВалютаРегламентированногоУчета И Шапка.Дата >= '20090101000000'))) Тогда
				
			Для Каждого СтрокаВзаиморасчетов Из ТаблицаСуммВзаиморасчетовПоРегистратору Цикл
				
				ТаблицаУслугиКопия = ТаблицаУслуги.СкопироватьКолонки();	
				СуммаВзаиморасчетов = СтрокаВзаиморасчетов.Сумма;
				
				Если Шапка.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоУслугам Тогда
					
					СтруктураОтбора = Новый Структура("Товар", СтрокаВзаиморасчетов.Номенклатура);
					СтрокиУслуг = ТаблицаУслуги.НайтиСтроки(СтруктураОтбора);
					Для каждого СтрокаУслуг Из СтрокиУслуг Цикл
						НоваяСтрока = ТаблицаУслугиКопия.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаУслуг);
					КонецЦикла;
					
				Иначе
					
					ТаблицаУслугиКопия = ТаблицаУслуги.Скопировать();
					
				КонецЕсли;
				
				Если НЕ СуммаВзаиморасчетов = 0 Тогда
					
					РасчетСуммыНДСПоСтавке = Истина;
					
					ТаблицаУслугиКопия.Колонки.Добавить("СуммаБезНДС");
					
					МассивРаспределения = Новый Массив;
					
					Для каждого СтрокаТовар Из ТаблицаУслугиКопия Цикл
						
						СуммаСНДС = СтрокаТовар.Сумма + ?(Шапка.СуммаВключаетНДС, 0, СтрокаТовар.СуммаНДС);
						СуммаБезНДС = СуммаСНДС - СтрокаТовар.СуммаНДС;
						
						МассивРаспределения.Добавить(СуммаСНДС);
						СтрокаТовар.СуммаБезНДС = СуммаБезНДС;
						
					КонецЦикла;
					
					ТаблицаУслугиКопия.Колонки.Добавить("СуммаРублевая");
					РаспределитьСуммуПоСтолбцу(МассивРаспределения, СуммаВзаиморасчетов, ТаблицаУслугиКопия, "СуммаРублевая");
					
					Для каждого СтрокаТовар Из ТаблицаУслугиКопия Цикл
						
						Если РасчетСуммыНДСПоСтавке Тогда
							//Выделение суммы НДС, Расчет суммы без НДС
							ЗначениеСтавкиНДС = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СтрокаТовар.СтавкаНДС);
							
							СтрокаТовар.СуммаНДС = ?(ЗначениеСтавкиНДС = 0, 0, Окр(СтрокаТовар.СуммаРублевая * ЗначениеСтавкиНДС/(100+ЗначениеСтавкиНДС),2));
							СтрокаТовар.Сумма = СтрокаТовар.СуммаРублевая - СтрокаТовар.СуммаНДС;
							
						Иначе
							МассивРаспределения.Очистить();
							МассивРаспределения.Добавить(СтрокаТовар.СуммаБезНДС);
							МассивРаспределения.Добавить(СтрокаТовар.СуммаНДС);
							МассивРаспределенныхСумм = ОбщегоНазначенияБПКлиентСервер.РаспределитьПропорционально(СтрокаТовар.СуммаРублевая, МассивРаспределения);
							Если МассивРаспределенныхСумм <> Неопределено Тогда
								СтрокаТовар.Сумма = МассивРаспределенныхСумм[0];
								СтрокаТовар.СуммаНДС = МассивРаспределенныхСумм[1];
							КонецЕсли;
						КонецЕсли;
						
						Если Шапка.СуммаВключаетНДС Тогда
							СтрокаТовар.Сумма = СтрокаТовар.Сумма+СтрокаТовар.СуммаНДС;
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
				Для каждого СтрокаТаблицы Из ТаблицаУслугиКопия Цикл
					НоваяСтрока = ТаблицаУслугиНовая.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
				КонецЦикла;
			
			КонецЦикла;
				
		Иначе
			
			ТаблицаУслугиНовая = ТаблицаУслуги;
				
		КонецЕсли;

		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = ОбщегоНазначенияБПВызовСервера.СформироватьЗаголовокДокумента(Шапка, "Акт");
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Поставщик");
		СведенияОбОрганизации    = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата);
		//ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
		ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		// + NAI Becar Комментирование Смирнов А.А. от 30.03.2017 16:17	письмо от 29.03.2017 17:50
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ПредставлениеПоставщика;
		//ОбластьМакета.Параметры.ПредставлениеПоставщика = ПредставлениеПоставщика +" р/с " +Шапка.Ссылка.СчетОрганизации.НомерСчета+", в банке " + Шапка.Ссылка.СчетОрганизации.Банк 
		//+ ", БИК " + Шапка.Ссылка.СчетОрганизации.Банк.Код + ", к/с" + Шапка.Ссылка.СчетОрганизации.Банк.КоррСчет;
		// - NAI Becar Комментирование Смирнов А.А.
		ОбластьМакета.Параметры.Поставщик 				= Шапка.Поставщик;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(Шапка.Организация, Шапка.Дата);
		ДолжностьИНазваниеОрганизации = ?(ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление),ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + " ","") + ПредставлениеПоставщика;
		
		Если ЗначениеЗаполнено(Шапка.Руководитель) Тогда
			Если Шапка.Руководитель = ОтветственныеЛицаОрганизации.Руководитель Тогда 
				ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
			Иначе
				ЗаместительПоПриказу = "(" + Шапка.ЗаРуководителяПоПриказу + " " +
					ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Шапка.Руководитель) + ")";
			КонецЕсли;
		Иначе
			ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
		КонецЕсли;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Покупатель");
		СведенияОКонтрагенте     = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		//ПредставлениеПолучателя = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОКонтрагенте, "НаименованиеДляПечатныхФорм,");
		СведенияОПокупателе     = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		ПредставлениеПолучателя = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОКонтрагенте, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ОбластьМакета.Параметры.Основание = Шапка.Ссылка.ДоговорКонтрагента;
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ПредставлениеПолучателя;
		ОбластьМакета.Параметры.Получатель = Шапка.Получатель;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ЕстьСкидки = Ложь;

		// Вывести табличную часть
		ОбластьШапки = "ШапкаТаблицы";
		ОбластьМакета = Макет.ПолучитьОбласть(ОбластьШапки);
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьСтроки = "Строка";
		ОбластьСтроки = Макет.ПолучитьОбласть(ОбластьСтроки);

		НомерСтроки = 0;

		Для каждого СтрокаТабличнойЧасти Из ТаблицаУслугиНовая Цикл

			НомерСтроки = НомерСтроки + 1;

			ОбластьСтроки.Параметры.Заполнить(СтрокаТабличнойЧасти);
			ОбластьСтроки.Параметры.НомерСтроки = НомерСтроки;
			
			ТоварНаименованиеПолное = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Товар), СтрокаТабличнойЧасти.Товар.НаименованиеПолное, "");
			ТоварНаименование = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Товар), СтрокаТабличнойЧасти.Товар.Наименование, "");
			
			Если Сводный Тогда
				НаименованиеУслуги = ?(НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Содержание), ТоварНаименование, СтрокаТабличнойЧасти.Содержание);
				НаименованиеУслуги = СокрЛП(НаименованиеУслуги)+" "+Шапка.ДоговорКонтрагента.Номер+" от "+Формат(Шапка.ДоговорКонтрагента.Дата,"ДЛФ=Д")+" за "+ПредставлениеПериода(Шапка.НачалоПериода,КонецДня(Шапка.ОкончаниеПериода));
			Иначе
				НаименованиеУслуги = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Содержание), СтрокаТабличнойЧасти.Содержание, ТоварНаименованиеПолное)+" "+Шапка.ДоговорКонтрагента.Номер+" от "+Формат(Шапка.ДоговорКонтрагента.Дата,"ДЛФ=Д")+" за "+ПредставлениеПериода(Шапка.НачалоПериода,КонецДня(Шапка.ОкончаниеПериода));			
			КонецЕсли;
			ОбластьСтроки.Параметры.Товар = СокрЛП(НаименованиеУслуги);

			Если Шапка.ВалютаДокумента <> ВалютаРегламентированногоУчета Тогда
				ОбластьСтроки.Параметры.Цена  = СтрокаТабличнойЧасти.Сумма / ?(СтрокаТабличнойЧасти.Количество = 0, 1, СтрокаТабличнойЧасти.Количество);
			КонецЕсли;
			
			//+са
			ОбластьСтроки.Параметры.Сумма = СтрокаТабличнойЧасти.Сумма - ?(Шапка.СуммаВключаетНДС, СтрокаТабличнойЧасти.СуммаНДС,0);	
			ОбластьСтроки.Параметры.Цена = ОбластьСтроки.Параметры.Сумма;
			//-са

			ТабличныйДокумент.Вывести(ОбластьСтроки);

		КонецЦикла;

		Если ТаблицаУслугиНовая <> Неопределено Тогда

			Сумма    = ТаблицаУслугиНовая.Итог("Сумма")- ?(Шапка.СуммаВключаетНДС, ТаблицаУслугиНовая.Итог("СуммаНДС"),0);
			СуммаНДС = ТаблицаУслугиНовая.Итог("СуммаНДС");

		Иначе

			Сумма    = 0;
			СуммаНДС = 0;

		КонецЕсли;

		ОбластьМакета = Макет.ПолучитьОбласть("Итого");
		ОбластьМакета.Параметры.Всего = ОбщегоНазначенияБПВызовСервера.ФорматСумм(Сумма);
		ТабличныйДокумент.Вывести(ОбластьМакета);
        
		ОбластьМакета = Макет.ПолучитьОбласть("ИтогоНДС");
		
		Если СуммаНДС <> 0 Тогда
			ОбластьМакета.Параметры.ВсегоНДС = ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаНДС);
			ОбластьМакета.Параметры.НДС      = ?(Шапка.СуммаВключаетНДС, "В том числе НДС", " Сумма НДС");
		Иначе
			ОбластьМакета.Параметры.ВсегоНДС = "-";
			ОбластьМакета.Параметры.НДС      = "Без налога (НДС)";
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		СуммаКПрописи = Сумма;
		ОбластьМакета = Макет.ПолучитьОбласть("СуммаПрописью");
		ОбластьМакета.Параметры.ИтоговаяСтрока = "Всего оказано услуг " + НомерСтроки
		                                       + ", на сумму " + ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаКПрописи, ВалютаПечати);
		ОбластьМакета.Параметры.СуммаПрописью  = ОбщегоНазначенияБПВызовСервера.СформироватьСуммуПрописью(СуммаКПрописи, ВалютаПечати);
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Подписи");
		ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм");
		ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(Шапка.Организация, Шапка.Дата);
		Если ЗначениеЗаполнено(Шапка.Руководитель) Тогда
			Если Шапка.Руководитель = ОтветственныеЛицаОрганизации.Руководитель Тогда 
				ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
				Если ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда 
					ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + ", " + ПредставлениеПоставщика;
				ИначеЕсли ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) Тогда 
					ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление;
				Иначе
					ДолжностьИНазваниеОрганизации = "" + ПредставлениеПоставщика;
				КонецЕсли;
			Иначе
				ЗаместительПоПриказу = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Шапка.Руководитель);
				Если ЗначениеЗаполнено(Шапка.ЗаРуководителяПоПриказу) Тогда 
					ЗаместительПоПриказу = ЗаместительПоПриказу + ", " + Шапка.ЗаРуководителяПоПриказу;
				КонецЕсли;
				ДанныеОтветственногоЛица = ОбщегоНазначенияБПВызовСервера.ДанныеФизЛица(Шапка.Организация, Шапка.Руководитель, Шапка.Дата);
				Если ЗначениеЗаполнено(ДанныеОтветственногоЛица.Должность) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда
					ДолжностьИНазваниеОрганизации = "" + ДанныеОтветственногоЛица.Должность + ", " + ПредставлениеПоставщика;
				ИначеЕсли ЗначениеЗаполнено(ДанныеОтветственногоЛица.Должность) Тогда
					ДолжностьИНазваниеОрганизации = "" + ДанныеОтветственногоЛица.Должность;
				Иначе
					ДолжностьИНазваниеОрганизации = ПредставлениеПоставщика;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
			Если ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда 
				ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + ", " + ПредставлениеПоставщика;
			ИначеЕсли ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) Тогда 
				ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление;
			Иначе
				ДолжностьИНазваниеОрганизации = "" + ПредставлениеПоставщика;
			КонецЕсли;
		КонецЕсли;
		
		//+са
		
		//Уполномоченные = УстановитьРуководителяИГлавногоБухгалтера(Шапка.Организация,Шапка);
		//ЗаместительПоПриказу = Уполномоченные.Руководитель;
		//
		ЗаместительПоПриказу	= АР_ОбщиеПроцедуры.НастройкаПечатнойФормы(Шапка, Перечисления.ОтветственныеЛицаОрганизаций.Руководитель);
		Бухгалтер		        = АР_ОбщиеПроцедуры.НастройкаПечатнойФормы(Шапка, Перечисления.ОтветственныеЛицаОрганизаций.ГлавныйБухгалтер);
		//-са
		
		//ЗаместительПоПриказу = ?(ЗначениеЗаполнено(ЗаместительПоПриказу), ЗаместительПоПриказу, Уполномоченные.Руководитель);
		
		ОбластьМакета.Параметры.ДолжностьИНазваниеОрганизации = ДолжностьИНазваниеОрганизации;
		ОбластьМакета.Параметры.ЗаместительПоПриказу = ЗаместительПоПриказу;
		
		
		ЗапросИК = Новый Запрос;
		ЗапросИК.Текст = "ВЫБРАТЬ
		                 |	АР17_ЗаключениеДоговораАренды.ИК КАК ИК,
		                 |	АР17_ЗаключениеДоговораАренды.ВидДоговора КАК ВидДоговора
		                 |ИЗ
		                 |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		                 |ГДЕ
		                 |	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
		
		
		ЗапросИК.УстановитьПараметр("ДоговорКонтрагента",Шапка.ДоговорКонтрагента);
		ВыборкаИК = ЗапросИК.Выполнить().Выбрать();
		ВыборкаИК.Следующий();
		ОбъектАренды = ВыборкаИК.ИК;
		ВидДоговора = ВыборкаИК.ВидДоговора;

		ЗапросНПФ = Новый Запрос;
		ЗапросНПФ.Текст = "ВЫБРАТЬ
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.УполномоченноеЛицо КАК УполномоченноеЛицо,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.Доверенность КАК Доверенность,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.РС КАК РС,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.ОбъектыАренды КАК ОбъектыАренды,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.Период КАК Период,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.ЗаКогоПодписывает КАК ЗаКогоПодписывает,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.ВидДоговора КАК ВидДоговора,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.ФайлПечать КАК ФайлПечать,
		                  |	АР_НастройкаПечатнойФормыСрезПоследних.ФайлПодписьРуководителя КАК ФайлПодписьРуководителя
		                  |ИЗ
		                  |	РегистрСведений.АР_НастройкаПечатнойФормы.СрезПоследних(
		                  |			&Период,
		                  |			Организация = &Организация
		                  //|				И ЗаКогоПодписывает = &ЗаКогоПодписывает
		                  |				И ОбъектыАренды = &ОбъектАренды) КАК АР_НастройкаПечатнойФормыСрезПоследних
		                  |ГДЕ
		                  |	ВЫБОР
		                  |			КОГДА АР_НастройкаПечатнойФормыСрезПоследних.ВидДоговора = ЗНАЧЕНИЕ(Справочник.АР_видыДоговоров.ПустаяСсылка)
		                  |				ТОГДА ИСТИНА
		                  |			ИНАЧЕ АР_НастройкаПечатнойФормыСрезПоследних.ВидДоговора = &ВидДоговора
		                  |		КОНЕЦ
		                  |
		                  |УПОРЯДОЧИТЬ ПО
		                  |	Период УБЫВ";	

		
		ЗапросНПФ.УстановитьПараметр("Период", Шапка.Дата);
		ЗапросНПФ.УстановитьПараметр("Организация", Шапка.Организация);
		//ЗапросНПФ.УстановитьПараметр("ЗаКогоПодписывает", Перечисления.ОтветственныеЛицаОрганизаций.Руководитель);
		ЗапросНПФ.УстановитьПараметр("ОбъектАренды", ОбъектАренды);
		ЗапросНПФ.УстановитьПараметр("ВидДоговора", ВидДоговора);
		
		ВыгрузкаНПФ = ЗапросНПФ.Выполнить().Выгрузить();
		ВыборкаНПФ = ЗапросНПФ.Выполнить().Выбрать();
		ВыборкаНПФ.Следующий();
		ФайлПечать = ВыборкаНПФ.ФайлПечать;
		
		//ДвоичныеДанныеПечать                    = Справочники.Организации.ДвоичныеДанныеКартинкиОрганизации(Шапка.Организация, "ФайлПечать");
		Отбор = Новый Структура;
		Отбор.Вставить("Организация", Шапка.Организация);
		Отбор.Вставить("ОбъектыАренды", ОбъектАренды);
		//Отбор.Вставить("ГруппаУслуг", ЭлементСправочника.ГруппаУслуг);
		Отбор.Вставить("ЗаКогоПодписывает", Перечисления.ОтветственныеЛицаОрганизаций.Руководитель);
		Отбор.Вставить("ВидДоговора", ВидДоговора);
		Отбор.Вставить("Период", Шапка.Дата);
		КлючЗаписиРег = РегистрыСведений.АР_НастройкаПечатнойФормы.СоздатьКлючЗаписи(Отбор);
		//АдресПечать = ПолучитьНавигационнуюСсылку(КлючЗаписиРег,"ФайлПечать"); 

		ДвоичныеДанныеПечать = ВыборкаНПФ.ФайлПечать;//ПолучитьНавигационнуюСсылку(КлючЗаписиРег,"ФайлПечать");
		ДвоичныеДанныеПодписьРуководителя       = ВыборкаНПФ.ФайлПодписьРуководителя;//Справочники.Организации.ДвоичныеДанныеКартинкиОрганизации(Шапка.Организация, "ФайлПодписьРуководителя");
		ДвоичныеДанныеПодписьГлавногоБухгалтера = Справочники.Организации.ДвоичныеДанныеКартинкиОрганизации(Шапка.Организация, "ФайлПодписьГлавногоБухгалтера");			
		Если ЗначениеЗаполнено(ДвоичныеДанныеПечать)
			ИЛИ ЗначениеЗаполнено(ДвоичныеДанныеПодписьРуководителя)
			ИЛИ ЗначениеЗаполнено(ДвоичныеДанныеПодписьГлавногоБухгалтера) Тогда
			Если ДвоичныеДанныеПечать.Получить() <> Неопределено Тогда
				ОбластьМакета.Рисунки.КартинкаПечати.Картинка            = ДвоичныеДанныеПечать.Получить();//Новый Картинка(ДвоичныеДанныеПечать);
			КонецЕсли;
			Если ДвоичныеДанныеПодписьРуководителя.Получить() <> Неопределено Тогда
				ОбластьМакета.Рисунки.ПодписьРуководителя.Картинка       = ДвоичныеДанныеПодписьРуководителя.Получить();//Новый Картинка(ДвоичныеДанныеПодписьРуководителя);
			КонецЕсли;
			//бух
			НайденнаяСтрока = ВыгрузкаНПФ.Найти(Перечисления.ОтветственныеЛицаОрганизаций.ГлавныйБухгалтер,"ЗаКогоПодписывает");
			Если НайденнаяСтрока <> Неопределено Тогда
				ДвоичныеДанныеПодписьГлавногоБухгалтера       = НайденнаяСтрока.ФайлПодписьРуководителя;
				Если ДвоичныеДанныеПодписьГлавногоБухгалтера.Получить() <> Неопределено Тогда
					ОбластьМакета.Рисунки.ПодписьБухгалтера.Картинка 		 = ДвоичныеДанныеПодписьГлавногоБухгалтера.Получить();
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		

		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);

	КонецЦикла;

	Возврат ТабличныйДокумент;

КонецФункции // ПечатьАкта()

Функция УстановитьРуководителяИГлавногоБухгалтера(Организация,Шапка)
	
	СтруктураВозврата = Новый Структура("Руководитель, ЗаРуководителяПоПриказу");
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура("Руководитель, ЗаРуководителяПоПриказу,ГлавныйБухгалтер");
	
	ДанныеУполномоченногоЛица = ОтветственныеЛицаБППереопределяемый.ДанныеУполномоченногоЛица(Организация, Пользователи.ТекущийПользователь());
	ОтветственныеЛица = ОтветственныеЛицаБППереопределяемый.ОтветственныеЛица(Организация, Шапка.НачалоПериода);
	
	Если ДанныеУполномоченногоЛица = Неопределено Тогда 
		СтруктураВозврата.Руководитель = ОтветственныеЛица.Руководитель;
		СтруктураВозврата.ГлавныйБухгалтер = "";
		СтруктураВозврата.ГлавныйБухгалтер = ОтветственныеЛица.ГлавныйБухгалтер;
	Иначе
		СтруктураВозврата.Руководитель = ?(ЗначениеЗаполнено(ДанныеУполномоченногоЛица.Руководитель), ДанныеУполномоченногоЛица.Руководитель, ОтветственныеЛица.Руководитель);
		//СтруктураВозврата.ЗаРуководителяПоПриказу = ?(ЗначениеЗаполнено(ДанныеУполномоченногоЛица.Руководитель), ДанныеУполномоченногоЛица.ПриказРуководитель, "");
		СтруктураВозврата.Руководитель = ?(ЗначениеЗаполнено(ДанныеУполномоченногоЛица.Руководитель), СокрЛП(ДанныеУполномоченногоЛица.Руководитель) + " (" +ДанныеУполномоченногоЛица.РуководительНаОсновании+")", "");
		СтруктураВозврата.ГлавныйБухгалтер = ?(ЗначениеЗаполнено(ДанныеУполномоченногоЛица.ГлавныйБухгалтер), СокрЛП(ДанныеУполномоченногоЛица.ГлавныйБухгалтер) + " (" + ДанныеУполномоченногоЛица.ГлавныйБухгалтерНаОсновании+")", ""); 
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

