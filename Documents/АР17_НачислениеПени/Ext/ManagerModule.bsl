// Печать

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Акт") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "Акт", "Акт сдачи-премки услуг", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Ложь));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктРуб") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктРуб", "Акт сдачи-премки услуг (руб.)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Ложь, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктСводный") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктСводный", "Акт сдачи-приемки услуг (сводный по услугам)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Истина));
	КонецЕсли;
    Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктСводныйРуб") Тогда
        УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктСводныйРуб", "Акт сдачи-приемки услуг (сводный по услугам) (руб.)", ПечатьАкта(МассивОбъектов, ОбъектыПечати, Истина, Истина));
	КонецЕсли;
	
КонецПроцедуры

// Формирует и возвращает текст запроса для выборки данных,
// необходимых для формирования печатной формы
Функция ПолучитьТекстЗапросаДляФормированияПечатнойФормыАкта()
		
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НачислениеПени.Ссылка КАК Ссылка,
	|	НачислениеПени.Ссылка.Номер КАК Номер,
	|	НачислениеПени.Ссылка.Дата КАК Дата,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
	|	НачислениеПени.Ссылка.Контрагент КАК Получатель,
	|	НачислениеПени.Ссылка.Организация КАК Поставщик,
	|	НачислениеПени.Ссылка.Организация,
	|	НачислениеПени.Ссылка.СуммаДокумента КАК СуммаДокумента,
	|	НачислениеПени.Ссылка.ВалютаДокумента,
	|	НачислениеПени.Ссылка.СуммаВключаетНДС,
	|	НачислениеПени.Ссылка.Проведен,
	|	НачислениеПени.Номенклатура КАК Товар,
	|	МАКСИМУМ(1) КАК Количество,
	|	"""" КАК ЕдиницаИзмерения,
	|	СУММА(НачислениеПени.Сумма) КАК Цена,
	|	СУММА(НачислениеПени.Сумма) КАК Сумма,
	|	НачислениеПени.СтавкаНДС,
	|	СУММА(НачислениеПени.СуммаНДС) КАК СуммаНДС,
	|	ВЫРАЗИТЬ(НачислениеПени.Содержание КАК СТРОКА(1000)) КАК Содержание,
	|	НачислениеПени.Ссылка.КурсВзаиморасчетов,
	|	НачислениеПени.Ссылка.КратностьВзаиморасчетов,
	|	НачислениеПени.Ссылка.Руководитель,
	|	НачислениеПени.Ссылка.ЗаРуководителяПоПриказу
	|ИЗ
	|	Документ.АР17_НачислениеПени.Состав КАК НачислениеПени
	|ГДЕ
	|	НачислениеПени.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачислениеПени.Ссылка.Номер,
	|	НачислениеПени.Ссылка.Дата,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента,
	|	НачислениеПени.Ссылка.Контрагент,
	|	НачислениеПени.Ссылка.Организация,
	|	НачислениеПени.Ссылка.ВалютаДокумента,
	|	НачислениеПени.Ссылка.СуммаВключаетНДС,
	|	НачислениеПени.Номенклатура,
	|	НачислениеПени.СтавкаНДС,
	|	НачислениеПени.Ссылка.СуммаДокумента,
	|	НачислениеПени.Ссылка,
	|	НачислениеПени.Ссылка.КурсВзаиморасчетов,
	|	НачислениеПени.Ссылка.КратностьВзаиморасчетов,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах,
	|	НачислениеПени.Ссылка.Проведен,
	|	ВЫРАЗИТЬ(НачислениеПени.Содержание КАК СТРОКА(1000)),
	|	НачислениеПени.Ссылка.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка";
	
	Возврат ТекстЗапроса;

КонецФункции

// Формирует и возвращает текст запроса для выборки данных,
// необходимых для формирования печатной формы
Функция ПолучитьТекстЗапросаДляФормированияПечатнойФормыАктаСводный()
		
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НачислениеПени.Ссылка КАК Ссылка,
	|	НачислениеПени.Ссылка.Номер КАК Номер,
	|	НачислениеПени.Ссылка.Дата КАК Дата,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
	|	НачислениеПени.Ссылка.Контрагент КАК Получатель,
	|	НачислениеПени.Ссылка.Организация КАК Поставщик,
	|	НачислениеПени.Ссылка.Организация,
	|	НачислениеПени.Ссылка.СуммаДокумента КАК СуммаДокумента,
	|	НачислениеПени.Ссылка.ВалютаДокумента,
	|	НачислениеПени.Ссылка.СуммаВключаетНДС,
	|	НачислениеПени.Ссылка.Проведен,
	|	МАКСИМУМ(1) КАК Количество,
	|	"""" КАК ЕдиницаИзмерения,
	|	СУММА(НачислениеПени.Сумма) КАК Цена,
	|	СУММА(НачислениеПени.Сумма) КАК Сумма,
	|	НачислениеПени.СтавкаНДС,
	|	СУММА(НачислениеПени.СуммаНДС) КАК СуммаНДС,
	|	НачислениеПени.Ссылка.КурсВзаиморасчетов,
	|	НачислениеПени.Ссылка.КратностьВзаиморасчетов,
	|	НачислениеПени.Ссылка.Руководитель,
	|	НачислениеПени.Ссылка.ЗаРуководителяПоПриказу
	|ИЗ
	|	Документ.АР17_НачислениеПени.Состав КАК НачислениеПени
	|ГДЕ
	|	НачислениеПени.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачислениеПени.Ссылка,
	|	НачислениеПени.Ссылка.Номер,
	|	НачислениеПени.Ссылка.Дата,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента,
	|	НачислениеПени.Ссылка.Контрагент,
	|	НачислениеПени.Ссылка.Организация,
	|	НачислениеПени.Ссылка.ВалютаДокумента,
	|	НачислениеПени.Ссылка.СуммаВключаетНДС,
	|	НачислениеПени.СтавкаНДС,
	|	НачислениеПени.Ссылка.СуммаДокумента,
	|	НачислениеПени.Ссылка.КурсВзаиморасчетов,
	|	НачислениеПени.Ссылка.КратностьВзаиморасчетов,
	|	НачислениеПени.Ссылка.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах,
	|	НачислениеПени.Ссылка.Проведен,
	|	НачислениеПени.Ссылка.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка";
	
	Возврат ТекстЗапроса;

КонецФункции

// Функция формирует табличный документ с печатной формой акта сдачи-приемки услуг
//
// Возвращаемое значение:
//  Табличный документ - сформированная печатная форма
//
Функция ПечатьАкта(МассивОбъектов, ОбъектыПечати, Сводный, СуммыВРублях = Ложь)
	
	ВалютаРегламентированногоУчета   = Константы.ВалютаРегламентированногоУчета.Получить();

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_НачислениеПени_Акт";
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Если Сводный Тогда
		Запрос.Текст = ПолучитьТекстЗапросаДляФормированияПечатнойФормыАктаСводный();
	Иначе 
		Запрос.Текст = ПолучитьТекстЗапросаДляФормированияПечатнойФормыАкта();
	КонецЕсли;
	
	Шапка = Запрос.Выполнить().Выбрать(); 
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_ВзаиморасчетыПоАрендеОбороты.Регистратор КАК Регистратор,
	|	АР_ВзаиморасчетыПоАрендеОбороты.УслугаАренды КАК Номенклатура,
	|	АР_ВзаиморасчетыПоАрендеОбороты.СуммаПриход КАК Сумма
	|ИЗ
	|	РегистрНакопления.АР_ВзаиморасчетыПоАренде.Обороты(, , Регистратор, ) КАК АР_ВзаиморасчетыПоАрендеОбороты
	|ГДЕ
	|	АР_ВзаиморасчетыПоАрендеОбороты.Регистратор В (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор";
	
	ТаблицаСуммВзаиморасчетов = Запрос.Выполнить().Выгрузить();
	Если Сводный Тогда
		ТаблицаСуммВзаиморасчетов.Свернуть("Регистратор", "Сумма");
	КонецЕсли;
		
	ПервыйДокумент = Истина;
	
	Пока Шапка.СледующийПоЗначениюПоля("Ссылка") Цикл
		
		ВалютаПечати = ?(СуммыВРублях, ВалютаРегламентированногоУчета, Шапка.ВалютаДокумента);
		
		Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР17_НачислениеПени.Акт");

		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

		ТаблицаУслуги = Новый ТаблицаЗначений;
		ТаблицаУслуги.Колонки.Добавить("Номенклатура");
		ТаблицаУслуги.Колонки.Добавить("Содержание");
		ТаблицаУслуги.Колонки.Добавить("Товар");
		ТаблицаУслуги.Колонки.Добавить("Количество");
		ТаблицаУслуги.Колонки.Добавить("ЕдиницаИзмерения");
		ТаблицаУслуги.Колонки.Добавить("Цена");
		ТаблицаУслуги.Колонки.Добавить("Сумма");
		ТаблицаУслуги.Колонки.Добавить("СтавкаНДС");
		ТаблицаУслуги.Колонки.Добавить("СуммаНДС");
		ТаблицаУслуги.Колонки.Добавить("НомерСтроки");
        	
		Пока Шапка.Следующий() Цикл
			
			СтрокаТовар = ТаблицаУслуги.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТовар, Шапка);
					
		КонецЦикла;	
		
		ТаблицаУслугиНовая = ТаблицаУслуги.СкопироватьКолонки();
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Регистратор", Шапка.Ссылка);
		
		ТаблицаСуммВзаиморасчетовПоРегистратору = ТаблицаСуммВзаиморасчетов.Скопировать(СтруктураПоиска);
		
		
		Если СуммыВРублях И (Шапка.Проведен 
			И (Шапка.РасчетыВУсловныхЕдиницах
			ИЛИ (Шапка.ВалютаДокумента <> ВалютаРегламентированногоУчета И Шапка.Дата >= '20090101000000'))) Тогда
				
			Для Каждого СтрокаВзаиморасчетов Из ТаблицаСуммВзаиморасчетовПоРегистратору Цикл
				
				ТаблицаУслугиКопия = ТаблицаУслуги.СкопироватьКолонки();	
				СуммаВзаиморасчетов = СтрокаВзаиморасчетов.Сумма;
				
				Если НЕ Сводный И Шапка.ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоУслугам Тогда
					
					СтруктураОтбора = Новый Структура("Товар", СтрокаВзаиморасчетов.Номенклатура);
					СтрокиУслуг = ТаблицаУслуги.НайтиСтроки(СтруктураОтбора);
					Для каждого СтрокаУслуг Из СтрокиУслуг Цикл
						НоваяСтрока = ТаблицаУслугиКопия.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаУслуг);
					КонецЦикла;
					
				Иначе
					
					ТаблицаУслугиКопия = ТаблицаУслуги.Скопировать();
					
				КонецЕсли;
				
				Если НЕ СуммаВзаиморасчетов = 0 Тогда
					
					РасчетСуммыНДСПоСтавке = Истина;
					
					ТаблицаУслугиКопия.Колонки.Добавить("СуммаБезНДС");
					
					МассивРаспределения = Новый Массив;
					
					Для каждого СтрокаТовар Из ТаблицаУслугиКопия Цикл
						
						СуммаСНДС = СтрокаТовар.Сумма + ?(Шапка.СуммаВключаетНДС, 0, СтрокаТовар.СуммаНДС);
						СуммаБезНДС = СуммаСНДС - СтрокаТовар.СуммаНДС;
						
						МассивРаспределения.Добавить(СуммаСНДС);
						СтрокаТовар.СуммаБезНДС = СуммаБезНДС;
						
					КонецЦикла;
					
					ТаблицаУслугиКопия.Колонки.Добавить("СуммаРублевая");
					РаспределитьСуммуПоСтолбцу(МассивРаспределения, СуммаВзаиморасчетов, ТаблицаУслугиКопия, "СуммаРублевая");
					
					Для каждого СтрокаТовар Из ТаблицаУслугиКопия Цикл
						
						Если РасчетСуммыНДСПоСтавке Тогда
							//Выделение суммы НДС, Расчет суммы без НДС
							ЗначениеСтавкиНДС = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СтрокаТовар.СтавкаНДС);
							
							СтрокаТовар.СуммаНДС = ?(ЗначениеСтавкиНДС = 0, 0, Окр(СтрокаТовар.СуммаРублевая * ЗначениеСтавкиНДС/(100+ЗначениеСтавкиНДС),2));
							СтрокаТовар.Сумма = СтрокаТовар.СуммаРублевая - СтрокаТовар.СуммаНДС;
							
						Иначе
							МассивРаспределения.Очистить();
							МассивРаспределения.Добавить(СтрокаТовар.СуммаБезНДС);
							МассивРаспределения.Добавить(СтрокаТовар.СуммаНДС);
							МассивРаспределенныхСумм = ОбщегоНазначенияБПКлиентСервер.РаспределитьПропорционально(СтрокаТовар.СуммаРублевая, МассивРаспределения);
							Если МассивРаспределенныхСумм <> Неопределено Тогда
								СтрокаТовар.Сумма = МассивРаспределенныхСумм[0];
								СтрокаТовар.СуммаНДС = МассивРаспределенныхСумм[1];
							КонецЕсли;
						КонецЕсли;
						
						Если Шапка.СуммаВключаетНДС Тогда
							СтрокаТовар.Сумма = СтрокаТовар.Сумма+СтрокаТовар.СуммаНДС;
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
				Для каждого СтрокаТаблицы Из ТаблицаУслугиКопия Цикл
					НоваяСтрока = ТаблицаУслугиНовая.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
				КонецЦикла;
			
			КонецЦикла;
				
		Иначе
			
			ТаблицаУслугиНовая = ТаблицаУслуги;
				
		КонецЕсли;

		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = ОбщегоНазначенияБПВызовСервера.СформироватьЗаголовокДокумента(Шапка, "Акт");
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Поставщик");
		СведенияОбОрганизации    = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата);
		ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,");
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ПредставлениеПоставщика;
		ОбластьМакета.Параметры.Поставщик 				= Шапка.Поставщик;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(Шапка.Организация, Шапка.Дата);
		ДолжностьИНазваниеОрганизации = ?(ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление),ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + " ","") + ПредставлениеПоставщика;
		
		Если ЗначениеЗаполнено(Шапка.Руководитель) Тогда
			Если Шапка.Руководитель = ОтветственныеЛицаОрганизации.Руководитель Тогда 
				ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
			Иначе
				ЗаместительПоПриказу = "(" + Шапка.ЗаРуководителяПоПриказу + " " +
					ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Шапка.Руководитель) + ")";
			КонецЕсли;
		Иначе
			ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
		КонецЕсли;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Покупатель");
		СведенияОКонтрагенте     = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		ПредставлениеПолучателя = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОКонтрагенте, "НаименованиеДляПечатныхФорм,");
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ПредставлениеПолучателя;
		ОбластьМакета.Параметры.Получатель = Шапка.Получатель;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ЕстьСкидки = Ложь;

		// Вывести табличную часть
		ОбластьШапки = "ШапкаТаблицы";
		ОбластьМакета = Макет.ПолучитьОбласть(ОбластьШапки);
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьСтроки = "Строка";
		ОбластьСтроки = Макет.ПолучитьОбласть(ОбластьСтроки);

		НомерСтроки = 0;

		Для каждого СтрокаТабличнойЧасти Из ТаблицаУслугиНовая Цикл

			НомерСтроки = НомерСтроки + 1;

			ОбластьСтроки.Параметры.Заполнить(СтрокаТабличнойЧасти);
			ОбластьСтроки.Параметры.НомерСтроки = НомерСтроки;
			
			ТоварНаименованиеПолное = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Товар), СтрокаТабличнойЧасти.Товар.НаименованиеПолное, "");
			ТоварНаименование = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Товар), СтрокаТабличнойЧасти.Товар.Наименование, "");
			
			Если Не Сводный Тогда
				НаименованиеУслуги = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Содержание), СтрокаТабличнойЧасти.Содержание, ТоварНаименованиеПолное);
				Если Не ЗначениеЗаполнено(НаименованиеУслуги) Тогда
					НаименованиеУслуги = ТоварНаименование;				
				КонецЕсли;
			Иначе
				НаименованиеУслуги = "Пени по договору " + Шапка.ДоговорКонтрагента;			
			КонецЕсли;
			ОбластьСтроки.Параметры.Товар = СокрЛП(НаименованиеУслуги);

			Если Шапка.ВалютаДокумента <> ВалютаРегламентированногоУчета Тогда
				ОбластьСтроки.Параметры.Цена  = СтрокаТабличнойЧасти.Сумма / ?(СтрокаТабличнойЧасти.Количество = 0, 1, СтрокаТабличнойЧасти.Количество);
			КонецЕсли;

			ТабличныйДокумент.Вывести(ОбластьСтроки);

		КонецЦикла;

		Если ТаблицаУслугиНовая <> Неопределено Тогда

			Сумма    = ТаблицаУслугиНовая.Итог("Сумма");
			СуммаНДС = ТаблицаУслугиНовая.Итог("СуммаНДС");

		Иначе

			Сумма    = 0;
			СуммаНДС = 0;

		КонецЕсли;

		ОбластьМакета = Макет.ПолучитьОбласть("Итого");
		ОбластьМакета.Параметры.Всего = ОбщегоНазначенияБПВызовСервера.ФорматСумм(Сумма);
		ТабличныйДокумент.Вывести(ОбластьМакета);
        
		ОбластьМакета = Макет.ПолучитьОбласть("ИтогоНДС");
		
		Если СуммаНДС <> 0 Тогда
			ОбластьМакета.Параметры.ВсегоНДС = ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаНДС);
			ОбластьМакета.Параметры.НДС      = ?(Шапка.СуммаВключаетНДС, "В том числе НДС", " Сумма НДС");
		Иначе
			ОбластьМакета.Параметры.ВсегоНДС = "-";
			ОбластьМакета.Параметры.НДС      = "Без налога (НДС)";
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		СуммаКПрописи = Сумма + ?(Шапка.СуммаВключаетНДС, 0, СуммаНДС);
		ОбластьМакета = Макет.ПолучитьОбласть("СуммаПрописью");
		ОбластьМакета.Параметры.ИтоговаяСтрока = "Всего оказано услуг " + НомерСтроки
		                                       + ", на сумму " + ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаКПрописи, ВалютаПечати);
		ОбластьМакета.Параметры.СуммаПрописью  = ОбщегоНазначенияБПВызовСервера.СформироватьСуммуПрописью(СуммаКПрописи, ВалютаПечати);
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Подписи");
		ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(СведенияОбОрганизации, "НаименованиеДляПечатныхФорм");
		ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(Шапка.Организация, Шапка.Дата);
		Если ЗначениеЗаполнено(Шапка.Руководитель) Тогда
			Если Шапка.Руководитель = ОтветственныеЛицаОрганизации.Руководитель Тогда 
				ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
				Если ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда 
					ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + ", " + ПредставлениеПоставщика;
				ИначеЕсли ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) Тогда 
					ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление;
				Иначе
					ДолжностьИНазваниеОрганизации = "" + ПредставлениеПоставщика;
				КонецЕсли;
			Иначе
				ЗаместительПоПриказу = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Шапка.Руководитель);
				Если ЗначениеЗаполнено(Шапка.ЗаРуководителяПоПриказу) Тогда 
					ЗаместительПоПриказу = ЗаместительПоПриказу + ", " + Шапка.ЗаРуководителяПоПриказу;
				КонецЕсли;
				ДанныеОтветственногоЛица = ОбщегоНазначенияБПВызовСервера.ДанныеФизЛица(Шапка.Организация, Шапка.Руководитель, Шапка.Дата);
				Если ЗначениеЗаполнено(ДанныеОтветственногоЛица.Должность) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда
					ДолжностьИНазваниеОрганизации = "" + ДанныеОтветственногоЛица.Должность + ", " + ПредставлениеПоставщика;
				ИначеЕсли ЗначениеЗаполнено(ДанныеОтветственногоЛица.Должность) Тогда
					ДолжностьИНазваниеОрганизации = "" + ДанныеОтветственногоЛица.Должность;
				Иначе
					ДолжностьИНазваниеОрганизации = ПредставлениеПоставщика;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ЗаместительПоПриказу = ОтветственныеЛицаОрганизации.РуководительПредставление;
			Если ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) И ЗначениеЗаполнено(ПредставлениеПоставщика) Тогда 
				ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление + ", " + ПредставлениеПоставщика;
			ИначеЕсли ЗначениеЗаполнено(ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление) Тогда 
				ДолжностьИНазваниеОрганизации = "" + ОтветственныеЛицаОрганизации.РуководительДолжностьПредставление;
			Иначе
				ДолжностьИНазваниеОрганизации = "" + ПредставлениеПоставщика;
			КонецЕсли;
		КонецЕсли;
		
		ОбластьМакета.Параметры.ДолжностьИНазваниеОрганизации = ДолжностьИНазваниеОрганизации;
		ОбластьМакета.Параметры.ЗаместительПоПриказу = ЗаместительПоПриказу;
		ТабличныйДокумент.Вывести(ОбластьМакета);

		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);

	КонецЦикла;

	Возврат ТабличныйДокумент;

КонецФункции // ПечатьАкта()

Функция ТекстЗапросаДанныеДляПечатиСчетовФактур(НомераТаблиц) Экспорт

	НомераТаблиц.Вставить("Реквизиты",     НомераТаблиц.Количество());
	НомераТаблиц.Вставить("СуммыПроводок", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВТ_РублевыеСуммыДокументовВВалюте", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВременнаяТаблицаДокумента", НомераТаблиц.Количество());
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК ДатаОснования,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.Организация КАК Поставщик,
	|	ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка) КАК Подразделение,
	|	Реквизиты.Организация.КПП КАК КППпоставщика,
	|	Реквизиты.Контрагент КАК Грузополучатель,
	|	Реквизиты.Контрагент КАК Покупатель,
	|	""он же"" КАК Грузоотправитель,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.ДоговорКонтрагента.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	Реквизиты.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
	|	ЛОЖЬ КАК ЕстьТовары
	|ИЗ
	|	Документ.АР17_НачислениеПени КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СуммыПроводок.ДокументОснование,
	|	СУММА(СуммыПроводок.Всего) КАК Всего,
	|	СУММА(СуммыПроводок.ВсегоНДС) КАК ВсегоНДС
	|ИЗ
	|	(ВЫБРАТЬ
	|		Хозрасчетный.Регистратор КАК ДокументОснование,
	|		СУММА(Хозрасчетный.Сумма) КАК Всего,
	|		0 КАК ВсегоНДС
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|	ГДЕ
	|		Хозрасчетный.Регистратор = &ДокументОснование
	|		И ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).ДоговорКонтрагента.РасчетыВУсловныхЕдиницах = ИСТИНА
	|		И ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).ВалютаДокумента <> &ВалютаРеглУчета
	|		И Хозрасчетный.СчетДт = ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).СчетУчетаРасчетовСКонтрагентом
	|		И Хозрасчетный.СчетКт <> ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).СчетУчетаРасчетовСКонтрагентом
	|		И Хозрасчетный.ВалютнаяСуммаДт <> 0
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Хозрасчетный.Регистратор
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Хозрасчетный.Регистратор,
	|		0,
	|		СУММА(Хозрасчетный.Сумма)
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|	ГДЕ
	|		Хозрасчетный.Регистратор = &ДокументОснование
	|		И ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).ДоговорКонтрагента.РасчетыВУсловныхЕдиницах = ИСТИНА
	|		И ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.АР17_НачислениеПени).ВалютаДокумента <> &ВалютаРеглУчета
	|		И Хозрасчетный.СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДС)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Хозрасчетный.Регистратор) КАК СуммыПроводок
	|
	|СГРУППИРОВАТЬ ПО
	|	СуммыПроводок.ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.ТабличнаяЧастьДокумента КАК ТабличнаяЧастьДокумента,
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.Всего,
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.НДС,
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.НалоговаяБазаНДС
	|ПОМЕСТИТЬ РублевыеСуммыДокументовВВалютеСрезПоследних
	|ИЗ
	|	РегистрСведений.РублевыеСуммыДокументовВВалюте КАК РублевыеСуммыДокументовВВалютеСрезПоследних
	|ГДЕ
	|	РублевыеСуммыДокументовВВалютеСрезПоследних.Регистратор = &ДокументОснование
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСтрокиДокумента,
	|	ТабличнаяЧастьДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	1 КАК НомерТабЧасти,
	|	1 КАК НомерСтроки,
	|	ТаблицаУслуги.Номенклатура КАК Товар,
	|	ТаблицаУслуги.Содержание КАК ТоварНаименование,
	|	"""" КАК СтранаПроисхождения,
	|	"""" КАК ПредставлениеСтраны,
	|	"""" КАК НомерГТД,
	|	"""" КАК ПредставлениеГТД,
	|	ЕСТЬNULL(КлассификаторЕдиницИзмерения.Ссылка, ТаблицаУслуги.Номенклатура.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
	|	1 КАК Количество,
	|	СУММА(ТаблицаУслуги.Сумма) КАК Цена,
	|	СУММА(ТаблицаУслуги.Сумма) КАК Сумма,
	|	СУММА(ТаблицаУслуги.СуммаНДС) КАК СуммаНДС,
	|	ТаблицаУслуги.СтавкаНДС КАК СтавкаНДС,
	|	ИСТИНА КАК ЭтоУслуга,
	|	ТаблицаУслуги.Ссылка.СуммаВключаетНДС КАК СуммаВключаетНДС,
	|	ТаблицаУслуги.Ссылка КАК Ссылка,
	|	ЛОЖЬ КАК ЭтоКомиссия,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.Всего, 0)) КАК ВсегоРуб,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.НДС, 0)) КАК НДСРуб,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.НалоговаяБазаНДС, 0)) КАК СуммаБезНДСРуб
	|ПОМЕСТИТЬ ТаблицаДокумента
	|ИЗ
	|	Документ.АР17_НачислениеПени.Состав КАК ТаблицаУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	|		ПО (КлассификаторЕдиницИзмерения.Наименование = ""шт"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РублевыеСуммыДокументовВВалютеСрезПоследних КАК РублевыеСуммыДокументовВВалютеСрезПоследних
	|		ПО ТаблицаУслуги.НомерСтроки = РублевыеСуммыДокументовВВалютеСрезПоследних.НомерСтрокиДокумента
	|			И (РублевыеСуммыДокументовВВалютеСрезПоследних.ТабличнаяЧастьДокумента = ЗНАЧЕНИЕ(Перечисление.ТабличныеЧастиДокументов.Услуги))
	|ГДЕ
	|	ТаблицаУслуги.Ссылка = &ДокументОснование
	|	И НЕ &СчетФактураСводный
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаУслуги.Номенклатура,
	|	ТаблицаУслуги.Содержание,
	|	ЕСТЬNULL(КлассификаторЕдиницИзмерения.Ссылка, ТаблицаУслуги.Номенклатура.ЕдиницаИзмерения),
	|	ТаблицаУслуги.СтавкаНДС,
	|	ТаблицаУслуги.Ссылка.СуммаВключаетНДС,
	|	ТаблицаУслуги.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1,
	|	1,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка),
	|	""Оплата пени "" + ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаУслуги.Номенклатура.АР_ПостояннаяЧастьОплаты, ИСТИНА)
	|			ТОГДА """"
	|		ИНАЧЕ ""(переменная часть)""
	|	КОНЕЦ + "" по договору "" + ТаблицаУслуги.Ссылка.ДоговорКонтрагента.Наименование + "" по состоянию на "" + &ПредставлениеПериода,
	|	"""",
	|	"""",
	|	"""",
	|	"""",
	|	ЕСТЬNULL(КлассификаторЕдиницИзмерения.Ссылка, ТаблицаУслуги.Номенклатура.ЕдиницаИзмерения),
	|	1,
	|	СУММА(ТаблицаУслуги.Сумма),
	|	СУММА(ТаблицаУслуги.Сумма),
	|	СУММА(ТаблицаУслуги.СуммаНДС),
	|	ТаблицаУслуги.СтавкаНДС,
	|	ИСТИНА,
	|	ТаблицаУслуги.Ссылка.СуммаВключаетНДС,
	|	ТаблицаУслуги.Ссылка КАК Ссылка,
	|	ЛОЖЬ КАК ЭтоКомиссия,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.Всего, 0)) КАК ВсегоРуб,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.НДС, 0)) КАК НДСРуб,
	|	СУММА(ЕСТЬNULL(РублевыеСуммыДокументовВВалютеСрезПоследних.НалоговаяБазаНДС, 0)) КАК СуммаБезНДСРуб
	|ИЗ
	|	Документ.АР17_НачислениеПени.Состав КАК ТаблицаУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	|		ПО (КлассификаторЕдиницИзмерения.Наименование = ""шт"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РублевыеСуммыДокументовВВалютеСрезПоследних КАК РублевыеСуммыДокументовВВалютеСрезПоследних
	|		ПО ТаблицаУслуги.НомерСтроки = РублевыеСуммыДокументовВВалютеСрезПоследних.НомерСтрокиДокумента
	|			И (РублевыеСуммыДокументовВВалютеСрезПоследних.ТабличнаяЧастьДокумента = ЗНАЧЕНИЕ(Перечисление.ТабличныеЧастиДокументов.Услуги))
	|ГДЕ
	|	ТаблицаУслуги.Ссылка = &ДокументОснование
	|	И &СчетФактураСводный
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаУслуги.СтавкаНДС,
	|	ТаблицаУслуги.Ссылка.СуммаВключаетНДС,
	|	ТаблицаУслуги.Ссылка,
	|	ЕСТЬNULL(КлассификаторЕдиницИзмерения.Ссылка, ТаблицаУслуги.Номенклатура.ЕдиницаИзмерения),
	|	""Оплата пени "" + ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаУслуги.Номенклатура.АР_ПостояннаяЧастьОплаты, ИСТИНА)
	|			ТОГДА """"
	|		ИНАЧЕ ""(переменная часть)""
	|	КОНЕЦ + "" по договору "" + ТаблицаУслуги.Ссылка.ДоговорКонтрагента.Наименование + "" по состоянию на "" + &ПредставлениеПериода";
	
	Возврат ТекстЗапроса + ОбщегоНазначенияБПВызовСервера.ТекстРазделителяЗапросовПакета();

КонецФункции

Процедура РаспределитьСуммуПоСтолбцу(МассивБазыРаспределения, РаспределяемаяСумма, ТаблицаРезультата, ИдКолонкиРезультата)

	// Определяем сумму базы
	СуммаБазы = 0;

	Для Индекс = 0 По МассивБазыРаспределения.Количество() - 1 Цикл
		СуммаБазы = СуммаБазы + МассивБазыРаспределения[Индекс];
	КонецЦикла;

	Если СуммаБазы > 0 Тогда
		// Выполняем распределение
		УчтеноБазыРаспределения = 0;
		УжеРаспределено = 0;

		Для Индекс = 0 По МассивБазыРаспределения.Количество() - 1 Цикл

			// Рассчитываем шаг распределения
			ШагРаспределения = Окр(РаспределяемаяСумма * (УчтеноБазыРаспределения + МассивБазыРаспределения[Индекс])/СуммаБазы, 2) - УжеРаспределено;

			// Записываем результат
			ТаблицаРезультата[Индекс][ИдКолонкиРезультата] = ШагРаспределения;

			// Учитываем полученный результат для вычисления последующих шагов распределения
			УчтеноБазыРаспределения = УчтеноБазыРаспределения + МассивБазыРаспределения[Индекс];
			УжеРаспределено         = УжеРаспределено + ШагРаспределения;

		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

