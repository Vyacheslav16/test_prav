
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	// Открыть форму выбора печатных форм
	Параметры = Новый Структура;
	Параметры.Вставить("Объект", ПараметрКоманды);
	Форма = ПолучитьФорму("ОбщаяФорма.АР_ФормаВыбораПечатныхФормУправляемая", Параметры);
	
	Результат = Форма.ОткрытьМодально();
	Если Результат = Неопределено Тогда
		Возврат;
	Иначе
		АР_ОбщиеПроцедурыКлиент.ПечатьШаблонаВорд(Результат, ПараметрКоманды);
	КонецЕсли;
	
КонецПроцедуры
