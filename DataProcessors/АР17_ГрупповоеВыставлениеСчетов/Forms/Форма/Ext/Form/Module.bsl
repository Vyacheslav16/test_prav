	КонецЦикла;
	
КонецПроцедуры


Функция ПакетнаяПечать(МассивТекДоков,БезЕдИзм=Ложь)
	
	ПакетОбработка = Обработки.АР17_ПакетнаяПечать.Создать();
	
	ПакетОбработка.ПечатьБезЕдИзм = БезЕдИзм;
	
	//МассивПечФорм = Новый Массив;
	//МассивПечФорм.Добавить("Счет");
	//МассивПечФорм.Добавить("Акт (штрих-код)");
	//МассивПечФорм.Добавить("Сч/ф");
	
	ТзДокиНаПечать = Новый ТаблицаЗначений;
	ТзДокиНаПечать.Колонки.Добавить("Документ");
	ТзДокиНаПечать.Колонки.Добавить("ПечатныеФормы");
	
	Для каждого ТекДок Из МассивТекДоков Цикл
		
		ТабПечФорм = Новый ТаблицаЗначений;
		ТабПечФорм.Колонки.Добавить("ПечФорма");
		ТабПечФорм.Колонки.Добавить("Колво");
		
		Нстрока = ТзДокиНаПечать.Добавить();
		Нстрока.Документ = ТекДок;
		ТипДока = ТипЗнч(ТекДок);
		
		Если ТипДока = Тип("ДокументСсылка.АР17_СчетНаАренду") Тогда
			
			НСтрокаПеч = ТабПечФорм.Добавить();
			НСтрокаПеч.ПечФорма = "Счет";
			НСтрокаПеч.Колво = 1;
			
		ИначеЕсли ТипДока = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			
			НСтрокаПеч = ТабПечФорм.Добавить();
			НСтрокаПеч.ПечФорма = "Акт (штрих-код)";
			НСтрокаПеч.Колво = 2;
			
		ИначеЕсли ТипДока = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
			
			НСтрокаПеч = ТабПечФорм.Добавить();
			НСтрокаПеч.ПечФорма = "Сч/ф";
			НСтрокаПеч.Колво = 1;
			
		КонецЕсли;
		
		Нстрока.ПечатныеФормы = ТабПечФорм;
		
	КонецЦикла;
	
	Возврат ПакетОбработка.СформироватьПечатныйДокумент(ТзДокиНаПечать,МассивТекДоков);
	
КонецФункции

&НаСервере
Функция НайтиСФ(ДокументОснование)
	
	Запрос1 = Новый Запрос;
	Запрос1.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктураПодчиненности.Ссылка
	|ИЗ
	|	КритерийОтбора.СвязанныеДокументы(&ЗначениеКритерияОтбора) КАК СтруктураПодчиненности
	|ГДЕ
	|	СтруктураПодчиненности.Ссылка ССЫЛКА Документ.РеализацияТоваровУслуг";
	
	Запрос1.УстановитьПараметр("ЗначениеКритерияОтбора", ДокументОснование);
	Выборка = Запрос1.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктураПодчиненности.Ссылка
	|ИЗ
	|	КритерийОтбора.СвязанныеДокументы(&ЗначениеКритерияОтбора) КАК СтруктураПодчиненности
	|ГДЕ Ссылка ССЫЛКА Документ.СчетФактураВыданный";
	
	Запрос.УстановитьПараметр("ЗначениеКритерияОтбора", Выборка.Ссылка);
	ТЗ = Запрос.Выполнить().Выгрузить();
	МассивСФ = Новый Массив;
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		МассивСФ.Добавить(СтрокаТЗ.Ссылка);
	КонецЦикла;	
	Возврат МассивСФ;
	
КонецФункции



&НаКлиенте
Процедура ВыполнитьПечатьНаКлиенте(ПечатнаяФорма, НаПринтер,БезЕдИзм=Ложь)
	
	МассивДокументов = Новый Массив;	
	Для каждого СтрокаТЧ Из Объект.СформированныеДокументы Цикл
		Если СтрокаТЧ.Пометка Тогда
			МассивДокументов.Добавить(СтрокаТЧ.Документ);
			ТекДок = СтрокаТЧ.Документ;
			// Начало изменений NAI Becar Матюхин Н.О. № 89683 от 08.12.2015 14:22
			Если ТипЗнч(ТекДок) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
				СФ = НайтиСФ(ТекДок);
				Для Каждого СтрокаСФ Из СФ Цикл
					Если МассивДокументов.Найти(СтрокаСФ) <> Неопределено Тогда
						МассивДокументов.Добавить(СтрокаСФ);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			// Конец изменений NAI Becar Матюхин Н.О. № 89683от 08.12.2015 14:22
		КонецЕсли;
	КонецЦикла;
	
	Если МассивДокументов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Начало изменений NAI Becar Матюхин Н.О. № 89683 от 08.12.2015 14:22
	ТекТабДок = ПакетнаяПечать(МассивДокументов, БезЕдИзм);
	Если НаПринтер Тогда
		ТекТабДок.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
		ТекТабДок.Напечатать();
	Иначе	
		//ТекТабДок.Показать();
		
		Стр = ПечатныеФормы.Добавить();
		Стр.ПечатнаяФорма = "Счет";
		Стр.Количество = 1;
		Стр.Печать = Истина;

		Пар = Новый Структура();
		Пар.Вставить("ИтогоТабДок",ТекТабДок);
		Пар.Вставить("ТабДокументов",Объект.СформированныеДокументы);
		Пар.Вставить("ПечатныеФормы",ПечатныеФормы);
		Пар.Вставить("ВидДокумента","Счета");
		Пар.Вставить("ПечатьБезЕдИзм",БезЕдИзм);
		Форма = ПолучитьФорму("Обработка.АР17_ПакетнаяПечать.Форма.ФормаПросмотра",Пар);
		Форма.Открыть();

	КонецЕсли;
	
	Возврат;
	// Конец изменений NAI Becar Матюхин Н.О. № 89683от 08.12.2015 14:22
	
	//Если НаПринтер Тогда  // + NAI Becar Конюшок С.Н. от 09.02.2017 15:11 лишний код
	//	УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_СчетНаАренду", ПечатнаяФорма, МассивДокументов, Неопределено);
	//Иначе
	//	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.АР17_СчетНаАренду", ПечатнаяФорма, МассивДокументов,	ЭтаФорма, Неопределено);
	//КонецЕсли;
	
КонецПроцедуры



