	|	АР_СтатусыОбъектовАренды.ЗаключениеДоговора КАК ЗДАОснование
	|ИЗ
	|	РегистрСведений.АР_СтатусыОбъектовАренды КАК АР_СтатусыОбъектовАренды
	|ГДЕ
	|	(АР_СтатусыОбъектовАренды.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|			ИЛИ АР_СтатусыОбъектовАренды.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|			ИЛИ АР_СтатусыОбъектовАренды.ДатаНачалаАренды <= &НачалоПериода
	|				И АР_СтатусыОбъектовАренды.ДатаОкончанияАренды >= &ОкончаниеПериода)
	|	И АР_СтатусыОбъектовАренды.Статус = &ВАренде
	|	И АР_СтатусыОбъектовАренды.Договор В(&СписокДоговоров)
	|	И АР_СтатусыОбъектовАренды.ОбъектАренды В(&СписокОбъектовАренды)
	|	И АР_СтатусыОбъектовАренды.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды";
	
	
	// + NAI Becar Комментирование Смирнов А.А. от 21.10.2016 14:41
	Если ЕстьОтборПоГруппамУслуг Тогда
		ЗапросДок.Текст = ЗапросДок.Текст + " И АР_СтатусыОбъектовАренды.ГруппаУслуг В(&СписокГруппаУслуг)";
	КонецЕсли;
	ЗапросДок.Текст = ЗапросДок.Текст + 
	// - NAI Becar Комментирование Смирнов А.А.
	"	И АР_СтатусыОбъектовАренды.Договор.Владелец В(&СписокКонтрагентов)
	
	|	И ВЫБОР
	|			КОГДА АР_СтатусыОбъектовАренды.ЗаключениеДоговора ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды
	|				ТОГДА АР_СтатусыОбъектовАренды.ЗаключениеДоговора.СтатусДоговора = ЗНАЧЕНИЕ(Перечисление.АР_СтатусДоговора.Согласован)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ	
	|";	
	
	ЗапросДок.УстановитьПараметр("ВАренде", Перечисления.АР_СтатусыОбъектовАренды.ВАренде);
	ЗапросДок.УстановитьПараметр("СписокКонтрагентов", СписокКонтрагентов);
	ЗапросДок.УстановитьПараметр("СписокДоговоров", СписокДоговоров);
	ЗапросДок.УстановитьПараметр("СписокУслуг", СписокУслуг);
	ЗапросДок.УстановитьПараметр("СписокОбъектовАренды", СписокОбъектовАренды);
	ЗапросДок.УстановитьПараметр("НачалоПериода",  Объект.НачалоПериода);
	ЗапросДок.УстановитьПараметр("ОкончаниеПериода",  Объект.ОкончаниеПериода);
	ЗапросДок.УстановитьПараметр("СписокГруппаУслуг", СписокГруппаУслуг); // + NAI Becar Комментирование Смирнов А.А. от 21.10.2016 10:59
	
	Комментарий = "Групповое выставление счетов от " + Формат(ТекущаяДата(), "ДФ = дд.ММ.гггг");
	Выгрузка = ЗапросДок.Выполнить().Выгрузить();
	Выборка = ЗапросДок.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл  //по парам "Контрагент-Договор"
		//+са
		Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 1 Тогда
			
			
			
			
			Счет = Документы.АР17_СчетНаАренду.СоздатьДокумент();
			
			ЗаполнитьЗначенияСвойств(Счет, Выборка);
			//+са
			//Счет.СчетОрганизации = Счет.Организация.ОсновнойБанковскийСчет;
			Счет.СчетОрганизации = Выборка.ЗДАОснование.БанковскийСчет; // + NAI Becar Комментирование Смирнов А.А. от 19.01.2017 10:35
			Счет.Дата = Объект.ДатаСчета;
			Счет.ДатаКурса = Объект.ДатаКурса;
			Счет.ВалютаДокумента = Счет.ДоговорКонтрагента.ВалютаВзаиморасчетов;
			Счет.СуммаВключаетНДС = Объект.СуммаВключаетНДС;
			Счет.ВидПериода = Объект.ВидПериода;
			Счет.НачалоПериода = Объект.НачалоПериода;
			Счет.ОкончаниеПериода = Объект.ОкончаниеПериода;
			
			// + NAI Becar Матюхин Н.О. от 10.11.2016 17:40 по заявке № 116341
			Если Объект.Депозит Тогда
				Счет.ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита;
			Иначе
				Счет.ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаАренды;
			КонецЕсли;
			// - NAI Becar Матюхин Н.О.
			
			Счет.Комментарий = Комментарий;
			
			СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Счет.ВалютаДокумента, Объект.ДатаКурса);
			Счет.КурсВзаиморасчетов = СтруктураКурса.Курс;
			Счет.КратностьВзаиморасчетов = СтруктураКурса.Кратность;
			Счет.Ответственный = Пользователи.ТекущийПользователь();
			
		ИначеЕсли Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда
			
			ЗапросДок = Новый Запрос;
			
			Если Не Объект.Депозит Тогда
				ЗапросДок.Текст =
				"ВЫБРАТЬ
				|	АР_СчетНаАрендуСостав.Ссылка
				|ИЗ
				|	Документ.АР17_СчетНаАренду.Состав КАК АР_СчетНаАрендуСостав
				|ГДЕ
