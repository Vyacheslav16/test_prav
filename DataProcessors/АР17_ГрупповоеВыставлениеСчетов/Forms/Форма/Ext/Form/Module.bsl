	//|	АР_СтатусыОбъектовАрендыСрезПоследних.Договор.Организация КАК Организация
	//|ИЗ
	//|	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(
	//|			,
	//|			Договор.Владелец В (&СписокКонтрагентов)
	//|				И Договор В (&СписокДоговоров)) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	//|ГДЕ
	//|	АР_СтатусыОбъектовАрендыСрезПоследних.Статус = &ВАренде
	//|	И (АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	//|			ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	//|			ИЛИ АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды <= &НачалоПериода
	//|				И АР_СтатусыОбъектовАрендыСрезПоследних.ДатаОкончанияАренды >= &ОкончаниеПериода)";
	
	
	//ЗапросДок = Новый Запрос;
	//ЗапросДок.Текст =
	//"ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|	АР_СтатусыОбъектовАренды.Договор КАК ДоговорКонтрагента,
	//|	АР_СтатусыОбъектовАренды.Договор.Владелец КАК Контрагент,
	//|	АР_СтатусыОбъектовАренды.Договор.Организация КАК Организация,
	//|	АР_СтатусыОбъектовАренды.ЗаключениеДоговора КАК ЗДАОснование,
	//|	АР_СтатусыОбъектовАренды.Услуга КАК Услуга,
	//|	АР_СтатусыОбъектовАренды.ДатаНачалаАренды,
	//|	АР_СтатусыОбъектовАренды.ДатаОкончанияАренды
	//|ИЗ
	//|	РегистрСведений.АР_СтатусыОбъектовАренды КАК АР_СтатусыОбъектовАренды
	//|ГДЕ
	//|	(АР_СтатусыОбъектовАренды.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	//|			ИЛИ АР_СтатусыОбъектовАренды.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	//|			ИЛИ АР_СтатусыОбъектовАренды.ДатаНачалаАренды <= &НачалоПериода
	//|				И АР_СтатусыОбъектовАренды.ДатаОкончанияАренды >= &ОкончаниеПериода)
	//|	И АР_СтатусыОбъектовАренды.Статус = &ВАренде
	//|	И АР_СтатусыОбъектовАренды.Договор В(&СписокДоговоров)
	//|	И АР_СтатусыОбъектовАренды.ОбъектАренды В(&СписокОбъектовАренды)";
	
	ЗапросДок = Новый Запрос;
	ЗапросДок.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АР_СтатусыОбъектовАренды.Договор КАК ДоговорКонтрагента,
	|	АР_СтатусыОбъектовАренды.Договор.Владелец КАК Контрагент,
