// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.ДатаСчета = ТекущаяДата();
	Объект.ДатаКурса = ТекущаяДата();
	Объект.ПометитьНаУдалениеСуществующиеДокументы = 2;
	
	Если Не ЗначениеЗаполнено(Объект.ВидПериода) Тогда
		Объект.ВидПериода = АР_ОбщиеПроцедуры.ПолучитьВидПериодаПоПериодичности(Константы.АР_ПериодНачисленияАренднойПлаты.Получить());
	КонецЕсли;
	
	ИнициализироватьКомпоновщикНастроек();
	
	//ВыборПериодаКлиентСервер.ЗаполнитьСписокВыбораВидПериода(
	//	ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День"),
	//	Элементы.ВидПериода.СписокВыбора, Объект.ВидПериода);
	
	//+са
	Объект.СуммаВключаетНДС = Истина;
	УправлениеФормой(ЭтаФорма);
	
	//передача параметров
	//Если Параметры <> Неопределено Тогда
	Если Параметры.Свойство("Ссылка") Тогда
		КомпоновщикНастроек.Настройки.Отбор.Элементы.Очистить();
		
		ЭлементОтбораОрганизация = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ЭлементОтбораОрганизация.ЛевоеЗначение=КомпоновщикНастроек.Настройки.Отбор.ДоступныеПоляОтбора.Элементы.Найти("Организация").Поле;
		ЭлементОтбораОрганизация.ВидСравнения=ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбораОрганизация.ПравоеЗначение=Параметры.Ссылка.Организация;
		
		Если Параметры.Свойство("СписокКА") Тогда // + NAI Becar Конюшок С.Н. от 23.01.2017 09:59 
			ЭлементОтбораКонтрагент = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
			ЭлементОтбораКонтрагент.ЛевоеЗначение=КомпоновщикНастроек.Настройки.Отбор.ДоступныеПоляОтбора.Элементы.Найти("Контрагент").Поле;
			ЭлементОтбораКонтрагент.ВидСравнения=ВидСравненияКомпоновкиДанных.ВСписке; 
			ЭлементОтбораКонтрагент.ПравоеЗначение=Параметры.СписокКА;
			
			ЭлементОтбораДоговор = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
			ЭлементОтбораДоговор.ЛевоеЗначение=КомпоновщикНастроек.Настройки.Отбор.ДоступныеПоляОтбора.Элементы.Найти("Договор").Поле;
			ЭлементОтбораДоговор.ВидСравнения=ВидСравненияКомпоновкиДанных.ВСписке; 
			ЭлементОтбораДоговор.ПравоеЗначение=Параметры.СписокДоговоровКА;
			
		Иначе	
			ЭлементОтбораКонтрагент = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
			ЭлементОтбораКонтрагент.ЛевоеЗначение=КомпоновщикНастроек.Настройки.Отбор.ДоступныеПоляОтбора.Элементы.Найти("Контрагент").Поле;
			ЭлементОтбораКонтрагент.ВидСравнения=ВидСравненияКомпоновкиДанных.Равно; 
			ЭлементОтбораКонтрагент.ПравоеЗначение=Параметры.Ссылка.Контрагент;
			
			ЭлементОтбораДоговор = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
			ЭлементОтбораДоговор.ЛевоеЗначение=КомпоновщикНастроек.Настройки.Отбор.ДоступныеПоляОтбора.Элементы.Найти("Договор").Поле;
			ЭлементОтбораДоговор.ВидСравнения=ВидСравненияКомпоновкиДанных.Равно; 
			ЭлементОтбораДоговор.ПравоеЗначение=Параметры.Ссылка.ДоговорКонтрагента;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Параметры.Свойство("ВидПериода") Тогда
		Объект.ВидПериода = Параметры.ВидПериода;
	КонецЕсли;
	Если Параметры.Свойство("НачалоПериода") Тогда
		Объект.НачалоПериода = Параметры.НачалоПериода;
	КонецЕсли;
	Если Параметры.Свойство("ОкончаниеПериода") Тогда
		Объект.ОкончаниеПериода = Параметры.ОкончаниеПериода;
