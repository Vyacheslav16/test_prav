	ЕстьОтборПоУслугам = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 6) = "Услуга" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоУслугам = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ЕстьОтборПоОбъекту = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 6) = "Объект" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоОбъекту = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если Не ЕстьОтборПоОбъекту Тогда 
		СписокОбъектовАренды.Добавить(Справочники.АР_ОбъектыАренды.ПустаяСсылка());
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	// Сделаем проверку на то, сфорированны ли ранее документы
	Запрос.УстановитьПараметр("СписокКонтрагентов", СписокКонтрагентов);
	Запрос.УстановитьПараметр("СписокДоговоров", СписокДоговоров);
	Запрос.УстановитьПараметр("СписокУслуг", СписокУслуг);
	Запрос.УстановитьПараметр("СписокОбъектовАренды", СписокОбъектовАренды);
	Запрос.УстановитьПараметр("НачалоПериода",  Объект.НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода",  Объект.ОкончаниеПериода);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АР_СчетНаАрендуСостав.Ссылка
	|ИЗ
	|	Документ.АР17_СчетНаАренду.Состав КАК АР_СчетНаАрендуСостав
	|ГДЕ
	|	АР_СчетНаАрендуСостав.Ссылка.Контрагент В(&СписокКонтрагентов)
	|	И АР_СчетНаАрендуСостав.Ссылка.ДоговорКонтрагента В(&СписокДоговоров)
	|	И АР_СчетНаАрендуСостав.Ссылка.НачалоПериода >= &НачалоПериода
	|	И АР_СчетНаАрендуСостав.Ссылка.ОкончаниеПериода <= &ОкончаниеПериода
	|	И НЕ АР_СчетНаАрендуСостав.Ссылка.ПометкаУдаления
	|	И АР_СчетНаАрендуСостав.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита)";
	Выборка = Запрос.Выполнить().Выбрать();
	Отказ = Ложь;
	
	Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда // + NAI Becar Конюшок С.Н. от 21.09.2017 14:55 
		ВыставленныеСчета = Новый Массив;
	КонецЕсли; // - NAI Becar Конюшок С.Н. 
	
	Пока Выборка.Следующий() Цикл
		Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 1 Тогда
			ДокОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ДокОбъект.УстановитьПометкуУдаления(Истина);
			ТекстСообщения = НСтр("ru = 'Документ """ + Строка(Выборка.Ссылка) + """ помечен на удаление'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Выборка.Ссылка);
		ИначеЕсли Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда
			ТекстСообщения = НСтр("ru = 'Имеется документ """ + Строка(Выборка.Ссылка) + """, созданный ранее по текущим параметрам отбора'");
			//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Выборка.Ссылка,,, Отказ);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Выборка.Ссылка);
			
			//Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда // + NAI Becar Конюшок С.Н. от 21.09.2017 14:55 
				ВыставленныеСчета.Добавить(Выборка.Ссылка.ДоговорКонтрагента);
			//КонецЕсли; // - NAI Becar Конюшок С.Н. 
			
		Иначе
			а=а; //-са
		КонецЕсли;
	КонецЦикла;
	
	Если Отказ Тогда
		ТекстСообщения = НСтр("ru = 'Формирование документов прервано'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	СформированныеДоки = Новый СписокЗначений;
	
	//+са
	
	ЗапросОтдельныйДок = Новый Запрос;
	ЗапросОтдельныйДок.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	                           |	АР_СтатусыОбъектовАренды.Договор КАК ДоговорКонтрагента,
	                           |	АР_СтатусыОбъектовАренды.Договор.Владелец КАК Контрагент,
	                           |	АР_СтатусыОбъектовАренды.Договор.Организация КАК Организация,
	                           |	АР_СтатусыОбъектовАренды.ЗаключениеДоговора.Ссылка КАК ЗДАОснование
	                           |ИЗ
	                           |	РегистрСведений.АР_СтатусыОбъектовАренды КАК АР_СтатусыОбъектовАренды
	                           |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_Ставки КАК АР_Ставки
	                           |		ПО АР_СтатусыОбъектовАренды.Регистратор = АР_Ставки.Регистратор
	                           |			И АР_СтатусыОбъектовАренды.Услуга = АР_Ставки.Услуга
	                           |ГДЕ
	                           |	(АР_СтатусыОбъектовАренды.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	                           |			ИЛИ АР_СтатусыОбъектовАренды.ДатаОкончанияАренды МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	                           |			ИЛИ АР_СтатусыОбъектовАренды.ДатаНачалаАренды <= &НачалоПериода
	                           |				И АР_СтатусыОбъектовАренды.ДатаОкончанияАренды >= &ОкончаниеПериода)
	                           |	И АР_СтатусыОбъектовАренды.Договор В(&СписокДоговоров)
	                           |	И НЕ АР_СтатусыОбъектовАренды.Договор В (&ВыставленныеСчета)
	                           |	И АР_СтатусыОбъектовАренды.Договор.Владелец В(&СписокКонтрагентов)
	                           |	И ВЫБОР
	                           |			КОГДА АР_СтатусыОбъектовАренды.ЗаключениеДоговора.СпособРасчетаЗалога = ЗНАЧЕНИЕ(Перечисление.АР_СпособРасчетаЗалога.АренднаяПлата)
	                           |				ТОГДА АР_СтатусыОбъектовАренды.Депозит = ИСТИНА
	                           |			ИНАЧЕ АР_СтатусыОбъектовАренды.ЗаключениеДоговора.СпособРасчетаЗалога <> ЗНАЧЕНИЕ(Перечисление.АР_СпособРасчетаЗалога.ПустаяСсылка)
	                           |		КОНЕЦ
	                           |	И АР_Ставки.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды";
	ЗапросОтдельныйДок.УстановитьПараметр("ВАренде", Перечисления.АР_СтатусыОбъектовАренды.ВАренде);
	ЗапросОтдельныйДок.УстановитьПараметр("СписокКонтрагентов", СписокКонтрагентов);
	ЗапросОтдельныйДок.УстановитьПараметр("СписокДоговоров", СписокДоговоров);
	//ЗапросОтдельныйДок.УстановитьПараметр("СписокУслуг", СписокУслуг);
	//ЗапросОтдельныйДок.УстановитьПараметр("СписокОбъектовАренды", СписокОбъектовАренды);
	ЗапросОтдельныйДок.УстановитьПараметр("НачалоПериода",  Объект.НачалоПериода);
	ЗапросОтдельныйДок.УстановитьПараметр("ОкончаниеПериода",  Объект.ОкончаниеПериода);
	Комментарий = "Групповое выставление счетов от " + Формат(ТекущаяДата(), "ДФ = дд.ММ.гггг");
	
	Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда // + NAI Becar Конюшок С.Н. от 21.09.2017 14:55 
		ЗапросОтдельныйДок.УстановитьПараметр("ВыставленныеСчета", ВыставленныеСчета);
	Иначе
		ЗапросОтдельныйДок.Текст = СтрЗаменить(ЗапросОтдельныйДок.Текст, "И НЕ АР_СтатусыОбъектовАренды.Договор В (&ВыставленныеСчета)", ""); 
	КонецЕсли; // - NAI Becar Конюшок С.Н. 
	
	Выгрузка = ЗапросОтдельныйДок.Выполнить().Выгрузить();
	Выборка = ЗапросОтдельныйДок.Выполнить().Выбрать();
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ДоговорКонтрагента");
	ТЗ.Колонки.Добавить("Контрагент");
	ТЗ.Колонки.Добавить("Организация");
	ТЗ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("ЗДАОснование");
	ТЗ.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
	Для Каждого	Стр из Выгрузка Цикл
		СтрТЗ = ТЗ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрТЗ, Стр);
	КонецЦикла;	
	Если Выгрузка.Количество() > 0 Тогда
		СформироватьДокументыПродолжениеДепозит(ТЗ,СписокУслуг,СписокОбъектовАренды,ЕстьОтборПоУслугам,ЕстьОтборПоОбъекту,Истина,СформированныеДоки);
	КонецЕсли;	
	
	ЗаполнитьСостоянияДокументов();
	
	ТекстСообщения = НСтр("ru = 'Формирование документов завершено'");
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры




Процедура СформироватьДокументыПродолжениеДепозит(Выборка,СписокУслуг,СписокОбъектовАренды,ЕстьОтборПоУслугам,ЕстьОтборПоОбъекту,ПризнакСчета,СформированныеДоки)
	
	СЗ = Новый СписокЗначений;
	ТЗАкты = Новый ТаблицаЗначений;
	ТЗАкты.Колонки.Добавить("Номенклатура");
	СтараяУслуга = "";
	СтарыйДоговор = "";
	Переформировать = Ложь;
	
	СтарыйСчет = ""; // + NAI Becar Комментирование Смирнов А.А. от 31.01.2017 15:54
	
	ТЗДоговоры = Выборка.Скопировать();
	ТЗДоговоры.Сортировать("ДоговорКонтрагента");
	ТЗДоговоры.Свернуть("ДоговорКонтрагента");//,ЗДАОснование");
	
	Если Не ПризнакСчета Тогда
		ВыборкаРаздельно = Выборка.Скопировать();
		Выборка = ВыборкаРаздельно.Скопировать(,"ДоговорКонтрагента,Контрагент,Организация");
		Выборка.Свернуть("ДоговорКонтрагента,Контрагент,Организация");
	КонецЕсли;	
	
	
	
	//Пока Выборка.Следующий() Цикл  //по парам "Контрагент-Договор"
	Для Каждого СтрДоговор из ТЗДоговоры Цикл
		
		//////////////Если (СтарыйДоговор <> СтрДоговор.ДоговорКонтрагента) Тогда //Продолжить; КонецЕсли;
			
			Отбор = Новый Структура("ДоговорКонтрагента", СтрДоговор.ДоговорКонтрагента);
			ВыборкаДоговор = Выборка.Скопировать(Отбор);
			// + NAI Becar Комментирование Смирнов А.А. от 06.02.2017 14:17
			Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 1 Тогда
				ВыборкаДоговор.Свернуть("ДоговорКонтрагента"); 
			КонецЕсли;
			// - NAI Becar Комментирование Смирнов А.А.
			
			СуммаДепозит = 0;
			Для Каждого Стр Из ВыборкаДоговор Цикл
				
				// + NAI Becar Комментирование Смирнов А.А. от 31.01.2017 11:10
				Отбор = Новый Структура("ДоговорКонтрагента", СтрДоговор.ДоговорКонтрагента);
				ВыборкаДепозит = Выборка.Скопировать(Отбор);
				ТЗДепозит = ВыборкаДепозит.Скопировать(,"Номенклатура,Сумма");
				// - NAI Becar Комментирование Смирнов А.А.
				
				//+са
				Если Объект.ПометитьНаУдалениеСуществующиеДокументы = 1 Тогда
					
					//+са
					//+кусок элиаса
					Счет = Документы.АР17_СчетНаАренду.СоздатьДокумент();
					Счет.ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита;
					//ЗаполнитьЗначенияСвойств(Счет, СтрДоговор.ЗДАОснование,,"Номер");
					// + NAI Becar Комментирование Смирнов А.А. от 19.01.2017 11:20
					//Счет.СчетОрганизации = Счет.Организация.ОсновнойБанковскийСчет;
					ЗапросРС = Новый Запрос;
					ЗапросРС.Текст = "ВЫБРАТЬ
					|	АР17_ЗаключениеДоговораАренды.Ссылка
					|ИЗ
					|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
					|ГДЕ
					|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
					ЗапросРС.УстановитьПараметр("ДоговорКонтрагента", СтрДоговор.ДоговорКонтрагента);
					ВыборкаРС = ЗапросРС.Выполнить().Выбрать();
					ВыборкаРС.Следующий();
					ЗаполнитьЗначенияСвойств(Счет, ВыборкаРС.Ссылка,,"Номер");
					Счет.СчетОрганизации = ВыборкаРС.Ссылка.БанковскийСчет; // + NAI Becar Комментирование Смирнов А.А. от 19.01.2017 10:35
					// - NAI Becar Комментирование Смирнов А.А.
					Счет.Дата = Объект.ДатаСчета;
					Счет.ДатаКурса = Объект.ДатаКурса;
					Счет.ВалютаДокумента = Счет.ДоговорКонтрагента.ВалютаВзаиморасчетов;
					Счет.СуммаВключаетНДС = Объект.СуммаВключаетНДС;
					Счет.ВидПериода = Объект.ВидПериода;
					Счет.НачалоПериода = Объект.НачалоПериода;
					Счет.ОкончаниеПериода = Объект.ОкончаниеПериода;
					//Счет.ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаАренды;
					Счет.Комментарий = "Групповое выставление счетов от " + Формат(ТекущаяДата(), "ДФ = дд.ММ.гггг");
					
					СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Счет.ВалютаДокумента, Объект.ДатаКурса);
					Счет.КурсВзаиморасчетов = СтруктураКурса.Курс;
					Счет.КратностьВзаиморасчетов = СтруктураКурса.Кратность;
					Счет.Ответственный = Пользователи.ТекущийПользователь();
					//-кусок Элиаса
					
				
				ИначеЕсли Объект.ПометитьНаУдалениеСуществующиеДокументы = 2 Тогда
					
					//+са
					
					//////////ЗапросДок = Новый Запрос;
					//////////ЗапросДок.Текст = 
					//////////"ВЫБРАТЬ
					//////////|	АР17_ЗаключениеДоговораАренды.СуммаЗалога,
					//////////|	ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстатокКт, 0) КАК СуммаОстатокКт,
					//////////|	АР17_СчетНаАрендуДепозит.Ссылка,
					//////////|	АР17_СчетНаАрендуДепозит.Номенклатура,
					//////////|	АР17_СчетНаАрендуСостав.Сумма КАК Сумма
					//////////|ИЗ
					//////////|	Документ.АР17_СчетНаАренду.Депозит КАК АР17_СчетНаАрендуДепозит
					//////////|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
					//////////|		ПО АР17_СчетНаАрендуДепозит.Ссылка.ДоговорКонтрагента = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
					//////////|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Остатки(&ОкончаниеПериода, Счет В (&СписокСчетов), , ) КАК ХозрасчетныйОстатки
					//////////|		ПО АР17_СчетНаАрендуДепозит.Ссылка.ДоговорКонтрагента = ХозрасчетныйОстатки.Субконто2
					//////////|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_СчетНаАренду.Состав КАК АР17_СчетНаАрендуСостав
					//////////|		ПО АР17_СчетНаАрендуДепозит.Ссылка = АР17_СчетНаАрендуСостав.Ссылка
					//////////|ГДЕ
					//////////|	АР17_СчетНаАрендуДепозит.Ссылка.Контрагент = &Контрагент
					//////////|	И АР17_СчетНаАрендуДепозит.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
					//////////|	И АР17_СчетНаАрендуДепозит.Ссылка.НачалоПериода >= &НачалоПериода
