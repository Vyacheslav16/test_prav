&НаКлиенте
Процедура СформироватьДокументы(Команда)
	
	Если Объект.СформированныеДокументы.Количество() > 0 Тогда
		Ответ = Вопрос("Таблица сформированных документов будет очищена. Продолжить?", РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Нет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			Объект.СформированныеДокументы.Очистить();
		Иначе
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		Если Не Объект.Депозит Тогда
			
			Если Не Объект.ОтключитьНачислениеПоИндексам Тогда
				СформироватьДокументыНаСервереИнд();
			Иначе 	
				// + NAI Becar Матюхин Н.О. от 10.11.2016 15:38 по заявке № 116341
				//Если Объект.Депозит Тогда
				//	СформироватьДокументыПоДепозитуНаСервере();			
				//Иначе	
				СформироватьДокументыНаСервере();
				//КонецЕсли;
				// - NAI Becar Матюхин Н.О.
			КонецЕсли;
		Иначе
			СформироватьДокументыПоДепозитуНаСервере();
		КонецЕсли;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаСформированныеДокументы;
		ОформитьСтрокиТЧСервер();
	КонецЕсли;
	
КонецПроцедуры

//+са
Процедура ОформитьСтрокиТЧСервер()
	//ОформитьСтрокиТЧ(Объект,УсловноеОформление,"Документ");
КонецПроцедуры

&НаСервере
Процедура ОформитьСтрокиТЧ(Объект,УсловноеОформление,ИмяОбъектаСОформлением) Экспорт
	
	ОбъектДанные = ДанныеФормыВЗначение(Объект,Тип("ОбработкаОбъект.АР17_ГрупповоеВыставлениеСчетов"));
	
	Для каждого СтрТЧ Из ОбъектДанные["СформированныеДокументы"] Цикл
		
		
		ОбъектСОформлением  = СтрТЧ[ИмяОбъектаСОформлением];
		
		Если ТипЗнч(СтрТЧ.Документ) = Тип("ДокументСсылка.СчетФактураВыданный") или (СтрТЧ.СуммаДоговора - СтрТЧ.СуммаДокумента = 0) Тогда 
			//ЦветФонаСтроки      = WebЦвета.Черный;
			ЦветШрифтаСтроки    = WebЦвета.Черный;
		Иначе	
			//ЦветФонаСтроки      = WebЦвета.Красный;
			ЦветШрифтаСтроки    = WebЦвета.Красный;
		КонецЕсли;	
		
		ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
		ЭлементУсловногоОформления.Использование    = Истина;
		
		ОформлениеУО        = ЭлементУсловногоОформления.Оформление;
		ОтборУО             = ЭлементУсловногоОформления.Отбор;
		ОформляемыеПоляУО   = ЭлементУсловногоОформления.Поля;
		
		//ОформлениеУО.УстановитьЗначениеПараметра("ЦветФона", ЦветФонаСтроки);
		ОформлениеУО.УстановитьЗначениеПараметра("ЦветТекста", ЦветШрифтаСтроки);
		
		//ЭлементОтбора                = ОтборУО.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		//ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.СформированныеДокументы" + "." + ИмяОбъектаСОформлением);
		//ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		//ЭлементОтбора.ПравоеЗначение = ОбъектСОформлением;
		//ЭлементОтбора.Использование  = Истина;
		
		ЭлементОтбора                = ОтборУО.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.СформированныеДокументы" + "." + ИмяОбъектаСОформлением);
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = СтрТЧ.Документ;
		ЭлементОтбора.Использование  = Истина;
		
		Для каждого РеквизитТЧ Из Метаданные.Обработки["АР17_ГрупповоеВыставлениеСчетов"].ТабличныеЧасти["СформированныеДокументы"].Реквизиты Цикл
			
			НазваниеРеквизита   = РеквизитТЧ.Имя;
			ОформляемоеПоле     = ОформляемыеПоляУО.Элементы.Добавить();
			ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("СформированныеДокументы" + НазваниеРеквизита);
			ОформляемоеПоле.Использование = Истина;
			
		КонецЦикла;
		
		//ОформляемоеПоле      = ОформляемыеПоляУО.Элементы.Добавить();
		//ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("СформированныеДокументы" + "НомерСтроки");
		
	КонецЦикла;
КонецПроцедуры
