
Процедура ЗаполнитьНаСервере(АвтоФормирование = Ложь) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Контрагент
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	И Контрагенты.Ссылка В ИЕРАРХИИ(&Родитель)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоговорыКонтрагентов.Ссылка КАК БухДоговор,
		|	ВТ.Контрагент
		|ПОМЕСТИТЬ БухДоговора
		|ИЗ
		|	ВТ КАК ВТ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО ВТ.Контрагент = ДоговорыКонтрагентов.Владелец
		|ГДЕ
		|	ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	БухДоговора.БухДоговор КАК БухДоговор,
		|	БухДоговора.Контрагент КАК Контрагент,
		|	БухДоговора.БухДоговор.Владелец.Код КАК КодКА,
		|	СписаниеСРасчетногоСчета.Ссылка КАК ПлатежныйДокумент,
		|	СписаниеСРасчетногоСчета.НомерВходящегоДокумента КАК Номер,
		|	СписаниеСРасчетногоСчета.ДатаВходящегоДокумента КАК Дата,
		|	СписаниеСРасчетногоСчета.СуммаДокумента КАК СуммаСписания,
		|	NULL КАК СуммаПоступления
		|ИЗ
		|	БухДоговора КАК БухДоговора
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеСРасчетногоСчета КАК СписаниеСРасчетногоСчета
		|		ПО БухДоговора.БухДоговор.Ссылка = СписаниеСРасчетногоСчета.ДоговорКонтрагента
		|ГДЕ
		|	СписаниеСРасчетногоСчета.Проведен = ИСТИНА
		|	И СписаниеСРасчетногоСчета.Дата >= &ДатаН
		|	И СписаниеСРасчетногоСчета.Дата <= &ДатаК
		|	И СписаниеСРасчетногоСчета.Организация = &УК
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	БухДоговора.БухДоговор,
		|	БухДоговора.Контрагент,
		|	БухДоговора.БухДоговор.Владелец.Код,
		|	ПоступлениеНаРасчетныйСчет.Ссылка,
		|	ПоступлениеНаРасчетныйСчет.НомерВходящегоДокумента,
		|	ПоступлениеНаРасчетныйСчет.ДатаВходящегоДокумента,
		|	NULL,
		|	ПоступлениеНаРасчетныйСчет.СуммаДокумента
		|ИЗ
		|	БухДоговора КАК БухДоговора
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеНаРасчетныйСчет КАК ПоступлениеНаРасчетныйСчет
		|		ПО БухДоговора.БухДоговор.Ссылка = ПоступлениеНаРасчетныйСчет.ДоговорКонтрагента
		|ГДЕ
		|	ПоступлениеНаРасчетныйСчет.Проведен = ИСТИНА
		|	И ПоступлениеНаРасчетныйСчет.Дата >= &ДатаН
		|	И ПоступлениеНаРасчетныйСчет.Дата <= &ДатаК
		|	И ПоступлениеНаРасчетныйСчет.Организация = &УК
		|
		|УПОРЯДОЧИТЬ ПО
		|	Контрагент,
		|	Дата";
		
	Запрос.УстановитьПараметр("ДатаН", Период.ДатаНачала); 
	Запрос.УстановитьПараметр("ДатаК", Период.ДатаОкончания); 
	Запрос.УстановитьПараметр("Родитель", Справочники.Контрагенты.НайтиПоКоду("00-006870"));
	Запрос.УстановитьПараметр("УК", Справочники.Организации.НайтиПоРеквизиту("ИНН", "7801178126  ")); 
	
	
	РЗ = Запрос.Выполнить().Выгрузить();
	
	Договора.Загрузить(РЗ);
	
	Если АвтоФормирование Тогда
		ЗаписатьФайл("\\172.17.1.6\obmen\Exchange_1C\vertical.xls\");
		//
		//Файл = Новый ТекстовыйДокумент;
		//
		////КаталогНаДиске = Новый Файл(СокрЛП(Путь));
		//
		////а = КаталогНаДиске.Существует();
		//Файл.Записать("\\172.17.1.6\obmen\Exchange_1C\vertical.xls\");
		////Файл.Записать();
	КонецЕсли;
		
КонецПроцедуры

Процедура ЗаписатьФайл(ПутьКФайлу)
	
