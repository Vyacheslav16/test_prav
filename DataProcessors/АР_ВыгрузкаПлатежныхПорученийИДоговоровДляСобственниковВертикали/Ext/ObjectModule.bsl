		Если Стр.СуммаПоступления > 0 Тогда 
			Ячейка.Value = Стр.СуммаПоступления;
		КонецЕсли;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 9);
		Ячейка.Value = Строка(Стр.ПлатежныйДокумент.УникальныйИдентификатор());
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		//Ячейка.WrapText = истина;
		
	КонецЦикла; 
	
	//Попытка        
	Книга.Save();  
	//Сообщить("Файл успешно сохранен!");
