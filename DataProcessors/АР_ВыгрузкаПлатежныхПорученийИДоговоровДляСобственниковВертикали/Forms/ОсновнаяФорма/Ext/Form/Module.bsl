
&НаКлиенте
Процедура Выгрузить(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Период) Тогда
		Сообщить("Внимание! Необходимо указать период!");
		Возврат;
	КонецЕсли;
	
	Режим = РежимДиалогаВыбораФайла.Сохранение; 
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим); 
	ДиалогОткрытияФайла.ПолноеИмяФайла = "";
	Фильтр = "Файл Excel (*,xls; *.xlsx)|*.xls; *.xlsx|";
	//+
	//"Файл Excel 2013 (*,xlsx)|*.xlsx|"; 
	ДиалогОткрытияФайла.Фильтр = Фильтр; 
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь; 
	ДиалогОткрытияФайла.Заголовок = "Выберите файл для сохранения бланка"; 
	
	ПутьКФайлу = "Выгрузка платежных документов и договоров собственников вертикали из 1С от " + Формат(ТекущаяДата(),"ДЛФ=Д");
	ДиалогОткрытияФайла.ПолноеИмяФайла = ПутьКФайлу;
	Если ДиалогОткрытияФайла.Выбрать() Тогда 
		ПутьКФайлу = ДиалогОткрытияФайла.ПолноеИмяФайла; 
		//Иначе
		//	ПутьКФайлу="";
	КонецЕсли;
	
	ЗаполнитьНаСервере();
	
	ЗаписатьФайл(ПутьКФайлу);
КонецПроцедуры


&НаКлиенте
Процедура ЗаписатьФайл(ПутьКФайлу)
	
	Эксель = Новый COMОбъект("Excel.Application");
	Книга = Эксель.WorkBooks().Add();
	
	Книга = Эксель.Application.Workbooks(1);
	Лист = Книга.WorkSheets(1); 
	Лист.Cells.Clear(); //ClearContents();
	
	Лист.Columns(2).ColumnWidth = 40;
	Лист.Columns(3).ColumnWidth = 15;
	Лист.Columns(4).ColumnWidth = 40;
	Лист.Columns(5).ColumnWidth = 20;
	Лист.Columns(6).ColumnWidth = 20;
	Лист.Columns(7).ColumnWidth = 20;
	Лист.Columns(8).ColumnWidth = 20;
	Лист.Columns(9).ColumnWidth = 35;
	//Лист.Columns(10).ColumnWidth = 40;
	
	Ячейка =  Лист.Cells(3, 2);
	Ячейка.Value = "Контрагент";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 3);
	Ячейка.Value = "Код контрагента";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	//Ячейка =  Лист.Cells(3, 4);
	//Ячейка.Value =  "Договор аренды";
	//Ячейка.Borders.LineStyle = 1;
	//Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	//Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 4);
	Ячейка.Value = "Договор";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	//Ячейка =  Лист.Cells(3, 5);
	//Ячейка.Value =  "Вид бух. договора";
	//Ячейка.Borders.LineStyle = 1;
	//Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	//Ячейка.WrapText = истина;

	//Ячейка =  Лист.Cells(3, 6);
	//Ячейка.Value =  "Организация";
	//Ячейка.Borders.LineStyle = 1;
	//Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	//Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 5);
	Ячейка.Value =  "Номер платежного поручения";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 6);
	Ячейка.Value =  "Дата платежного поручения";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 7);
	Ячейка.Value =  "Списание(в отчете агента это - дебет)";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;

	Ячейка =  Лист.Cells(3, 8);
	Ячейка.Value =  "Поступление (в отчете агента- это кредит)";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, 9);
	Ячейка.Value =  "GUID";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Инд = 3;
	ПредКА = Неопределено;
	Для каждого Стр Из Объект.Договора Цикл
		
		Инд = Инд +	1;
		
		Если Стр.Контрагент <> ПредКА Тогда
			ПредКА = Стр.Контрагент;
			
			Ячейка =  Лист.Cells(Инд, 2);
			Ячейка.Value = Строка(Стр.Контрагент);
			Ячейка.Borders.LineStyle = 1;
			Ячейка.HorizontalAlignment = 2;
			Ячейка.WrapText = истина;
			
			Ячейка =  Лист.Cells(Инд, 3);
			Ячейка.Value = Строка(Стр.КодКА);
			Ячейка.Borders.LineStyle = 1;
			Ячейка.HorizontalAlignment = 2;
			Ячейка.WrapText = истина;
		Иначе	
						
			Ячейка =  Лист.Cells(Инд, 2);
			Ячейка.Borders.LineStyle = 1;
			
			Ячейка =  Лист.Cells(Инд, 3);
			Ячейка.Borders.LineStyle = 1;
			
		КонецЕсли;
		
		//Ячейка =  Лист.Cells(Инд, 4);
		//Ячейка.Value = Строка(Стр.ДоговорАренды);
		//Ячейка.Borders.LineStyle = 1;
		//Ячейка.HorizontalAlignment = 2;
		//Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 4);
		Ячейка.Value = Строка(Стр.БухДоговор);
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		//Ячейка =  Лист.Cells(Инд, 5);
		//Ячейка.Value = Строка(Стр.ВидДоговора);
		//Ячейка.Borders.LineStyle = 1;
		//Ячейка.HorizontalAlignment = 2;
		//Ячейка.WrapText = истина;
		//
		//Ячейка =  Лист.Cells(Инд, 6);
		//Ячейка.Value = Строка(Стр.Организация);
		//Ячейка.Borders.LineStyle = 1;
		//Ячейка.HorizontalAlignment = 2;
		//Ячейка.WrapText = истина;

		Ячейка =  Лист.Cells(Инд, 5);
		Ячейка.Value = Строка(Стр.Номер);
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 6);
		Ячейка.Value = Строка(Стр.Дата);
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 7);
		Ячейка.NumberFormat = "0,00";
		Если Стр.СуммаСписания > 0 Тогда 
			Ячейка.Value = Стр.СуммаСписания;
		КонецЕсли;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 8);
		Ячейка.NumberFormat = "0,00";
		Если Стр.СуммаПоступления > 0 Тогда 
			Ячейка.Value = Стр.СуммаПоступления;
		КонецЕсли;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, 9);
		Ячейка.Value = Строка(Стр.ПлатежныйДокумент.УникальныйИдентификатор());
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		
	КонецЦикла; 
	
	Попытка        
		Книга.SaveAs(ПутьКФайлу);  
		Сообщить("Файл успешно сохранен!");
	Исключение
		Сообщить(ОписаниеОшибки()+ "Файл не сохранен!");
	КонецПопытки;
	
	Эксель.Application.Quit();
	
КонецПроцедуры


