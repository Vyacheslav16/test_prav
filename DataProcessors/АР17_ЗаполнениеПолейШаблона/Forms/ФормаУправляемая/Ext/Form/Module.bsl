&НаКлиенте
Процедура КомпоновщикНастроекВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	// + NAI Becar Матюхин Н.О. от 13.01.2017 12:35 по заявке № 
	Формат = "";
	Если Найти(ВыбраннаяСтрока,"Основные.") <> 0 Тогда
		
		ТекСтрокаПоле = Сред(ВыбраннаяСтрока,10);
		
		ПрописьюПоложение = Найти(ТекСтрокаПоле,"Прописью");
		Формат = "";
		Если ПрописьюПоложение <> 0 Тогда
			ТекСтрокаПоле = Лев(ТекСтрокаПоле,ПрописьюПоложение-2);
			Формат = "Прописью";
		КонецЕсли;
			
		ДатаСтрокойПоложение = Найти(ТекСтрокаПоле,"ДатаСтрокой");
		Если ДатаСтрокойПоложение <> 0 Тогда
			ТекСтрокаПоле = Лев(ТекСтрокаПоле,ДатаСтрокойПоложение-2);
			Формат  = "ДФ=дд ММММ гггг";
		КонецЕсли;
			
		ТекстСтроки = ПреобразоватьСтроку(ТекСтрокаПоле);
		
	Иначе	
	    ТекстСтроки = Строка(КомпоновщикНастроек.Настройки.ДоступныеПоляПорядка.ПолучитьОбъектПоИдентификатору(ВыбраннаяСтрока).Поле);
	КонецЕсли;
	// - NAI Becar Матюхин Н.О.
	
	ДобавитьПоле(ОбработатьТекстПоля(ТекстСтроки),Формат);
	
КонецПроцедуры

&НаКлиенте
Функция ПреобразоватьСтроку(ТекСтрока)
	
	Если Лев(ТекСтрока,1) = "[" Тогда
		ТекСтрока = Сред(ТекСтрока,2);
		
		Если Прав(ТекСтрока,1) = "]" Тогда
	        ТекСтрока = Лев(ТекСтрока,СтрДлина(ТекСтрока)-1);
		КонецЕсли;
	КонецЕсли;
	
	
	
	ТекСтрока = СтрЗаменить(ТекСтрока,"__"," ");
	
	МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ТекСтрока, "_");
	ТекСтрока = "";
	ДопРеквизиты = Ложь;
	
	Если СтрНайти(ТекСтрока,"ДопРеквизиты") <> 0 Тогда
		ДопРеквизиты = Истина;
	КонецЕсли;
	
	НачалоДопЭлементаОпределили = Ложь;
	
	Для каждого ТекЗнач Из МассивСтрок Цикл
		
		Добавка = "";
		Если НачалоДопЭлементаОпределили Тогда
			
			Добавка = "]";
			НачалоДопЭлементаОпределили = Ложь;
			ТекСтрока = ТекСтрока + ТекЗнач + Добавка + ".";
			Продолжить;
			
		ИначеЕсли ТекЗнач = "ДопРеквизиты" Тогда
			
			НачалоДопЭлементаОпределили = Истина;
			ТекСтрока = ТекСтрока + "[";
			Продолжить;
			
		КонецЕсли;
		
		ТекСтрока = ТекСтрока + ТекЗнач + ".";
	
	КонецЦикла;
	
	ТекСтрока = Лев(ТекСтрока,СтрДлина(ТекСтрока)-1);
	
	Возврат ТекСтрока;
	
КонецФункции


