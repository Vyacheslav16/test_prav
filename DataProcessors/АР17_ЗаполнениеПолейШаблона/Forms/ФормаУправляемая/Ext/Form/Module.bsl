			Если ДатаСтрокойПоложение <> 0 Тогда
				ТекСтрокаПоле = Лев(ТекСтрокаПоле,ДатаСтрокойПоложение-2);
				Формат  = "ДФ=дд ММММ гггг";
			КонецЕсли;
			
			
			ТекстСтроки = ПреобразоватьСтроку(ТекСтрокаПоле);
			
			ДобавитьПоле(ОбработатьТекстПоля(ТекстСтроки),Формат);
			
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

