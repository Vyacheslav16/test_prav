Функция ПолучитьЗДАПоДоговору(ТекДоговорКонтрагента)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАренды.Ссылка КАк ЗДА
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	НЕ АР17_ЗаключениеДоговораАренды.ПометкаУдаления
	               |	И АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
				   
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ТекДоговорКонтрагента);
	
	Возврат Запрос.Выполнить().Выгрузить()[0].ЗДА;
	
