&НаКлиенте
Процедура ОтобратьДолжников(Команда)
	
	Если ТаблицаДолжников.Количество() > 0 Тогда
		Ответ = Вопрос("Таблица сформированных документов будет очищена. Продолжить?", РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Нет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			ТаблицаДолжников.Очистить();
		Иначе
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		ТЗЗапроса = ОтобратьДолжниковНаСервере();
		
		Элементы.ТаблицаДолжниковОрганизация.Видимость = НЕ ЕстьОтборПоОрганизации;
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаТаблицаДолжников;
		
		//ЗначениеВРеквизитФормы(ТЗЗапроса , "ТаблицаДолжников"); 
	КонецЕсли;
	
КонецПроцедуры


