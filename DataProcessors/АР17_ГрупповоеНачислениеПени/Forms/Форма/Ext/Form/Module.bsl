// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Функция ПолучитьТзСтарымСпособом()
	
	СхемаКомпоновкиДанных = Обработки.АР17_ГрупповоеНачислениеПени.ПолучитьМакет("Макет");;
	НастройкиКомпоновки = КомпоновщикНастроек.Настройки;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Попытка 
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , , Истина);
		
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		
		ТаблицаЗначений =  Новый ТаблицаЗначений;
		
		ПроцессорВывода.УстановитьОбъект(ТаблицаЗначений);
		ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	СписокКонтрагентов = Новый СписокЗначений;
	СписокДоговоров = Новый СписокЗначений;
	СписокОрганизаций = Новый СписокЗначений;
	//СписокОбъектовАренды = Новый СписокЗначений;
	СписокУслуг = Новый СписокЗначений;
	
	СписокКонтрагентов.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("КонтрагентСсылка"));
	СписокДоговоров.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ДоговорСсылка"));
	СписокОрганизаций.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ОрганизацияСсылка"));
	//СписокОбъектовАренды.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ОбъектАрендыСсылка"));
	СписокУслуг.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("УслугаСсылка"));

	
	ТекТзНаФорму = РеквизитФормыВЗначение("ТаблицаДолжников"); 
	ТекТзНаФорму.Очистить();
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	ХозрасчетныйОстатки.Счет КАК Счет,
	               |	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты) КАК Контрагент,
	               |	ХозрасчетныйОстатки.Субконто2 КАК Договор,
	               |	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто3 КАК Документ.РеализацияТоваровУслуг) КАК Акт,
	               |	ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю КАК ДокументСчет,
	               |	ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю.Дата КАК ДатаВыставленияСчета,
	               |	ХозрасчетныйОстатки.СуммаОстаток КАК СуммаДолга,
	               |	ВЫБОР
	               |		КОГДА СрокНачисленияПениСрезПоследних.КолвоДней ЕСТЬ NULL 
	               |			ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю.Дата, ДЕНЬ, 20), ДЕНЬ)
	               |		ИНАЧЕ НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю.Дата, ДЕНЬ, СрокНачисленияПениСрезПоследних.КолвоДней), ДЕНЬ)
	               |	КОНЕЦ КАК СрокОплаты
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Остатки(
	               |			&Дата,
	               |			Счет = &Счет,
	               |			,
	               |			Организация В (&СписокОрганизаций)
	               |				И Субконто1 В (&СписокКонтрагентов)
	               |				И Субконто2 В (&СписокДоговоров)) КАК ХозрасчетныйОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СрокНачисленияПени.СрезПоследних(&Дата, ) КАК СрокНачисленияПениСрезПоследних
	               |		ПО ХозрасчетныйОстатки.Субконто1 = СрокНачисленияПениСрезПоследних.Контрагент
	               |ГДЕ
	               |	НЕ ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю В (&СчетНаОплатуПокупателю)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СрокОплаты";
	
	Запрос.УстановитьПараметр("Счет", ПланыСчетов.Хозрасчетный.НайтиПоКоду("62.01"));
	
	Если ВыборПериодаНачисления = 1 Тогда
		Запрос.УстановитьПараметр("Дата", КонПериодаНачисления);			
	ИначеЕсли ВыборПериодаНачисления = 0 Тогда
		Запрос.УстановитьПараметр("Дата", Объект.ДатаНачисления);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СписокКонтрагентов", СписокКонтрагентов);
	Запрос.УстановитьПараметр("СписокДоговоров", СписокДоговоров);
	Запрос.УстановитьПараметр("СписокОрганизаций", СписокОрганизаций);
	
	Счета = Новый Массив;
	Счета.Добавить(Документы.СчетНаОплатуПокупателю.ПустаяСсылка());
	Счета.Добавить(Неопределено);
	Запрос.УстановитьПараметр("СчетНаОплатуПокупателю", Счета);
	
	
	ТекТз = Запрос.Выполнить().Выгрузить();
	
	Возврат ТекТз;
	
КонецФункции


&НаСервере
Функция ОтобратьДолжниковНаСервере()
	
	// + NAI Becar Комментирование Смирнов А.А. от 22.02.2017 11:50
	//ТзДокументыДляРасчета = ЗаполнитьПоДаннымБухгалтерскогоУчета(Истина);
	//
	//СписокРеализаций = ТзДокументыДляРасчета.ВыгрузитьКолонку("Реализация");
	//
	//ТзДанныхБухгалтерии = ЗаполнитьПоДаннымБухгалтерскогоУчета(,СписокРеализаций);
	
	ТзДокументыДляРасчета = ЗаполнитьПоДаннымРегистраБухгалтерии(Истина);
	СписокРеализаций = ТзДокументыДляРасчета.ВыгрузитьКолонку("Документ");
	ТзДанныхБухгалтерии = ЗаполнитьПоДаннымРегистраБухгалтерии(,СписокРеализаций);
	
	//ТзДокументыДляРасчета = ЗаполнитьПоДаннымРегистраБухгалтерии(Истина);
	//ТзДанныхБухгалтерии = ЗаполнитьПоДаннымРегистраБухгалтерии(,СписокРеализаций);

	// - NAI Becar Комментирование Смирнов А.А.
		
	ТекТз = ТзДанныхБухгалтерии;
	
	ТекТзНаФорму = РеквизитФормыВЗначение("ТаблицаДолжников"); 
	ТекТзНаФорму.Очистить();
	
	Если ВыборПериодаНачисления = 1 Тогда
		ДатаКонцаНачисления = КонПериодаНачисления;			
		ДатаНачалаНачисления = НачПериодаНачисления;
	ИначеЕсли ВыборПериодаНачисления = 0 Тогда
		ДатаКонцаНачисления = Объект.ДатаНачисления;
		ДатаНачалаНачисления = Неопределено;
	КонецЕсли;
	
	Для каждого СтрДокументы Из ТзДокументыДляРасчета Цикл
		
		СтрПоиска = Новый Структура("Документ", СтрДокументы.Документ);
		МассивСтрок = ТекТз.НайтиСтроки(СтрПоиска);
		ТзОтбора = ТекТз.Скопировать(МассивСтрок);
		
		Если ТзОтбора.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрДокументы.ОбъектИК.РасчетПени = Перечисления.АР_РасчетПени.ВТиповомДоговоре Тогда
			ОбъектДанных = СтрДокументы.ОбъектИК;
		Иначе
			ОбъектДанных = СтрДокументы.ЗДА;
		КонецЕсли;
		
		ФиксированнойСуммой = (ОбъектДанных.СпособНачисленияПени = Перечисления.АР_СпособыНачисленияПени.Суммой);
		СпособРасчетаПросрочки = ОбъектДанных.СпособРасчетаПросрочки;
		
		НачалоОтсчета = Неопределено;
		
		//НачислениеССылка = СтрДокументы.Начисление.Ссылка; // + NAI Becar Комментирование Смирнов А.А. от 27.02.2017 14:44
		СрокОплаты = ОбъектДанных.СрокОплаты;
		ОтсрочкаПоОплате = ОбъектДанных.ОтсрочкаПоОплате;
		ПериодМесяц = ОбъектДанных.МесяцСрокаОплаты;
		
		// + NAI Becar Комментирование Смирнов А.А. от 03.03.2017 17:33
		//СчетНаАренду = ПолучитьСчет(СтрДокументы.Договор);
		СчетНаАренду = СтрДокументы.Документ;
		Реализация = ПолучитьРеализацию(СчетНаАренду);
		// - NAI Becar Комментирование Смирнов А.А.
		
		Если СпособРасчетаПросрочки = Перечисления.АР_СпособыРасчетаПросрочки.ПоПериодуНачисления Тогда
			//1.	По периоду. В этом случае расчет пени осуществляется от первого числа периода, в котором арендатор допустил просрочку платежа
			//НачалоОтсчета = СтрДокументы.Начисление.НачалоПериода;
			НачалоОтсчета = СчетНаАренду.Дата;
			ДатаНачалаНачисления = ДобавитьМесяц(НачалоМесяца(НачалоОтсчета),ПериодМесяц) + СрокОплаты*60*60*24 + ОтсрочкаПоОплате*60*60*24;		
		ИначеЕсли СпособРасчетаПросрочки = Перечисления.АР_СпособыРасчетаПросрочки.ПоДатеНачисления Тогда
			//3.	По дате акта. В этом случае расчет пени осуществляется от даты первого акта по которому контрагент допустил просрочку платежа, вне зависимости от даты выставления счета
			// + NAI Becar Комментирование Смирнов А.А. от 28.02.2017 12:57
			Если НЕ ЗначениеЗаполнено(Реализация) Тогда
				ТекСообщение = "Для документа " + СчетНаАренду + " нет начисления аренды, дата которого необходима для расчета просрочки. Расчет прерван";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекСообщение, СчетНаАренду, , , );
				Продолжить;
			КонецЕсли;
			//НачалоОтсчета = СтрДокументы.Реализация.Дата;
			НачалоОтсчета = Реализация.Дата;
			// - NAI Becar Комментирование Смирнов А.А.
			ДатаНачалаНачисления = НачалоДня(НачалоОтсчета) + СрокОплаты*60*60*24 + ОтсрочкаПоОплате*60*60*24;	
		ИначеЕсли СпособРасчетаПросрочки = Перечисления.АР_СпособыРасчетаПросрочки.ПоДатеСчета Тогда
			//2.	По дате счета. В этом случае расчет пени осуществляется от даты выставленного счета, по которому контрагент допустил просрочку платежа
			// + NAI Becar Комментирование Смирнов А.А. от 27.02.2017 14:44
			//Если НЕ ЗначениеЗаполнено(СтрДокументы.СчетНаАренду) Тогда
				//ТекСообщение = "Для документа " + НачислениеССылка + " не указан счет аренды, дата которого необходима для расчета просрочки. Расчет прерван";
				//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекСообщение, НачислениеССылка, , , );
			//	Продолжить;
			//КонецЕсли;
			// - NAI Becar Комментирование Смирнов А.А.
			НачалоОтсчета = СчетНаАренду.Дата;
			ДатаНачалаНачисления = НачалоДня(НачалоОтсчета) + СрокОплаты*60*60*24 + ОтсрочкаПоОплате*60*60*24;	
		КонецЕсли;
		
		//ДатаНачалаНачисления = ДобавитьМесяц(НачалоМесяца(НачалоОтсчета),ПериодМесяц) + СрокОплаты*60*60*24 + ОтсрочкаПоОплате*60*60*24;	
		
		БазоваяСтавкаПени = ОбъектДанных.СтавкаПени;
		
		Если ОбъектДанных.Пени.Количество() = 0 И БазоваяСтавкаПени = 0 Тогда
			ТекСообщение = "Для документа " + ОбъектДанных + " не указана ставка пени. Расчет прерван";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекСообщение, ОбъектДанных, , , );
			Продолжить;
		КонецЕсли;
		
		Если ФиксированнойСуммой Тогда
			
			// + NAI Becar Комментирование Смирнов А.А. от 22.02.2017 15:04
			//СуммаДолга = ТзОтбора[ТзОтбора.Количество() - 1 ].СуммаОстаток;
			СуммаДолга = СтрДокументы.СуммаОстаток;
			// - NAI Becar Комментирование Смирнов А.А.
			Пени = ОбъектДанных.СтавкаПени;
			
			//Реализация = СтрДокументы.РЕализация; // + NAI Becar Комментирование Смирнов А.А. от 27.02.2017 15:40
			
			НСтрокаТзФормы = ТекТзНаФорму.Добавить();
			
			НСтрокаТзФормы.НачалоНачисления = ДатаНачалаНачисления;
			НСтрокаТзФормы.КонецНачисления = ДатаКонцаНачисления;
			
			// + NAI Becar Комментирование Смирнов А.А. от 27.02.2017 15:40
			//НСтрокаТзФормы.Акт = Реализация;
			//НСтрокаТзФормы.ДокументСчет = Реализация.СчетНаОплатуПокупателю;
			//НСтрокаТзФормы.Контрагент = Реализация.Контрагент;
			//НСтрокаТзФормы.Организация = Реализация.Организация;
			
			НСтрокаТзФормы.ДокументСчет = СчетНаАренду;
			//НСтрокаТзФормы.ВидОперации = СчетНаАренду.ВидОперации;
			НСтрокаТзФормы.Контрагент = СчетНаАренду.Контрагент;
			НСтрокаТзФормы.Организация = СчетНаАренду.Организация;
			// - NAI Becar Комментирование Смирнов А.А.
			НСтрокаТзФормы.СуммаДолга = СуммаДолга;
			
			// + NAI Becar Комментирование Смирнов А.А. от 13.01.2017 17:01
			КоличествоРабДней = ПолучитьЗапросДляРасчетаРабочихДней(ДатаНачалаНачисления, ДатаКонцаНачисления);
			Если ОбъектДанных.УчитыватьТолькоРабочиеДниПросрочки Тогда
				КолвоДнейПросрочки = КоличествоРабДней;	
			Иначе	
				КолвоДнейПросрочки = (ДатаКонцаНачисления - ДатаНачалаНачисления) / (60*60*24);
			КонецЕсли;
			// - NAI Becar Комментирование Смирнов А.А.
			
			НСтрокаТзФормы.СрокОплаты = КолвоДнейПросрочки;
			
			НСтрокаТзФормы.Пени = Пени;
			
		Иначе
			
			//ТзОтбора[0].НачалоНачисления = ДатаНачалаНачисления; // + NAI Becar Комментирование Смирнов А.А. от 03.03.2017 17:58
			Если Ложь Тогда
				НТаблицаОтбор = РазбитьТаблицуНаПериоды(ТзОтбора,ОбъектДанных);
			Иначе
				НТаблицаОтбор = ТзОтбора;
			КонецЕсли;
			
			
//Сумма пени = Ставка (в %) * Сумма долга * Количество дней просрочки
//Количество дней прострочки (за период) = Дата начисления пени – Макс((Срок оплаты + Отсрочка по оплате), Дата последнего начисления пени).
//Сумма долга = Сумма начисления – Оплаченная сумма.

			Если ОбъектДанных.Пени.Количество() <> 0 Тогда
				
				ТаблицаСтавокПени = Новый ТаблицаЗначений;
				ТаблицаСтавокПени.Колонки.Добавить("СтавкаПениПослеНовойДаты");
				ТаблицаСтавокПени.Колонки.Добавить("СтавкаПениСДня");
				
				ТабТекущая = ОбъектДанных.Пени.Выгрузить(,"СтавкаПениПослеНовойДаты,СтавкаПениСДня");
				Для каждого СтрТекущая Из ТабТекущая Цикл
					ЗаполнитьЗначенияСвойств(ТаблицаСтавокПени.Добавить(),СтрТекущая);
				КонецЦикла;
				
				//ТаблицаСтавокПени = ОбъектДанных.Пени.Выгрузить(,"СтавкаПениПослеНовойДаты,СтавкаПениСДня");
				ПерваяСтрока = ТаблицаСтавокПени[0];
				
				Если ЗначениеЗаполнено(ОбъектДанных.СтавкаПени) Тогда
					
					БазоваяСтавка = ОбъектДанных.СтавкаПени;
					
					Если ПерваяСтрока.СтавкаПениСДня = 1 Тогда
						
						МассивДней = ТаблицаСтавокПени.ВыгрузитьКолонку("СтавкаПениСДня");
						МассивДней.Удалить(0);
						ТаблицаСтавокПени.ЗагрузитьКолонку(МассивДней,"СтавкаПениСДня");
						
					Иначе
						
						МассивДней = ТаблицаСтавокПени.ВыгрузитьКолонку("СтавкаПениПослеНовойДаты");
						МассивДней.Вставить(0,БазоваяСтавка);
						ТаблицаСтавокПени.Добавить();
						ТаблицаСтавокПени.ЗагрузитьКолонку(МассивДней,"СтавкаПениПослеНовойДаты");
				
					КонецЕсли;
					
					ПоследняяСтрока = ТаблицаСтавокПени[ТаблицаСтавокПени.Количество() - 1];
					ПоследняяСтрока.СтавкаПениСДня = Pow(10,10);
					
				КонецЕсли;
								
			Иначе
				
				ТаблицаСтавокПени = Новый ТаблицаЗначений;
				
				ТаблицаСтавокПени.Колонки.Добавить("СтавкаПениПослеНовойДаты");	
				ТаблицаСтавокПени.Колонки.Добавить("СтавкаПениСДня");	
				
