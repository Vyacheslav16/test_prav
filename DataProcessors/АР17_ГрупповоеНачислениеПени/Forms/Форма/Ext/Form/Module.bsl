Функция ЗаполнитьПоДаннымБухгалтерскогоУчета(ТолькоДокументы = Ложь,СписокРеализаций = Неопределено)
	
	СхемаКомпоновкиДанных = Обработки.АР17_ГрупповоеНачислениеПени.ПолучитьМакет("Макет");;
	НастройкиКомпоновки = КомпоновщикНастроек.Настройки;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Попытка 
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , , Истина);
		
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		
		ТаблицаЗначений =  Новый ТаблицаЗначений;
		
		ПроцессорВывода.УстановитьОбъект(ТаблицаЗначений);
		ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	СписокКонтрагентов = Новый СписокЗначений;
	СписокДоговоров = Новый СписокЗначений;
	СписокОрганизаций = Новый СписокЗначений;
	СписокУслуг = Новый СписокЗначений;
	СписокГруппаУслуг = Новый СписокЗначений;
	СписокОбъектАренды = Новый СписокЗначений;
	
	СписокКонтрагентов.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("КонтрагентСсылка"));
	СписокДоговоров.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ДоговорСсылка"));
	СписокОрганизаций.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ОрганизацияСсылка"));
	СписокУслуг.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("УслугаСсылка"));
	СписокГруппаУслуг.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ГруппаУслугСсылка"));
	СписокОбъектАренды.ЗагрузитьЗначения(ТаблицаЗначений.ВыгрузитьКолонку("ОбъектАрендыСсылка"));
	
	//проверим заполненность обязательных реквизитов
	//Если НЕ ЗначениеЗаполнено(Объект.Организация) 
	//	ИЛИ НЕ ЗначениеЗаполнено(Объект.Контрагент)
	//	ИЛИ НЕ ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
	//	Возврат Истина;
	//КонецЕсли;
	
	ЕстьОтборПоОрганизации = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 11) = "Организация" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоОрганизации = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ЕстьОтборПоКонтрагентам = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 10) = "Контрагент" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоКонтрагентам = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ЕстьОтборПоДоговорам = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 7) = "Договор" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоДоговорам = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ЕстьОтборПоГруппамУслуг = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 11) = "ГруппаУслуг" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоГруппамУслуг = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ЕстьОтборПоОбъектамАренды = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиКомпоновки.Отбор.Элементы Цикл
		Если Лев(Строка(ЭлементОтбора.ЛевоеЗначение), 12) = "ОбъектАренды" Тогда
			Если ЭлементОтбора.Использование Тогда
				ЕстьОтборПоОбъектамАренды = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	
	СписокОрганизацийВЗапрос = Новый СписокЗначений;
	СписокКонтрагентовВЗапрос = Новый СписокЗначений;
	СписокДоговоровВЗапрос = Новый СписокЗначений;
	СписокГруппУслугВЗапрос = Новый СписокЗначений;
	СписокОбъектовАрендыВЗапрос = Новый СписокЗначений;
	
	СписокКонтрагентов.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	СписокОрганизаций.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	СписокДоговоров.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	СписокОбъектАренды.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	СписокГруппаУслуг.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
	
	Если ЕстьОтборПоКонтрагентам Тогда
	    Для каждого ТекЗначКонтрагента Из СписокКонтрагентов Цикл
			ЗначСпискаКонтр = ТекЗначКонтрагента.Значение;
			Если НЕ ЗначениеЗаполнено(ЗначСпискаКонтр) Тогда
				Прервать;
			КонецЕсли;
			СписокКонтрагентовВЗапрос.Добавить(ЗначСпискаКонтр); 	
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьОтборПоДоговорам Тогда
	    Для каждого ТекЗначДоговор Из СписокДоговоров Цикл
			ЗначСпискаДог = ТекЗначДоговор.Значение;
			Если НЕ ЗначениеЗаполнено(ЗначСпискаДог) Тогда
				Прервать;
			КонецЕсли;
			СписокДоговоровВЗапрос.Добавить(ЗначСпискаДог); 	
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьОтборПоОрганизации Тогда
	    Для каждого ТекЗначОрг Из СписокОрганизаций Цикл
			ЗначСпискаОрг = ТекЗначОрг.Значение;
			Если НЕ ЗначениеЗаполнено(ЗначСпискаОрг) Тогда
				Прервать;
			КонецЕсли;
			СписокОрганизацийВЗапрос.Добавить(ЗначСпискаОрг); 	
		КонецЦикла;
	КонецЕсли;

	Если ЕстьОтборПоГруппамУслуг Тогда
	    Для каждого ТекЗначГрУсл Из СписокГруппаУслуг Цикл
			ЗначСпискаГрУсл = ТекЗначГрУсл.Значение;
			Если НЕ ЗначениеЗаполнено(ЗначСпискаГрУсл) Тогда
				Прервать;
			КонецЕсли;
			СписокГруппУслугВЗапрос.Добавить(ЗначСпискаГрУсл); 	
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьОтборПоОбъектамАренды Тогда
	    Для каждого ТекЗначОбАренды Из СписокОбъектАренды Цикл
			ЗначСпискаОбАренды = ТекЗначОбАренды.Значение;
			Если НЕ ЗначениеЗаполнено(ЗначСпискаОбАренды) Тогда
				Прервать;
			КонецЕсли;
			СписокОбъектовАрендыВЗапрос.Добавить(ЗначСпискаОбАренды); 	
		КонецЦикла;
	КонецЕсли;
	
	ВалютаРегламентированногоУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	СтруктураПараметров = Новый Структура;
	
	Если ВыборПериодаНачисления = 1 Тогда
		ДатаНачисления = КонПериодаНачисления;			
	ИначеЕсли ВыборПериодаНачисления = 0 Тогда
		ДатаНачисления = Объект.ДатаНачисления;
	КонецЕсли;
	
	ТекКонтрагент = СписокКонтрагентов[0].Значение;
	ТекДоговор = СписокДоговоров[0].Значение;
	ТекОрганизация = СписокОрганизаций[0].Значение;
	
	СтруктураПараметров.Вставить("Дата", ДатаНачисления);
	СтруктураПараметров.Вставить("Организация", СписокОрганизацийВЗапрос);
	СтруктураПараметров.Вставить("Контрагент", СписокКонтрагентовВЗапрос);
	СтруктураПараметров.Вставить("ДоговорКонтрагента", СписокДоговоровВЗапрос);
	СтруктураПараметров.Вставить("ГруппаУслуг", СписокГруппУслугВЗапрос);
	СтруктураПараметров.Вставить("ОбъектАренды", СписокОбъектовАрендыВЗапрос);
	СтруктураПараметров.Вставить("ВалютаДокумента",Неопределено);
	
	АналитикаРасчетов = Новый Массив;
	АналитикаРасчетов.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	АналитикаРасчетов.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	СтруктураПараметров.Вставить("АналитикаРасчетов", АналитикаРасчетов);
			
	СтруктураПараметров.Вставить("ВалютаРегламентированногоУчета", ВалютаРегламентированногоУчета);
	
	НаименованиеЗадания = "ЗаполнитьПениПоДаннымБухУчета";
	
	Если Истина Тогда
	//	
		АдресХранилища = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
		//Документы.НачислениеПеней.ПодготовитьДанныеДляЗаполнения(СтруктураПараметров,АдресХранилища);
		ПодготовитьДанныеДляЗаполнения(СтруктураПараметров,АдресХранилища,ТолькоДокументы,СписокРеализаций);
		Результат = Новый Структура("ЗаданиеВыполнено,АдресХранилища", Истина,АдресХранилища);
	//	
	Иначе
	//	
		Результат = ДлительныеОперации.ЗапуститьВыполнениеВФоне(
		УникальныйИдентификатор, 
		"Документы.НачислениеПеней.ПодготовитьДанныеДляЗаполнения", 
		СтруктураПараметров, 
		НаименованиеЗадания);
	
	КонецЕсли; 
	
	//Если Результат.ЗаданиеВыполнено Тогда
	//	Результат.Вставить("СтруктураДанныхКлиента", ЗагрузитьПодготовленныеДанные());
	//КонецЕсли;
	
		
	АдресХранилища = Результат.АдресХранилища;
	
	Если Результат.ЗаданиеВыполнено Тогда
		
		ТаблицаДанных = ПолучитьИзВременногоХранилища(АдресХранилища);
	
		Если ТипЗнч(ТаблицаДанных) <> Тип("ТаблицаЗначений") Тогда
			Возврат Неопределено;
		Иначе
			Возврат ТаблицаДанных;
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции


Процедура ПодготовитьДанныеДляЗаполнения(СтруктураПараметров, АдресХранилища, ТолькоДокументы, СписокРеализаций) Экспорт
	
	ТаблицаРезультата = Новый ТаблицаЗначений;
	
	//ТабличнаяЧастьМетаданные = Метаданные.Документы.СчетНаПениПокупателю.ТабличныеЧасти.Товары.Реквизиты;
	//
	//ТипРеквизитаСделка        = ТабличнаяЧастьМетаданные.Сделка.Тип;
	//ТипРеквизитаПредставление = Тип;
	//ТипРеквизитаЗадолженность = ТабличнаяЧастьМетаданные.Задолженность.Тип;
	//ТипРеквизитаПросрочка     = ТабличнаяЧастьМетаданные.Просрочка.Тип;
	
	//ТаблицаРезультата.Колонки.Добавить("Сделка",        ТипРеквизитаСделка);
	//ТаблицаРезультата.Колонки.Добавить("Представление", ТипРеквизитаПредставление);
	//ТаблицаРезультата.Колонки.Добавить("Задолженность", ТипРеквизитаЗадолженность);
	//ТаблицаРезультата.Колонки.Добавить("Просрочка",     ТипРеквизитаПросрочка);
	
	ТаблицаРезультата.Колонки.Добавить("Сделка");
	ТаблицаРезультата.Колонки.Добавить("Представление");
	ТаблицаРезультата.Колонки.Добавить("Задолженность");
	ТаблицаРезультата.Колонки.Добавить("Просрочка");
	
	СчетаУчетаРасчетов = БухгалтерскиеОтчеты.СчетаУчетаРасчетовПокупателей();
	
	СчетаРасчетовБезАналитикиПоДокументам = СчетаУчетаРасчетов.СчетаБезДокументаРасчетов;
	СчетаРасчетовСАналитикойПоДокументам  = СчетаУчетаРасчетов.СчетаСДокументомРасчетов;
	
	СписокВалютыРеглУчета = Новый СписокЗначений;
	СписокВалютыРеглУчета.Добавить(СтруктураПараметров.ВалютаРегламентированногоУчета);
	СписокВалютыРеглУчета.Добавить(Справочники.Валюты.ПустаяСсылка());
	
	Запрос = Новый Запрос;
	
	ЧастиЗапроса = Новый Массив;
	
	///Здесь формируется основная часть запроса
	Если СчетаРасчетовСАналитикойПоДокументам.Количество() <> 0 Тогда
		ЧастиЗапроса.Добавить(ТекстЗапросаПоДокументам(ТолькоДокументы,СписокРеализаций));
	КонецЕсли;
	
	ТекстЗапроса = СтрСоединить(ЧастиЗапроса, Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" +Символы.ПС);
	
	
	ВалютаДокумента = ?(ЗначениеЗаполнено(СтруктураПараметров.ВалютаДокумента), СтруктураПараметров.ВалютаДокумента, СтруктураПараметров.ВалютаРегламентированногоУчета);
	
	Если ВалютаДокумента  = СтруктураПараметров.ВалютаРегламентированногоУчета Тогда
	
		Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&УсловиеВалюта", 
			"(ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов).РасчетыВУсловныхЕдиницах = ИСТИНА 
			|	ИЛИ ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВалютаВзаиморасчетов В (&ВалютаРеглУчета)) 
			|И ХозрасчетныйОстатки.СуммаОстатокДт > 0");
			
			
			
	Иначе
		
		Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&УсловиеВалюта", 
			"НЕ ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВалютаВзаиморасчетов В (&ВалютаРеглУчета) И ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт > 0");
			
	КонецЕсли;
	
	ДокументВВалюте = ЗначениеЗаполнено(СтруктураПараметров.ВалютаДокумента);
	
	Если ДокументВВалюте Тогда
		//Документ в иностранной валюте. Установим отбор только по договорам в нужной валюте
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Организация = &Организация","Организация = &Организация и Валюта = &ВалютаДокумента");
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Период1", ДобавитьМесяц(СтруктураПараметров.Дата,-36));
	Запрос.УстановитьПараметр("Период2", КонецДня(СтруктураПараметров.Дата));
	Запрос.УстановитьПараметр("Период", СтруктураПараметров.Дата);
	
	
	СтрокаУсловийДляНачисленийНаЗамену	= "";
	
	Если ЗначениеЗаполнено(СтруктураПараметров.ГруппаУслуг) Тогда
		СтрокаУсловийДляНачисленийНаЗамену = СтрокаУсловийДляНачисленийНаЗамену + "
		|			И АР17_НачислениеАренднойПлатыСостав.ГруппаУслуг в (&ГруппаУслуг)";
		Запрос.УстановитьПараметр("ГруппаУслуг",  СтруктураПараметров.ГруппаУслуг);	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.ОбъектАренды) Тогда
	    СтрокаУсловийДляНачисленийНаЗамену = СтрокаУсловийДляНачисленийНаЗамену + "
		|			И АР17_НачислениеАренднойПлатыСостав.ОбъектАренды в (&ОбъектАренды)";
		Запрос.УстановитьПараметр("ОбъектАренды",     СтруктураПараметров.ОбъектАренды);	
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"УсловиеПоНачислениюНаЗамену",СтрокаУсловийДляНачисленийНаЗамену);
	

	СтрокаУсловийНаЗамену = "Истина";
	Если ЗначениеЗаполнено(СтруктураПараметров.Организация) Тогда
		СтрокаУсловийНаЗамену = СтрокаУсловийНаЗамену + "
		|				И Организация в (&Организация)";
		Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.Контрагент) Тогда
		СтрокаУсловийНаЗамену = СтрокаУсловийНаЗамену + "
		|				И Субконто1 В (&Контрагент)";
		Запрос.УстановитьПараметр("Контрагент",  СтруктураПараметров.Контрагент);	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.ДоговорКонтрагента) Тогда
	    СтрокаУсловийНаЗамену = СтрокаУсловийНаЗамену + "
		|				И Субконто2 в (&Договор)";
		Запрос.УстановитьПараметр("Договор",     СтруктураПараметров.ДоговорКонтрагента);	
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"УсловиеПоТаблицеОстаткиНаЗамену",СтрокаУсловийНаЗамену);
	
	Запрос.УстановитьПараметр("ВалютаРеглУчета",  СписокВалютыРеглУчета);
	
	Если СписокРеализаций <> Неопределено Тогда
		Запрос.УстановитьПараметр("Реализации",СписокРеализаций);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СчетаРасчетовБезАналитикиПоДокументам",СчетаРасчетовБезАналитикиПоДокументам);
	Запрос.УстановитьПараметр("СчетаРасчетовСАналитикойПоДокументам", СчетаРасчетовСАналитикойПоДокументам);
	Запрос.УстановитьПараметр("ВидыСубконтоБезДокументов",СтруктураПараметров.АналитикаРасчетов);
	Запрос.УстановитьПараметр("ВалютаДокумента", ВалютаДокумента);
	//Запрос.УстановитьПараметр("ТипыДокументовРасчетов", ТипРеквизитаСделка.Типы());
	
	ВидыСубконтоСДокументами = СтруктураПараметров.АналитикаРасчетов;
	ВидыСубконтоСДокументами.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);
	
	Запрос.УстановитьПараметр("ВидыСубконтоСДокументами", ВидыСубконтоСДокументами);
	
	ТаблицаОстатки = Запрос.Выполнить().Выгрузить();
	
	Если ТолькоДокументы Тогда
		ПоместитьВоВременноеХранилище(ТаблицаОстатки, АдресХранилища);
		Возврат;
	КонецЕсли;
	
	
	ТабНаВыход = Новый ТаблицаЗначений;
	ТабНаВыход.Колонки.Добавить("ВалютаВзаиморасчетов");
	ТабНаВыход.Колонки.Добавить("ВалютнаяСуммаОстаток");
	ТабНаВыход.Колонки.Добавить("ВидДоговора");
	ТабНаВыход.Колонки.Добавить("ДатаВходящегоДокумента");
	ТабНаВыход.Колонки.Добавить("Договор");
	ТабНаВыход.Колонки.Добавить("ДокументРасчетов");
	ТабНаВыход.Колонки.Добавить("Контрагент");
	ТабНаВыход.Колонки.Добавить("НомерВходящегоДокумента");
	ТабНаВыход.Колонки.Добавить("Просрочка");
	ТабНаВыход.Колонки.Добавить("РасчетыВУсловныхЕдиницах");
	ТабНаВыход.Колонки.Добавить("СуммаОстаток");
	ТабНаВыход.Колонки.Добавить("Счет");
	ТабНаВыход.Колонки.Добавить("НачалоНачисления");
	ТабНаВыход.Колонки.Добавить("КонецНачисления");
	
	ТекДокумент = Неопределено;
	ДобавляемСтрочку = Ложь;
	
	ВыборкаРезультатЗапроса = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРезультатЗапроса.Следующий() Цикл
		
		СтрокаВТаблицуНаВыход = Новый Структура("ВалютаВзаиморасчетов,ВалютнаяСуммаОстаток,ВидДоговора,ДатаВходящегоДокумента,Договор,ДокументРасчетов,Контрагент,НомерВходящегоДокумента,Просрочка,РасчетыВУсловныхЕдиницах,СуммаОстаток,Счет,НачалоНачисления,КонецНачисления");
		ПерваяСтрокаСтруктура = Новый Структура("ВалютаВзаиморасчетов,ВалютнаяСуммаОстаток,ВидДоговора,ДатаВходящегоДокумента,Договор,ДокументРасчетов,Контрагент,НомерВходящегоДокумента,Просрочка,РасчетыВУсловныхЕдиницах,СуммаОстаток,Счет,НачалоНачисления,КонецНачисления");
		ПоследняяСтрокаСтруктура = Новый Структура("ВалютаВзаиморасчетов,ВалютнаяСуммаОстаток,ВидДоговора,ДатаВходящегоДокумента,Договор,ДокументРасчетов,Контрагент,НомерВходящегоДокумента,Просрочка,РасчетыВУсловныхЕдиницах,СуммаОстаток,Счет,НачалоНачисления,КонецНачисления");
		
		ТекДокументРасчетов = ВыборкаРезультатЗапроса.ДокументРасчетов;
		
		ЗаполнилиСтруктуру = Ложь;
		ИтоговыеПени = 0;
		
		ПерваяСтрока = Неопределено;
		ПоследняяСтрока = Неопределено;
		
		ЭтоПродолжение = Ложь;
		
		ПрошлаяДатаНачисления = Неопределено;
		
		ВыборкаДанные = ВыборкаРезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДанные.Следующий() Цикл
			
			Если ВыборкаДанные.Договор.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомитентом Тогда
				Продолжить;
			КонецЕсли;
			
			Если ПерваяСтрока = Неопределено И Не ЭтоПродолжение Тогда
				
				ПрошлаяДатаНачисления = ВыборкаДанные.ПериодСуммы;
				ЗаполнитьЗначенияСвойств(ПерваяСтрокаСтруктура,ВыборкаДанные);
				ПерваяСтрокаСтруктура.СуммаОстаток = ВыборкаДанные.СуммаОборот;
				ПерваяСтрокаСтруктура.НачалоНачисления = НачалоДня(ВыборкаДанные.ПериодСуммы);
				ПерваяСтрокаСтруктура.КонецНачисления = СтруктураПараметров.Дата;
				ПерваяСтрока = ПерваяСтрокаСтруктура;
				ТекущаяЗадолженность = ВыборкаДанные.СуммаОборот;
				Продолжить;
				
			Иначе	
				
				ЭтоПродолжение = Истина;
				ПерваяСтрока = Неопределено;
				
			КонецЕсли;
			
			РазницаСПредудущимПериодом = (КонецДня(ВыборкаДанные.ПериодСуммы)+ 1 - НачалоДня(ПрошлаяДатаНачисления)) / 60 / 60 / 24;
			
			НоваяСтрока = ТабНаВыход.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДанные);
			
			НоваяСтрока.Просрочка = РазницаСПредудущимПериодом;
			НоваяСтрока.СуммаОстаток = ТекущаяЗадолженность;
			
			НоваяСтрока.НачалоНачисления = НачалоДня(ПрошлаяДатаНачисления);
			НоваяСтрока.КонецНачисления = КонецДня(ВыборкаДанные.ПериодСуммы);
			
			ТекущаяЗадолженность = ТекущаяЗадолженность + ВыборкаДанные.СуммаОборот;
			
			Если ТекущаяЗадолженность = 0 Тогда
				ПоследняяСтрока = Неопределено;
				Продолжить;
				
			Иначе
				
				РазницаСПредудущимПериодом = (НачалоДня(СтруктураПараметров.Дата) - НачалоДня(ВыборкаДанные.ПериодСуммы)) / 60 / 60 / 24;

				ЗаполнитьЗначенияСвойств(ПоследняяСтрокаСтруктура,ВыборкаДанные);
				ПоследняяСтрокаСтруктура.Просрочка = РазницаСПредудущимПериодом;
				ПоследняяСтрокаСтруктура.СуммаОстаток = ТекущаяЗадолженность;
				ПоследняяСтрокаСтруктура.НачалоНачисления = КонецДня(ВыборкаДанные.ПериодСуммы)+ 1;
				ПоследняяСтрокаСтруктура.КонецНачисления = НачалоДня(СтруктураПараметров.Дата);
				ПоследняяСтрока = ПоследняяСтрокаСтруктура;
				
			КонецЕсли;
			
			ПрошлаяДатаНачисления = КонецДня(ВыборкаДанные.ПериодСуммы)+ 1;
			
		КонецЦикла; 
		
		//Если строк больше нет, то добавляем в таблицу, все обнуляем, кроме первой, идем дальше
		
		Если ПерваяСтрока <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(ТабНаВыход.Добавить(),ПерваяСтрокаСтруктура);
		КонецЕсли;
		
		Если ПоследняяСтрока <> Неопределено Тогда
		
			ЗаполнитьЗначенияСвойств(ТабНаВыход.Добавить(),ПоследняяСтрокаСтруктура);
		
		КонецЕсли;
		
	КонецЦикла;
	
	
	Для каждого СтрокаОстатков Из ТабНаВыход Цикл
		// Сформируем строку представления
		ПредставлениеВида = ВидДокументаОстатка(СтрокаОстатков);
		
		Если СтрокаОстатков.НомерВходящегоДокумента = Неопределено Тогда
			ДатаДокументаОстатки = ФорматДата(СтрокаОстатков.Дата);
			Если ПредставлениеВида = "Продажа" И ТипЗнч(СтрокаОстатков.ДокументРасчетов) <> Тип("ДокументСсылка.ОперацияБух") Тогда
				Представление = СтрШаблон("%1 (%2 от %3)",
					ПредставлениеВида, 
					ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(СтрокаОстатков.Номер, Истина, Ложь), 
					ДатаДокументаОстатки);
			Иначе
				Представление = СтрШаблон("%1 (%2)", 
					ПредставлениеВида, 
					ДатаДокументаОстатки);
			КонецЕсли;
		Иначе
			НомерВходящегоДокумента = ?(НЕ ЗначениеЗаполнено(СтрокаОстатков.НомерВходящегоДокумента),"_______", СтрокаОстатков.НомерВходящегоДокумента);
			ДатаВходящегоДокумента = ?(НЕ ЗначениеЗаполнено(СтрокаОстатков.ДатаВходящегоДокумента), "'  .  .    '", ФорматДата(СтрокаОстатков.ДатаВходящегоДокумента));
			
			Представление = СтрШаблон("%1 (%2 от %3)",
				ПредставлениеВида,
				НомерВходящегоДокумента,
				ДатаВходящегоДокумента);
		КонецЕсли;
		
		НоваяСтрока                  = ТаблицаРезультата.Добавить();
		НоваяСтрока.Сделка           = СтрокаОстатков.ДокументРасчетов;
		НоваяСтрока.Представление    = Представление;
		НоваяСтрока.Просрочка        = СтрокаОстатков.Просрочка;
		
		Если ДокументВВалюте Тогда
			НоваяСтрока.Задолженность = СтрокаОстатков.ВалютнаяСуммаОстаток;
		Иначе
			НоваяСтрока.Задолженность = СтрокаОстатков.СуммаОстаток;
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТабНаВыход, АдресХранилища);
	
КонецПроцедуры

Функция ТекстЗапросаПоДокументам(ТолькоДокументы,СписокРеализаций)
	
	Если ТолькоДокументы Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Субконто3 КАК Реализация,
		|	АР17_НачислениеАренднойПлаты.Ссылка КАК Начисление,
		|	АР17_НачислениеАренднойПлаты.Ссылка.ДокументОснование КАК СчетНаАренду,
		|	ДоговорыКонтрагентов.Ссылка КАК Договор,
		|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ЗДА,
		|	АР17_УстановкаПараметровИК.Ссылка КАК ОбъектИК
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период2
		|			,
		|			Счет В (&СчетаРасчетовСАналитикойПоДокументам),
		|			,
		//|			УсловиеПоТаблицеОстаткиНаЗамену
		|) КАК ХозрасчетныйОстатки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|		ПО ХозрасчетныйОстатки.Субконто2 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_НачислениеАренднойПлаты КАК АР17_НачислениеАренднойПлаты
		|		ПО ХозрасчетныйОстатки.Субконто3.СчетНаОплатуПокупателю = АР17_НачислениеАренднойПлаты.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_НачислениеАренднойПлаты.Состав КАК АР17_НачислениеАренднойПлатыСостав
		|		ПО (АР17_НачислениеАренднойПлаты.Ссылка = АР17_НачислениеАренднойПлатыСостав.Ссылка)
		//|			УсловиеПоНачислениюНаЗамену
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
		|		ПО (АР17_ЗаключениеДоговораАренды.ДокументОснование = АР17_УстановкаПараметровИК.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
		|		ПО ХозрасчетныйОстатки.Субконто3 = ДанныеПервичныхДокументов.Документ
		|			И (ДанныеПервичныхДокументов.Организация = ХозрасчетныйОстатки.Организация)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО ХозрасчетныйОстатки.Субконто2 = ДоговорыКонтрагентов.Ссылка
		|			И (ДоговорыКонтрагентов.АР_АрендныйДоговор)
		|ГДЕ
		|		АР17_НачислениеАренднойПлаты.ПометкаУдаления = ЛОЖЬ
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОстатки.Субконто3,
		|	АР17_НачислениеАренднойПлаты.Ссылка,
		|	АР17_НачислениеАренднойПлаты.Ссылка.ДокументОснование,
		|	ДоговорыКонтрагентов.Ссылка,
		|	АР17_ЗаключениеДоговораАренды.Ссылка,
		|	АР17_УстановкаПараметровИК.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	Договор";
		
		
	Иначе
		
		ТекстЗапроса = 
		"ВЫБРАТЬ 
		|	ХозрасчетныйОбороты.Счет КАК Счет,
		|	ХозрасчетныйОбороты.Субконто1 КАК Контрагент,
		|	ХозрасчетныйОбороты.Субконто2 КАК Договор,
		|	ХозрасчетныйОбороты.Субконто3 КАК ДокументРасчетов,
		|	СУММА(ХозрасчетныйОбороты.СуммаОборот) КАК СуммаОборот,
		|	ХозрасчетныйОбороты.Период КАК ПериодСуммы,
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, НЕОПРЕДЕЛЕНО) КАК НомерВходящегоДокумента,
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, НЕОПРЕДЕЛЕНО) КАК ДатаВходящегоДокумента,
		|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВидДоговора КАК ВидДоговора,
		|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
		|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов).РасчетыВУсловныхЕдиницах КАК РасчетыВУсловныхЕдиницах,
		|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), &Период2, ДЕНЬ) - ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение) КАК Просрочка,
		|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), ДЕНЬ, ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение)) Как ДатаСтартаНачисления,
		|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), ДЕНЬ, ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение)), ХозрасчетныйОбороты.Период, ДЕНЬ) КАК КолвоДнейДействияТекущейСуммы
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&Период1,
		|			&Период2,
		|			Регистратор,
		|			Счет В (&СчетаРасчетовСАналитикойПоДокументам),
		|			,
		//|			УсловиеПоТаблицеОстаткиНаЗамену" + ?(СписокРеализаций <> Неопределено,"				И Субконто3 в (&Реализации), ",",") + "
		|			,
		|			) КАК ХозрасчетныйОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
		|		ПО ХозрасчетныйОбороты.Субконто3 = ДанныеПервичныхДокументов.Документ
		|			И (ДанныеПервичныхДокументов.Организация = ХозрасчетныйОбороты.Организация)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО ХозрасчетныйОбороты.Субконто2 = ДоговорыКонтрагентов.Ссылка
		|			И (ДоговорыКонтрагентов.УстановленСрокОплаты),
		|	Константа.СрокОплатыПокупателей КАК СрокОплатыПокупателей
		//|ГДЕ
		////|	Не ХозрасчетныйОбороты.Субконто3.СчетНаОплатуПокупателю Ссылка Документ.СчетНаПениПокупателю И
		//|	РАЗНОСТЬДАТ(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), &Период2, ДЕНЬ) > ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение)
		|
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОбороты.Счет,
		|	ХозрасчетныйОбороты.Субконто1,
		|	ХозрасчетныйОбороты.Субконто2,
		|	ХозрасчетныйОбороты.Субконто3,
		|	ХозрасчетныйОбороты.Период,
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, НЕОПРЕДЕЛЕНО),
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, НЕОПРЕДЕЛЕНО),
		|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), &Период2, ДЕНЬ) - ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение),
		|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), ДЕНЬ, ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение)),
		|	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, &Период2), МЕСЯЦ), СЕКУНДА, 1), ДЕНЬ, ЕСТЬNULL(ДоговорыКонтрагентов.СрокОплаты, СрокОплатыПокупателей.Значение)), ХозрасчетныйОбороты.Период, ДЕНЬ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументРасчетов,
		|	ПериодСуммы
		|ИТОГИ ПО
		|	НомерВходящегоДокумента";
		
	КонецЕсли; 
	
	Возврат ТекстЗапроса;
	
КонецФункции	


