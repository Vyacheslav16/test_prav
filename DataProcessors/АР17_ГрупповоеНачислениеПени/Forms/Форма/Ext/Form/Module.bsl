&НаКлиенте
Процедура ТаблицаДолжниковВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СсылкаНаОбъект = Элемент.ТекущиеДанные.ДокументСчет;
	ТекКолонка = Элемент.ТекущийЭлемент.Имя;
	
	Если Найти(ТекКолонка,"ДокументСчет") <> 0  Тогда
		
		СсылкаНаОбъект = Элемент.ТекущиеДанные.ДокументСчет;
		
		Пар = Новый Структура("Ключ",СсылкаНаОбъект); 
		
		Если ТипЗнч(СсылкаНаОбъект) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			форма = ПолучитьФорму("Документ.АР17_НачислениеАренднойПлаты.Форма.ФормаДокумента",пар);
		// + NAI Becar Комментирование Смирнов А.А. от 02.03.2017 16:00
		ИначеЕсли ТипЗнч(СсылкаНаОбъект) = Тип("ДокументСсылка.АР17_СчетНаАренду") Тогда
			форма = ПолучитьФорму("Документ.АР17_СчетНаАренду.Форма.ФормаДокумента",пар);
		// - NAI Becar Комментирование Смирнов А.А.
		Иначе
			форма = ПолучитьФорму("Документ.СчетНаоплатуПокупателю.Форма.ФормаДокумента",пар);
		КонецЕсли;
		
		форма.Открыть();
		
	ИначеЕсли Найти(ТекКолонка,"Контрагент") <> 0  Тогда
		
		СсылкаНаОбъект = Элемент.ТекущиеДанные.Контрагент;
		Пар = Новый Структура("Ключ",СсылкаНаОбъект); 
		форма = ПолучитьФорму("Справочник.Контрагенты.Форма.ФормаЭлемента",пар);
		форма.Открыть();
		
	ИначеЕсли Найти(ТекКолонка,"Акт") <> 0  Тогда
		
		СсылкаНаОбъект = Элемент.ТекущиеДанные.Акт;
		Пар = Новый Структура("Ключ",СсылкаНаОбъект); 
		форма = ПолучитьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаДокументаОбщая",пар);
		форма.Открыть();
	
	КонецЕсли;
	
КонецПроцедуры


