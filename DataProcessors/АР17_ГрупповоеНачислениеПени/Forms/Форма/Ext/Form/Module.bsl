&НаСервере
Процедура СозданиеСчетаПокупателюНаСервере(ТекДокОбъект)
	
	ДокументОбъект = ДанныеФормыВЗначение(ТекДокОбъект, Тип("ДокументОбъект.СчетНаПениПокупателю"));
	ТекТзНаФорму = РеквизитФормыВЗначение("ТаблицаДолжников"); 
	
	ДокументОбъект.Контрагент = ТекКонтрагент;
	ДокументОбъект.Организация = ТекОрганизация;
	ДокументОбъект.ДоговорКонтрагента = ТекДоговор;
	ДокументОбъект.ДокументБезНДС = Истина;
	ДокументОбъект.ответственный = ПараметрыСеанса.ТекущийПользователь;
	
	ДокументОбъект.СтавкаЦБ = СтавкаРефинансированияЦБ;
	
	ДокументОбъект.Комментарий = "Документ сформирован обработкой начисления пени " + ТекущаяДата();
	
	ТзДанныеДляДокумента = ТекТзНаФорму.СкопироватьКолонки();
	
	
	Для каждого ТекСтрокаТз Из ТекТзНаФорму Цикл
		
		Если НЕ ТекСтрокаТз.Пометка Тогда
		    Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ТзДанныеДляДокумента.Добавить(),ТекСтрокаТз);
		
	КонецЦикла;
	
	Для каждого ТекСтрока Из ТзДанныеДляДокумента Цикл
		
		//ЗаполнитьЗначенияСвойств(СтруктураДанных,ТекСтрока);
		
		НстрокаТабЧасть = ДокументОбъект.Товары.Добавить();
		
		НСтрокаТабЧасть.Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию("Выставленные пени");
		НСтрокаТабЧасть.Содержание = "Начисление пени по документу: " + ТекСтрока.ДокументСчет;
		НСтрокаТабЧасть.Количество = ТекСтрока.СрокОплаты;
		НСтрокаТабЧасть.Просрочка = ТекСтрока.СрокОплаты;
		НСтрокаТабЧасть.Цена = ТекСтрока.Пени/ТекСтрока.СрокОплаты;
		НСтрокаТабЧасть.Сумма = ТекСтрока.Пени;
		
		НСтрокаТабЧасть.НачалоНачисления = ТекСтрока.НачалоНачисления;
		НСтрокаТабЧасть.КонецНачисления = ТекСтрока.КонецНачисления;
		
		НСтрокаТабЧасть.Сделка = ТекСтрока.Акт;
		НСтрокаТабЧасть.Задолженность = ТекСтрока.СуммаДолга;
		
		НСтрокаТабЧасть.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		НСтрокаТабЧасть.СуммаНДС = 0;
		
	КонецЦикла;
	
	ПеребираемДаты = Истина;
	
	ДокументОбъект.Номер = "";
	
	ЗначениеВДанныеФормы(ДокументОбъект, ТекДокОбъект);
	
	Возврат;      
	
	
	
	
	
	ТекТзНаФорму = РеквизитФормыВЗначение("ТаблицаДолжников"); 

	Для каждого ТекСтрока Из ТекТзНаФорму Цикл
	
		Если НЕ ТекСтрока.Пометка Тогда
		    Продолжить;
		КонецЕсли;
	
	 	ЗаполнитьЗначенияСвойств(Объект,ТекСтрока.ДокументСчет);
		Объект.Дата						= Объект.ДатаНачисления;
		Объект.Проведен					= Ложь;
	
		Объект.Записать();
	
		СтатусДокумента = Перечисления.СтатусОплатыСчета.НеОплачен;
		РегистрыСведений.СтатусыДокументов.УстановитьСтатусДокумента(Объект.Ссылка, СтатусДокумента);
		
	КонецЦикла;
	
	Возврат;
	
	Если Объект = Неопределено Тогда
		НоваяСчетФактура = Документы.СчетНаОплатуПокупателю.СоздатьДокумент();
		//Объект.УстановитьСсылкуНового(Ссылка);
	КонецЕсли;
	
	Объект.Записать();
	
	СтатусДокумента = Перечисления.СтатусОплатыСчета.НеОплачен;
	РегистрыСведений.СтатусыДокументов.УстановитьСтатусДокумента(Объект.Ссылка, СтатусДокумента);
	
КонецПроцедуры

