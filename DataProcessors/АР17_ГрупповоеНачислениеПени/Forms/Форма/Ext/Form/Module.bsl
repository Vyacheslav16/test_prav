Функция РазбитьТаблицуНаПериоды(ТзОтбора,ОбъектДанных)
	
	//ТзОтбора = Новый ТаблицаЗначений;	
	ОсновнаяСтавка = ОбъектДанных.СтавкаПени;
	ТаблицаСтавок = ОбъектДанных.Пени.Выгрузить();
	ТаблицаСтавок.Сортировать("СтавкаПениСДня");
	
	Если ТаблицаСтавок.Количество() = 0 Тогда
		ТзОтбора.Колонки.Доавить("Ставка");
		Для каждого СтрТзОтобра Из ТзОтбора Цикл
			СтрТзОтобра.Ставка = ОсновнаяСтавка;								
		КонецЦикла;
		Возврат ТзОтбора;
	КонецЕсли;
	
	НТаблицаОтбор = ТзОтбора.СкопироватьКолонки();
	НТаблицаОтбор.Колонки.Добавить("Ставка");
	
	ТаблицаСтавок = ОбъектДанных.Пени;
	
	СледПериод = КонецМесяца(ТзОтбора[0].НачалоНачисления)+1;
	
	МассивДатыРазделенияПериода = Новый Массив;
	ТаблицаСтавок.Сортировать("СтавкаПениСДня");
	Для каждого СтрСтавки Из ТаблицаСтавок Цикл
		МассивДатыРазделенияПериода.Добавить(СледПериод + 60*60*24*СтрСтавки.СтавкаПениСДня);
	КонецЦикла;
	
	ПерваяДатаРазбивки = МассивДатыРазделенияПериода[0]; 
	
	Для каждого СтрТзОтбора Из ТзОтбора Цикл
		
		//ДеньНачала = День(СтрТзОтбора.НачалоНачисления);
		//СледМесяцОтНачала = КонецМесяца(СтрТзОтбора.НачалоНачисления)+1;
		
		Если СтрТзОтбора.КонецНачисления < СледПериод
			ИЛИ СтрТзОтбора.КонецНачисления < ПерваяДатаРазбивки Тогда
			
			НСтрока = НТаблицаОтбор.Добавить();
			ЗаполнитьЗначенияСвойств(НСтрока,СтрТзОтбора);
	    	НСтрока.Ставка = ОсновнаяСтавка;
		    Продолжить;
			
		КонецЕсли;
		
		//Для каждого СтрСтавки Из МассивДатыРазделенияПериода Цикл

		//	Если СтрСтавки <  Тогда
		//	
		//		
		//	
		//	КонецЕсли;
		//	
		//	ТекДатаРазбивки = СтрСтавки;
		//	
		//	
		//	
		//КонецЦикла;
		//
		
		
		ДатаОкончанияПредПериода = СтрТзОтбора.НачалоНачисления;
		
		Для каждого СтрСтавки Из ТаблицаСтавок Цикл
			
			ДатаСменыСтавкиСледПериода = СледПериод + 60*60*24*СтрСтавки.СтавкаПениСДня;
			
			Если ДатаСменыСтавкиСледПериода < СтрТзОтбора.КонецНачисления Тогда
				
				НСтрока = НТаблицаОтбор.Добавить();
				ЗаполнитьЗначенияСвойств(НСтрока,СтрТзОтбора);
				НСтрока.НачалоНачисления = ДатаОкончанияПредПериода;
				НСтрока.КонецНачисления = ДатаСменыСтавкиСледПериода;
	    		НСтрока.Ставка = ОсновнаяСтавка;
				
				НСтрока = НТаблицаОтбор.Добавить();
				ЗаполнитьЗначенияСвойств(НСтрока,СтрТзОтбора);
				НСтрока.НачалоНачисления = КонецДня(ДатаСменыСтавкиСледПериода)+1;
				НСтрока.Ставка = ОсновнаяСтавка;
				
				ДатаОкончанияПредПериода = КонецДня(НСтрока.КонецНачисления) + 1;
			КонецЕсли;
			
		КонецЦикла;
		
		//Первая строка С большим интервалом, останавливаемся, переделываем и прерываемся
		СледМесяцОтНачала = КонецМесяца(СтрТзОтбора.НачалоНачисления)+1;
		МесяцОкончания = НачалоМесяца(СтрТзОтбора.КонецНачисления);
		
		
		
		//СтрПоиска = Новый Структура("СтавкаПениСДня",ДеньНачала);
		//ТаблицаСтавок2 = ТаблицаСтавок.Скопировать(СтрПоиска);
		
		НСтрока = НТаблицаОтбор.Добавить();
		ЗаполнитьЗначенияСвойств(НСтрока,СтрТзОтбора);
	    НСтрока.Ставка = ОсновнаяСтавка
		
	КонецЦикла;

	Возврат НТаблицаОтбор;
	
КонецФункции
		


Функция ДобавитьДней(ТекДата,КолвоДней)
	
	Датавозврата = ТекДата + 86400*КолвоДней;
	
	Возврат Датавозврата
	
КонецФункции


