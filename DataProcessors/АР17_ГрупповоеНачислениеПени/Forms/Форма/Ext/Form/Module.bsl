	Запрос.УстановитьПараметр("Период1", ДобавитьМесяц(СтруктураПараметров.Дата,-36));
	Запрос.УстановитьПараметр("Период2", КонецДня(СтруктураПараметров.Дата));
	Условие = "";
	Если ЗначениеЗаполнено(СтруктураПараметров.Организация) Тогда
		Условие = Условие + "и (Субконто1.Организация в (&Организация))";
		Запрос.УстановитьПараметр("Организация",  СтруктураПараметров.Организация);	
	КонецЕсли;
	Если ЗначениеЗаполнено(СтруктураПараметров.Контрагент) Тогда
		Условие = Условие + "и (Субконто1.Владелец в (&Владелец))";
		Запрос.УстановитьПараметр("Владелец",  СтруктураПараметров.Контрагент);	
	КонецЕсли;	
	Если ЗначениеЗаполнено(СтруктураПараметров.ДоговорКонтрагента) Тогда
		Условие = Условие + "и (Субконто1 В (&ДоговорКонтрагента))";
		Запрос.УстановитьПараметр("ДоговорКонтрагента",  СтруктураПараметров.ДоговорКонтрагента);	
	КонецЕсли;
	
	Если СписокРеализаций <> Неопределено Тогда
		Условие = Условие + "и (Субконто2 В (&СписокРеализаций)))";
		Запрос.УстановитьПараметр("СписокРеализаций",СписокРеализаций);
	КонецЕсли;
	
	Условие = Сред(Условие,3); // без И

	
	Запрос.УстановитьПараметр("Счет",ПланыСчетов.АР_РасчетыПоСчетам.НайтиПоНаименованию("Услуга"));
	
	
	Если ТолькоДокументы Тогда
	
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР_РасчетыПоСчетамБухОстатки.СуммаОстаток КАК СуммаОстаток,
		               |	АР_РасчетыПоСчетамБухОстатки.Субконто1 КАК Договор,
		               |	АР17_УстановкаПараметровИК.Ссылка КАК ОбъектИК,
		               |	АР17_ЗаключениеДоговораАренды.Ссылка КАК ЗДА,
		               |	АР_РасчетыПоСчетамБухОстатки.Субконто2 КАК Документ
		               |ИЗ
					   //|	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.Остатки(&Период2, , , {(Субконто1 В (&Договор)) КАК Поле2}) КАК АР_РасчетыПоСчетамБухОстатки
					   |	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.Остатки(&Период2, , , "+ Условие +") КАК АР_РасчетыПоСчетамБухОстатки
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |			ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
		               |			ПО АР17_ЗаключениеДоговораАренды.ДокументОснование = АР17_УстановкаПараметровИК.Ссылка
		               |		ПО АР_РасчетыПоСчетамБухОстатки.Субконто1 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
					   |";
					   
	Иначе
					   
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто1 КАК Договор,
		               |	АР17_УстановкаПараметровИК.Ссылка КАК ОбъектИК,
		               |	АР17_ЗаключениеДоговораАренды.Ссылка КАК ЗДА,
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто2 КАК Документ,
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто2.Дата КАК ПериодСуммы,
		               |	СУММА(АР_РасчетыПоСчетамБухОстаткиИОбороты.СуммаОборот) КАК СуммаОборот,
		               |	СУММА(АР_РасчетыПоСчетамБухОстаткиИОбороты.СуммаКонечныйОстаток) КАК СуммаОстаток
		               |ИЗ
					   //|	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.ОстаткиИОбороты(&Период1, &Период2, , , Счет = &Счет, , {(Субконто1 В (&Договор)
					   |	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.ОстаткиИОбороты(&Период1, &Период2, , , Счет = &Счет, , ("+ Условие +"
		               |			    ) КАК АР_РасчетыПоСчетамБухОстаткиИОбороты
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |			ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_УстановкаПараметровИК КАК АР17_УстановкаПараметровИК
		               |			ПО АР17_ЗаключениеДоговораАренды.ДокументОснование = АР17_УстановкаПараметровИК.Ссылка
		               |		ПО АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто1 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	АР17_ЗаключениеДоговораАренды.Ссылка,
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто2,
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто2.Дата,
		               |	АР_РасчетыПоСчетамБухОстаткиИОбороты.Субконто1,
		               |	АР17_УстановкаПараметровИК.Ссылка";
					   
	КонецЕсли;				   
	
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	
	Возврат Выгрузка;

КонецФункции	
