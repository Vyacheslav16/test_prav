Функция ПолучитьРеализацию(СчетНаАренду)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_НачислениеАренднойПлаты.Ссылка
	               |ИЗ
	               |	Документ.АР17_НачислениеАренднойПлаты КАК АР17_НачислениеАренднойПлаты
	               |ГДЕ
	               |	АР17_НачислениеАренднойПлаты.ДокументОснование = &ДокументОснование
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	АР17_НачислениеАренднойПлаты.Дата";
				   
	Запрос.УстановитьПараметр("ДокументОснование",СчетНаАренду);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
	
КонецФункции

Функция ПолучитьСчет(Договор)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	-1 * АР_РасчетыПоСчетамБухОстатки.СуммаОстаток КАК СуммаОстаток,
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто1 КАК Договор,
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто2
	               |ИЗ
	               |	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.Остатки(&Период, Счет = &Счет, , {(Субконто1 В (&Договор)) КАК Поле2}) КАК АР_РасчетыПоСчетамБухОстатки
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто2.Дата";
				   
	Запрос.УстановитьПараметр("Период",Объект.ДатаНачисления);
	Запрос.УстановитьПараметр("Договор", Договор);	
	Запрос.УстановитьПараметр("Счет",ПланыСчетов.АР_РасчетыПоСчетам.НайтиПоНаименованию("Услуга"));
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка[0].Субконто2;
	
КонецФункции	
