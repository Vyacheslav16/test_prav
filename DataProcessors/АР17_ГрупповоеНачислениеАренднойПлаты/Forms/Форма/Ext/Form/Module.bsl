&НаСервере
Функция ПолучениеДней(Строка, Док)
	
	ОдинДень = 60*60*24;
	Дни = День(КонецМесяца(Док.ОкончаниеПериода));
	Если ЗначениеЗаполнено(Строка.ДатаНачалаАренды) И ЗначениеЗаполнено(Строка.ДатаОкончанияАренды) Тогда
		Если Строка.ДатаНачалаАренды > Док.НачалоПериода И Строка.ДатаОкончанияАренды < КонецДня(Док.ОкончаниеПериода) Тогда
			Дни = (НачалоДня(Строка.ДатаОкончанияАренды) - НачалоДня(Строка.ДатаНачалаАренды))/ОдинДень + 1;
		ИначеЕсли  Строка.ДатаНачалаАренды < Док.НачалоПериода И Строка.ДатаОкончанияАренды < КонецДня(Док.ОкончаниеПериода) Тогда
			Дни = (НачалоДня(Строка.ДатаОкончанияАренды) - НачалоДня(Док.НачалоПериода))/ОдинДень + 1;
		ИначеЕсли  Строка.ДатаНачалаАренды > Док.НачалоПериода И Строка.ДатаОкончанияАренды > КонецДня(Док.ОкончаниеПериода) Тогда
			Дни = (НачалоДня(Док.ОкончаниеПериода) - НачалоДня(Строка.ДатаНачалаАренды))/ОдинДень + 1;
		КонецЕсли;
	КонецЕсли;
	Возврат Дни;
	
КонецФункции

