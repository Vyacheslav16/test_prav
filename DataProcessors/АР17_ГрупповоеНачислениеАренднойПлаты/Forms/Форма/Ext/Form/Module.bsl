Процедура ОбновитьСодержание(ТекСтрока, ДоговорКонтрагента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАренды.Ссылка
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
	Запрос.УстановитьПараметр("ДоговорКонтрагента",	ДоговорКонтрагента);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
				   
		Если Найти(ТекСтрока.Содержание, "[наименование ИК]") > 0 Тогда
			ТекСтрока.Содержание = СтрЗаменить(ТекСтрока.Содержание, "[наименование ИК]", Выборка.Ссылка.ИК.Наименование);
		КонецЕсли;
		Если Найти(ТекСтрока.Содержание, "[адрес место нахождения]") > 0 Тогда
			ТекСтрока.Содержание = СтрЗаменить(ТекСтрока.Содержание, "[адрес место нахождения]", ПолучитьАдрес(Выборка.Ссылка));
		КонецЕсли;
		Если Найти(ТекСтрока.Содержание, "[номер договора]") > 0 Тогда
			ТекСтрока.Содержание = СтрЗаменить(ТекСтрока.Содержание, "[номер договора]", СокрЛП(ДоговорКонтрагента.Номер));
		КонецЕсли;
		Если Найти(ТекСтрока.Содержание, "[дата договора]") > 0 Тогда
			ТекСтрока.Содержание = СтрЗаменить(ТекСтрока.Содержание, "[дата договора]", формат(ДоговорКонтрагента.Дата,"ДЛФ=Д"));
		КонецЕсли;
		
		Если Найти(ТекСтрока.Содержание, "[период]") > 0 Тогда
			// + NAI Becar Конюшок С.Н. от 26.12.2016 15:36 представление периода
			Если НачалоМесяца(Объект.ОкончаниеПериода) < ТекСтрока.ДатаНачалаАренды Или КонецМесяца(Объект.ОкончаниеПериода) > КонецДня(ТекСтрока.ДатаОкончанияАренды) Тогда
				
				КонецМесяца = КонецДня(КонецМесяца(Объект.ОкончаниеПериода));
				НачалоМесяца = НачалоМесяца(Объект.ОкончаниеПериода);
				
				Если ЗначениеЗаполнено(ТекСтрока.ДатаНачалаАренды) И ЗначениеЗаполнено(ТекСтрока.ДатаОкончанияАренды) Тогда
					Если ТекСтрока.ДатаНачалаАренды >= (НачалоМесяца +1) И КонецДня(ТекСтрока.ДатаОкончанияАренды) <= (КонецМесяца-1) Тогда
						ПериодУслуги = "период с "+ Формат(ТекСтрока.ДатаНачалаАренды, "ДЛФ=Д") + " по " + Формат(ТекСтрока.ДатаОкончанияАренды, "ДЛФ=Д");
					ИначеЕсли  ТекСтрока.ДатаНачалаАренды < (НачалоМесяца +1) И КонецДня(ТекСтрока.ДатаОкончанияАренды) < КонецМесяца Тогда
						ПериодУслуги = "период с "+ Формат(НачалоМесяца, "ДЛФ=Д") + " по " + Формат(ТекСтрока.ДатаОкончанияАренды, "ДЛФ=Д");
					ИначеЕсли  ТекСтрока.ДатаНачалаАренды > НачалоМесяца И КонецДня(ТекСтрока.ДатаОкончанияАренды) >= КонецМесяца Тогда
						ПериодУслуги = "период с "+ Формат(ТекСтрока.ДатаНачалаАренды, "ДЛФ=Д") + " по " + Формат(КонецМесяца, "ДЛФ=Д");
					КонецЕсли;
				КонецЕсли;
			Иначе
				ПериодУслуги = ЭтотОбъект.Период;
			КонецЕсли;
			// - NAI Becar Конюшок С.Н. 
			
			ТекСтрока.Содержание = СтрЗаменить(ТекСтрока.Содержание, "[период]", ПериодУслуги);
		КонецЕсли;
		
	КонецЕсли;	
КонецПроцедуры	

