				СтрокаТЧ.ДоговорКонтрагента = Начисление.ДоговорКонтрагента;
				СтрокаТЧ.СуммаДокумента = Начисление.СуммаДокумента;
				СтрокаТЧ.СуммаДоговора = Начисление.Состав.Итог("СуммаПоДоговору");
				
				Если НайтиПодчиненнуюРеализацию(Начисление.Ссылка) <> Неопределено тогда
					РН = НайтиПодчиненнуюРеализацию(Начисление.Ссылка).ПолучитьОбъект();
					Если НайтиПодчиненныйСчетФактуруВыданныйНаРеализацию(РН.Ссылка) <> Неопределено Тогда
						ОбъектСчетаФактуры = НайтиПодчиненныйСчетФактуруВыданныйНаРеализацию(РН.Ссылка);
						СтрокаТЧ = Объект.СформированныеДокументы.Добавить();
						СтрокаТЧ.Документ = ОбъектСчетаФактуры.Ссылка;
						СтрокаТЧ.Контрагент = ОбъектСчетаФактуры.Контрагент;
						СтрокаТЧ.ДоговорКонтрагента = ОбъектСчетаФактуры.ДоговорКонтрагента;
						СтрокаТЧ.СуммаДокумента = ОбъектСчетаФактуры.СуммаДокумента;
					КонецЕсли;
				КонецЕсли;

				
			Исключение
				Отказ = Истина;
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
			
			Если Отказ Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаполнитьСостоянияДокументов();
	
	ТекстСообщения = НСтр("ru = 'Формирование документов завершено'");
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры


