		|	АР_СобственникиОбъектовАрендыСпр.АгентскаяСхема КАК АгентскаяСхема,
		|	ЕСТЬNULL(АР_СобственникиОбъектовАрендыСпр.ДоляСобственника, 0) КАК ДоляСобственника,
		|	АР_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.ЗначениеХарактеристики КАК ОбъектАрендыОбщаяПлощадь,
		|	АР_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.АП КАК ОбъектАрендыАП,
		|	АР_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.МОП КАК ОбъектАрендыМОП,
		|	АР_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка КАК Ссылка,
		|	ОбщаяПлощадь.ОбщаяПлощадьПоДоговору КАК ОбщаяПлощадьПоДоговору,
		|	АР_СобственникиОбъектовАрендыСпр.ОбъектАренды КАК ОбъектАренды1,
		|	ЗаписиСМаксДатами.Период КАК Период,
		|	АР_СобственникиОбъектовАрендыСпр.Регистратор КАК Распределение
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР_ЗаключениеДоговораАрендыОбъектыАренды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_СобственникиОбъектовАрендыСпр КАК АР_СобственникиОбъектовАрендыСпр
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗаписиСМаксДатами КАК ЗаписиСМаксДатами
		|			ПО АР_СобственникиОбъектовАрендыСпр.ОбъектАренды = ЗаписиСМаксДатами.ОбъектАренды
		|				И АР_СобственникиОбъектовАрендыСпр.Период = ЗаписиСМаксДатами.Период
		|		ПО АР_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды = АР_СобственникиОбъектовАрендыСпр.ОбъектАренды,
		|	ОбщаяПлощадь КАК ОбщаяПлощадь
		|ГДЕ
		|	АР_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка.ДоговорКонтрагента = &ДоговорКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Собственник КАК Собственник,
		|	ВТ.ДоговорСобственника КАК ДоговорСобственника,
		|	ВТ.Контрагент КАК Контрагент,
		|	ВТ.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ВТ.ОбщаяПлощадьПоДоговору КАК ОбщаяПлощадьПоДоговору,
		|	ВТ.ДоляСобственника / 100 * ВТ.ОбъектАрендыОбщаяПлощадь КАК ДоляОтПлощади,
		|	ВТ.ОбъектАрендыОбщаяПлощадь КАК ОбъектАрендыОбщаяПлощадь,
		|	ВТ.ОбъектАренды КАК ОбъектАренды,
		|	ВТ.Период КАК Период,
		|	ВТ.Распределение КАК Распределение
		|ИЗ
		|	ВТ КАК ВТ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора КАК АР17_ЗаключениеАгентскогоДоговора
		|		ПО ВТ.ДоговорКонтрагента = АР17_ЗаключениеАгентскогоДоговора.ДоговорКонтрагента
		|ГДЕ
		|	АР17_ЗаключениеАгентскогоДоговора.СтавкаНДС = &СтавкаНДС
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ
		|ИТОГИ
		|	МАКСИМУМ(ОбъектАрендыОбщаяПлощадь)
		|ПО
		|	ОбъектАренды";
		
		Запрос.УстановитьПараметр("ДоговорКонтрагента",Начисление.ДоговорКонтрагента);
		Запрос.УстановитьПараметр("ДатаН",Объект.НачалоПериода);
		Запрос.УстановитьПараметр("ДатаК",КонецДня(Объект.ОкончаниеПериода));
		Запрос.УстановитьПараметр("СтавкаНДС",Справочники.Номенклатура.СтавкаНДС(Услуга, Объект.ОкончаниеПериода));
		
		
		РЗГрупп = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Собственник");
		ТЗ.Колонки.Добавить("ДоговорСобственника");
		ТЗ.Колонки.Добавить("Контрагент");
		ТЗ.Колонки.Добавить("ДоговорКонтрагента");
		ТЗ.Колонки.Добавить("ОбщаяПлощадьПоДоговору");
		ТЗ.Колонки.Добавить("ДоляОтПлощади");
		ТЗ.Колонки.Добавить("ДоляСобственника");
		
		//Выгрузка = Запрос.Выполнить().Выгрузить();
		
		тзНачисление = Начисление.Состав.Выгрузить();
		//ЭлементыФормы.ТабличноеПоле.СоздатьКолонки();
		
		ТЧ = Новый ТаблицаЗначений;
		ТЧ = тзНачисление.Скопировать();
		ТЧ.Очистить();
		
		Если тзНачисление.Количество() <> 0 Тогда   //не распределяем ку+
			Для ИндОбхода = (-1)*(тзНачисление.Количество()-1) По 0 Цикл
				Инд = (-1)*ИндОбхода;
				Если тзНачисление[Инд].Номенклатура.АР_КоммунальныеУслуги Тогда
					НСТр = ТЧ.Добавить();
					ЗаполнитьЗначенияСвойств(НСТр, тзНачисление[Инд]);
					тзНачисление.Удалить(Инд);
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;  //не распределяем ку-
		
		Если Услуга <> Неопределено Тогда
			ПроверятьНаСоответствиеУслуге = Истина;
		Иначе	
			ПроверятьНаСоответствиеУслуге = Ложь;
		КонецЕсли; 
		
		
		Если РЗГрупп.Количество() > 0 Тогда
			
			ДнейВТекМесяце = День(Объект.ОкончаниеПериода);
			
			Пока РЗГрупп.Следующий() Цикл
				
				РЗ = РЗГрупп.Выбрать();
				РегистраторВерхнейГраницы = Неопределено;
				ПромежуточныйРегистратор = Неопределено; 
				//СуммаПлощадей = 0;
				
				НесколькоРаспределенийВПериоде = Ложь;
				
				Пока РЗ.Следующий() Цикл
					
					НСтр = ТЗ.Добавить();
					ЗаполнитьЗначенияСвойств(НСтр, РЗ);
					
					Если ПромежуточныйРегистратор <> РЗ.Распределение Тогда
						РегистраторВерхнейГраницы = ПромежуточныйРегистратор;
					КонецЕсли;
					
					ПромежуточныйРегистратор = РЗ.Распределение;
					
					Если РЗ.Период > Объект.НачалоПериода Тогда 
						НесколькоРаспределенийВПериоде = Истина;
					КонецЕсли;
					
					Если НесколькоРаспределенийВПериоде Тогда
						
						Если РЗ.Период < Объект.НачалоПериода Тогда
							НижняяГраница = НачалоДня(Объект.НачалоПериода);
						Иначе
							НижняяГраница = НачалоДня(РЗ.Период);					
						КонецЕсли; 
						
						ВерхняяГраница = ?(РегистраторВерхнейГраницы = Неопределено, КонецДня(Объект.ОкончаниеПериода), КонецДня(НачалоДня(РегистраторВерхнейГраницы.Дата) - 1));
						ПериодДействия = Окр((ВерхняяГраница - НижняяГраница) / 86400);
						НСтр.ДоляОтПлощади = НСтр.ДоляОтПлощади * ПериодДействия / ДнейВТекМесяце;
					КонецЕсли;
					
					//СуммаПлощадей = СуммаПлощадей + НСтр.ДоляОтПлощади;
					
				КонецЦикла;
				
				//Если СуммаПлощадей <> РЗГрупп.ОбъектАрендыОбщаяПлощадь Тогда
				//	
				//	НСтр.ДоляОтПлощади = НСтр.ДоляОтПлощади + (РЗГрупп.ОбъектАрендыОбщаяПлощадь - СуммаПлощадей);
				//	
				//КонецЕсли;
				
			КонецЦикла; 
			
			ТЗ.Свернуть("Контрагент, ДоговорКонтрагента, ОбщаяПлощадьПоДоговору","ДоляОтПлощади, ДоляСобственника");
			Для каждого СтрТЗ Из ТЗ Цикл
				СтрТЗ.ДоляСобственника = СтрТЗ.ДоляОтПлощади / СтрТЗ.ОбщаяПлощадьПоДоговору;
			КонецЦикла; 
			
			//Если Выгрузка.Количество() > 0 Тогда
			
			Для Каждого СтрНачисление Из тзНачисление Цикл
				
				Если ПроверятьНаСоответствиеУслуге Тогда
					Если СтрНачисление.Номенклатура <> Услуга Тогда
						СтрокаТЧ = ТЧ.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрНачисление);
						Продолжить;
					КонецЕсли; 
				КонецЕсли; 
				
				ПолнаяСуммаУслуги = СтрНачисление.Сумма;
				ПеревыставленнаяСумма = 0;
				Доля = 0;
				Для Каждого СтрВыгрузка Из ТЗ Цикл
					Если СтрВыгрузка.Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда Продолжить; КонецЕсли;
					//АП
					СтрокаТЧ = ТЧ.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрНачисление);
					//
					СтрокаТЧ.Сумма = СтрНачисление.Сумма * (СтрВыгрузка.ДоляСобственника);
					СтрокаТЧ.Количество = СтрНачисление.Количество * (СтрВыгрузка.ДоляСобственника); 
					СтрокаТЧ.Контрагент = СтрВыгрузка.Контрагент;
					СтрокаТЧ.ДоговорКонтрагента = СтрВыгрузка.ДоговорКонтрагента;
					
					ПеревыставленнаяСумма = ПеревыставленнаяСумма + СтрокаТЧ.Сумма;
					Доля = Доля + СтрВыгрузка.ДоляСобственника;
					
				КонецЦикла;
				
				Если Окр(Доля, 2) = 1 Тогда
					СтрокаТЧ.Сумма = СтрокаТЧ.Сумма + (ПолнаяСуммаУслуги - ПеревыставленнаяСумма); // + NAI Becar Конюшок С.Н. от 30.01.2017 12:11 если потерялись какие-нибудь копейки, отдадим их последнему
				Иначе
					Сообщить("Внимание! По договору " +Начисление.ДоговорКонтрагента + " предусмотрено перевыставление услуг комитентам, однако не для всех объектов аренды договора указан комитент! Необходимо ввести новый документ ""Распределение долей собственников"" с указанием комитентов и их долей по недостающим помещениям! Также, возможно для одного или нескольких помещений сумма долей собственников больше или меньше 100%, необходимо внести исправление в соответствующий документ ""Распределение долей собственников""!");
				КонецЕсли; 
				
			КонецЦикла;
			
			
			//Начисление.Состав.Очистить();
			Начисление.Состав.Загрузить(ТЧ);
			
			ТабЧасть = Начисление.Состав;
			Для Каждого ТекСтрока Из ТабЧасть Цикл 
				АР_ОбщиеПроцедурыПереопределяемый.РассчитатьСуммуНДСТабЧасти(ТекСтрока, Начисление);
			КонецЦикла;	
			
		КонецЕсли;	
		
		
	КонецЕсли;
	
	
КонецПроцедуры
