&НаСервере
Функция ПарсингДатыСтрокиИПереводВДату(Строка)
	
	Месяц = "00";
	Год = "0000";
	Если СтрНайти(Строка, "Сентябрь") > 0 Тогда
		Месяц = "09";
		Год = СтрЗаменить(Строка, "Сентябрь ","");
	ИначеЕсли СтрНайти(Строка, "Октябрь") > 0 Тогда
		Месяц = "10";
		Год = СтрЗаменить(Строка, "Октябрь ","");
	ИначеЕсли СтрНайти(Строка, "Ноябрь") > 0 Тогда
		Месяц = "11";
		Год = СтрЗаменить(Строка, "Ноябрь ","");
	ИначеЕсли СтрНайти(Строка, "Декабрь") > 0 Тогда
		Месяц = "12";
		Год = СтрЗаменить(Строка, "Декабрь ","");
	ИначеЕсли СтрНайти(Строка, "Январь") > 0 Тогда
		Месяц = "01";
		Год = СтрЗаменить(Строка, "Январь ","");
	ИначеЕсли СтрНайти(Строка, "Февраль") > 0 Тогда
		Месяц = "02";
		Год = СтрЗаменить(Строка, "Февраль ","");
	ИначеЕсли СтрНайти(Строка, "Март") > 0 Тогда
		Месяц = "03";
		Год = СтрЗаменить(Строка, "Март ","");
	ИначеЕсли СтрНайти(Строка, "Апрель") > 0 Тогда
		Месяц = "04";
		Год = СтрЗаменить(Строка, "Апрель ","");
	ИначеЕсли СтрНайти(Строка, "Май") > 0 Тогда
		Месяц = "05";
		Год = СтрЗаменить(Строка, "Май ","");
	ИначеЕсли СтрНайти(Строка, "Июнь") > 0 Тогда
		Месяц = "06";
		Год = СтрЗаменить(Строка, "Июнь ","");
	ИначеЕсли СтрНайти(Строка, "Июль") > 0 Тогда
		Месяц = "07";
		Год = СтрЗаменить(Строка, "Июль ","");
	ИначеЕсли СтрНайти(Строка, "Август") > 0 Тогда
		Месяц = "08";
		Год = СтрЗаменить(Строка, "Август ","");
	КонецЕсли;
	
	Возврат (Дата(Год+ Месяц + "010100"));
	
КонецФункции


