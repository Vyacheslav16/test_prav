Функция ПоискИСозданиеСчетчика(Номер)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_Счетчики.Ссылка
	|ИЗ
	|	Справочник.АР_Счетчики КАК АР_Счетчики
	|ГДЕ
	|	АР_Счетчики.НомерСчетчика = &НомерСчетчика
	|	И АР_Счетчики.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("НомерСчетчика", Номер);
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Счетчик = РЗ.Ссылка;
	Иначе
		Счетчик = Справочники.АР_Счетчики.СоздатьЭлемент();
		Счетчик.НомерСчетчика = Номер;
	КонецЕсли;
	
	//Счетчик = Справочники.АР_Счетчики4.НайтиПоРеквизиту("НомерСчетчика", СокрЛП(Номер));
	//
	//Если Не ЗначениеЗаполнено(Счетчик) Тогда 
