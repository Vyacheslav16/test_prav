Функция НайтиАкт(Договор,СтрокаТЧ)
	
	ЗапросАкт = Новый Запрос;
	ЗапросАкт.Текст = "ВЫБРАТЬ
	                  |	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка
	                  |ИЗ
	                  |	Документ.АР_АктСнятияПоказанийСчетчика.Показания КАК АР_АктСнятияПоказанийСчетчикаПоказания
	                  |ГДЕ
	                  |	АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка.ДокументОснование = &ДокументОснование
	                  |	И АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка.НачалоПериода = &НачалоПериода
	                  |	И АР_АктСнятияПоказанийСчетчикаПоказания.Ссылка.ОкончаниеПериода = &ОкончаниеПериода";
					  
	ЗапросАкт.УстановитьПараметр("ДокументОснование",Договор.Ссылка);
	//ЗапросАкт.УстановитьПараметр("Счетчик",СтрокаТЧ.Счетчик);
	ЗапросАкт.УстановитьПараметр("НачалоПериода",СтрокаТЧ.ДатаНачалаПериода);
	ЗапросАкт.УстановитьПараметр("ОкончаниеПериода",СтрокаТЧ.ДатаОкончанияПериода);
	
	ВыборкаАкт = ЗапросАкт.Выполнить().Выбрать();
	Если ВыборкаАкт.Следующий() Тогда
		Возврат ВыборкаАкт.Ссылка;
	Иначе	
		Возврат "";
	КонецЕсли;
	
КонецФункции	

Функция ПолучитьНомерФайла(НомерФайла)
	НаборЗаписей = РегистрыСведений.АР_НомераФайлов.СоздатьНаборЗаписей();
    НаборЗаписей.Отбор.НомерФайла.Установить(НомерФайла);
	//НаборКурсов.Отбор.Период.Установить(ТекущаяДата());
    НаборЗаписей.Прочитать();
 
    Если НаборЗаписей.Количество() = 0 Тогда
        НоваяЗапись = НаборЗаписей.Добавить();
        НоваяЗапись.Период = ТекущаяДата();
        НоваяЗапись.НомерФайла = НомерФайла;
		НаборЗаписей.Записать();
		Возврат Ложь;
    ИначеЕсли НаборЗаписей.Количество() >0 Тогда
        НоваяЗапись = НаборЗаписей[0];
		Возврат Истина;
	КонецЕсли;
	
