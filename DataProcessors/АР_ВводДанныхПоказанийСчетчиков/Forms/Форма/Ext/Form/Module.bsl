Функция ПолучитьПлощадьПодчиненных(Помещение)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(АР17_ЗаключениеДоговораАрендыОбъектыАренды.Площадь) КАК Площадь,
	               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ОбъектыАренды КАК АР17_ЗаключениеДоговораАрендыОбъектыАренды
	               |ГДЕ
	               |	(АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель = &Родитель
	               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель.Родитель = &Родитель
	               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель.Родитель.Родитель = &Родитель
	               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель.Родитель.Родитель.Родитель = &Родитель
	               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель.Родитель.Родитель.Родитель.Родитель = &Родитель
	               |			ИЛИ АР17_ЗаключениеДоговораАрендыОбъектыАренды.ОбъектАренды.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = &Родитель)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеДоговораАрендыОбъектыАренды.Ссылка";
				   
	Запрос.УстановитьПараметр("Родитель",Помещение);			   
