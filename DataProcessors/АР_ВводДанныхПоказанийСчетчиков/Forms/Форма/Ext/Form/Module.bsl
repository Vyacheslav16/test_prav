&НаСервере
Функция СформироватьАкт(Тариф, ВидАкта, ПолноеИмяФайла)
	
	Если Не ЗначениеЗаполнено(ТЗ) Тогда
		Возврат Неопределено;
	КОнецЕсли;
	
	//поиск акта
	Акт = ПоискИСозданиеАкта(ПолноеИмяФайла);
	
	//заполнение ТЧ
	Если ВидАкта = "Электричество" Тогда
		Акт.Показания.Очистить();
		ЗаполнениеТЧДляЭлектроэнергии(Акт,Тариф);
	ИначеЕсли  ВидАкта = "Вода" Тогда
		Акт.ПоказанияВодоснабжение.Очистить();		
		ЗаполнениеТЧДляВодоснабжения(Акт);
	ИначеЕсли  ВидАкта = "Тепло" Тогда
		Акт.ПоказанияТеплоснабжение.Очистить();		
		ЗаполнениеТЧДляТеплоснабжения(Акт, Тариф);
	КонецЕсли;
	
	Акт.Записать(РежимЗаписиДокумента.Проведение);
	
КОнецФункции

Функция ПоискИСозданиеАкта(ПолноеИмяФайла)
	
	Код = ПолучениеКодаСправочникаИзПути(ПолноеИмяФайла);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_ОбъектыАренды.Ссылка
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", Код);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		ОбъектАр = РЗ.Ссылка;
	Иначе
		ВызватьИсключение "Не найден объект аренды по коду в названии файла Excel!!";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_АктСнятияПоказанийСчетчика.Ссылка
		|ИЗ
		|	Документ.АР_АктСнятияПоказанийСчетчика КАК АР_АктСнятияПоказанийСчетчика
		|ГДЕ
		|	АР_АктСнятияПоказанийСчетчика.ИК = &ИК
		|	И АР_АктСнятияПоказанийСчетчика.ПометкаУдаления = ЛОЖЬ
		|	И АР_АктСнятияПоказанийСчетчика.НачалоПериода = &НачалоПериода
		|	И АР_АктСнятияПоказанийСчетчика.ОкончаниеПериода = &ОкончаниеПериода";
	
	Запрос.УстановитьПараметр("ИК", ОбъектАр);
	Запрос.УстановитьПараметр("НачалоПериода", Объект.НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", Объект.ОкончаниеПериода);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Акт = РЗ.Ссылка.ПолучитьОбъект();
	Иначе
		Акт = Документы.АР_АктСнятияПоказанийСчетчика.СоздатьДокумент();
		Акт.НачалоПериода = Объект.НачалоПериода;
		Акт.ОкончаниеПериода = Объект.ОкончаниеПериода;
		Акт.ИК = ОбъектАр;
		Акт.Дата = Объект.ОкончаниеПериода;
		Акт.ВидОперации = Перечисления.АР_ВидыОперацийАктСнятияПоказанийСчетчика.ПоказаниеСчетчика;
		Акт.Услуга = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
		
	КонецЕсли;
	Возврат Акт;
	
КонецФункции

Функция ПолучениеКодаСправочникаИзПути(ПолноеИмяФайла)
	
	  А = ПолноеИмяФайла;
	  ПолноеИмяФайла = СтрЗаменить(ПолноеИмяФайла, ".xls", "");
	  ПолноеИмяФайла = СтрЗаменить(ПолноеИмяФайла, ".xlsx", "");
	  
	  КолвоСимв = СтрДлина(ПолноеИмяФайла);
	  КолвоСимв = (-1)* КолвоСимв;
	  Код = "";
	  Для Инд = КолвоСимв По 0 Цикл
		  
		  Симв = Сред(ПолноеИмяФайла, (-1)*Инд, 1);
		  Если Симв <> "_" Тогда
			  Код = Симв + Код;
		  Иначе
			  Прервать;
		  КонецЕсли;
		  
	  КонецЦикла;
	  
	  Если Код <> "" Тогда
		  Возврат Код;
	  КонецЕСли;
	
КонецФункции


&НаСервере
Процедура ЗаполнениеТЧДляТеплоснабжения(Акт, Тариф)
	
	РЗ = ПоискСчетчиковИДоговоров("Тепло");
	КУ = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
	Организация = Неопределено;
	
	Тарифы = ТЗТарифов.Выгрузить();
	СтрТ = Тарифы.Найти("ТНКуб", "ВидТарифа");
	Акт.ТарифТеплоносительКуб = СтрТ.Тариф;
	СтрТ = Тарифы.Найти("ТНТ", "ВидТарифа");
	Акт.ТарифТеплоносительТ = СтрТ.Тариф;
	СтрТ = Тарифы.Найти("Тепло", "ВидТарифа");
	Акт.ТарифТепло = СтрТ.Тариф;
	
	Пока РЗ.Следующий() Цикл
		
		Если Организация = Неопределено Тогда
			Если РЗ.Организация <> Null Тогда
				Организация = РЗ.Организация;
