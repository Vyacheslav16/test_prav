&НаСервере
Процедура ЗаполнениеТЧДляВодоснабжения(Акт)
	
	РЗ = ПоискСчетчиковИДоговоров("Вода");
	Тарифы = ТЗТарифов.Выгрузить();
	КУ = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
	Организация = Неопределено;
	//Акт.ТарифХолВодоснабжение = 0;
	ТарифГВ = 0;
	СтрТ = Тарифы.Найти("ХВ", "ВидТарифа");
	Акт.ТарифХолВодоснабжение = СтрТ.Тариф;
	СтрТ = Тарифы.Найти("ГВ", "ВидТарифа");
	Акт.ТарифГорВодоснабжение = СтрТ.Тариф;
	СтрТ = Тарифы.Найти("ВО", "ВидТарифа");
	Акт.ТарифВодоотведение = СтрТ.Тариф;
	
	КубМ = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду("113");
	
	Пока РЗ.Следующий() Цикл
		
		Если Организация = Неопределено Тогда
			Если РЗ.Организация <> Null Тогда
				Организация = РЗ.Организация;
			КонецЕсли;
		КонецЕсли;
		НСтр = Акт.ПоказанияВодоснабжение.Добавить();
		
		Если Не РЗ.Название = Null Тогда
			
			ЗаполнитьЗначенияСвойств(НСтр, РЗ);
			//тариф
			Если ЗначениеЗаполнено(РЗ.Счетчик) Тогда 
				Если РЗ.Счетчик.НазваниеРесурса.ВидРесурса = Перечисления.АР_ВидРесурса.ХолоднаяВодаПоРасходомерам Тогда
					НСтр.Сумма = РЗ.Потребление * Акт.ТарифХолВодоснабжение;
					НСтр.СуммаВодоотведение = РЗ.Потребление * Акт.ТарифВодоотведение;
					НСтр.Итого = НСтр.Сумма + НСтр.СуммаВодоотведение;
					НСтр.Цена = Акт.ТарифХолВодоснабжение;
				ИначеЕсли РЗ.Счетчик.НазваниеРесурса.ВидРесурса = Перечисления.АР_ВидРесурса.ГорячаяВодаПоРасходомерам Тогда
					НСтр.Сумма = РЗ.Потребление * Акт.ТарифГорВодоснабжение;
					НСтр.СуммаВодоотведение = РЗ.Потребление * Акт.ТарифВодоотведение;
					НСтр.Итого = НСтр.Сумма + НСтр.СуммаВодоотведение;
					НСтр.Цена = Акт.ТарифГорВодоснабжение;
				КонецЕсли;
			КонецЕсли;
			НСтр.ЕдиницаИзмерения = КубМ;
			НСтр.ДоляВМОП = РЗ.ДоляАрендатора;
			
			Если Не ЗначениеЗаполнено(РЗ.Счетчик) Тогда
				Счетчик = Справочники.АР_Счетчики.СоздатьЭлемент();
				Счетчик.НомерСчетчика = РЗ.Номер;
				Счетчик.Наименование = РЗ.Название;
				Счетчик.Записать();
				НСтр.Счетчик = Счетчик.Ссылка;
			КонецЕсли;
			
		Иначе
			
			Если Не ЗначениеЗаполнено(РЗ.СчетчикЭкс) Тогда
				Счетчик = Справочники.АР_Счетчики.СоздатьЭлемент();
				Счетчик.НомерСчетчика = РЗ.НомерЭкс;
				Счетчик.Наименование = РЗ.НазваниеЭкс;
				Счетчик.Записать();
				НСтр.Счетчик = Счетчик.Ссылка;
			Иначе
				НСтр.Счетчик = РЗ.СчетчикЭкс;
			КонецЕсли;
			
			НСтр.ПоказаниеНаКонецПериода =  РЗ.ПоказаниеСчетчикаЭкс;
			НСтр.ОбъектАренды = РЗ.ПомещениеЭкс;
			
		КонецЕсли;
		
	КонецЦикла;

	Акт.Организация = Организация;
КонецПроцедуры


&НаСервере
Процедура ЗаполнениеТЧДляЭлектроэнергии(Акт,Тариф)
	
	РЗ = ПоискСчетчиковИДоговоров("Электроэнергия");
	
	КУ = Справочники.Номенклатура.НайтиПоНаименованию("Коммунальные услуги");
	Организация = Неопределено;
	
	Акт.ТарифЭлектроэнергия = Тариф;
	Квт = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду("214");
	Пока РЗ.Следующий() Цикл
		
		Если Организация = Неопределено Тогда
			Если РЗ.Организация <> Null Тогда
				Организация = РЗ.Организация;
			КонецЕсли;
		КонецЕсли;
		
		//Счетчик = ПоискИСозданиеСчетчика(СокрЛП(СтрТЗ.Номер));
		
		НСтр = Акт.Показания.Добавить();
		
		Если Не РЗ.Название = Null Тогда
			
			ЗаполнитьЗначенияСвойств(НСтр, РЗ);
			
			НСтр.Сумма = (РЗ.Потребление) * Акт.ТарифЭлектроэнергия; 
			НСтр.Услуга = КУ; 
			НСтр.ЕдиницаИзмерения = Квт;
			НСтр.ДоляВМОП = РЗ.ДоляАрендатора;
			НСтр.Цена = Акт.ТарифЭлектроэнергия;
			Если Не ЗначениеЗаполнено(РЗ.Счетчик) Тогда
				Счетчик = Справочники.АР_Счетчики.СоздатьЭлемент();
				Счетчик.НомерСчетчика = РЗ.Номер;
				Счетчик.Наименование = РЗ.Название;
				Счетчик.Записать();
				НСтр.Счетчик = Счетчик.Ссылка;
			КонецЕсли;
			
		Иначе
			
			Если Не ЗначениеЗаполнено(РЗ.СчетчикЭкс) Тогда
				Счетчик = Справочники.АР_Счетчики.СоздатьЭлемент();
				Счетчик.НомерСчетчика = РЗ.НомерЭкс;
				Счетчик.Наименование = РЗ.НазваниеЭкс;
				Счетчик.Записать();
				НСтр.Счетчик = Счетчик.Ссылка;
			Иначе
				НСтр.Счетчик = РЗ.СчетчикЭкс;
			КонецЕсли;
			
			НСтр.ПоказаниеНаКонецПериода =  РЗ.ПоказаниеСчетчикаЭкс;
			НСтр.ОбъектАренды = РЗ.ПомещениеЭкс;

		КонецЕсли;
		
	КонецЦикла;

	Акт.Организация = Организация;
КонецПроцедуры

&НаСервере
Функция ПоискСчетчиковИДоговоров(ВидАкта)
	
	ТЗДляЗагрузки = ТЗ.Выгрузить();
	
	Если ВидАкта = "Электроэнергия" Тогда
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗ.Номер КАК Номер,
		|	ВЫРАЗИТЬ(ТЗ.Название КАК СТРОКА(100)) КАК Название,
		|	ТЗ.ДатаСнятияПоказаний КАК ДатаСнятияПоказаний,
		|	ТЗ.ПоказаниеСчетчика КАК ПоказаниеСчетчика
		|ПОМЕСТИТЬ Показания
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Показания.Номер КАК Номер,
		|	Показания.Название КАК Название,
		|	Показания.ДатаСнятияПоказаний КАК ДатаСнятияПоказаний,
		|	Показания.ПоказаниеСчетчика КАК ПоказаниеСчетчика,
		|	АР_Счетчики.Ссылка КАК Счетчик,
		|	АР_Счетчики.Помещение КАК Помещение
		|ПОМЕСТИТЬ ПоказанияИСчетчики
		|ИЗ
		|	Показания КАК Показания
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.АР_Счетчики КАК АР_Счетчики
		|		ПО Показания.Номер = АР_Счетчики.НомерСчетчика
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ АР_Счетчики.ПометкаУдаления ЕСТЬ NULL
		|				ТОГДА АР_Счетчики.ПометкаУдаления = ЛОЖЬ
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
