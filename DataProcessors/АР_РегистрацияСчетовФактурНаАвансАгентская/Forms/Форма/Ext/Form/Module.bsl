// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаКлиенте
Процедура ЗафиксироватьДлительностьКлючевойОперации()
	
	Если ВремяНачалаОперации <> Неопределено Тогда
		ОценкаПроизводительностиКлиент.ЗавершитьЗамерВремени(
			КлючеваяОперация, 
			ВремяНачалаОперации
		);
		ВремяНачалаОперации = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЗначениеТаймера()
	Если ВыполнятьЗамерыПроизводительности() Тогда
		Возврат РегламентированнаяОтчетностьКлиентСервер.ЗначениеТаймера();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ВыполнятьЗамерыПроизводительности()
	Возврат ОценкаПроизводительностиВызовСервераПовтИсп.ВыполнятьЗамерыПроизводительности()
КонецФункции

&НаКлиенте
Процедура ПоказатьПредупреждениеОбИзменениях(КлючНастроек, ВладелецФормы = Неопределено, 
			НастройкаПредупреждений = Неопределено) Экспорт
	
	// Проверим на клиенте, нужно ли показывать предупреждения
	Если ТипЗнч(НастройкаПредупреждений) = Тип("Структура") Тогда
		Если НастройкаПредупреждений.Свойство(КлючНастроек) Тогда
			Если НастройкаПредупреждений[КлючНастроек] = Ложь Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
			
	ПараметрыСообщения	= Новый Структура;
	ПараметрыСообщения.Вставить("КлючНастроек",КлючНастроек);
	
	// бит_AMuntyan изменение кода. Начало. 07.08.2015{{
	Если бит_ПраваДоступа.ЕстьПравоДоступа("Просмотр", "Обработка.ПредупреждениеОбИзменениях") Тогда
		
		ОткрытьФорму("Обработка.ПредупреждениеОбИзменениях.Форма", ПараметрыСообщения, ВладелецФормы, Истина);
		
	КонецЕсли;
	// бит_AMuntyan изменение кода. Конец. 07.08.2015}}
	
КонецПроцедуры

