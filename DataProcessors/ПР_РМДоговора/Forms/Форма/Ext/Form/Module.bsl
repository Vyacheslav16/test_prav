	               |	ПР_ДоговорОснащения.ДатаНачала КАК ДатаНачала,
	               |	ПР_ДоговорОснащения.Контрагент КАК Контрагент
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	Документ.ПР_ДоговорОснащения КАК ПР_ДоговорОснащения
	               |ГДЕ
	               |	ПР_ДоговорОснащения.Помещение = &Помещение
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_ДоговорДолевогоУчастия.Ссылка,
	               |	ПР_ДоговорДолевогоУчастия.Дата,
	               |	ПР_ДоговорДолевогоУчастия.Номер,
	               |	ПР_ДоговорДолевогоУчастия.Помещение,
	               |	ПР_ДоговорДолевогоУчастия.ДатаНачала,
	               |	ПР_ДоговорДолевогоУчастия.Контрагент
	               |ИЗ
	               |	Документ.ПР_ДоговорДолевогоУчастия КАК ПР_ДоговорДолевогоУчастия
	               |ГДЕ
	               |	ПР_ДоговорДолевогоУчастия.Помещение = &Помещение
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_АППЗастройщик.Ссылка,
	               |	ПР_АППЗастройщик.Дата,
	               |	ПР_АППЗастройщик.Номер,
	               |	ПР_АППЗастройщик.Помещение,
	               |	ПР_АППЗастройщик.ДатаПередачи,
	               |	ПР_АППЗастройщик.Контрагент
	               |ИЗ
	               |	Документ.ПР_АППЗастройщик КАК ПР_АППЗастройщик
	               |ГДЕ
	               |	ПР_АППЗастройщик.Помещение = &Помещение
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Дата,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Номер,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |ГДЕ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды = &Помещение
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	КВП_ОткрытиеЛицевогоСчета.Ссылка,
	               |	КВП_ОткрытиеЛицевогоСчета.Ссылка.Дата,
	               |	КВП_ОткрытиеЛицевогоСчета.Ссылка.Номер,
	               |	КВП_ОткрытиеЛицевогоСчета.ЛицевойСчет.Адрес,
	               |	КВП_ОткрытиеЛицевогоСчета.Дата,
	               |	КВП_ОткрытиеЛицевогоСчета.Ссылка.Контрагент
	               |ИЗ
	               |	Документ.КВП_ОткрытиеЛицевогоСчета КАК КВП_ОткрытиеЛицевогоСчета
	               |ГДЕ
	               |	(ВЫРАЗИТЬ(КВП_ОткрытиеЛицевогоСчета.ЛицевойСчет.Адрес.Наименование КАК СТРОКА(5))) = (ВЫРАЗИТЬ(&ПомещениеНаименование КАК СТРОКА(5)))
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_ДПП.Ссылка,
	               |	ПР_ДПП.Ссылка.Дата,
	               |	ПР_ДПП.Ссылка.Номер,
	               |	ПР_ДПП.Помещение,
	               |	ПР_ДПП.ДатаПередачи,
	               |	ПР_ДПП.Ссылка.Контрагент
	               |ИЗ
	               |	Документ.ПР_ДПП КАК ПР_ДПП
	               |ГДЕ
	               |	ПР_ДПП.Помещение = &Помещение
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_ДоговорОтделки.Ссылка,
	               |	ПР_ДоговорОтделки.Дата,
	               |	ПР_ДоговорОтделки.Номер,
	               |	ПР_ДоговорОтделки.Помещение,
	               |	ПР_ДоговорОтделки.ДатаНачала,
	               |	ПР_ДоговорОтделки.Контрагент
	               |ИЗ
	               |	Документ.ПР_ДоговорОтделки КАК ПР_ДоговорОтделки
	               |ГДЕ
	               |	ПР_ДоговорОтделки.Помещение = &Помещение
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.Ссылка КАК Ссылка,
	               |	ВТ.Дата КАК Дата,
	               |	ВТ.Номер КАК Номер,
	               |	ВТ.Помещение КАК Помещение,
	               |	ВТ.ДатаНачала КАК ДатаНачала,
	               |	ВТ.Контрагент КАК Контрагент,
	               |	ВЫБОР
	               |		КОГДА ВТ.Ссылка.Проведен
	               |			ТОГДА 2
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА ВТ.Ссылка.ПометкаУдаления
	               |					ТОГДА 3
	               |				ИНАЧЕ 0
	               |			КОНЕЦ
	               |	КОНЕЦ КАК СостояниеДокумента
	               |ИЗ
	               |	ВТ КАК ВТ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Дата";
	Запрос.УстановитьПараметр("Помещение",ОбъектАренды);
	Запрос.УстановитьПараметр("ПомещениеНаименование",ОбъектАренды.Наименование);
	Рез = Запрос.Выполнить().Выгрузить();
	Для каждого стр Из Рез Цикл
		Док = Подробно.Добавить();
		Док.Дата = стр.Дата;
		Док.Ссылка = стр.Ссылка;
		Попытка
			Док.ПрограммаДоходности = стр.Ссылка.ПрограммаДоходности;  
		Исключение
		КонецПопытки;
		Док.НомерДоговора = стр.Номер;
		Док.ДатаДоговора = стр.ДатаНачала;
		Док.Контрагент = стр.Контрагент;
		Док.СостояниеДокумента = стр.СостояниеДокумента;
	КонецЦикла	
КонецПроцедуры

&НаСервере
Процедура КомплектПриИзмененииНаСервере()
	Компл = Комплект.ПолучитьОбъект();
	Для каждого стр Из Компл.Договора Цикл
		Док = ТабДокументы.Добавить();
		Док.ТипДокумента = стр.ТипДоговора;
		Док.Приоритет = стр.Приоритет;
		Док.Документ = НайтиДок(стр.ТипДоговора);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура КомплектПриИзменении(Элемент = Неопределено) 
	Если ЗначениеЗаполнено(Комплект) Тогда   
		ТабДокументы.Очистить(); 
		КомплектПриИзмененииНаСервере(); 
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСостояние(Док)
	Если Док.Проведен Тогда
		Возврат 2;
	ИначеЕсли Док.ПометкаУдаления Тогда
		Возврат 1;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

Функция НайтиДок(ТипДоговора) 
	Для каждого стр Из Подробно Цикл
		Если стр.Контрагент = Собственники И ТипЗнч(стр.Ссылка) = ТипДоговора.ТипЗначения.Типы()[0] И стр.Ссылка.Проведен И НЕ ТипЗнч(стр.Ссылка) = Тип("ДокументСсылка.ПР_ДПП") Тогда  
			Возврат стр.Ссылка;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция НайтиОснованиеДляЗАД()
	Для каждого стр Из ТабДокументы Цикл
		Если ТипЗнч(стр.Документ) = Тип("ДокументСсылка.ПР_АППЗастройщик") 
					ИЛИ ТипЗнч(стр.Документ) = Тип("ДокументСсылка.ПР_ДПП") Тогда
			Возврат стр.Документ;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

&НаСервере
Функция СоздатьДоговораНаСервере(ТипД)
	Док = Документы[Метаданные.НайтиПоТипу(ТипД.ТипЗначения.Типы()[0]).Имя].СоздатьДокумент();
	Если ТипЗнч(Док) = Тип("ДокументОбъект.ПР_ДоговорДолевогоУчастия") Тогда
		Док.Дата = ТекущаяДата();
		Док.Помещение = Помещение;
		Док.Записать(РежимЗаписиДокумента.Запись); 
		Возврат Док.Ссылка;
	КонецЕсли;
	Если ТипЗнч(Док) = Тип("ДокументОбъект.АР17_ЗаключениеАгентскогоДоговора") Тогда 
		ДокОснование = НайтиОСнованиеДляЗАД();
		Если НЕ ДокОснование = Неопределено  Тогда  
			Док.Заполнить(ДокОснование);
			Док.Дата = ТекущаяДата();
			Док.Записать(РежимЗаписиДокумента.Запись); 
			Возврат Док.Ссылка;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Док) = Тип("ДокументОбъект.ПР_ДоговорОснащения") Тогда
		Док.Дата = ТекущаяДата();
		Док.Помещение = Помещение;
		//Док.Записать(РежимЗаписиДокумента.Запись); 
		//Возврат Док.Ссылка;
	КонецЕсли;
	ТабДокументы.Сортировать("Приоритет");
	Для каждого табдок Из ТабДокументы Цикл
		Если табдок.Документ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Попытка
			Док.Заполнить(табдок.Документ); 
			Док.ДокументОСнование = табдок.Документ.Ссылка; 
		Исключение
		КонецПопытки;
		ДокК = Ложь;
		ДокО = Ложь;
		Попытка 
			ДокК = ЗначениеЗаполнено(Док.Контрагент);
		Исключение
		КонецПопытки;
		Попытка 
			ДокО = ЗначениеЗаполнено(Док.Организация);
		Исключение
		КонецПопытки;
		Если ДокК ИЛИ ДокО Тогда
			Док.Записать(РежимЗаписиДокумента.Запись); 
			Возврат Док.Ссылка;
		КонецЕсли;
	КонецЦикла;
	Если ТипЗнч(Док) = Тип("ДокументОбъект.АР17_ЗаключениеАгентскогоДоговора") Тогда
		Док.Дата = ТекущаяДата();
		Док.ИК = Помещение.Родитель.Родитель.Родитель;
		Док.Контрагент = Собственники;
		Стр = Док.ОбъектыАренды.Добавить();
		Стр.ОбъектАренды = Помещение;
		ЗаполнитьТЧ(Док,Стр.НомерСтроки,Стр.ОбъектАренды);
	КонецЕсли;	
	Док.Записать(РежимЗаписиДокумента.Запись); 
	Возврат Док.Ссылка;
КонецФункции

Процедура ЗаполнитьТЧ(Док,НомерСтроки,ОбъектАренды)
	
	Стр = Док.ОбъектыАренды[НомерСтроки-1];
	Если Стр.ОбъектАренды.МОП > 0 Тогда	
		Стр.ТипПомещения = "МОП";
	ИначеЕсли Стр.ОбъектАренды.АП > 0 Тогда
		Стр.ТипПомещения = "АП";
	ИначеЕсли Стр.ОбъектАренды.ТП > 0 Тогда
		Стр.ТипПомещения = "ТП";
	ИначеЕсли Стр.ОбъектАренды.ВП > 0 Тогда
		Стр.ТипПомещения = "ВП";
	КонецЕсли;
	// Расположение
	Стр.Расположение = СокрЛП(Стр.ОбъектАренды.Родитель.Родитель.Родитель) + ", " + СокрЛП(Стр.ОбъектАренды.Родитель.Родитель);
	Стр.Площадь = Стр.ОбъектАренды.ЗначениеХарактеристики;
	Стр.КлассПомещения = Стр.ОбъектАренды.КлассПомещения;
	
КонецПроцедуры	

&НаКлиенте
Процедура СоздатьДоговора(Команда)  
	//ТекДанные = Документы.те
	Для каждого стр из ТабДокументы Цикл
		Если стр.Создать и Не ЗначениеЗаполнено(стр.Документ) Тогда
			Док = СоздатьДоговораНаСервере(стр.ТипДокумента);  
			стр.Документ = Док;
			ПоказатьЗначение(,Док);
		КонецЕсли;
	КонецЦикла; 
	ЗаполнитьПодробно(Помещение);
	КомплектПриИзменении(Команда);
КонецПроцедуры

