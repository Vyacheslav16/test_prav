
&НаСервере
Процедура НайтиНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент КАК Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК КАК ИК,
	               |	МАКСИМУМ(КОНЕЦПЕРИОДА(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи, ДЕНЬ)) КАК ДатаПередачи,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ ЗАД
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |ГДЕ
	               |	(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент.Наименование ПОДОБНО &Наименование
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды.Наименование ПОДОБНО &Наименование
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды.ПомещениеНомерБТИ ПОДОБНО &Наименование)
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_ДоговорДолевогоУчастия.Ссылка.Контрагент,
	               |	ПР_ДоговорДолевогоУчастия.Помещение,
	               |	NULL,
	               |	КОНЕЦПЕРИОДА(ПР_ДоговорДолевогоУчастия.ДатаНачала, ДЕНЬ),
	               |	ПР_ДоговорДолевогоУчастия.Ссылка
	               |ИЗ
	               |	Документ.ПР_ДоговорДолевогоУчастия КАК ПР_ДоговорДолевогоУчастия
	               |ГДЕ
	               |	ПР_ДоговорДолевогоУчастия.Ссылка.Проведен
	               |	И (ПР_ДоговорДолевогоУчастия.Ссылка.Контрагент.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_ДоговорДолевогоУчастия.Помещение.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_ДоговорДолевогоУчастия.Помещение.ПомещениеНомерБТИ ПОДОБНО &Наименование)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПР_ДоговорДолевогоУчастия.Ссылка.Контрагент,
	               |	ПР_ДоговорДолевогоУчастия.Помещение,
	               |	ПР_ДоговорДолевогоУчастия.Ссылка,
	               |	КОНЕЦПЕРИОДА(ПР_ДоговорДолевогоУчастия.ДатаНачала, ДЕНЬ)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_ДПП.Ссылка.Контрагент,
	               |	ПР_ДПП.Помещение,
	               |	NULL,
	               |	КОНЕЦПЕРИОДА(ПР_ДПП.ДатаПередачи, ДЕНЬ),
	               |	ПР_ДПП.Ссылка
	               |ИЗ
	               |	Документ.ПР_ДПП КАК ПР_ДПП
	               |ГДЕ
	               |	ПР_ДПП.Ссылка.Проведен
	               |	И (ПР_ДПП.Ссылка.Контрагент.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_ДПП.Помещение.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_ДПП.Помещение.ПомещениеНомерБТИ ПОДОБНО &Наименование)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПР_ДПП.Ссылка.Контрагент,
	               |	ПР_ДПП.Помещение,
	               |	ПР_ДПП.Ссылка,
	               |	КОНЕЦПЕРИОДА(ПР_ДПП.ДатаПередачи, ДЕНЬ)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ПР_АППЗастройщик.Ссылка.Контрагент,
	               |	ПР_АППЗастройщик.Помещение,
	               |	NULL,
	               |	КОНЕЦПЕРИОДА(ПР_АППЗастройщик.ДатаПередачи, ДЕНЬ),
	               |	ПР_АППЗастройщик.Ссылка
	               |ИЗ
	               |	Документ.ПР_АППЗастройщик КАК ПР_АППЗастройщик
	               |ГДЕ
	               |	ПР_АППЗастройщик.Ссылка.Проведен
	               |	И (ПР_АППЗастройщик.Ссылка.Контрагент.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_АППЗастройщик.Помещение.Наименование ПОДОБНО &Наименование
	               |			ИЛИ ПР_АППЗастройщик.Помещение.ПомещениеНомерБТИ ПОДОБНО &Наименование)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПР_АППЗастройщик.Ссылка.Контрагент,
	               |	ПР_АППЗастройщик.Помещение,
	               |	ПР_АППЗастройщик.Ссылка,
	               |	КОНЕЦПЕРИОДА(ПР_АППЗастройщик.ДатаПередачи, ДЕНЬ)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент КАК Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды КАК ОбъектАренды,
	               |	МАКСИМУМ(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи) КАК ДатаПередачи
	               |ПОМЕСТИТЬ ЗАД1
	               |ИЗ
	               |	Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |ГДЕ
	               |	(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент.Наименование ПОДОБНО &Наименование
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды.Наименование ПОДОБНО &Наименование
	               |			ИЛИ АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды.ПомещениеНомерБТИ ПОДОБНО &Наименование)
	               |	И АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Проведен
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗАД.ОбъектАренды КАК ОбъектАренды,
	               |	МАКСИМУМ(ЗАД.ДатаПередачи) КАК ДатаПередачи
	               |ПОМЕСТИТЬ ЗАДДата
	               |ИЗ
	               |	ЗАД КАК ЗАД
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗАД.ОбъектАренды
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗАД.Контрагент КАК Контрагент,
	               |	ЗАД.ОбъектАренды КАК ОбъектАренды,
	               |	ЗАД.ДатаПередачи КАК ДатаПередачи,
	               |	ЗАД.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ ЗАДКонтрагент
	               |ИЗ
	               |	ЗАД КАК ЗАД
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗАДДата КАК ЗАДДата
	               |		ПО ЗАД.ОбъектАренды = ЗАДДата.ОбъектАренды
	               |			И ЗАД.ДатаПередачи = ЗАДДата.ДатаПередачи
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗАДКонтрагент.Контрагент КАК Контрагент,
	               |	ЕСТЬNULL(ЗАДКонтрагент.ОбъектАренды, АР_ОбъектыАренды.Ссылка) КАК ОбъектАренды,
	               |	ЕСТЬNULL(АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.ИК, АР_ОбъектыАренды.Родитель.Родитель.Родитель) КАК ИК,
	               |	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка КАК Ссылка
	               |ИЗ
	               |	ЗАДКонтрагент КАК ЗАДКонтрагент
	               |		ПОЛНОЕ СОЕДИНЕНИЕ Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	               |		ПО ЗАДКонтрагент.ОбъектАренды = АР_ОбъектыАренды.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ЗАД1 КАК ЗАД1
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
	               |			ПО ЗАД1.Контрагент = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка.Контрагент
	               |				И ЗАД1.ОбъектАренды = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ОбъектАренды
	               |				И ЗАД1.ДатаПередачи = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи
	               |		ПО ЗАДКонтрагент.Контрагент = ЗАД1.Контрагент
	               |			И ЗАДКонтрагент.ОбъектАренды = ЗАД1.ОбъектАренды
	               |ГДЕ
	               |	(АР_ОбъектыАренды.Ссылка.Наименование ПОДОБНО &Наименование
	               |			ИЛИ АР_ОбъектыАренды.Ссылка.ПомещениеНомерБТИ ПОДОБНО &Наименование
	               |			ИЛИ ЗАДКонтрагент.Контрагент.Наименование ПОДОБНО &Наименование)
	               |	И АР_ОбъектыАренды.ТипОбъекта = &ТипОбъекта";
	Запрос.УстановитьПараметр("Наименование","%" + СтрокаПоиска + "%"); 
	Запрос.УстановитьПараметр("ТипОбъекта",Справочники.АР_ТипыОбъектовАренды.Офис);
	Рез = Запрос.Выполнить().Выгрузить();
	Для каждого стр Из Рез Цикл
		СтрО = РезультатОтбора.Добавить(); 
		СтрО.ОбъектАренды = стр.ОбъектАренды;
		СтрО.Наименование = СокрЛП(стр.ОбъектАренды.Наименование) + " / ПИБ " + СокрЛП(стр.ОбъектАренды.ПомещениеНомерБТИ) + " / " + СокрЛП(стр.ИК.Наименование);
		СтрО.Собственник = стр.Контрагент;
		СтрО.ЗАД = стр.Ссылка;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура _Найти(Команда) 
	Если СокрЛП(СтрокаПоиска) = "" Тогда
		Сообщить("Не заданы параметры поиска!" );
		Возврат;
	КонецЕсли;   
	РезультатОтбора.Очистить();
	НайтиНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура Гоу()
	РезультатОтбора.Очистить();
	НайтиНаСервере();
КонецПроцедуры	

&НаКлиенте
Процедура РезультатОтбораПриАктивизацииСтроки(Элемент)
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекСтрока = Элемент.ТекущиеДанные; 
	Помещение = ТекСтрока.ОбъектАренды;
	Собственники = ТекСтрока.Собственник;
	ДоходнаяПрограмма =  ПолучитьПрограммуДоходности(ТекСтрока.ЗАД); 
	ПУД = ПолучитьПУД(ТекСтрока.Собственник,ТекСтрока.ОбъектАренды,ТекСтрока.ЗАД);
	Оснащение = ПолучитьОснащение(ТекСтрока.ЗАД);
	ЗаполнитьПодробно(ТекСтрока.ОбъектАренды);  
	КомплектПриИзменении(Элемент);
КонецПроцедуры  

Функция ПолучитьПУД(Собственник,ОбъектАренды,ЗАД)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(ПР_АППЗастройщик.Ссылка, НЕОПРЕДЕЛЕНО) КАК АПП
	               |ПОМЕСТИТЬ АППТ
	               |ИЗ
	               |	Документ.ПР_АППЗастройщик КАК ПР_АППЗастройщик
	               |ГДЕ
	               |	ПР_АППЗастройщик.Проведен
	               |	И ПР_АППЗастройщик.Помещение = &Помещение
	               |	И ПР_АППЗастройщик.Контрагент = &Контрагент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ПР_ДоговорДолевогоУчастия.Ссылка, НЕОПРЕДЕЛЕНО) КАК ДДУ
	               |ПОМЕСТИТЬ ДДУТ
	               |ИЗ
	               |	Документ.ПР_ДоговорДолевогоУчастия КАК ПР_ДоговорДолевогоУчастия
	               |ГДЕ
	               |	ПР_ДоговорДолевогоУчастия.Проведен
	               |	И ПР_ДоговорДолевогоУчастия.Помещение = &Помещение
	               |	И ПР_ДоговорДолевогоУчастия.Контрагент = &Контрагент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ПР_ДПП.Ссылка, НЕОПРЕДЕЛЕНО) КАК ДПП
	               |ПОМЕСТИТЬ ДППТ
	               |ИЗ
	               |	Документ.ПР_ДПП КАК ПР_ДПП
	               |ГДЕ
	               |	ПР_ДПП.Проведен
	               |	И ПР_ДПП.Помещение = &Помещение
	               |	И ПР_ДПП.Контрагент = &Контрагент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(АППТ.АПП, НЕОПРЕДЕЛЕНО) КАК АПП,
	               |	ЕСТЬNULL(ДДУТ.ДДУ, НЕОПРЕДЕЛЕНО) КАК ДДУ,
	               |	ЕСТЬNULL(ДППТ.ДПП, НЕОПРЕДЕЛЕНО) КАК ДПП
	               |ИЗ
	               |	АППТ КАК АППТ
	               |		ПОЛНОЕ СОЕДИНЕНИЕ ДДУТ КАК ДДУТ
	               |			ПОЛНОЕ СОЕДИНЕНИЕ ДППТ КАК ДППТ
	               |			ПО (ИСТИНА)
	               |		ПО (ИСТИНА)";
	Запрос.УстановитьПараметр("Помещение",ОбъектАренды);
	Запрос.УстановитьПараметр("Контрагент",Собственник);
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда
		Возврат ЗАД;
	ИначеЕсли НЕ Рез[0].ДПП = неопределено Тогда
		Возврат Рез[0].ДПП;
	ИначеЕсли НЕ Рез[0].АПП = неопределено Тогда
		Возврат Рез[0].АПП;
	ИначеЕсли НЕ Рез[0].ДДУ = неопределено Тогда
		Возврат Рез[0].ДДУ;
	Иначе 
		Возврат ЗАД;
	КонецЕсли;
КонецФункции

Функция ПолучитьПрограммуДоходности(ЗАД)
	Если ТипЗнч(ЗАД) = ТИП("ДокументСсылка.АР17_ЗаключениеАгентскогоДоговора") Тогда
		Возврат Строка(ЗАД.ПрограммаДоходности) + " Действует с " + Формат(ЗАД.ОбъектыАренды[0].ДатаПередачи,"ДФ=""дд ММММ гггг 'г.'""") 
					+ ?(ЗначениеЗаполнено(ЗАД.ОбъектыАренды[0].ДатаВозврата), " по " + Формат(ЗАД.ОбъектыАренды[0].ДатаВозврата,"ДФ=""дд ММММ гггг 'г.'"""),"") ;
	КонецЕсли
КонецФункции 

Функция ПолучитьОснащение(ЗАД)  
	Если ТипЗнч(ЗАД) = ТИП("ДокументСсылка.АР17_ЗаключениеАгентскогоДоговора") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	МАКСИМУМ(ПР_ДоговорОснащения.Дата) КАК Дата
		               |ПОМЕСТИТЬ ПоследнийДоговор
		               |ИЗ
		               |	Документ.ПР_ДоговорОснащения КАК ПР_ДоговорОснащения
		               |ГДЕ
		               |	ПР_ДоговорОснащения.АгентскийДоговор = &АгентскийДоговор
		               |	И ПР_ДоговорОснащения.Проведен
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ПР_ДоговорОснащения.Сумма КАК Сумма,
		               |	ПР_ДоговорОснащения.ТипОснащения КАК ТипОснащения,
		               |	ПР_ДоговорОснащения.ДатаОкончания КАК ДатаОкончания
		               |ИЗ
		               |	ПоследнийДоговор КАК ПоследнийДоговор
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПР_ДоговорОснащения КАК ПР_ДоговорОснащения
		               |		ПО ПоследнийДоговор.Дата = ПР_ДоговорОснащения.Дата
		               |ГДЕ
		               |	ПР_ДоговорОснащения.АгентскийДоговор = &АгентскийДоговор
		               |	И ПР_ДоговорОснащения.Проведен";
		Запрос.УстановитьПараметр("АгентскийДоговор",ЗАД);
		Рез = Запрос.Выполнить().Выгрузить();
		Если Рез.Количество() > 0 Тогда
			Возврат Строка(Рез[0].Сумма) + " " + Строка(Рез[0].ТипОснащения) + ?((Рез[0].ДатаОкончания = Дата(1,1,1)),"", " до " + Формат(Рез[0].ДатаОкончания,"ДФ=""дд ММММ гггг 'г.'"""));
		КонецЕсли; 
	КонецЕсли;
	Возврат 0;
КонецФункции         

