	Подробно.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПР_ДоговорОснащения.Ссылка КАК Ссылка,
	               |	ПР_ДоговорОснащения.Дата КАК Дата,
	               |	ПР_ДоговорОснащения.Номер КАК Номер,
