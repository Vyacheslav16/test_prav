Процедура КонтрагентПриИзменении(Элемент)
	
	Отбор = Новый Структура();
	Отбор.Вставить("ПечатнаяФорма","Реестр документов");
	Строки = ПечатныеФормы.НайтиСтроки(Отбор);
	Если Строки.Количество() = 0 Тогда
		Стр = ПечатныеФормы.Добавить();
		Стр.ПечатнаяФорма = "Реестр документов";
		Стр.Количество = 1;
		Стр.Печать = Истина;
	КонецЕсли;
	
