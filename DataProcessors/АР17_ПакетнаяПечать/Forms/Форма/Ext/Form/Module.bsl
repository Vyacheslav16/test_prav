	ЗапросНПФ = Новый Запрос;
	//ЗапросНПФ.Текст = "ВЫБРАТЬ
	//                  |	АР_НастройкаПечатнойФормыСрезПоследних.УполномоченноеЛицо,
	//                  |	АР_НастройкаПечатнойФормыСрезПоследних.Доверенность
	//                  |ИЗ
	//                  |	РегистрСведений.АР_НастройкаПечатнойФормы.СрезПоследних(
	//                  |			&Период,
	//                  |			Организация = &Организация
	//                  |				И ЗаКогоПодписывает = &ЗаКогоПодписывает
	//                  |				И ОбъектыАренды в иерархии (&ОбъектАренды)) КАК АР_НастройкаПечатнойФормыСрезПоследних";
	
	ЗапросНПФ.Текст =	
		"ВЫБРАТЬ
		|	АР_ОбъектыАренды.Ссылка
		|ПОМЕСТИТЬ ВТ_ГруппыОбъекты
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_ОбъектыАренды.Родитель
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_ОбъектыАренды.Родитель.Родитель
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_ОбъектыАренды.Родитель.Родитель.Родитель
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_ОбъектыАренды.Родитель.Родитель.Родитель.Родитель
		|ИЗ
		|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
		|ГДЕ
		|	АР_ОбъектыАренды.Ссылка = &ОбъектАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АР_НастройкаПечатнойФормыСрезПоследних.УполномоченноеЛицо,
		|	АР_НастройкаПечатнойФормыСрезПоследних.Доверенность,
		|	АР_НастройкаПечатнойФормыСрезПоследних.РС,
		|	АР_НастройкаПечатнойФормыСрезПоследних.ОбъектыАренды,
		|	АР_НастройкаПечатнойФормыСрезПоследних.Период
		|ИЗ
		|	РегистрСведений.АР_НастройкаПечатнойФормы.СрезПоследних(
		|			&Период,
		|			Организация = &Организация
		|				И ЗаКогоПодписывает = &ЗаКогоПодписывает) КАК АР_НастройкаПечатнойФормыСрезПоследних
		|ГДЕ
		|	АР_НастройкаПечатнойФормыСрезПоследних.ОбъектыАренды В
		|			(ВЫБРАТЬ
		|				ВТ_ГруппыОбъекты.Ссылка
		|			ИЗ
		|				ВТ_ГруппыОбъекты)";	

					  
	ЗапросНПФ.УстановитьПараметр("Период", Шапка.Дата);
	ЗапросНПФ.УстановитьПараметр("Организация", Шапка.Организация);
	ЗапросНПФ.УстановитьПараметр("ЗаКогоПодписывает", ЗаКогоПодписывает);
	ЗапросНПФ.УстановитьПараметр("ОбъектАренды", ПолучитьОбъектАренды(Шапка.ДоговорКонтрагента));
	ВыборкаНПФ = ЗапросНПФ.Выполнить().Выбрать();
	ВыборкаНПФ.Следующий();
	Возврат СокрЛП(ВыборкаНПФ.УполномоченноеЛицо) +?(СокрЛП(ВыборкаНПФ.Доверенность)<>""," (" +ВыборкаНПФ.Доверенность + ")","");

