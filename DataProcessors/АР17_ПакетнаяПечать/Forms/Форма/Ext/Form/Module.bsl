&НаСервере
Процедура ПолучитьТабДокументов()
	
		ЗапросСчет =
		"ВЫБРАТЬ
		|	АР_СчетНаАрендуСостав.Ссылка КАК Документ,
		|	АР_СчетНаАрендуСостав.Ссылка.Контрагент КАК Контрагент,
		|	АР_СчетНаАрендуСостав.Ссылка.ДоговорКонтрагента КАК Договор,
		|	АР_СчетНаАрендуСостав.Ссылка.ВалютаДокумента КАК Валюта,
		|	АР_СчетНаАрендуСостав.Ссылка.СуммаДокумента КАК Сумма,
		|	АР_СчетНаАрендуСостав.Ссылка.Организация КАК Организация
		|ИЗ
		|	Документ.АР17_СчетНаАренду.Состав КАК АР_СчетНаАрендуСостав
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		|		ПО АР_СчетНаАрендуСостав.Ссылка.ДоговорКонтрагента = АР_ЗаключениеДоговораАренды.ДоговорКонтрагента,
		|	Справочник.АР_ГруппыУслуг.Услуги КАК АР_ГруппыУслугУслуги
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ОрганизацияВыбрана
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.Организация = &Организация
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ИмущественныйКомплексВыбран
		|				ТОГДА АР_ЗаключениеДоговораАренды.ИК = &ИмущественныйКомплекс
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &КонтрагентВыбран
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.Контрагент = &Контрагент
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ГруппаУслугВыбрана
		|				ТОГДА АР_СчетНаАрендуСостав.ГруппаУслуг = &ГруппаУслуг
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И АР_СчетНаАрендуСостав.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И ВЫБОР
		|			КОГДА &НачПериодаВыбрано
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.Дата >= &НачПериода
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &КонПериодаВыбрано
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.Дата <= &КонПериода
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ПериодСЧетВыбран
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.НачалоПериода >= &НачПериодаСчет
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ПериодСЧетВыбран
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.ОкончаниеПериода <= &КонПериодаСчет
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &НачалоНачисленийВыбран
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.НачалоПериода >= &НачПериодаНачисления
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &КонецНачисленийВыбран
		|				ТОГДА АР_СчетНаАрендуСостав.Ссылка.ОкончаниеПериода <= &КонПериодаНачисления
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &НоменклатураВыбрана
		|				ТОГДА АР_СчетНаАрендуСостав.Номенклатура В ИЕРАРХИИ (&Номенклатура)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &УточнениеНоменклатуры = ""Постоянная""
		|				ТОГДА АР_СчетНаАрендуСостав.Номенклатура.АР_ПостояннаяЧастьОплаты = ИСТИНА
		|			КОГДА &УточнениеНоменклатуры = ""Переменная""
		|				ТОГДА АР_СчетНаАрендуСостав.Номенклатура.АР_ПостояннаяЧастьОплаты = ЛОЖЬ
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	АР_СчетНаАрендуСостав.Ссылка,
		|	АР_СчетНаАрендуСостав.Ссылка.Контрагент,
		|	АР_СчетНаАрендуСостав.Ссылка.ДоговорКонтрагента,
		|	АР_СчетНаАрендуСостав.Ссылка.ВалютаДокумента,
		|	АР_СчетНаАрендуСостав.Ссылка.СуммаДокумента,
		|	АР_СчетНаАрендуСостав.Ссылка.Организация";
		//|	И АР_СчетНаАрендуСостав.Ссылка.ПериодНачисления = &ПериодНачисленияСчет
		
	ЗапросАкт =
	      "ВЫБРАТЬ
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка КАК Документ,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.Контрагент,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.ДоговорКонтрагента КАК Договор,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.ВалютаДокумента КАК Валюта,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.СуммаДокумента КАК Сумма,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.Организация
	      |ИЗ
	      |	Документ.АР17_НачислениеАренднойПлаты.Состав КАК АР_НачислениеАренднойПлатыСостав
	      |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
	      |		ПО АР_НачислениеАренднойПлатыСостав.Ссылка.ДоговорКонтрагента = АР_ЗаключениеДоговораАренды.ДоговорКонтрагента,
	      |	Справочник.АР_ГруппыУслуг.Услуги КАК АР_ГруппыУслугУслуги
	      |ГДЕ
	      |	ВЫБОР
	      |			КОГДА &ОрганизацияВыбрана
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.Организация = &Организация
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &КонтрагентВыбран
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.Контрагент = &Контрагент
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &ИмущественныйКомплексВыбран
	      |				ТОГДА АР_ЗаключениеДоговораАренды.ИК = &ИмущественныйКомплекс
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &ГруппаУслугВыбрана
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.ГруппаУслуг = &ГруппаУслуг
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И АР_НачислениеАренднойПлатыСостав.Ссылка.Проведен = ИСТИНА
	      |	И АР_НачислениеАренднойПлатыСостав.Ссылка.ПометкаУдаления = ЛОЖЬ
	      |	И ВЫБОР
	      |			КОГДА &НачПериодаВыбрано
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.Дата >= &НачПериода
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &КонПериодаВыбрано
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.Дата <= &КонПериода
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &ПериодАктВыбран
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.НачалоПериода >= &НачПериодаАкт
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &ПериодАктВыбран
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.ОкончаниеПериода <= &КонПериодаАкт
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &НачалоНачисленийВыбран
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.НачалоПериода >= &НачПериодаНачисления
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &КонецНачисленийВыбран
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Ссылка.ОкончаниеПериода <= &КонПериодаНачисления
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &НоменклатураВыбрана
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Номенклатура В ИЕРАРХИИ (&Номенклатура)
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &УточнениеНоменклатуры = ""Постоянная""
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Номенклатура.АР_ПостояннаяЧастьОплаты = ИСТИНА
	      |			КОГДА &УточнениеНоменклатуры = ""Переменная""
	      |				ТОГДА АР_НачислениеАренднойПлатыСостав.Номенклатура.АР_ПостояннаяЧастьОплаты = ЛОЖЬ
	      |			ИНАЧЕ ИСТИНА
	      |		КОНЕЦ
	      |
	      |СГРУППИРОВАТЬ ПО
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.Контрагент,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.ДоговорКонтрагента,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.ВалютаДокумента,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.СуммаДокумента,
	      |	АР_НачислениеАренднойПлатыСостав.Ссылка.Организация";
		
	Запрос = Новый Запрос;	
	Если ВидДокумента = "Счета" Тогда
		Запрос.Текст = ЗапросСчет;			
		//Запрос.УстановитьПараметр("ПериодНачисленияСчет",ТекПериод);
	ИначеЕсли ВидДокумента = "Акты" Тогда
		Запрос.Текст = ЗапросАкт;
	//	Запрос.УстановитьПараметр("ПериодНачисления",ТекПериод);
	ИначеЕсли ВидДокумента = "СчетаАкты" Тогда	
		Запрос.Текст = ЗапросСчет+Символы.ПС+"ОБЪЕДИНИТЬ ВСЕ"+Символы.ПС+ЗапросАкт;
		//Запрос.УстановитьПараметр("ПериодНачисленияСчет",ТекПериодСчет);
		//Запрос.УстановитьПараметр("ПериодНачисления",ТекПериод);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачПериодаВыбрано",ЗначениеЗаполнено(НачПериода));
	Запрос.УстановитьПараметр("НачПериода",НачПериода);
	Запрос.УстановитьПараметр("КонПериодаВыбрано",ЗначениеЗаполнено(КонПериода));
	Запрос.УстановитьПараметр("КонПериода",КонПериода);
	
	Запрос.УстановитьПараметр("ПериодСЧетВыбран",ЗначениеЗаполнено(Объект.ТекПериодСчет));// Изменения NAI Becar Матюхин Н.О. № 97249 от 30.03.2016 15:09
	Запрос.УстановитьПараметр("НачПериодаСчет",НачалоМесяца(Объект.ТекПериодСчет));
	Запрос.УстановитьПараметр("КонПериодаСчет",КонецМесяца(Объект.ТекПериодСчет));
	Запрос.УстановитьПараметр("НачПериодаАкт",НачалоМесяца(Объект.ТекПериод));
	Запрос.УстановитьПараметр("КонПериодаАкт",КонецМесяца(Объект.ТекПериод));
	
	Запрос.УстановитьПараметр("НачалоНачисленийВыбран",ЗначениеЗаполнено(НачПериодаНачисления));// Изменения NAI Becar Матюхин Н.О. № 97249 от 30.03.2016 15:09
	Запрос.УстановитьПараметр("КонецНачисленийВыбран",ЗначениеЗаполнено(КонПериодаНачисления));// Изменения NAI Becar Матюхин Н.О. № 97249 от 30.03.2016 15:09
	Запрос.УстановитьПараметр("НачПериодаНачисления",НачалоДня(НачПериодаНачисления));
	Запрос.УстановитьПараметр("КонПериодаНачисления",КонецДня(КонПериодаНачисления));
	
	Запрос.УстановитьПараметр("УточнениеНоменклатуры",УточнениеНоменклатуры); // Начало изменений NAI Becar Матюхин Н.О. № 105406 от 06.04.2016 16:23
	
	Запрос.УстановитьПараметр("ПериодАктВыбран",ЗначениеЗаполнено(Объект.ТекПериод)); 	// Изменения NAI Becar Матюхин Н.О. № 97249 от 30.03.2016 15:11
	Запрос.УстановитьПараметр("НачПериодаАкт",НачалоМесяца(Объект.ТекПериод));
	Запрос.УстановитьПараметр("КонПериодаАкт",КонецМесяца(Объект.ТекПериод));
	
	Запрос.УстановитьПараметр("ОрганизацияВыбрана",ЗначениеЗаполнено(Объект.Организация));
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
