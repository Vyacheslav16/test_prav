&НаКлиенте
Процедура ПакетнаяПечать(Команда)
	
	// проверим есть ли документы для печати...
	//Если ТабДокументов.Итог("Печатать") = 0 Тогда
	//	Предупреждение("Выберите документы для печати!",,"Предупреждение"); 
	//	Возврат;
	//КонецЕсли; 
	
	//+Конюшок СН 101019
	ПодготовкаДанныхСОМ();	
	//-Конюшок СН 101019

	Если ВидДокумента = "Счета" Тогда
	
		// подготовим табличные документы для каждой формы...
		СоответствиеТабДоков = Новый Соответствие;
		Для каждого СтрокаТЧ Из ПечатныеФормы Цикл
			СоответствиеТабДоков.Вставить(СтрокаТЧ,Новый ТабличныйДокумент);
		КонецЦикла; 
		
		// перебор строк...
		ВсегоДок = ТабДокументов.Количество();
		Ном = 0;
		Для Каждого Стр Из ТабДокументов Цикл
			Ном = Ном + 1;
			Процент = Цел(Ном/ВсегоДок*100); 
			Состояние("Формирование печатных форм " + Процент + "%",Процент); 
			Если Не Стр.Печатать Тогда
				Продолжить;
			КонецЕсли;
			
			МассивОбъект = новый массив(1);    
			МассивОбъект.Добавить(Стр.Документ);
			Для Каждого ПечФормы Из ПечатныеФормы Цикл
				Если ПечФормы.ПечатнаяФорма = "Счет" и ПечФормы.Печать = Истина 
					и ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_СчетНаАренду")
					Тогда
					Количество = ПечФормы.Количество;
					Пока Количество > 0 Цикл
						МассивОбъект = новый массив(1);    
						МассивОбъект.Добавить(Стр.Документ);
						МассивОбъект.Удалить(0);
						Если Объект.ПечатьБезЕдИзм Тогда // + NAI Becar Конюшок С.Н. от 08.02.2017 17:50 
							УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_СчетНаАренду","СчетСводныйБезЕдИзм",МассивОбъект, Неопределено); 
						Иначе
							УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_СчетНаАренду","СчетСводный",МассивОбъект, Неопределено);
						КонецЕсли;
						Количество = Количество-1;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;	
		КонецЦикла;
		
	ИначеЕсли ВидДокумента = "Акты" Тогда
		// подготовим табличные документы для каждой формы...
		СоответствиеТабДоков = Новый Соответствие;
		Для каждого СтрокаТЧ Из ПечатныеФормы Цикл
			СоответствиеТабДоков.Вставить(СтрокаТЧ,Новый ТабличныйДокумент);
		КонецЦикла; 
		
		// Начало изменений NAI Becar Матюхин Н.О. № 93484 от 03.02.2016 16:07
		ПараметрПечатиКодаДокумента = "";
		Если Объект.ТекПериод < Дата('20160101') И Вопрос("Распечатать акты 2015 года с номером начисления?",РежимДиалогаВопрос.ДаНет,10) = КодВозвратаДиалога.Да Тогда
			ПараметрПечатиКодаДокумента = "ПечатьКодаНачисления";
		КонецЕсли;
		// Конец изменений NAI Becar Матюхин Н.О. № 93484 от 03.02.2016 16:07
		
		// перебор строк...
		ВсегоДок = ТабДокументов.Количество();
		Ном = 0;
		Для Каждого Стр Из ТабДокументов Цикл
			Ном = Ном + 1;
			Процент = Цел(Ном/ВсегоДок*100); 
			Состояние("Формирование печатных форм " + Процент + "%",Процент); 
			Если Не Стр.Печатать Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ПечФормы Из ПечатныеФормы Цикл
				Если ПечФормы.ПечатнаяФорма = "Акт (печати+подписи)" и ПечФормы.Печать = Истина 
					и ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты")
					Тогда
					Количество = ПечФормы.Количество;
					Пока Количество > 0 Цикл
						МассивОбъект = новый массив(1);    
						МассивОбъект.Добавить(Стр.Документ);
						МассивОбъект.Удалить(0);
						МассивОбъект.Добавить(ПараметрПечатиКодаДокумента);  // Начало изменений NAI Becar Матюхин Н.О. № 93484 от 03.02.2016 16:07
						//УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.РеализацияТоваровУслуг","Акт",МассивОбъект, Неопределено);
						УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_НачислениеАренднойПлаты","Акт",МассивОбъект, Неопределено);
						Количество = Количество-1;
					КонецЦикла;	
				ИначеЕсли ПечФормы.ПечатнаяФорма = "Акт (штрих-код)" и ПечФормы.Печать = Истина 
					и ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты")
					Тогда
					Количество = ПечФормы.Количество;
					Пока Количество > 0 Цикл
						МассивОбъект = новый массив(1);    
						МассивОбъект.Добавить(Стр.Документ);
						МассивОбъект.Удалить(0);
						МассивОбъект.Добавить(ПараметрПечатиКодаДокумента);  // Начало изменений NAI Becar Матюхин Н.О. № 93484 от 03.02.2016 16:07
						//УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.РеализацияТоваровУслуг","Акт",МассивОбъект, Неопределено);
						//УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_НачислениеАренднойПлаты","АктШК",МассивОбъект, Неопределено);
						Если Объект.ПечатьБезЕдИзм Тогда // + NAI Becar Конюшок С.Н. от 08.02.2017 17:07 
							УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_НачислениеАренднойПлаты","АктШКБезЕдИзм",МассивОбъект, Неопределено);
						Иначе
							УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.АР17_НачислениеАренднойПлаты","АктШК",МассивОбъект, Неопределено);
						КонецЕсли;
						Количество = Количество-1;
					КонецЦикла;	
				ИначеЕсли ПечФормы.ПечатнаяФорма = "Сч/ф" и ПечФормы.Печать = Истина Тогда
					ПараметрыПечати = Новый Структура;
					ПараметрыПечати.Вставить("СчетФактураСводный",Неопределено);
					ПараметрыПечати.Вставить("Подписанты",Истина);
					Количество = ПечФормы.Количество;
					ОбъектыПечати = Новый СписокЗначений;
					Пока Количество > 0 Цикл
						СФ = НайтиСФ(Стр.Документ);
						Для Каждого СтрокаСФ Из СФ Цикл
							МассивОбъект = новый массив(1);
							МассивОбъект.Добавить(СтрокаСФ);
							МассивОбъект.Удалить(0);
							ТабДок = ПечатьСчетовФактур1137(МассивОбъект, ОбъектыПечати, ТекстЗапросаПечатьСчетовФактур(), ПараметрыПечати, Объект.ПечатьБезЕдИзм);
							//УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.СчетФактураВыданный","СчетФактура",МассивОбъект, Неопределено);
							//УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.СчетФактураВыданный","СчетФактура1137",МассивОбъект, ПараметрыПечати);
							ТабДок.Напечатать();
							//ТабДок.Показать();
