Функция НапечататьРеестр(ТабДок)
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб			= Истина;
	ТабДок.ИмяПараметровПечати	= "Реестр";
	Макет = ПолучитьМакетДок();
	//Макет = Обработки.АР17_ПакетнаяПечать.ПолучитьМакет("Док");

	Область = Макет.ПолучитьОбласть("Шапка");
	ТабДок.Вывести(Область);
	
	Сч = 0;	
	Для Каждого Стр из ТабДокументов Цикл
		Если Не Стр.Печатать Тогда
			Продолжить;
		КонецЕсли;
		
		Сч = Сч+1;
		Область = Макет.ПолучитьОбласть("Ссылка");
		Если ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_СчетНаАренду") Тогда
			Ссылка = "Счет №" + ВыделитьНомер(СокрЛП(Стр.Документ.Номер)) + " от " + Формат(Стр.Документ.Дата, "ДФ=дд.ММ.гггг");
			Область.Параметры.Ссылка = Ссылка;
			Область.Параметры.Контрагент = Стр.Документ.Контрагент;
			Область.Параметры.Период = Формат(Стр.Документ.НачалоПериода,"ДФ=ММММгггг");
			Область.Параметры.Сч = Сч;
			
			Отбор = Новый Структура();
			Отбор.Вставить("ПечатнаяФорма","Счет");
			НайденныеСтроки = ПечатныеФормы.НайтиСтроки(Отбор);
			Если НайденныеСтроки.Количество() > 0 Тогда 
				Область.Параметры.Кол = НайденныеСтроки[0].Количество;
			КонецЕсли;
			ТабДок.Вывести(Область);
		ИначеЕсли ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			Ссылка = АР_РаботаСоШтрихКодами.ПолучитьРегистратор(Стр.Документ);
			Если НайтиПодчиненнуюРеализацию(Стр.Документ) <> Неопределено Тогда
				Реализация = НайтиПодчиненнуюРеализацию(Стр.Документ);
				Область.Параметры.Ссылка = "Акт №" + ВыделитьНомер(Реализация.Номер) + " от " + Формат(Реализация.Дата,"ДЛФ=Д");
			Иначе
				Область.Параметры.Ссылка = Ссылка;
			КонецЕсли;	
			
			
			Область.Параметры.Контрагент = Стр.Документ.Контрагент;
			Область.Параметры.Период = Формат(Стр.Документ.НачалоПериода,"ДФ=ММММгггг");
			Область.Параметры.Сч = Сч;
			
			Отбор = Новый Структура();
			Отбор.Вставить("ПечатнаяФорма","Акт (штрих-код)");
			НайденныеСтроки = ПечатныеФормы.НайтиСтроки(Отбор);
			Если НайденныеСтроки.Количество() > 0 Тогда
				Область.Параметры.Кол = НайденныеСтроки[0].Количество;
			КонецЕсли;	
			ТабДок.Вывести(Область);
			
			СФ = НайтиСФ(Стр.Документ);
			Для Каждого СтрокаСФ Из СФ Цикл
				//Область.Параметры.Ссылка = АР_РаботаСоШтрихКодами.ПолучитьРегистратор(СтрокаСФ.Ссылка);
