&НаСервере
Функция ПолучитьТЗЛССОМ(ИБСом)
	
	ТЗПоиска = ИБСом.NewObject("ТаблицаЗначений");
	ТЗПоиска.Колонки.Добавить("НаимДог", ИБСом.NewObject("ОписаниеТипов","Строка"));
	ТЗПоиска.Колонки.Добавить("ГуидАр", ИБСом.NewObject("ОписаниеТипов","Строка"));
	
	Для Каждого Стр Из ТабДокументов Цикл
		Если Стр.Печатать
			И ЗначениеЗаполнено(Стр.Документ)
			И ТипЗнч(Стр.Документ) = Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			НСтр = ТЗПоиска.Добавить();
			НСтр.НаимДог = Стр.Документ.ДоговорКонтрагента.Наименование;
			НСтр.ГуидАр = Строка(Стр.Документ.УникальныйИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
	Запрос = ИБСом.NewObject("Запрос");
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТЗДогПоиска.НаимДог КАК НаимДог,
	|	ТЗДогПоиска.ГуидАр КАК ГуидАр
	|ПОМЕСТИТЬ ДоговорыПоиска
	|ИЗ
	|	&ТЗДогПоиска КАК ТЗДогПоиска
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка КАК ДогСС,
	|	ДоговорыПоиска.НаимДог КАК НаимДогАр,
	|	ДоговорыПоиска.ГуидАр КАК ГуидАр
	|ПОМЕСТИТЬ ДоговорыЛок
	|ИЗ
	|	ДоговорыПоиска КАК ДоговорыПоиска
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Выразить(ДоговорыПоиска.НаимДог Как Строка(150)) = ДоговорыКонтрагентов.Наименование
	|			И (НЕ ДоговорыКонтрагентов.ПометкаУдаления)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних.ЛицевойСчет КАК ЛицевойСчет,
	|	КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних.Договор КАК Договор,
	|	КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних.Организация КАК Организация,
	|	ДоговорыЛок.НаимДогАр КАК НаимДогАр,
	|	ДоговорыЛок.ГуидАр КАК ГуидАр
	|ИЗ
	|	ДоговорыЛок КАК ДоговорыЛок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УПЖКХ_СведенияДляВзаиморасчетовПоЛС.СрезПоследних(&Дата, ) КАК КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних
	|		ПО ДоговорыЛок.ДогСС = КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних.Договор
	|       И Не КВП_ОсновнойДоговорЛицевогоСчетаСрезПоследних.ЛицевойСчет.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ТЗДогПоиска", ТЗПоиска);
	Запрос.УстановитьПараметр("Дата", КонПериодаНачисления);
	
	РЗ = Запрос.Выполнить().Выгрузить();
	
	Возврат РЗ;	
	
КонецФункции

