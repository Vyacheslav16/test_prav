&НаСервере
Процедура ВывестиКвитанцию(ИтогоТабДок, Документ, Количество)
	
	МКв = Квитации.НайтиСтроки(Новый Структура("Документ", Документ));
	
	Для Каждого СтрКв Из МКв Цикл
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(СтрКв.ПутьККвитанции);
		Для н = 1 По Количество Цикл
			ВывестиТабДок(ИтогоТабДок,ТабДок);
		КонецЦикла;
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Функция НайтиСФТСЖ(Документ)
	
	МСФ = Новый Массив;
	
	Если ТипЗнч(Документ) <> Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
		Возврат МСФ;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураВыданный.Ссылка КАК СФ
		|ПОМЕСТИТЬ ВТСФВсе
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактураВыданный
		|ГДЕ
		|	СчетФактураВыданный.Дата >= &ДатаН
		|	И СчетФактураВыданный.Дата <= &ДатаК
		|	И СчетФактураВыданный.ДоговорКонтрагента = &ДоговорКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСФВсе.СФ КАК СФ
		|ИЗ
		|	ВТСФВсе КАК ВТСФВсе
		|ГДЕ
		|	ПОДСТРОКА(ВТСФВсе.СФ.Комментарий, 0, 17) = ""Номер из базы ТСЖ""";
	
	Запрос.УстановитьПараметр("ДатаК", КонецДня(КонецМесяца(Документ.Дата)));
	Запрос.УстановитьПараметр("ДатаН", НачалоМесяца(Документ.Дата));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Документ.ДоговорКонтрагента);

	РЗ = Запрос.Выполнить().Выбрать();
	
	Пока РЗ.Следующий() Цикл
		МСФ.Добавить(РЗ.СФ);
	КонецЦикла;
	
	Возврат МСФ;
	
КонецФункции

