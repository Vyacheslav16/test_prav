Функция ПросмотрДок(Вид,МассивОбъект,ПараметрыПечати = Неопределено)
	ОбъектыПечати = Новый СписокЗначений;
	Если Вид = "Счет" Тогда
		ТабДок = Документы.АР17_СчетНаАренду.ПечатьСчета(МассивОбъект,ОбъектыПечати,Истина,Объект.ПечатьБезЕдИзм,Объект.ЕстьПрефикс);
	ИначеЕсли Вид = "Акт (печати+подписи)" Тогда
		ТабДок = Документы.АР17_НачислениеАренднойПлаты.ПечатьАкта(МассивОбъект,ОбъектыПечати,Истина,);
	ИначеЕсли Вид = "Акт (штрих-код)" Тогда
		ТабДок = Документы.АР17_НачислениеАренднойПлаты.ПечатьАктаШК(МассивОбъект, ОбъектыПечати, Истина,,Объект.ПечатьБезЕдИзм)
	ИначеЕсли Вид = "Сч/ф" Тогда
		ТабДок = ПечатьСчетовФактур1137(МассивОбъект, ОбъектыПечати, ТекстЗапросаПечатьСчетовФактур(), ПараметрыПечати, Объект.ПечатьБезЕдИзм);
	ИначеЕсли Вид = "УПД" Тогда
		ТабДок = ПечатьУПД(МассивОбъект,, ОбъектыПечати, ПараметрыПечати, Объект.ПечатьБезЕдИзм);
	КонецЕсли;	
	Возврат ТабДок;
	
