&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.ВидДокумента.СписокВыбора.Добавить("Счета","Счета");
	Элементы.ВидДокумента.СписокВыбора.Добавить("Акты","Акты");
	Элементы.ВидДокумента.СписокВыбора.Добавить("СчетаАкты","Счета и Акты"); 
	 
	ВидДокумента = Элементы.ВидДокумента.СписокВыбора[0];
	
	УточнениеНоменклатуры = "ПостПерем"; // Начало изменений NAI Becar Матюхин Н.О. № 105406 от 06.04.2016 16:24
	
	НачПериодаНачисления = НачалоМесяца(Объект.ТекПериод);//НачалоМесяца(ТекущаяДата());
	КонПериодаНачисления = КонецМесяца(Объект.ТекПериод);//КонецМесяца(ТекущаяДата());
	
	ЗаполнитьПечатныеФормы();
	
КонецПроцедуры

