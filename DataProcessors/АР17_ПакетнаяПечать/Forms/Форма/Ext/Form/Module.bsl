&НаСервере
Процедура ПодготовкаДанныхСОМ()
	
	СтрСФКвитанция = ПечатныеФормы.НайтиСтроки(Новый Структура("ПечатнаяФорма", "Сч/ф + Квитанция (Сколково)"));
	Если СтрСФКвитанция.Количество() = 0 Тогда
		Возврат;
	ИначеЕсли Не СтрСФКвитанция[0].Печать Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИБСом = УстановитьСоединениеСОМ();
	
	ТЗЛССОМ = ПолучитьТЗЛССОМ(ИБСом);
	
	Для Каждого Стр Из ТабДокументов Цикл
		
		Если ТипЗнч(Стр.Документ) <> Тип("ДокументСсылка.АР17_НачислениеАренднойПлаты") Тогда
			Продолжить;
		КонецЕсли;
				
		СФ = НайтиСФТСЖ(Стр.Документ);
		Если СФ.Количество() > 0 Тогда
			СтруктПоиска = ИБСом.NewObject("Структура");
			СтруктПоиска.Вставить("ГуидАр", Строка(Стр.Документ.УникальныйИдентификатор()));
			МЛС = ТЗЛССОМ.НайтиСтроки(СтруктПоиска); //найти строки тк есть эксклюзивные дог-ры с неск лс
		КонецЕсли; 
		
		Для Каждого СтрокаСФ Из СФ Цикл
			Для Каждого СтрЛС Из МЛС Цикл
				
				Если СтрЛС.ЛицевойСчет = Null Тогда
					Сообщить("Внимание! Не обнаружен лицевой счет для договора " + СтрЛС.НаимДогАр);
					Продолжить;
				КонецЕсли;
				
				ПустаяТЗУслуг = ПолучитьПустуюТаблицуУслуг(ИБСом);
				
				СпЗданий = ИБСом.NewObject("СписокЗначений");
				СпЗданий.Добавить(СтрЛС.ЛицевойСчет.Адрес.Владелец);
				
				СпЛС = ИБСом.NewObject("СписокЗначений"); 
				СпЛС.Добавить(СтрЛС.ЛицевойСчет);
				
				СпПом = ИБСом.NewObject("СписокЗначений"); 
				СпПом.Добавить(СтрЛС.ЛицевойСчет.Адрес);
				
				ПараметрыОтчета = ИБСом.NewObject("Структура");
				ПараметрыОтчета.Вставить("ВариантСортировки", "");
				ПараметрыОтчета.Вставить("ВедетсяРаздельныйУчетПоУслугамКапремонта", Ложь);
				ПараметрыОтчета.Вставить("ВидЗапроса", "форма_03");
				ПараметрыОтчета.Вставить("ВключатьКассовыйСбор", Ложь);
				ПараметрыОтчета.Вставить("ВключениеНачальнойЗадолженности", "ВключатьНачСальдо");
				ПараметрыОтчета.Вставить("ВыборУслуг", "");
				ПараметрыОтчета.Вставить("ВыбранныеУслуги", ПустаяТЗУслуг); //не соотв
				ПараметрыОтчета.Вставить("ВыводитьНачальноеСальдо", Ложь);
				ПараметрыОтчета.Вставить("ВыводитьОтрицательнуюСуммуКОплате", Ложь);
				ПараметрыОтчета.Вставить("ВыводитьПоОднойКвитанции", Ложь);
				ПараметрыОтчета.Вставить("ИсполнительРасчетов", ИБСом.Справочники.Контрагенты.ПустаяСсылка());
				ПараметрыОтчета.Вставить("КассовыйСборБанка", 3);
				ПараметрыОтчета.Вставить("КомпонентаQRКодаПодключена", Истина);
				ПараметрыОтчета.Вставить("КомпонентаШКПодключена", Истина);
				ПараметрыОтчета.Вставить("НеПечататьНулевыеКвитанции", Ложь);
				ПараметрыОтчета.Вставить("ОбъектОтчета", СтрЛС.ЛицевойСчет);
				ПараметрыОтчета.Вставить("Организация", СтрЛС.Организация);
				ПараметрыОтчета.Вставить("ПериодПросмотра", СтрокаСФ.Дата);
				ПараметрыОтчета.Вставить("ПечататьКвитанциюКапРемонт", Ложь);
				ПараметрыОтчета.Вставить("СписокЗданий", СпЗданий);
				ПараметрыОтчета.Вставить("СписокЛицевыхСчетов", СпЛС);
				ПараметрыОтчета.Вставить("СписокПодъездов", ИБСом.NewObject("СписокЗначений"));
				ПараметрыОтчета.Вставить("СписокПомещений", СпПом);
				ПараметрыОтчета.Вставить("СписокУслуг", ИБСом.NewObject("СписокЗначений")); //не соотв
				ПараметрыОтчета.Вставить("СписокУслугКапРемонт", ИБСом.NewObject("СписокЗначений")); //не соотв
				ПараметрыОтчета.Вставить("СпособПечатиКвитанцииКапРемонт", "основную квитанцию и квитанцию на кап. ремонт");
				////ПараметрыОтчета.Вставить("ТаблицаВидовУслуг",);
				////ПараметрыОтчета.Вставить("ТекущийСписокУслуг",);
				ПараметрыОтчета.Вставить("Форма", "03");
				
				ИБСом.УПЖКХ_ПечатьКвитанцийСервер.ПолучитьСпискиУслуг(ПараметрыОтчета);
				
				ТаблицаОбъектов = ИБСом.УПЖКХ_ПечатьКвитанцийСервер.ПолучитьТаблицуОбъектовКвитанции(ПараметрыОтчета);
				ПараметрыОтчета.Вставить("ТаблицаОбъектов", ТаблицаОбъектов);
				
				АдресХранилища = ИБСом.ПоместитьВоВременноеХранилище(Неопределено, ИБСом.NewObject("УникальныйИдентификатор", Строка(УникальныйИдентификатор)));
				ИБСом.Отчеты.УПЖКХ_КвитанцииИзвещения.СформироватьОтчет(ПараметрыОтчета, АдресХранилища);
				
				ВремПуть = ПолучитьИмяВременногоФайла("mxl");
				
				ТабДокСОМ = ИБСом.ПолучитьИзВременногоХранилища(АдресХранилища);
				ТабДокСОМ.Записать(ВремПуть);
				
				НСтрПуть = Квитации.Добавить();
				НСтрПуть.Документ = Стр.Документ;
				НСтрПуть.ПутьККвитанции = ВремПуть;
				
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	ИБСом.Close();
	ИБСом = Неопределено;
КонецПроцедуры

