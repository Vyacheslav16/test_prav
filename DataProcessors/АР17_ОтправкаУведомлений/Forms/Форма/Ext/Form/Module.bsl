Процедура ОтправитьПисьмоНаСервере(НомерСтроки, Знач Адрес)
	
	Стр = Объект.ТЧ[НомерСтроки-1];
	
	//ТабВыгрузки = Объект.ТЧ.Выгрузить();
	//
