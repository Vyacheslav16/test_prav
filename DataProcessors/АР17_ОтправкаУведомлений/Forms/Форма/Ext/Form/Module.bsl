		//ОбъектыПечати.Добавить(Стр.Ссылка);
		
		//ТабДок = ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина);
		
		Профиль = Новый ИнтернетПочтовыйПрофиль;
		Профиль.АдресСервераSMTP 	= "172.17.1.248";
		
		Сообщение 					= Новый ИнтернетПочтовоеСообщение;
		//Сообщение.Отправитель = "adminskolkovo@becar-group.com";
		
		Если Найти(Стр.Email,",")>0 Тогда
			МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр.Email, ",");
			Для Каждого СтрМассива Из МассивСтрок Цикл
				Если СтрМассива <> "" Тогда
					Сообщение.Получатели.Добавить(СтрМассива);
				КонецЕсли;	
			КонецЦикла;	
		Иначе
			Сообщение.Получатели.Добавить(Стр.Email);
		КонецЕсли;
		
		Сообщение.Отправитель.Адрес = СокрЛП(Объект.ИК.EmailДляУведомлений);
		
		Сообщение.Тема = Стр.Шаблон.Наименование;
		Тело = Стр.Шаблон.Текст;
		Тело = СтрЗаменить(Тело,"[Организация]",Стр.ЗДА.Организация.НаименованиеПолное);
		Тело = СтрЗаменить(Тело,"[НомерДоговора]",Стр.ЗДА.ДоговорКонтрагента.Номер);
		Тело = СтрЗаменить(Тело,"[ДатаДоговора]",Формат(Стр.ЗДА.ДоговорКонтрагента.Дата, "ДФ=dd.MM.yyyy"));
		Тело = СтрЗаменить(Тело,"[Контрагент]",Стр.ЗДА.Контрагент.Наименование);
		Тело = СтрЗаменить(Тело,"[ДатаНачалаДоговора]",Формат(Стр.ЗДА.Дата, "ДФ=dd.MM.yyyy"));
		Тело = СтрЗаменить(Тело,"[ТекущаяДата]",Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy"));
		Тело = СтрЗаменить(Тело,"[СуммаОстаток]",Стр.СуммаОстаток);
		СуммаОстатокПрописью = ЧислоПрописью(Стр.СуммаОстаток, "Л=ru_RU", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
		Тело = СтрЗаменить(Тело,"[СуммаОстатокПрописью]",СуммаОстатокПрописью);
		Тело = СтрЗаменить(Тело,"[ТекущийМесяц]",Формат(ТекущаяДата(), "ДФ=MMMMyyyy"));
		Тело = СтрЗаменить(Тело,"[СледующийДень]",Формат(КонецДня(ТекущаяДата())+1, "ДФ=dd.MM.yyyy"));
		Тело = СтрЗаменить(Тело,"[ИК]",Стр.ЗДА.ИК.Наименование);
		Тело = СтрЗаменить(Тело,"[Менеджер]",Стр.ЗДА.ИК.Менеджер.Наименование);
		Контрагент_Руководитель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.ЗДА.Контрагент, "ОсновноеКонтактноеЛицо");
		Тело = СтрЗаменить(Тело,"[Контрагент_Руководитель]",Контрагент_Руководитель);
		Тело = СтрЗаменить(Тело,"[Контрагент_РуководительИО]",Сред(Контрагент_Руководитель,Найти(Контрагент_Руководитель," ")+1));
		Тело = СтрЗаменить(Тело,"[Контрагент_РуководительДатП]",СклонениеФИО(СокрЛП(Контрагент_Руководитель),3,1));
		Тело = СтрЗаменить(Тело,"[СрокОплаты]",Формат(Стр.СрокОплаты, "ДФ=dd.MM.yyyy"));
		Тело = СтрЗаменить(Тело,"[ТекстДолга]",?(Стр.Долг>0,Стр.Шаблон.ТекстДолга,""));
		Тело = СтрЗаменить(Тело,"[СрокОплатыЗДА]",Стр.СрокОплатыЗДА);
		СтрокаМесяц = "";
		Если Стр.МесяцСрокаОплатыЗДА = -1 Тогда
			СтрокаМесяц = "предыдущего периода";
		ИначеЕсли Стр.МесяцСрокаОплатыЗДА = 0 Тогда
			СтрокаМесяц = "текущего периода";
		Иначе
			СтрокаМесяц = "следующего периода";
		КонецЕсли; 
		Тело = СтрЗаменить(Тело,"[МесяцСрокаОплатыЗДА]",СтрокаМесяц);

		
		ФайлВременногоХранилища = ПолучитьИзВременногоХранилища(Адрес);
		ИмяФайла = КаталогВременныхФайлов() + Стр.Шаблон.Наименование + ".pdf";//ПолучитьИмяВременногоФайла("docx");
		ФайлВременногоХранилища.Записать(ИмяФайла);
		Сообщение.Вложения.Добавить(ИмяФайла);
		УдалитьИзВременногоХранилища(Адрес);
		//УдалитьФайлы(ИмяФайла);
		
		//+ счета 
		Если ТипЗнч(Стр.Реализация) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			СтрокаСчета = "";
			ТЗСчета = ПолучитьСчета(Стр.Договор, Стр.Реализация);
			Для Каждого СтрСчета из ТЗСчета Цикл
				СтрокаСчета = Формат(СтрСчета.Ссылка.НачалоПериода, "ДФ=MMMMyyyy") + " - " + СокрЛП(СтрСчета.СуммаДокумента) + " ";
				ОбъектыПечати = Новый СписокЗначений;
				МассивОбъекетов = Новый Массив;
				МассивОбъекетов.Добавить(СтрСчета.Ссылка);
				ТабДок = Документы.АР17_СчетНаАренду.ПечатьСчета(МассивОбъекетов,ОбъектыПечати,Истина,Ложь,Ложь);
				//ИмяФайлаСчет = ПолучитьИмяВременногоФайла("PDF");
				НомерСчета = СтрЗаменить(СтрСчета.Ссылка.Номер,"/","");
				ИмяФайлаСчет = КаталогВременныхФайлов() + "Счет " + НомерСчета + ".PDF";//ПолучитьИмяВременногоФайла("docx");
				ТабДок.Записать(ИмяФайлаСчет, ТипФайлаТабличногоДокумента.PDF);
				Сообщение.Вложения.Добавить(ИмяФайлаСчет);
			КонецЦикла;
			Тело = СтрЗаменить(Тело,"[СуммаПериод]",СтрокаСчета); 
		КонецЕсли;	
		//- счета
		
		Сообщение.Тексты.Добавить(Тело, ТипТекстаПочтовогоСообщения.ПростойТекст);
		
		ИнтернетПочта = Новый ИнтернетПочта;
		ИнтернетПочта.Подключиться(Профиль);
		ИнтернетПочта.Послать(Сообщение);
		ИнтернетПочта.Отключиться();
		
		//
		НаборЗаписей = РегистрыСведений.АР17_ИсторияРассылок.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ДоговорКонтрагента.Установить(Стр.Договор);
		НаборЗаписей.Отбор.Период.Установить(ТекущаяДата());

		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ТекущаяДата();
		НоваяЗапись.ДоговорКонтрагента = Стр.Договор;
		НоваяЗапись.ШаблонОповещения = Стр.Шаблон;
		НоваяЗапись.Контрагент = Стр.Контрагент;
		НоваяЗапись.ИК = Стр.ЗДА.ИК;
		НаборЗаписей.Записать();
		//
		
	//КонецЦикла;	
	
КонецПроцедуры

 &НаСервере
Функция ПолучитьСчета(Договор, Реализация)
	
	Если ЗначениеЗаполнено(Реализация.СчетНаОплатуПокупателю) Тогда
		
		Если ТипЗнч(Реализация.СчетНаОплатуПокупателю) = Тип("ДокументСсылка.АР17_СчетНаАренду") Тогда
		
			Запрос = Новый Запрос;
		    Запрос.Текст = "ВЫБРАТЬ
		                   |	АР_СчетНаАренду.Ссылка КАК Ссылка,
		                   |	АР_СчетНаАренду.СуммаДокумента КАК СуммаДокумента
		                   |ИЗ
		                   |	Документ.АР17_СчетНаАренду КАК АР_СчетНаАренду
		                   |ГДЕ
		                   |	АР_СчетНаАренду.ДоговорКонтрагента = &ДоговорКонтрагента
		                   |	И АР_СчетНаАренду.Проведен = ИСТИНА
		                   |	И АР_СчетНаАренду.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита)
		                   |	И АР_СчетНаАренду.НачалоПериода = &НачалоПериода
		                   |
		                   |УПОРЯДОЧИТЬ ПО
		                   |	АР_СчетНаАренду.НачалоПериода УБЫВ";
						   
			Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор);	
			Запрос.УстановитьПараметр("НачалоПериода", Реализация.СчетНаОплатуПокупателю.НачалоПериода);
			Выборка = Запрос.Выполнить().Выбрать();
			Выгрузка = Запрос.Выполнить().Выгрузить();
			
			ТЗ = Выгрузка.Скопировать();
			ТЗ.Очистить();
			
			Для Каждого Стр из Выгрузка Цикл
				НовСтр = ТЗ.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтр,Стр);
				Прервать;
			КонецЦикла;
		Иначе
			ТЗ = Новый ТаблицаЗначений;
		КонецЕсли;	
	Иначе
		ТЗ = Новый ТаблицаЗначений;
	КонецЕсли;	
	
	//Для Каждого Стр из Выгрузка Цикл
	//	Если СуммаОстаток >= Стр.СуммаДокумента Тогда
	//		НовСтр = ТЗ.Добавить();
	//		ЗаполнитьЗначенияСвойств(НовСтр,Стр);
	//		СуммаОстаток = СуммаОстаток - Стр.СуммаДокумента;
	//	Иначе
	//		НовСтр = ТЗ.Добавить();
	//		ЗаполнитьЗначенияСвойств(НовСтр,Стр);
	//		Прервать;
	//	КонецЕсли;	
	//КонецЦикла;	
	
	Возврат ТЗ;
	
	//Пока Выборка.Следующий() Цикл
