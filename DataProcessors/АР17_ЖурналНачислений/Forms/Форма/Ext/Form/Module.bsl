&НаКлиенте
Процедура СформироватьСчета(Команда)
	
	Пар = Новый Структура;
	// + NAI Becar Конюшок С.Н. от 27.12.2016 14:21 
	Пар.Вставить("Ссылка", Элементы.Договора.ТекущиеДанные.Договор);
	//Пар.Вставить("Ссылка", Элементы.Счета.ТекущиеДанные.Ссылка);   + NAI Becar Конюшок С.Н. от 27.12.2016 14:15 это была ошибка 
	// - NAI Becar Конюшок С.Н. 
	Пар.Вставить("ВидПериода", Объект.ВидПериода);
	Пар.Вставить("НачалоПериода", Объект.НачалоПериода);
	Пар.Вставить("ОкончаниеПериода", Объект.ОкончаниеПериода);
	Пар.Вставить("Период", ЭтаФорма.Период); 
	
	// + NAI Becar Конюшок С.Н. от 23.01.2017 09:43 групповой отбор
	СписокКА = Новый СписокЗначений;
	СписокДоговоровКА = Новый СписокЗначений;
	Для каждого Стр Из Объект.Договора Цикл
		Если Стр.УстановленВыбор Тогда
		    СписокКА.Добавить(Стр.Контрагент);
			СписокДоговоровКА.Добавить(ПолучитьДоговор(Стр.Договор));
		КонецЕсли; 
	КонецЦикла;
	
	Если СписокКА.Количество() > 1 Тогда
		Пар.Вставить("СписокКА", СписокКА);
		Пар.Вставить("СписокДоговоровКА", СписокДоговоровКА);
	КонецЕсли; 
	// - NAI Becar Конюшок С.Н. 
	
	форма = ПолучитьФорму("Обработка.АР17_ГрупповоеВыставлениеСчетов.Форма.Форма",Пар);
	Если форма.Открыта() Тогда
		Форма.Закрыть();
		форма = ПолучитьФорму("Обработка.АР17_ГрупповоеВыставлениеСчетов.Форма.Форма",Пар);
	КонецЕсли;
	форма.Открыть();

КонецПроцедуры

&НаКлиенте
Процедура СформироватьАкты(Команда)
	
	Пар = Новый Структура;
	// + NAI Becar Конюшок С.Н. от 19.01.2017 11:34 
	//Пар.Вставить("Ссылка", Элементы.Акты.ТекущиеДанные.Ссылка);
	Пар.Вставить("Ссылка", Элементы.Договора.ТекущиеДанные.Договор);
    // - NAI Becar Конюшок С.Н. 
	Пар.Вставить("ВидПериода", Объект.ВидПериода);
	Пар.Вставить("НачалоПериода", Объект.НачалоПериода);
	Пар.Вставить("ОкончаниеПериода", Объект.ОкончаниеПериода);
	Пар.Вставить("Период", ЭтаФорма.Период);
	
	// + NAI Becar Конюшок С.Н. от 23.01.2017 09:43 групповой отбор
	СписокКА = Новый СписокЗначений;
	СписокДоговоровКА = Новый СписокЗначений;
	СписокИК = Новый СписокЗначений;
	Для каждого Стр Из Объект.Договора Цикл
		Если Стр.УстановленВыбор Тогда
			СписокКА.Добавить(Стр.Контрагент);
			СписокДоговоровКА.Добавить(ПолучитьДоговор(Стр.Договор));
			СписокИК.Добавить(ПолучитьИК(Стр.Договор));
		КонецЕсли; 
	КонецЦикла;
	
	Если СписокКА.Количество() > 1 Тогда
		Пар.Вставить("СписокКА", СписокКА);
		Пар.Вставить("СписокДоговоровКА", СписокДоговоровКА);
		СписокИК = СвернутьСЗ(СписокИК);
		Пар.Вставить("СписокИК", СписокИК);
	КонецЕсли; 
	// - NAI Becar Конюшок С.Н.
	
	форма = ПолучитьФорму("Обработка.АР17_ГрупповоеНачислениеАренднойПлаты.Форма.Форма",Пар);
	Если форма.Открыта() Тогда
		Форма.Закрыть();
		форма = ПолучитьФорму("Обработка.АР17_ГрупповоеНачислениеАренднойПлаты.Форма.Форма",Пар);
	КонецЕсли;
	форма.Открыть();
	
КонецПроцедуры

Функция СвернутьСЗ(сзИсходная)
    
    сзСвернуто = Новый СписокЗначений;
    
    Для Каждого эл_сзИсходная Из сзИсходная Цикл
        Если сзСвернуто.НайтиПоЗначению(эл_сзИсходная.Значение) = Неопределено Тогда
            сзСвернуто.Добавить(эл_сзИсходная.Значение, эл_сзИсходная.Представление);
        КонецЕсли;
    КонецЦикла;
    
    Возврат сзСвернуто;
    
КонецФункции

