&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Форма.Период = ВыборПериодаКлиентСервер.ПолучитьПредставлениеПериодаОтчета(
		Объект.ВидПериода, Объект.НачалоПериода, Объект.ОкончаниеПериода);
		
	АР_ОбщиеПроцедурыКлиентСервер.ПереключитьТекущуюСтраницуВыбораПериода(Объект.ВидПериода, Элементы.ГруппаПоляВводаПериода); //-са
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УправлениеФормой(ЭтаФорма);

	Если Не ЗначениеЗаполнено(Объект.ВидПериода) Тогда
		Объект.ВидПериода = АР_ОбщиеПроцедуры.ПолучитьВидПериодаПоПериодичности(Константы.АР_ПериодНачисленияАренднойПлаты.Получить());
	КонецЕсли;
	
	//ВыборПериодаКлиентСервер.ЗаполнитьСписокВыбораВидПериода(
	//	ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День"),
	//	Элементы.ВидПериода.СписокВыбора, Объект.ВидПериода);

	Объект.НачалоПериода = НачалоДня(НачалоМесяца(ТекущаяДата()));
	Объект.ОкончаниеПериода = КонецДня(КонецМесяца(ТекущаяДата()));
	Период = Формат(ТекущаяДата(),"ДФ='ММММ гггг'");
	//ЗаполнитьДоговора();
	
КонецПроцедуры

Процедура ЗаполнитьДоговора()
	
	Объект.Договора.Очистить();
	
	Запрос = Новый Запрос;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	АР17_ЗаключениеДоговораАренды.Ссылка КАК ДоговорАренды
		|ПОМЕСТИТЬ ДоговорыАренды
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР17_ЗаключениеДоговораАренды.Проведен
		|	И АР17_ЗаключениеДоговораАренды.Организация = &Организация
		|	И АР17_ЗаключениеДоговораАренды.ИК = &ИК
		|	И АР17_ЗаключениеДоговораАренды.ВидДоговора = &ВидДоговора
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ДоговорАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДоговорыАренды.ДоговорАренды КАК ДоговорАренды,
		|	СУММА(АР17_ПроведениеДоговораАренды.СуммаПоДоговору) КАК СуммаПоДоговору
		|ПОМЕСТИТЬ ДоговорыИСуммы
		|ИЗ
		|	ДоговорыАренды КАК ДоговорыАренды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ПроведениеДоговораАренды КАК АР17_ПроведениеДоговораАренды
		|		ПО ДоговорыАренды.ДоговорАренды = АР17_ПроведениеДоговораАренды.ДоговорАренды
		|ГДЕ
		|	АР17_ПроведениеДоговораАренды.Дата >= &ДатаН
		|	И АР17_ПроведениеДоговораАренды.Дата <= &ДатаК
		|	И АР17_ПроведениеДоговораАренды.Проведен
		|
		|СГРУППИРОВАТЬ ПО
		|	ДоговорыАренды.ДоговорАренды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДоговорыИСуммы.СуммаПоДоговору КАК СуммаПоДоговору,
		|	ДоговорыИСуммы.ДоговорАренды.Организация КАК Организация,
		|	ДоговорыИСуммы.ДоговорАренды.Контрагент КАК Контрагент,
		|	ДоговорыИСуммы.ДоговорАренды.ВидДоговора КАК ВидДоговора,
		|	ДоговорыИСуммы.ДоговорАренды.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ДоговорыИСуммы.ДоговорАренды.Ссылка КАК Договор,
		|	ДоговорыИСуммы.ДоговорАренды.Номер КАК Номер,
		|	ДоговорыИСуммы.ДоговорАренды.Дата КАК Дата,
		|	ДоговорыИСуммы.ДоговорАренды.ИК КАК ИмущественныйКомплекс
		|ИЗ
		|	ДоговорыИСуммы КАК ДоговорыИСуммы";
	
	Если ЗначениеЗаполнено(Объект.ИК) Тогда
		Запрос.УстановитьПараметр("ИК", Объект.ИК);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И АР17_ЗаключениеДоговораАренды.ИК = &ИК", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ВидДоговора) Тогда
		Запрос.УстановитьПараметр("ВидДоговора", Объект.ВидДоговора);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И АР17_ЗаключениеДоговораАренды.ВидДоговора = &ВидДоговора", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И АР17_ЗаключениеДоговораАренды.Организация = &Организация", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаН", НачалоДня(Объект.НачалоПериода));
	Запрос.УстановитьПараметр("ДатаК", КонецДня(Объект.ОкончаниеПериода));
			   
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		стр = Объект.Договора.Добавить();
		Стр.Контрагент = Выборка.Контрагент;
		Стр.Договор = Выборка.Договор;//Выборка.Ссылка;
		Стр.ВидДоговора = Выборка.ВидДоговора;
		Стр.Организация = Выборка.Организация;
		Стр.ДоговорКонтрагента = Выборка.ДоговорКонтрагента;
		// счета
		ТЗСчета = ПолучитьСчета(Выборка.ДоговорКонтрагента, НачалоДня(Объект.НачалоПериода), КонецДня(Объект.ОкончаниеПериода));
		Стр.КолСчетов = ТЗСчета.Количество();
		//-
		Если Стр.КолСчетов >= 1 Тогда 
			Стр.КолСчетовК = 1;
		ИначеЕсли Стр.КолСчетов = 0 
			Тогда
			Стр.КолСчетовК = 0;
		КонецЕсли;
		//+
		СуммаДоговора = 0;
		//Для Каждого СтрС Из ТЗСчета Цикл
		//	СуммаДоговора = СуммаДоговора + СтрС.Ссылка.Состав.Итог("СуммаПоДоговору");
		//КонецЦикла;
		СуммаДоговора = Выборка.СуммаПоДоговору;
		Если ТЗСчета.Количество() > 0 Тогда
			ТЗСчета.Свернуть("ДоговорКонтрагента","СуммаДокумента");
			Стр.СуммаСчетов = ТЗСчета[0].СуммаДокумента;
		КонецЕсли;
		Если СуммаДоговора <> Стр.СуммаСчетов Тогда
			Стр.КолСчетовК = 0;
		КонецЕсли;	
		// акты
		ТЗАкты = ПолучитьАкты(Выборка.ДоговорКонтрагента, НачалоДня(Объект.НачалоПериода), КонецДня(Объект.ОкончаниеПериода));
		Стр.КолАктов = ТЗАкты.Количество();
		//-
		Если Стр.КолАктов >= 1 Тогда 
			Стр.КолАктовК = 1;
		ИначеЕсли Стр.КолАктов = 0 
			Тогда
			Стр.КолАктовК = 0;
		КонецЕсли;	
		//+
		//СуммаДоговора = 0;
		//Для Каждого СтрА Из ТЗАкты Цикл
		//	СуммаДоговора = СуммаДоговора + СтрА.Ссылка.Состав.Итог("СуммаПоДоговору");
		//КонецЦикла;	
		Если ТЗАкты.Количество() > 0 Тогда
			ТЗАкты.Свернуть("ДоговорКонтрагента","СуммаДокумента");
			Стр.СуммаАктов = ТЗАкты[0].СуммаДокумента;
		КонецЕсли;
		Если СуммаДоговора <> Стр.СуммаАктов Тогда
			Стр.КолАктовК = 0;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговораВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	// + Рогачев  Андрей от 15.08.2016  № 109181
	Если  Элемент.ТекущийЭлемент.Имя="ДоговораДоговорНомер" Тогда
		Если СокрЛП(Элемент.ТекущиеДанные.Договор)<>"" Тогда
			Попытка
				//Элемент.ТекущиеДанные.Договор.ПолучитьФорму().Открыть();
				ПоказатьЗначение(,Элемент.ТекущиеДанные.Договор);
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	// - Рогачев  Андрей от 15.08.2016  № 109181
	
	Попытка
		Элемент.ТекущиеДанные[Элемент.ТекущийЭлемент.Имя].ПолучитьФорму().Открыть();
	Исключение
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ДоговораПриАктивизацииСтроки(Элемент)
	
	Объект.Счета.Очистить();
	Объект.Акты.Очистить();
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		ДанныеСтрокиТаблицы = Новый Структура("ДоговорКонтрагента");
		ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, Элемент.ТекущиеДанные); 
		ДоговораПриАктивизацииСтрокиНаСервере(ДанныеСтрокиТаблицы);
	КонецЕсли;	
	
КонецПроцедуры


&НаСервере
Процедура ДоговораПриАктивизацииСтрокиНаСервере(СтрокаТаблицы)
	
	ТЗСчета = ПолучитьСчета(СтрокаТаблицы.ДоговорКонтрагента, НачалоДня(Объект.НачалоПериода), КонецДня(Объект.ОкончаниеПериода));
	Для Каждого СтрТЗ Из ТЗСчета Цикл	
		стр = Объект.Счета.Добавить();
		Стр.Ссылка = СтрТЗ.Ссылка;
		Стр.Номер = СтрТЗ.Номер;
		Стр.Дата = СтрТЗ.Дата;
		Стр.Контрагент = СтрТЗ.Контрагент;
		Стр.Сумма = СтрТЗ.СуммаДокумента;
	КонецЦикла;
	
	//////////////////////////////////////////////////////////
	
	ТЗАкты = ПолучитьАкты(СтрокаТаблицы.ДоговорКонтрагента, НачалоДня(Объект.НачалоПериода), КонецДня(Объект.ОкончаниеПериода));
	Для Каждого СтрТЗ Из ТЗАкты Цикл	
		стр = Объект.Акты.Добавить();
		Стр.Ссылка = СтрТЗ.Ссылка;
		Стр.Номер = СтрТЗ.Номер;
		Стр.Дата = СтрТЗ.Дата;
		Стр.Контрагент = СтрТЗ.Контрагент;
		Стр.Сумма = СтрТЗ.СуммаДокумента;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьСчета(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода)
	
	ЗапросСчета = Новый Запрос;
	ЗапросСчета.Текст = "ВЫБРАТЬ
	                    |	АР_СчетНаАренду.Ссылка,
	                    |	АР_СчетНаАренду.Номер,
	                    |	АР_СчетНаАренду.Дата,
	                    |	АР_СчетНаАренду.Контрагент,
	                    |	АР_СчетНаАренду.СуммаДокумента,
	                    |	АР_СчетНаАренду.ДоговорКонтрагента
	                    |ИЗ
	                    |	Документ.АР17_СчетНаАренду КАК АР_СчетНаАренду
	                    |ГДЕ
	                    |	АР_СчетНаАренду.ДоговорКонтрагента = &ДоговорКонтрагента
	                    |	И АР_СчетНаАренду.НачалоПериода <= &КонПериода
	                    |	И АР_СчетНаАренду.ОкончаниеПериода >= &НачПериода
	                    |	И АР_СчетНаАренду.ПометкаУдаления = ЛОЖЬ
	                    |	И АР_СчетНаАренду.ВидОперации <> Значение(Перечисление.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита)";
					   
					   
	ЗапросСчета.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	ЗапросСчета.УстановитьПараметр("НачПериода", НачалоПериода);
	ЗапросСчета.УстановитьПараметр("КонПериода", ОкончаниеПериода);
	
	Возврат ЗапросСчета.Выполнить().Выгрузить();
	
КонецФункции	

Функция ПолучитьАкты(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода)
	
	ЗапросАкты = Новый Запрос;
	ЗапросАкты.Текст = "ВЫБРАТЬ
	                   |	АР_НачислениеАренднойПлаты.Ссылка,
	                   |	АР_НачислениеАренднойПлаты.Номер,
	                   |	АР_НачислениеАренднойПлаты.Дата,
	                   |	АР_НачислениеАренднойПлаты.Контрагент КАК Контрагент,
	                   |	АР_НачислениеАренднойПлаты.ДоговорКонтрагента,
	                   |	АР_НачислениеАренднойПлаты.СуммаДокумента
	                   |ИЗ
	                   |	Документ.АР17_НачислениеАренднойПлаты КАК АР_НачислениеАренднойПлаты
	                   |ГДЕ
	                   |	АР_НачислениеАренднойПлаты.ДоговорКонтрагента = &ДоговорКонтрагента
	                   |	И АР_НачислениеАренднойПлаты.НачалоПериода <= &КонПериода
	                   |	И АР_НачислениеАренднойПлаты.ОкончаниеПериода >= &НачПериода
	                   |	И НЕ АР_НачислениеАренднойПлаты.ПометкаУдаления";
				   
						
	ЗапросАкты.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	ЗапросАкты.УстановитьПараметр("НачПериода", НачалоПериода);
	ЗапросАкты.УстановитьПараметр("КонПериода", ОкончаниеПериода);
	
	Возврат ЗапросАкты.Выполнить().Выгрузить();
	
КонецФункции	

&НаКлиенте
Процедура СчетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка=Ложь;
    СсылкаНаДокумент = Элемент.ТекущиеДанные.Ссылка;
	Пар = Новый Структура("Ключ",СсылкаНаДокумент); 
	Форма = ПолучитьФорму("Документ.АР17_СчетНаАренду.Форма.ФормаДокумента",Пар);
    Форма.Открыть();
	
