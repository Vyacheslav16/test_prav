&НаКлиенте
Процедура ВыборИмущественныйКомплексНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПараметрыВыбора1 = Новый Массив;//(Элемент.ПараметрыВыбора);
	НовыйПараметр = Новый ПараметрВыбора("ТипОбъекта", ПредопределенноеЗначение("Справочник.АР_ТипыОбъектовАренды.ИмущественныйКомплекс"));
	ПараметрыВыбора1.Очистить();
	ПараметрыВыбора1.Добавить(НовыйПараметр);
