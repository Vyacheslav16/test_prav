
&НаСервере
Процедура ЗаполнитьНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_СчетНаАренду.Ссылка КАК Ссылка,
	               |	АР17_СчетНаАренду.Контрагент КАК Контрагент,
	               |	АР17_СчетНаАренду.ОтправленНаПочту КАК Отправлен,
	               |	АР17_СчетНаАренду.ДатаОтправки КАК ДатаОтправки
	               |ИЗ
	               |	Документ.АР17_СчетНаАренду КАК АР17_СчетНаАренду
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |		ПО АР17_СчетНаАренду.ДоговорКонтрагента = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	               |ГДЕ
	               |	АР17_СчетНаАренду.Дата МЕЖДУ &ДатаН И &ДатаК
	               |	И ВЫБОР
	               |			КОГДА &Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_СчетНаАренду.Контрагент = &Контрагент
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_СчетНаАренду.Организация = &Организация
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Договор = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_СчетНаАренду.ДоговорКонтрагента = &Договор
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &ИК = ЗНАЧЕНИЕ(Справочник.АР_ОбъектыАренды.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ АР17_ЗаключениеДоговораАренды.ИК = &ИК
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ДатаН", НачалоПериода);
	Запрос.УстановитьПараметр("ДатаК", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ИК", Объект.ИК);
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("Договор", Объект.Договор);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТабДокументов.Загрузить(Выгрузка);
	
	Для Каждого Стр Из ТабДокументов Цикл
		
		Email = "";
		КонтактныеЛица = Справочники.КонтактныеЛица.СписокКонтактныхЛиц(Стр.Контрагент);
		Для Каждого СтрКЛ из КонтактныеЛица Цикл
			Если СтрКЛ.Значение.КонтактнаяИнформация.Количество()>0 Тогда
				Email = Email + ?(Email = "","",",") + 
				СтрКЛ.Значение.КонтактнаяИнформация[0].АдресЭП;	
			КонецЕсли;	
		КонецЦикла;
		
		МассивОбъектов = Новый Массив;
		МассивОбъектов.Добавить(Стр.Контрагент);
		
		КонтактнаяИнформацияОбъекта = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(МассивОбъектов,, Справочники.ВидыКонтактнойИнформации.EmailКонтрагенты, Неопределено);
		
		Для Каждого КИ Из КонтактнаяИнформацияОбъекта Цикл
			
			Если СокрЛП(КИ.Представление) <> "" Тогда
				
				Email = Email + ?(Email = "","",",") + 
				СокрЛП(КИ.Представление);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Стр.Email = Email;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда)
	ТабДокументов.Очистить();
	ЗаполнитьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ВыборПериода(Команда)
	НастройкаПериода = Новый ДиалогРедактированияСтандартногоПериода();
	НастройкаПериода.Период = Новый СтандартныйПериод(НачалоПериода,ОкончаниеПериода);
	Если НастройкаПериода.Редактировать() Тогда
         НачалоПериода = НастройкаПериода.Период.ДатаНачала;
         ОкончаниеПериода = НастройкаПериода.Период.ДатаОкончания;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОтправитьПисьмоНаСервере()
	
	ОбъектыПечати = Неопределено;
	
	ТабВыгрузки = ТабДокументов.Выгрузить();
	ТабДокументов.Очистить();
	
	Для Каждого Стр Из ТабВыгрузки Цикл
		
		Если НЕ Стр.Пометка Тогда Нов = ТабДокументов.Добавить(); ЗаполнитьЗначенияСвойств(Нов,Стр); Продолжить; КонецЕсли;
		Если Стр.Email = "" Тогда Нов = ТабДокументов.Добавить(); ЗаполнитьЗначенияСвойств(Нов,Стр); Продолжить; КонецЕсли;
		
		МассивОбъектов = Новый Массив;
		МассивОбъектов.Добавить(Стр.Ссылка);
			
		ОбъектыПечати = Новый СписокЗначений;
		ОбъектыПечати.Добавить(Стр.Ссылка);
		
		ТабДок = ПечатьСчета(МассивОбъектов, ОбъектыПечати, Истина);
		
		//файл
		Если В_ЛК Тогда
			ПутьСохраненияФайла = "\\server-str\obmen\SaaS\reports\"; 
			ПутьСохраненияФайла = ПутьСохраненияФайла + "Счет" + СтрЗаменить(Стр.Ссылка.Номер,"/","_") + "_" + Формат(Стр.Ссылка.Дата, "ДФ=dd.MM.yyyy")
			+ ";;" + Стр.Email + ".pdf";
			ТабДок.Записать(ПутьСохраненияФайла,ТипФайлаТабличногоДокумента.PDF);
		КонецЕсли;
		Если На_Email Тогда
			Профиль = Новый ИнтернетПочтовыйПрофиль;
			Профиль.АдресСервераSMTP 	= "172.17.1.248";
			
			Сообщение 					= Новый ИнтернетПочтовоеСообщение;
			Сообщение.Отправитель = "adminskolkovo@becar-group.com";
			
			Если Найти(Стр.Email,",")>0 Тогда
				МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Стр.Email, ",");
				Для Каждого СтрМассива Из МассивСтрок Цикл
					Если СтрМассива <> "" Тогда
						Сообщение.Получатели.Добавить(СтрМассива);
					КонецЕсли;	
				КонецЦикла;	
			Иначе
				Сообщение.Получатели.Добавить(Стр.Email);
			КонецЕсли;
			
			Если СокрЛП(ПолучатьКопиюНа) <> "" Тогда
				Сообщение.Получатели.Добавить(ПолучатьКопиюНа);
			КонецЕсли;
			
			ПутьСохраненияФайла = КаталогВременныхФайлов();
			ПутьСохраненияФайла = ПутьСохраненияФайла + "Счет_УК_Бекар" + ".pdf";
			ТабДок.Записать(ПутьСохраненияФайла,ТипФайлаТабличногоДокумента.PDF);
			Сообщение.Вложения.Добавить(ПутьСохраненияФайла);

			ИнтернетПочта = Новый ИнтернетПочта;
			ИнтернетПочта.Подключиться(Профиль);
			ИнтернетПочта.Послать(Сообщение);
			ИнтернетПочта.Отключиться();
			
			Док = Стр.Ссылка.ПолучитьОбъект();
			Док.ОтправленНаПочту = Истина;
			Док.ДатаОтправки = ТекущаяДата();
			Док.Записать(РежимЗаписиДокумента.Запись);
			
		КонецЕсли;	
		
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьПисьмо(Команда)
	ОтправитьПисьмоНаСервере();
	
	Сообщить("Отправка писем завершена");
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	Для Каждого Стр Из ТабДокументов Цикл
		Если СокрЛП(Стр.EMail) <> "" Тогда
			Стр.Пометка = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СнятьФлажки(Команда)
	Для Каждого Стр Из ТабДокументов Цикл
		Стр.Пометка = Ложь;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Одобрения = "ТребуетОдобрения";	
КонецПроцедуры

///////
// Функция формирует табличный документ с печатной формой заказа или счета,
// разработанного методистами
//
// Возвращаемое значение:
//  Табличный документ - сформированная печатная форма
//
Функция ПечатьСчета(МассивОбъектов, ОбъектыПечати, Сводный, БезЕдИзм = Ложь) Экспорт

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_АР_СчетНаАренду_СчетЗаказ";
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("УслугаАренда",   Константы.АР_УслугаАренда.Получить());
	
	// + NAI Becar Матюхин Н.О. от 24.10.2016 17:03 по заявке № 
	ЭтоОплатаПени = Ложь;
	Если МассивОбъектов.Количество() > 0 И МассивОбъектов[0].ВидОперации = Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаПени Тогда
		ЭтоОплатаПени = Истина;
	КонецЕсли;	
	// - NAI Becar Матюхин Н.О.
	
	Если ЭтоОплатаПени Тогда
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуПокупателюОплатаПени();
	ИначеЕсли Сводный = Неопределено Тогда
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуПокупателю();
	ИначеЕсли Сводный Тогда
		Если БезЕдИзм Тогда  // + NAI Becar Конюшок С.Н. от 07.02.2017 17:51 
			ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуСводный(Истина);
		Иначе
			ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуСводный();
		КонецЕсли;
	Иначе
		ТекстЗапроса = 	ПолучитьТекстЗапросаДляФормированияПечатнойФормыСчетаНаОплатуРазвернутый();
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;

	Шапка = Запрос.Выполнить().Выбрать();
	Шапка1 = Запрос.Выполнить().Выгрузить(); //-са
	
	ПервыйДокумент = Истина;
	
	Пока Шапка.СледующийПоЗначениюПоля("Ссылка") Цикл
		
		//+са
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_ЗаключениеДоговораАренды.Ссылка
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = &ДоговорКонтрагента";
		
		Запрос.УстановитьПараметр("ДоговорКонтрагента", Шапка.ДоговорКонтрагента);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		НайденныйДоговор = Выборка.Ссылка;	
		//-са

		
		//Макет = УправлениеПечатью.ПолучитьМакет("Документ.АР17_СчетНаАренду.СчетЗаказ");
		Макет = УправлениеПечатью.ПолучитьМакет("Обработка.АР17_ОтправкаНаПортал.СчетЗаказ");
		ОтчетОбъект = РеквизитФормыВЗначение("Объект");
		Макет = ОтчетОбъект.ПолучитьМакет("СчетЗаказ");

		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// Выводим шапку накладной
		
		СведенияОПолучателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		ОбластьМакета       = Макет.ПолучитьОбласть("ЗаголовокСчета");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.ИНН = СведенияОПолучателе.ИНН;
		ОбластьМакета.Параметры.КПП = СведенияОПолучателе.КПП;
		Если ТипЗнч(Шапка.СтруктурнаяЕдиница) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
			ОбластьМакета.Параметры.БИКБанкаПолучателя               = Шапка.БикБанкаПолучателя;
			ОбластьМакета.Параметры.БанкПолучателя                   = Шапка.БанкПолучателя;
			ОбластьМакета.Параметры.БанкПолучателяПредставление      = СокрЛП(Шапка.НаименованиеБанкаПолучателя);
			ОбластьМакета.Параметры.СчетБанкаПолучателя              = Шапка.СчетБанкаПолучателя;
			ОбластьМакета.Параметры.СчетБанкаПолучателяПредставление = Шапка.СчетБанкаПолучателя;
			ОбластьМакета.Параметры.СчетПолучателяПредставление      = Шапка.НомерСчетаПолучателя;
			//ОбластьМакета.Параметры.СчетПолучателяПредставление      = ?(СокрЛП(ПолучитьРС(Шапка)) <> "",СокрЛП(ПолучитьРС(Шапка)),Шапка.НомерСчетаПолучателя); //-са
			ОбластьМакета.Параметры.СчетПолучателя                   = Шапка.НомерСчетаПолучателя;
		КонецЕсли;
		
		Если ПустаяСтрока(Шапка.ТекстКорреспондента) Тогда
			ТекстКорреспондента = СведенияОПолучателе.НаименованиеДляПечатныхФорм;
			Если ЗначениеЗаполнено(Шапка.БанкДляРасчетов) Тогда
				ТекстКорреспондента = ТекстКорреспондента + Шапка.БанкТекстКорресподента;
			КонецЕсли;
		Иначе
			ТекстКорреспондента = Шапка.ТекстКорреспондента;
		КонецЕсли;
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ТекстКорреспондента;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = ОбщегоНазначенияБПВызовСервера.СформироватьЗаголовокДокумента(Шапка, "Счет на оплату");
		
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Поставщик");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		СведенияОбОрганизации    = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата);
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОбОрганизации, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("Покупатель");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		СведенияОПокупателе     = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Покупатель, Шапка.Дата);
		ОбластьМакета.Параметры.ПредставлениеПокупателя = ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОПокупателе, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ОбластьМакета.Параметры.Основание = Шапка.Ссылка.ДоговорКонтрагента;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
		ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицы|Данные");
		ОбластьСуммы  = Макет.ПолучитьОбласть("ШапкаТаблицы|Сумма");

		ТабличныйДокумент.Вывести(ОбластьНомера);
		ТабличныйДокумент.Присоединить(ОбластьДанных);
		ТабличныйДокумент.Присоединить(ОбластьСуммы);

		ОбластьКолонкаТовар = Макет.Область("Товар");

		ОбластьНомера = Макет.ПолучитьОбласть("Строка|НомерСтроки");
		ОбластьДанных = Макет.ПолучитьОбласть("Строка|Данные");
		ОбластьСуммы  = Макет.ПолучитьОбласть("Строка|Сумма");

		Сумма    = 0;
		СуммаНДС = 0;
		ВсегоСкидок    = 0;
