	|			ТОГДА "" р/с "" + Реквизиты.СчетОрганизации.НомерСчета + "" в "" + Реквизиты.СчетОрганизации.Банк.Наименование + "" "" + Реквизиты.СчетОрганизации.Банк.Город
	|	КОНЕЦ КАК БанкТекстКорресподента,
	|	Реквизиты.Контрагент КАК Покупатель,
	|	Реквизиты.Организация КАК Руководители,
	|	Реквизиты.Организация КАК Поставщик,
	|	Реквизиты.Организация КАК Получатель,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.ВалютаДокумента,
	|	Реквизиты.СуммаВключаетНДС,
	|	ЗаказПокупателя.Содержание,
	|	"+ ЧастьЗапросаДляВыбораСодержанияУслуг +" КАК Номенклатура,
	|	"+ ЧастьЗапросаДляВыбораСодержанияУслуг +" КАК Товар,
	|	"""" КАК Код,
	|	ЗаказПокупателя.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА НЕ ЗаказПокупателя.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
	|			ТОГДА ЗаказПокупателя.ЕдиницаИзмерения
	|		ИНАЧЕ ЗаказПокупателя.Номенклатура.ЕдиницаИзмерения.Наименование
	|	КОНЕЦ КАК ЕдиницаИзмерения,
	|	ЗаказПокупателя.Цена КАК Цена,
	|	ЗаказПокупателя.Сумма КАК Сумма,
	|	ЗаказПокупателя.СуммаНДС КАК СуммаНДС,
	|	ЗаказПокупателя.НомерСтроки КАК НомерСтроки,
	|	1 КАК ID,
	|	ЗаказПокупателя.ПериодАренды КАК НачалоПериода,
	|	ЗаказПокупателя.КоличествоДней Как КоличествоДней,
	|	ЗаказПокупателя.ДатаНачалаАренды Как ДатаНачалаАренды,
	|	ЗаказПокупателя.ОбъектАренды КАК ОбъектАренды
	|ИЗ
	|	Документ.АР17_СчетНаАренду.Состав КАК ЗаказПокупателя
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_СчетНаАренду КАК Реквизиты
	|		ПО ЗаказПокупателя.Ссылка = Реквизиты.Ссылка
	|ГДЕ
	|	ЗаказПокупателя.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Реквизиты.Ссылка,
	|	ID,
	|	НомерСтроки";

	Возврат ТекстЗапроса;

КонецФункции

&НаКлиенте
Процедура ИКНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ПараметрыВыбора1 = Новый Массив;//(Элемент.ПараметрыВыбора);
	НовыйПараметр = Новый ПараметрВыбора("ТипОбъекта", ТипИК());
	ПараметрыВыбора1.Очистить();
	ПараметрыВыбора1.Добавить(НовыйПараметр);
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора1);
КонецПроцедуры

Функция ТипИК()	
	Возврат (Справочники.АР_ТипыОбъектовАренды.ИмущественныйКомплекс);
КонецФункции	

&НаКлиенте
Процедура ТабДокументовПриИзменении(Элемент)
	СтрокаТабличнойЧасти = Элементы.ТабДокументов.ТекущиеДанные;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Ссылка) Тогда
		СтрокаТабличнойЧасти.Контрагент = ПолучитьКонтрагента(СтрокаТабличнойЧасти.Ссылка);
	КонецЕсли;	
КонецПроцедуры

Функция ПолучитьКонтрагента(Ссылка)
	Возврат Ссылка.Контрагент;
КонецФункции	