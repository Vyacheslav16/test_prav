Функция ПолучитьСчета(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода)
	
	ЗапросСчета = Новый Запрос;
	ЗапросСчета.Текст = "ВЫБРАТЬ
	                    |	АР17_СчетНаАренду.Ссылка,
	                    |	АР17_СчетНаАренду.Номер,
	                    |	АР17_СчетНаАренду.Дата,
	                    |	АР17_СчетНаАренду.Контрагент,
	                    |	АР17_СчетНаАренду.СуммаДокумента,
	                    |	АР17_СчетНаАренду.ДоговорКонтрагента
	                    |ИЗ
	                    |	Документ.АР17_СчетНаАренду КАК АР17_СчетНаАренду
	                    |ГДЕ
	                    |	АР17_СчетНаАренду.ДоговорКонтрагента = &ДоговорКонтрагента
						|	И НЕ АР17_СчетНаАренду.ПометкаУдаления
						|	И АР17_СчетНаАренду.ВидОперации = &ВидОперации";
					   
					   
	ЗапросСчета.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	ЗапросСчета.УстановитьПараметр("ВидОперации", Перечисления.АР_ВидыОперацийСчетНаАренду.ОплатаДепозита);
	//ЗапросСчета.УстановитьПараметр("НачПериода", НачалоПериода);
	//ЗапросСчета.УстановитьПараметр("КонПериода", ОкончаниеПериода);
	
	Возврат ЗапросСчета.Выполнить().Выгрузить();
	
КонецФункции	

Функция ПолучитьАкты(ДоговорКонтрагента,НачалоПериода,ОкончаниеПериода)
	
	ЗапросАкты = Новый Запрос;
	ЗапросАкты.Текст = "ВЫБРАТЬ
	                   |	АР_НачислениеАренднойПлаты.Ссылка,
	                   |	АР_НачислениеАренднойПлаты.Номер,
	                   |	АР_НачислениеАренднойПлаты.Дата,
	                   |	АР_НачислениеАренднойПлаты.Контрагент КАК Контрагент,
	                   |	АР_НачислениеАренднойПлаты.ДоговорКонтрагента,
	                   |	АР_НачислениеАренднойПлаты.СуммаДокумента
	                   |ИЗ
	                   |	Документ.АР17_НачислениеАренднойПлаты КАК АР_НачислениеАренднойПлаты
	                   |ГДЕ
	                   |	АР_НачислениеАренднойПлаты.ДоговорКонтрагента = &ДоговорКонтрагента
	                   |	И АР_НачислениеАренднойПлаты.НачалоПериода <= &КонПериода
	                   |	И АР_НачислениеАренднойПлаты.ОкончаниеПериода >= &НачПериода";
				   
						
	ЗапросАкты.УстановитьПараметр("ДоговорКонтрагента", ДоговорКонтрагента);
	ЗапросАкты.УстановитьПараметр("НачПериода", НачалоПериода);
	ЗапросАкты.УстановитьПараметр("КонПериода", ОкончаниеПериода);
	
	Возврат ЗапросАкты.Выполнить().Выгрузить();
	
КонецФункции	

