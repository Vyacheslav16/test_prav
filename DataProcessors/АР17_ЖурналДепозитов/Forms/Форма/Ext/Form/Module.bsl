&НаСервере
Процедура ПриЗакрытииНаСервере()
	ДанныеСохранения = Новый Структура();
	ДанныеСохранения.Вставить("Организация", Объект.Организация);
	ДанныеСохранения.Вставить("ИК", Объект.ИК);
	ДанныеСохранения.Вставить("Период", Период);
	ДанныеСохранения.Вставить("ВидПериода", Объект.ВидПериода);
	ДанныеСохранения.Вставить("НачалоПериода", Объект.НачалоПериода);
	ДанныеСохранения.Вставить("ОкончаниеПериода", Объект.ОкончаниеПериода);
	
	//СохранитьЗначение("АР_ЖурналНачислений", Структура);
	ХранилищеОбщихНастроек.Сохранить("Обработка.АР_ЖурналНачислений.Форма", "ДанныеСохранения", ДанныеСохранения);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПриОткрытииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПриОткрытииНаСервере()
	
	Настройки = ХранилищеОбщихНастроек.Загрузить("Обработка.АР_ЖурналНачислений.Форма", "ДанныеСохранения");
    Если Не Настройки = Неопределено И ТипЗнч(Настройки) = Тип("Структура") Тогда
		
		Объект.Организация = Настройки.Организация;
		Объект.ИК = Настройки.ИК;
		Период = Настройки.Период;
		Объект.ВидПериода = Настройки.ВидПериода;
		Объект.НачалоПериода = Настройки.НачалоПериода;
		Объект.ОкончаниеПериода = Настройки.ОкончаниеПериода;
        
	КонецЕсли;
	ЗаполнитьДоговора();
	
КонецПроцедуры

