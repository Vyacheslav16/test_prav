	КонецЕсли;
	
	//ВыборПериодаКлиентСервер.ЗаполнитьСписокВыбораВидПериода(
	//	ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День"),
	//	Элементы.ВидПериода.СписокВыбора, Объект.ВидПериода);

	Объект.НачалоПериода = НачалоДня(НачалоМесяца(ТекущаяДата()));
	Объект.ОкончаниеПериода = КонецДня(КонецМесяца(ТекущаяДата()));
	//ЗаполнитьДоговора();
	
КонецПроцедуры

Процедура ЗаполнитьДоговора()
	
	Объект.Договоры.Очистить();
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_ЗаключениеДоговораАренды.Ссылка КАК Договор,
	               |	АР17_ЗаключениеДоговораАренды.Контрагент КАК Контрагент,
	               |	АР17_ЗаключениеДоговораАренды.ВидДоговора КАК ВидДоговора,
	               |	АР17_ЗаключениеДоговораАренды.Организация КАК Организация,
	               |	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента КАК ДоговорКонтрагента,
	               |	АР17_ЗаключениеДоговораАренды.СуммаЗалога КАК СуммаЗалога,
	               |	ЕСТЬNULL(ХозрасчетныйОстатки.СуммаОстатокКт, 0) КАК ДепозитФакт
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Остатки(
	               |				&НачПериода,
	               |				Счет.Код = ""62.04""
	               |					ИЛИ Счет.Код = ""76.09.1"",
	               |				,
	               |				) КАК ХозрасчетныйОстатки
	               |		ПО (ХозрасчетныйОстатки.Субконто2 = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента)
	               |ГДЕ
	               |	НЕ АР17_ЗаключениеДоговораАренды.ПометкаУдаления
	               |	И АР17_ЗаключениеДоговораАренды.СтатусДоговора В(&СтатусыДоговора)
	               |	И (АР17_ЗаключениеДоговораАренды.ФактическоеЗакрытие >= &КонПериода
	               |			ИЛИ АР17_ЗаключениеДоговораАренды.ФактическоеЗакрытие = ДАТАВРЕМЯ(1, 1, 1))";
	
	
	Если ЗначениеЗаполнено(Объект.ИК) Тогда
		Запрос.Текст = Запрос.Текст +				   
		"	И АР17_ЗаключениеДоговораАренды.ИК = &ИК";
		Запрос.УстановитьПараметр("ИК", Объект.ИК);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		Запрос.Текст = Запрос.Текст +				   
		"	И АР17_ЗаключениеДоговораАренды.Организация = &Организация";
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.ВидДоговора) Тогда
		Запрос.Текст = Запрос.Текст +				   
		"	И АР17_ЗаключениеДоговораАренды.ВидДоговора = &ВидДоговора";
		Запрос.УстановитьПараметр("ВидДоговора", Объект.ВидДоговора);
	Иначе
		ВидДоговора = Новый Массив;
		ВидДоговора.Добавить(Справочники.АР_ВидыДоговоров.Аренда);
		ВидДоговора.Добавить(Справочники.АР_ВидыДоговоров.Субаренда);
		
		Запрос.Текст = Запрос.Текст +				   
		"	И АР17_ЗаключениеДоговораАренды.ВидДоговора В (&ВидДоговора)";
		Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("НачПериода", НачалоДня(Объект.НачалоПериода));
	Запрос.УстановитьПараметр("КонПериода", КонецДня(Объект.ОкончаниеПериода));
	СтатусыДоговора = Новый Массив;
	СтатусыДоговора.Добавить(Перечисления.АР_СтатусДоговора.Согласован);
	
	Запрос.УстановитьПараметр("СтатусыДоговора", СтатусыДоговора);
			   
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		стр = Объект.Договоры.Добавить();
		Стр.Контрагент = Выборка.Контрагент;
		Стр.Договор = Выборка.Договор;//Выборка.Ссылка;
		Стр.ВидДоговора = Выборка.ВидДоговора;
		Стр.Организация = Выборка.Организация;
		Стр.ДоговорКонтрагента = Выборка.ДоговорКонтрагента;
				
		// счета
		ТЗСчета = ПолучитьСчета(Выборка.ДоговорКонтрагента, НачалоДня(Объект.НачалоПериода), КонецДня(Объект.ОкончаниеПериода));
		
		СуммаСчета = ТЗСчета.Итог("СуммаДокумента");
		
		КолвоСчетов = ТЗСчета.Количество();
		Стр.КолСчетов = КолвоСчетов;
		Стр.СуммаСчетов = СуммаСчета;
		
		СуммаДоговора = 0;
		
		ДепозитПлан = Выборка.СуммаЗалога;
		ДепозитФакт = Выборка.ДепозитФакт;
		
		Стр.КолСчетовК = 4;
		
		//Цвета
		//2 синий
		//1 зеленый
		//0 красный
		Если ДепозитПлан <> 0 Тогда
			
			Если ДепозитПлан <= ДепозитФакт Тогда
				Стр.КолСчетовК = 1; //Зеленый
			Иначе
				Если КолвоСчетов = 0 Тогда
					Стр.КолСчетовК = 0; //Красный
				Иначе
					Если СуммаСчета + ДепозитФакт >= ДепозитПлан Тогда // Сумма счета покрывает депозит
						Стр.КолСчетовК = 2; //черный
					Иначе
						Стр.КолСчетовК = 3; //черный
					КонецЕсли;
					
				КонецЕсли; 
				
			КонецЕсли; 
			
		КонецЕсли;
		
		Стр.ДепозитПлан = ДепозитПлан;
		Стр.ДепозитФакт = ДепозитФакт;
		Стр.СуммаРазницы = ДепозитПлан - ДепозитФакт - СуммаСчета;

	КонецЦикла;
	
КонецПроцедуры

