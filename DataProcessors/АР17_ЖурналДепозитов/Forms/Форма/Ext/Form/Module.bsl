&НаКлиенте
Процедура СформироватьСчета(Команда)
	
	Пар = Новый Структура;
	
	// + NAI Becar Конюшок С.Н. от 23.01.2017 09:43 групповой отбор
	СписокКА = Новый СписокЗначений;
	СписокДоговоровКА = Новый СписокЗначений;
	Для каждого Стр Из Объект.Договоры Цикл
		Если Стр.УстановленВыбор Тогда
		    СписокКА.Добавить(Стр.Контрагент);
			СписокДоговоровКА.Добавить(ПолучитьДоговор(Стр.Договор));
		КонецЕсли; 
	КонецЦикла; 
	//
		
	// + Рогачев  Андрей от 12.08.2016  № 108740
	//Пар.Вставить("Ссылка", Элементы.Счета.ТекущиеДанные.Ссылка);
	Если  СокрЛП(Элементы.Договора.ТекущиеДанные.Договор) <> "" Тогда
		Пар.Вставить("Ссылка", Элементы.Договора.ТекущиеДанные.Договор);
	КонецЕсли;
	Пар.Вставить("ВидПериода", Объект.ВидПериода);
	Пар.Вставить("НачалоПериода", Объект.НачалоПериода);
	Пар.Вставить("ОкончаниеПериода", Объект.ОкончаниеПериода);
	Пар.Вставить("Период", ЭтаФорма.Период);
	Пар.Вставить("Депозит", Истина);
	Если СписокКА.Количество() > 1 Тогда
	
		Пар.Вставить("СписокКА", СписокКА);
		Пар.Вставить("СписокДоговоровКА", СписокДоговоровКА);
	
	КонецЕсли; 
	
	форма = ПолучитьФорму("Обработка.АР17_ГрупповоеВыставлениеСчетов.Форма.Форма",Пар);
	Если форма.Открыта() Тогда
		Форма.Закрыть();
		форма = ПолучитьФорму("Обработка.АР17_ГрупповоеВыставлениеСчетов.Форма.Форма",Пар);
	 	//форма.Открыть();
	КонецЕсли;
	форма.Открыть();
	
КонецПроцедуры

