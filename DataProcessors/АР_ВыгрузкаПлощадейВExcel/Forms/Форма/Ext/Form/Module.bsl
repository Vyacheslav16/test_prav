&НаКлиенте
Процедура ВыгрузитьВExcel(Команда)
	
	Режим = РежимДиалогаВыбораФайла.Сохранение; 
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим); 
	ДиалогОткрытияФайла.ПолноеИмяФайла = "";
	Фильтр = "Файл Excel (*,xls; *.xlsx)|*.xls; *.xlsx|";
	//+
	//"Файл Excel 2013 (*,xlsx)|*.xlsx|"; 
	ДиалогОткрытияФайла.Фильтр = Фильтр; 
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь; 
	ДиалогОткрытияФайла.Заголовок = "Выберите файл для сохранения бланка"; 
	
	ПутьКФайлу = "Выгрузка площадей объектов недвижимости из 1С по " + СтрЗаменить(СокрЛП(Объект.ИК), """", "") + " от " + Формат(ТекущаяДата(),"ДЛФ=Д");
	ДиалогОткрытияФайла.ПолноеИмяФайла = ПутьКФайлу;
	Если ДиалогОткрытияФайла.Выбрать() Тогда 
		ПутьКФайлу = ДиалогОткрытияФайла.ПолноеИмяФайла; 
		//Иначе
		//	ПутьКФайлу="";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ОбъектыАренды) Тогда
		ЗаполнитьНаСервере();
	КонецЕсли;
	
	ЗаписатьФайлСервер(ПутьКФайлу);
КонецПроцедуры

&НаСервере
Функция ДляИК()
	
	Если Объект.ИК.ТипОбъекта = Справочники.АР_ТипыОбъектовАренды.ИмущественныйКомплекс Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции


&НаКлиенте
Процедура ЗаписатьФайлСервер(ПутьКФайлу)
	
	Эксель = Новый COMОбъект("Excel.Application");
	Книга = Эксель.WorkBooks().Add();
	
	Книга = Эксель.Application.Workbooks(1);
	Лист = Книга.WorkSheets(1); 
	Лист.Cells.Clear(); //ClearContents();
	
	
	
	Лист.Columns(2).ColumnWidth = 20;
	Лист.Columns(3).ColumnWidth = 15;
	Лист.Columns(4).ColumnWidth = 15;
	Лист.Columns(5).ColumnWidth = 15;
	Лист.Columns(6).ColumnWidth = 15;
	
	Если ДляИК() Тогда
		
		Ячейка =  Лист.Cells(3, 2);
		Ячейка.Value = "Здание";
		Ячейка.Borders.LineStyle = 1;
		Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
		Ячейка.WrapText = истина;
		Лист.Columns(7).ColumnWidth = 15;
		
		ПК = 2;
		ЭтоИК = Истина;
	Иначе
		ПК = 1;
		ЭтоИК = Ложь;
		
	КонецЕсли;
	
	Ячейка =  Лист.Cells(3, ПК+1);
	Ячейка.Value = "Этаж";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, ПК+2);
	Ячейка.Value = "№ помещения по БТИ";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, ПК+3);
	Ячейка.Value =  "№ комнаты по плану БТИ";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, ПК+4);
	Ячейка.Value = "Индекс офиса (помещения по БОМА)";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Ячейка =  Лист.Cells(3, ПК+5);
	Ячейка.Value = "Площадь";
	Ячейка.Borders.LineStyle = 1;
	Ячейка.Interior.Color = (244*256*256 + 236*256 + 197);
	Ячейка.WrapText = истина;
	
	Инд = 3;
	Для каждого Стр Из Объект.ОбъектыАренды Цикл
		
		Инд = Инд +	1;
		
		Если ЭтоИК Тогда
			Ячейка =  Лист.Cells(Инд, ПК);
			Ячейка.Value = Строка(Стр.Здание);
			Ячейка.Borders.LineStyle = 1;
			Ячейка.HorizontalAlignment = 2;
			Ячейка.WrapText = истина;
		КонецЕсли;
		
		Ячейка =  Лист.Cells(Инд, ПК+1);
		Ячейка.Value = Строка(Стр.Этаж);
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, ПК+2);
		Ячейка.Value = Стр.ПомещениеНомерБТИ;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, ПК+3);
		Ячейка.Value = Стр.КомнатаНомерБТИ;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, ПК+4);
		Ячейка.Value = Стр.ИндексПоБома;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
		Ячейка =  Лист.Cells(Инд, ПК+5);
		Ячейка.Value = Стр.Площадь;
		Ячейка.Borders.LineStyle = 1;
		Ячейка.HorizontalAlignment = 2;
		Ячейка.WrapText = истина;
		
	КонецЦикла; 
	
	Попытка        
		Книга.SaveAs(ПутьКФайлу);  
		Сообщить("Файл успешно сохранен!");
	Исключение
		Сообщить(ОписаниеОшибки()+ "Файл не сохранен!");
	КонецПопытки;
	
	Эксель.Application.Quit();
	
КонецПроцедуры

&НаКлиенте
Процедура ИКНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПараметрыВыбора = Новый Массив;//(Элемент.ПараметрыВыбора);
	
	ПараметрыФормы= 	ПолучитьОбъектыАренды();
	ФормаВыбора = ПолучитьФорму("Справочник.АР_ОбъектыАренды.Форма.ФормаВыбора", ПараметрыФормы, Элемент);
	//Ф.Элементы.Объект.Отображение = ОтображениеТаблицы.Список; 
	ФормаВыбора.Элементы.Список.Отображение = ОтображениеТаблицы.Список;
	ФормаВыбора.открыть();
	
	ПараметрыВыбора = Новый Массив;//(Элемент.ПараметрыВыбора);
	
	НовыйПараметр = Новый ПараметрВыбора("ТипОбъекта", ПредопределенноеЗначение("Справочник.АР_ТипыОбъектовАренды.Здание"));
	ПараметрыВыбора.Добавить(НовыйПараметр);
	
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОбъектыАренды()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АР_ОбъектыАренды.Ссылка
	|ИЗ
	|	Справочник.АР_ОбъектыАренды КАК АР_ОбъектыАренды
	|ГДЕ
	|	(АР_ОбъектыАренды.ТипОбъекта = &ИК
	|			ИЛИ АР_ОбъектыАренды.ТипОбъекта = &Зд)";
	
	Запрос.УстановитьПараметр("Зд", Справочники.АР_ТипыОбъектовАренды.Здание);
	Запрос.УстановитьПараметр("ИК", Справочники.АР_ТипыОбъектовАренды.ИмущественныйКомплекс);
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	М = Новый Массив;
	
	Пока РЗ.Следующий() Цикл
		М.Добавить(РЗ.Ссылка);
	КонецЦикла; 
	
	СЗ = Новый СписокЗначений;
	СЗ.ЗагрузитьЗначения(М);
	
	//Возврат СЗ;
	
	НастройкиКомп = Новый НастройкиКомпоновкиДанных;
	
	ОтборСписка = НастройкиКомп.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборСписка.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка");
	ОтборСписка.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	ОтборСписка.ПравоеЗначение = СЗ;
	ОтборСписка.Использование = Истина;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ФиксированныеНастройки", НастройкиКомп);
	//ПараметрыФормы.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы); // Здесь устанавливается возможность выбора не только элементов, но групп
	ПараметрыФормы.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.Группы); // Здесь устанавливается возможность выбора не только элементов, но групп
	
	Возврат ПараметрыФормы;
	//ОткрытьФорму("Справочник.ДоговорыКонтрагентов.Форма.ФормаВыбора", ПараметрыФормы, Элемент);
	//ОткрытьФорму("Справочник.АР_ОбъектыАренды.Форма.ФормаВыбора", ПараметрыФормы, Элемент);
	
	
КонецФункции

