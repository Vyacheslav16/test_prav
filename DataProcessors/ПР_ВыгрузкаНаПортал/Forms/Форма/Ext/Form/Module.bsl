	Запрос.УстановитьПараметр("ДатаН",НачалоМесяца(Объект.ТекПериод));
	Запрос.УстановитьПараметр("ДатаК",КонецМесяца(Объект.ТекПериод));
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
	Запрос.УстановитьПараметр("ИК",Объект.ИК);
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	//Запрос.УстановитьПараметр("Статус",Справочники.бит_СтатусыОбъектов.Утвержден);
	
	тз = Новый ТаблицаЗначений;
	тз = Запрос.Выполнить().Выгрузить();
	тз.Сортировать("АгентскийДоговор,Договор, Реализация УБЫВ");
	
	Для Каждого Стр Из тз Цикл
		НовСтр = ТабДокументов.Добавить();
		Для Каждого Кол Из тз.Колонки Цикл
			НовСтр[Кол.Имя] = Стр[Кол.Имя];
		КонецЦикла;
		НовСтр.Печатать = Истина;
	КонецЦикла;

	//Возврат ТЗ;
	
