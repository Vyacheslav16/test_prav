Функция ДоходнаяПрограмма(АгентскийДоговор,Период)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_Д_ОтчетИнвестора.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	АР17_Д_ОтчетИнвестора.ДоговорИнвестора = &Ссылка
	               |	И КОНЕЦПЕРИОДА(АР17_Д_ОтчетИнвестора.Период, МЕСЯЦ) = &Период";
	Запрос.УстановитьПараметр("Ссылка",АгентскийДоговор);
	Запрос.УстановитьПараметр("Период",КонецМесяца(Период));
	Рез = Запрос.Выполнить().Выгрузить();
	Если Рез.Количество() = 0 Тогда 
		Возврат Ложь;
	КонецЕсли;
	Возврат Истина;
