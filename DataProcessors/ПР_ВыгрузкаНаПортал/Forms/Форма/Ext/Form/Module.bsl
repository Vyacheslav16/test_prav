&НаКлиенте
Процедура Заполнить(Команда)
	
	ТабДокументов.Очистить();
	ПолучитьТабДокументов();

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ТекПериод = ВыборПериодаКлиентСервер.ПолучитьПредставлениеПериодаОтчета(
	Перечисления.ДоступныеПериодыОтчета.Месяц, НачалоМесяца(ТекущаяДата()), КонецМесяца(ТекущаяДата()));
	Объект.ТекПериод = НачалоМесяца(ТекущаяДата());
КонецПроцедуры

Функция ЭтоТовар(Реализация)
	Возврат Реализация.Товары.Количество() > 0;
КонецФункции

Функция ЭтоОтчет(Реализация)
	Возврат ТипЗнч(Реализация) = Тип("ДокументСсылка.АР17_Д_ОтчетИнвестора");
КонецФункции

Функция НомерРеализации(Реализация)
	Возврат Реализация.Номер;
КонецФункции

