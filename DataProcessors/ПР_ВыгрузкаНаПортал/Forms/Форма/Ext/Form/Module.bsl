Функция НайтиПочтуКонтрагентов(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.АдресЭП
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка.ИНН = &ИНН
		|	И КонтрагентыКонтактнаяИнформация.Ссылка.КПП = &КПП";
		
	Запрос.Параметры.Вставить("ИНН", Контрагент.ИНН);
	Запрос.Параметры.Вставить("КПП", Контрагент.КПП);
	Получатели = Запрос.Выполнить().Выгрузить();
	Возврат Получатели;
	
	
КонецФункции	

