&НаСервере
Функция НайтиСФТСЖ(Документ)
	
	МСФ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураВыданный.Ссылка КАК СФ
		|ПОМЕСТИТЬ ВТСФВсе
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактураВыданный
		|ГДЕ
		|	СчетФактураВыданный.Дата >= &ДатаН
		|	И СчетФактураВыданный.Дата <= &ДатаК
		|	И СчетФактураВыданный.ДоговорКонтрагента = &ДоговорКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСФВсе.СФ КАК СФ
		|ИЗ
		|	ВТСФВсе КАК ВТСФВсе
		|ГДЕ
		|	ПОДСТРОКА(ВТСФВсе.СФ.Комментарий, 0, 17) = ""Номер из базы ТСЖ""";
	
	Запрос.УстановитьПараметр("ДатаК", КонецДня(КонецМесяца(Объект.ТекПериод)));
	Запрос.УстановитьПараметр("ДатаН", НачалоМесяца(Объект.ТекПериод));
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Документ);

	РЗ = Запрос.Выполнить().Выбрать();
	
	Пока РЗ.Следующий() Цикл
		МСФ.Добавить(РЗ.СФ);
	КонецЦикла;
	
	Возврат МСФ;
	
