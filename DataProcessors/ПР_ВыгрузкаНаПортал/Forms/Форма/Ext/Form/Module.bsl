Функция ПолучитьВсеОтчеты(Отчет)
	Отчеты_ = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР17_Д_ОтчетИнвестора.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
	               |ГДЕ
	               |	АР17_Д_ОтчетИнвестора.ИК = &ИК
	               |	И АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Контрагент = &Контрагент
	               |	И АР17_Д_ОтчетИнвестора.Проведен
	               |	И АР17_Д_ОтчетИнвестора.Период = &Период";
	Запрос.УстановитьПараметр("ИК",Отчет.ИК);
	Запрос.УстановитьПараметр("Контрагент",Отчет.ДоговорИнвестора.Контрагент);
	Запрос.УстановитьПараметр("Период",Отчет.Период);
    Рез = Запрос.Выполнить().Выгрузить();
	Для Каждого стр Из Рез Цикл
		Отчеты_.Добавить(стр.Ссылка);
	КонецЦикла;
	Возврат Отчеты_;
КонецФункции	
	
