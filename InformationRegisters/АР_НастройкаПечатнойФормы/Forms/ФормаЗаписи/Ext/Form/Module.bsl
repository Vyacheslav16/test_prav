		//ЭлементСправочника=ТекущийОбъект;
		//Отбор = Новый Структура;
		//Отбор.Вставить("Организация", ЭлементСправочника.Организация);
		//Отбор.Вставить("ОбъектыАренды", ЭлементСправочника.ОбъектыАренды);
		//Отбор.Вставить("ГруппаУслуг", ЭлементСправочника.ГруппаУслуг);
		//Отбор.Вставить("ЗаКогоПодписывает", ЭлементСправочника.ЗаКогоПодписывает);
		//Отбор.Вставить("ВидДоговора", ЭлементСправочника.ВидДоговора);
