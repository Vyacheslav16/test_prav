&НаКлиенте 
Процедура ПослеЗагрузкиФайла(ВыбранныйФайл,ДопПараметр) Экспорт 
	Если ВыбранныйФайл = Неопределено Тогда 
		Возврат; 
	КонецЕсли; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПомещенияФайла", ЭтаФорма, ДопПараметр); 
	НачатьПомещениеФайла(ОписаниеОповещения,, ВыбранныйФайл[0], Ложь, УникальныйИдентификатор); 
КонецПроцедуры	

&НаКлиенте 
Процедура ПослеПомещенияФайла(Результат, Адрес, ВыбранноеИмяФайла,ДопПараметры) Экспорт 
	Если Не Результат Тогда 
		Возврат; 
	КонецЕсли;
	Если ДопПараметры = "Печать" Тогда
		АдресПечать = Адрес; 
	ИначеЕсли ДопПараметры = "ПодписьРуководителя" Тогда
		АдресПодписьРуководителя = Адрес;
	КонецЕсли;	
	Модифицированность = Истина; 
КонецПроцедуры

Процедура УстановитьИзображение(хз,ИмяЭлементаСКартинкой)
	
	Если хз = Неопределено Тогда
		ХранНовое = Новый ХранилищеЗначения(Неопределено);
	Иначе	
		файл = ПолучитьИзВременногоХранилища(хз);
		ИмяТемпФайла = ПолучитьИмяВременногоФайла();
		файл.Записать(ИмяТемпФайла);
		НовоеХД=Новый Картинка(ИмяТемпФайла); 
	    ХранНовое=Новый ХранилищеЗначения(НовоеХД); 
	КонецЕсли;
    ЭлементСправочника = РеквизитФормыВЗначение("Запись");
	Если ИмяЭлементаСКартинкой = "Печать" Тогда
    	ЭлементСправочника.ФайлПечать=ХранНовое; 
	Иначе
    	ЭлементСправочника.ФайлПодписьРуководителя=ХранНовое; 
	КонецЕсли;	
    ЭлементСправочника.Записать(); 
    ЗначениеВРеквизитФормы(ЭлементСправочника, "Запись");
	
КонецПроцедуры 

