Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	ТабРезультат = Новый ТаблицаЗначений;
    КЧ = Новый КвалификаторыЧисла(12,2);
    КД = Новый КвалификаторыДаты(ЧастиДаты.Дата);
    КС = Новый КвалификаторыСтроки(80);
    Массив = Новый Массив;
    Массив.Добавить(Тип("Число"));
    ОписаниеТиповЧ = Новый ОписаниеТипов(Массив, , ,КЧ);
    Массив.Очистить();
    Массив.Добавить(Тип("Дата"));
    ОписаниеТиповД = Новый ОписаниеТипов(Массив, , ,КД);
	Массив.Очистить();
	Массив.Добавить(Тип("Строка"));
    ОписаниеТиповС = Новый ОписаниеТипов(Массив, , КС);
	
	ТабРезультат.Колонки.Добавить("ВидДоговора",Новый описаниеТипов("СправочникСсылка.АР_ВидыДоговоров"));
	ТабРезультат.Колонки.Добавить("ИмущественныйКомплекс",Новый ОписаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Контрагент",Новый описаниеТипов("СправочникСсылка.Контрагенты"));
	ТабРезультат.Колонки.Добавить("Договор",Новый описаниеТипов("ДокументСсылка.АР17_ЗаключениеДоговораАренды"));
	ТабРезультат.Колонки.Добавить("Счет", ОписаниеТиповС); //Новый описаниеТипов("ДокументСсылка.АР17_СчетНаАренду"));
	
	ТабРезультат.Колонки.Добавить("Организация",Новый описаниеТипов("СправочникСсылка.Организации"));
	
	ТабРезультат.Колонки.Добавить("Задолженность",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("СрокОплаты",ОписаниеТиповД);
	ТабРезультат.Колонки.Добавить("ПросроченныйПериод",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("ПросроченнаяЗадолженность",ОписаниеТиповЧ);
	
	ТабРезультат.Колонки.Добавить("Период1",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Период2",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Период3",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Период4",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Ответственный", ОписаниеТиповС);
	
	ТабРезультат.Колонки.Добавить("НачалоПериода", ОписаниеТиповД);

	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		//"ВЫБРАТЬ
		//|	АР17_ЗаключениеДоговораАренды.Ссылка,
		//|	МАКСИМУМ(АР17_ЗаключениеДоговораАренды.СуммаЗалога) КАК СуммаЗалога,
		//|	АР17_ЗаключениеДоговораАренды.ОбщаяПлощадь,
		//|	АР17_ЗаключениеДоговораАренды.Дата
		//|ИЗ
		//|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		//|ГДЕ
		//|	АР17_ЗаключениеДоговораАренды.ФактическоеОкончание <= &ДатаКон
		//|
		//|СГРУППИРОВАТЬ ПО
		//|	АР17_ЗаключениеДоговораАренды.Ссылка,
		//|	АР17_ЗаключениеДоговораАренды.ОбщаяПлощадь,
		//|	АР17_ЗаключениеДоговораАренды.Дата";
		
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АР_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АР_РасчетыПоДоговорамОстаткиИОбороты.Месяц) КАК Месяц,
	|	АР17_ЗаключениеДоговораАренды.Ссылка КАК Ссылка
	|ИЗ
	|	РегистрНакопления.АР_РасчетыПоДоговорам.ОстаткиИОбороты(, &ДатаКон, , , ) КАК АР_РасчетыПоДоговорамОстаткиИОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|		ПО АР_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента = АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента
	|
	|СГРУППИРОВАТЬ ПО
	|	АР_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента,
	|	АР17_ЗаключениеДоговораАренды.Ссылка";
		
	
	КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроек.ПолучитьНастройки());
	Настройки = КомпоновщикНастроек.Настройки; 
	
	//+ конец периода
	ИдНастройки = КомпоновщикНастроек.ПользовательскиеНастройки.ПолучитьИдентификаторПоОбъекту
	(КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("СтандартныйПериод")));
	ПараметрСКД = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(ИдНастройки);
	КонецПериода = ПараметрСКД.Значение.ДатаОкончания;
	НачалоПериода = ПараметрСКД.Значение.ДатаНачала;
	//- конец периода
	
	Запрос.УстановитьПараметр("ДатаКон",Дата(КонецПериода));
	//Запрос.УстановитьПараметр("ДоговорКонтрагента",Справочники.ДоговорыКонтрагентов.НайтиПоКоду("00-000046"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДог = РезультатЗапроса.Выбрать();
	Пока ВыборкаДог.Следующий() Цикл
		
		Задолженность = 0;
		//////////////////////////////+
		ТЗ = ПолучитьОЗ(ВыборкаДог.Ссылка,КонецПериода);
	
		//Мес = РазбитьПериод(ВыборкаДог.Ссылка.Дата, Мин(КонецПериода, ВыборкаДог.Ссылка.ФактическоеОкончание));
		Мес = РазбитьПериод(НачалоПериода, Мин(КонецПериода, ВыборкаДог.Ссылка.ФактическоеОкончание));
		Для Каждого СтрМес из Мес Цикл
			Нач = НачалоМесяца(СтрМес.НачалоПериода);
			Если ТЗ.Найти(Нач, "НачалоПериода") = Неопределено Тогда
				НоваяСтрока = ТЗ.Добавить();
				НоваяСтрока.НачалоПериода = СтрМес.НачалоПериода;
				НоваяСтрока.СуммаОстаток = ПолучитьСуммуЗаМесяц(ВыборкаДог.Ссылка, КонецМесяца(СтрМес.НачалоПериода));
			КонецЕсли;
		КонецЦикла;
		
		ТЗ.Сортировать("НачалоПериода Возр");
		
		Для Каждого Стр из ТЗ Цикл
			
			НовСтрока=ТабРезультат.Добавить();
			НовСтрока.ВидДоговора = ВыборкаДог.Ссылка.ВидДоговора;
			НовСтрока.ИмущественныйКомплекс = ВыборкаДог.Ссылка.ИК;
			НовСтрока.Контрагент = ВыборкаДог.Ссылка.Контрагент;
			НовСтрока.Договор = ВыборкаДог.Ссылка;
			Если Стр.СчетНаАренду = Неопределено Тогда
				НовСтрока.Счет = Формат(Стр.НачалоПериода, "ДФ='ММММ yyyy'");
			Иначе
				НовСтрока.Счет = Стр.СчетНаАренду;
				//НовСтрока.Задолженность = Макс(Стр.СуммаОстаток, -Стр.СуммаОстаток);
			КонецЕсли;	
				
			НовСтрока.Организация = ВыборкаДог.Ссылка.Организация;
			НовСтрока.НачалоПериода = Стр.НачалоПериода;
			
			
			НовСтрока.СрокОплаты = Стр.НачалоПериода + ВыборкаДог.Ссылка.СрокОплаты*60*60*24 - (60*60*24) + ВыборкаДог.Ссылка.ОтсрочкаПоОплате*60*60*24;
			НовСтрока.ПросроченныйПериод = (НачалоДня(КонецПериода)-НачалоДня(НовСтрока.СрокОплаты))/(60*60*24);//Стр.Ссылка.ПросроченнаяПериод;
			ПросроченныйПериод_ = НовСтрока.СрокОплаты + НовСтрока.ПросроченныйПериод*60*60*24;
			//НовСтрока.ПросроченнаяЗадолженность = ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,ПросроченныйПериод_);
			НовСтрока.ПросроченнаяЗадолженность = ПолучитьСуммуЗаМесяц(ВыборкаДог.Ссылка, КонецМесяца(Стр.НачалоПериода));//ПолучитьСуммуОборот(ВыборкаДог.Ссылка,НачалоМесяца(Стр.НачалоПериода),КонецМесяца(Стр.НачалоПериода));
			
			Период4 = 0;
			Если НовСтрока.ПросроченныйПериод < 0 Тогда
				НовСтрока.ПросроченнаяЗадолженность = 0;
			ИначеЕсли НовСтрока.ПросроченныйПериод >= 0 и НовСтрока.ПросроченныйПериод < 8 Тогда
				НовСтрока.Период1 = ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,НовСтрока.СрокОплаты + 1*60*60*24);
				//НовСтрока.ПросроченнаяЗадолженность = НовСтрока.Период1;
				НовСтрока.Задолженность = НовСтрока.Период1;
				НовСтрока.Период1 = НовСтрока.ПросроченнаяЗадолженность;
			ИначеЕсли НовСтрока.ПросроченныйПериод >= 8 и НовСтрока.ПросроченныйПериод <= 15 Тогда	
				НовСтрока.Период2 = ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,НовСтрока.СрокОплаты + 7*60*60*24);
				//НовСтрока.ПросроченнаяЗадолженность = НовСтрока.Период2;
				НовСтрока.Задолженность = НовСтрока.Период2;
				НовСтрока.Период2 = НовСтрока.ПросроченнаяЗадолженность;
			ИначеЕсли НовСтрока.ПросроченныйПериод >= 16 и НовСтрока.ПросроченныйПериод <= 30 Тогда		
				НовСтрока.Период3 = ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,НовСтрока.СрокОплаты + 15*60*60*24);
				//НовСтрока.ПросроченнаяЗадолженность = НовСтрока.Период3;
				НовСтрока.Задолженность = НовСтрока.Период3;
				НовСтрока.Период3 = НовСтрока.ПросроченнаяЗадолженность;
			Иначе
				КолДней = Сред(КонецМесяца(НовСтрока.СрокОплаты+60*60*24), 1, 2);
				НовСтрока.Период4 = ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,НовСтрока.СрокОплаты + КолДней*60*60*24);
				//НовСтрока.ПросроченнаяЗадолженность = НовСтрока.Период4;
				НовСтрока.Задолженность = НовСтрока.Период4;
				НовСтрока.Период4 = НовСтрока.ПросроченнаяЗадолженность;
				//
				
			КонецЕсли;
			
			НовСтрока.Ответственный = ВыборкаДог.Ссылка.Ответственный;
			
			Задолженность = Задолженность + ПолучитьСуммуЗаМесяц_(ВыборкаДог.Ссылка,НовСтрока.НачалоПериода);
			НовСтрока.Задолженность = Задолженность;
			НовСтрока.ПросроченныйПериод = ?(Задолженность = 0,0,НовСтрока.ПросроченныйПериод); // + NAI Becar Комментирование Смирнов А.А. от 24.07.2017 10:39
		КонецЦикла;	

	КонецЦикла;
	
	//ТабРезультат.Сортировать("Договор Возр, НачалоПериода Возр");
	
    ВнешниеНаборыДанных = Новый Структура; 
    ВнешниеНаборыДанных.Вставить("РеестрДоговоров", ТабРезультат); 

	СтандартнаяОбработка = Ложь;
    
     КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроек.ПолучитьНастройки());
     Настройки = КомпоновщикНастроек.Настройки; 
	 
 	 ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
    
    КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
    МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);
    ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
    ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки);
    ДокументРезультат.Очистить();
    
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);   
КонецПроцедуры

Функция ПолучитьСуммуОборот(Договор, НачалоПериода, КонецПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		//"ВЫБРАТЬ ПЕРВЫЕ 1
		//|	АР_РасчетыПоДоговорамОбороты.СуммаОборот
		//|ИЗ
		//|	РегистрНакопления.АР_РасчетыПоДоговорам.Обороты(&НачалоПериода, &КонецПериода, , ДоговорКонтрагента = &ДоговорКонтрагента) КАК АР_РасчетыПоДоговорамОбороты";
		
	"ВЫБРАТЬ
	|	АР_РасчетыПоДоговорамОбороты.Организация КАК Организация,
	|	АР_РасчетыПоДоговорамОбороты.Контрагент,
	|	АР_РасчетыПоДоговорамОбороты.ДоговорКонтрагента,
	|	АР_РасчетыПоДоговорамОбороты.Регистратор.СуммаПоДоговору КАК СуммаПоДоговору,
	|	АР_РасчетыПоДоговорамОбороты.Период КАК Период,
	|	АР_РасчетыПоДоговорамОбороты.Регистратор
	|ПОМЕСТИТЬ ВТ_Дог
	|ИЗ
	|	РегистрНакопления.АР_РасчетыПоДоговорам.Обороты(&НачалоПериода, &КонецПериода, Регистратор, ) КАК АР_РасчетыПоДоговорамОбороты
	|ГДЕ
	|	АР_РасчетыПоДоговорамОбороты.Регистратор ССЫЛКА Документ.АР17_ПроведениеДоговораАренды
	|	И 
	|АР_РасчетыПоДоговорамОбороты.СуммаОборот > 0
	|	И 
	|АР_РасчетыПоДоговорамОбороты.ДоговорКонтрагента = &ДоговорКонтрагента
	|
	|СГРУППИРОВАТЬ ПО
	|	АР_РасчетыПоДоговорамОбороты.ДоговорКонтрагента,
	|	АР_РасчетыПоДоговорамОбороты.Организация,
	|	АР_РасчетыПоДоговорамОбороты.Контрагент,
	|	АР_РасчетыПоДоговорамОбороты.Период,
	|	АР_РасчетыПоДоговорамОбороты.Регистратор,
	|	АР_РасчетыПоДоговорамОбороты.Регистратор.СуммаПоДоговору
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Дог.Регистратор.ДоговорАренды.Организация КАК Организация,
	|	ВТ_Дог.Регистратор.ДоговорАренды.Контрагент КАК Контрагент,
	|	ВТ_Дог.Регистратор.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	СУММА(ВТ_Дог.Регистратор.СуммаПоДоговору) КАК СуммаПоДоговору
	|ИЗ
	|	ВТ_Дог КАК ВТ_Дог
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Дог.Регистратор.ДоговорКонтрагента,
	|	ВТ_Дог.Регистратор.ДоговорАренды.Контрагент,
	|	ВТ_Дог.Регистратор.ДоговорАренды.Организация";	

	
	Запрос.УстановитьПараметр("ДоговорКонтрагента", Договор.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	//Запрос.УстановитьПараметр("Месяц", НачалоМесяца(Дата));
	
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		Возврат РЗ.СуммаПоДоговору;
	Иначе
		Возврат 0;
	КонецЕсли;

КонецФункции	

