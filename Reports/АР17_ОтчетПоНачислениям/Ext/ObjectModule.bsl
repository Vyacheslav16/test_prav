	МесяцКонец = Месяц(КонецПериода);
	Сумма = 0;
	//Если (День(НачалоМесяца(НачалоПериода)) <> День(НачалоПериода)) или (День(КонецМесяца(КонецПериода)) <> День(КонецПериода)) Тогда
		Сумма = Сумма + КоличествоДней*СтоимостьОдногоДня;
	//Иначе
