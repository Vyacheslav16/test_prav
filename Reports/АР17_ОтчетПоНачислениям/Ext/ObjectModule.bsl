Функция АР_РасчитатьСумму(ДатаНачалаАренды,ДатаОкончанияАренды,НачалоПериода,КонецПериода,СпособНачисления,Ставка,Сумма,Количество,ДоговорКонтрагента)
	
		Сумма1=Сумма;
	
		Если СпособНачисления.ИмяПредопределенныхДанных = "Директивный" Тогда
	    	//
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "КоличестваДнейАренды" Тогда
			КоличествоДней = КоличествоДней(ДатаНачалаАренды,ДатаОкончанияАренды, НачалоПериода, КонецПериода);
			Сумма1 = АР17_РассчитатьСтрокуНачисления(ДатаНачалаАренды,ДатаОкончанияАренды,СпособНачисления,Сумма,Ставка,Количество,НачалоПериода,КонецПериода,КоличествоДней);
			Сумма1 = Сумма1/День(КонецМесяца(НачалоПериода)) * КоличествоДней;
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "КоличестваМесяцевКонтракта" Тогда
			РазницаВМесяцах = РазницаВМесяцах(НачалоПериода, КонецПериода)+1;
			Сумма1 = Сумма/РазницаВМесяцах;
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "КоличестваКалендарныхДней" Тогда
			Сумма1 = АР17_РассчитатьСтрокуНачисления(ДатаНачалаАренды,ДатаОкончанияАренды,СпособНачисления,Сумма,Ставка,Количество,ДатаНачалаАренды,ДатаОкончанияАренды);
			КоличествоДней = КоличествоДней(ДатаНачалаАренды,ДатаОкончанияАренды,ДатаНачалаАренды,ДатаОкончанияАренды);
			СтоимостьОдногоДня 	= ?(КоличествоДней=0,0,Сумма1/КоличествоДней);
			//ПериодАренды = ((КонецДня(ПериодКонец) + 1) - ПериодНачало)/86400;
			ПериодАренды = ((КонецДня(КонецПериода) + 1) - НачалоПериода)/86400;
			Сумма1 = ПериодАренды*СтоимостьОдногоДня;
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "СтоимостьЗаМесяцСчетЗаКварталАктЗаМесяц" Тогда
			Сумма1 = АР17_РассчитатьСтрокуНачисления(ДатаНачалаАренды,ДатаОкончанияАренды,СпособНачисления,Сумма,Ставка,Количество,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);
			КоличествоДней = КоличествоДней(ДатаНачалаАренды,ДатаОкончанияАренды,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);//(СтрокаТаб.ДатаОкончанияАренды - СтрокаТаб.ДатаНачалаАренды) / 86400;
			СтоимостьОдногоДня 	= ?(КоличествоДней=0,0,Сумма1/КоличествоДней);
			Сумма1 = СтоимостьПоКварталам(СтоимостьОдногоДня,ДатаНачалаАренды,ДатаОкончанияАренды);
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "СтоимостьЗаМесяцСчетЗаКварталАктЗаКвартал" Тогда
			Сумма1 = АР17_РассчитатьСтрокуНачисления(ДатаНачалаАренды,ДатаОкончанияАренды,СпособНачисления,Сумма,Ставка,Количество,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);
			КоличествоДней = КоличествоДней(ДатаНачалаАренды,ДатаОкончанияАренды,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);//(СтрокаТаб.ДатаОкончанияАренды - СтрокаТаб.ДатаНачалаАренды) / 86400;
			СтоимостьОдногоДня 	= ?(КоличествоДней=0,0,Сумма1/КоличествоДней);
			Сумма1 = СтоимостьПоКварталам(СтоимостьОдногоДня,ДатаНачалаАренды,ДатаОкончанияАренды);
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "СтоимостьЗаКварталСчетЗаКварталАктЗаКвартал" Тогда	
			Сумма1 = АР17_РассчитатьСтрокуНачисления(ДатаНачалаАренды,ДатаОкончанияАренды,СпособНачисления,Сумма,Ставка,Количество,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);
			КоличествоДней = КоличествоДней(ДатаНачалаАренды,ДатаОкончанияАренды,ДатаНачалаАренды,ДатаОкончанияАренды-60*60*24);//(СтрокаТаб.ДатаОкончанияАренды - СтрокаТаб.ДатаНачалаАренды) / 86400;
			СтоимостьОдногоДня 	= ?(КоличествоДней=0,0,Сумма1/КоличествоДней);
			Сумма1 = СтоимостьПоКварталам(СтоимостьОдногоДня,ДатаНачалаАренды,ДатаОкончанияАренды);
		ИначеЕсли СпособНачисления.ИмяПредопределенныхДанных = "В_руб_за_м2_год" Тогда
			
			Если ДоговорКонтрагента.АР_ВестиВзаиморасчетыПоПериодам Тогда
				Периодичность = ДоговорКонтрагента.АР_Периодичность;
			Иначе
				Периодичность = СпособНачисления.ПериодНачисления;
				Если Не ЗначениеЗаполнено(Периодичность) Тогда
					Периодичность = Константы.АР_ПериодНачисленияАренднойПлаты.Получить();
				КонецЕсли;
			КонецЕсли;
			ПериодАренды = НачалоПериода(НачалоПериода, Периодичность);		
			// Если периодичность больше месяца, то разобъем по месяцам
			// кроме случа Периодичность = Год и период начисления - календарный год или несколько
			Если Периодичность = Перечисления.Периодичность.Год
				И НачалоПериода = НачалоГода(НачалоПериода)
				И КонецДня(КонецПериода) = КонецГода(КонецПериода) Тогда
			ИначеЕсли Не (Периодичность = Перечисления.Периодичность.День ИЛИ Периодичность = Перечисления.Периодичность.Неделя) Тогда
