Функция ПолучитьМакетНаСервере()
	Возврат Отчеты.АР17_ОтчетПоНачислениям.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");	
КонецФункции 

Процедура СформироватьОтчет(НастройкиРасшифровки)
	
	//МакетСКД = Отчеты.АР_ОтчетПоНачислениям.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	МакетСКД = Отчеты.АР17_ОтчетПоНачислениям.ПолучитьМакет("Расшифровка");
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(МакетСКД.НастройкиПоУмолчанию);
	Настройки = КомпоновщикНастроек.Настройки;//.ПолучитьНастройки();
	//
	//КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиРасшифровки);
	//Настройки = КомпоновщикНастроек.Настройки;//.ПолучитьНастройки();
	//
	
    ДанныеРасшифровкиОтчета = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	// параметры
    Настройки.ПараметрыДанных.Элементы.Найти("ВидДокумента").Значение = НастройкиРасшифровки.ПараметрыДанных.Элементы.Найти("ВидДокумента").Значение; //"Счета";
	Настройки.ПараметрыДанных.Элементы.Найти("ДатаНачало").Значение = НастройкиРасшифровки.ПараметрыДанных.Элементы.Найти("ДатаНачало").Значение;
	Настройки.ПараметрыДанных.Элементы.Найти("ДатаКонец").Значение = НастройкиРасшифровки.ПараметрыДанных.Элементы.Найти("ДатаКонец").Значение;
	
	// отборы
	ОтборДоговор = КомпоновщикНастроек.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборДоговор.ЛевоеЗначение 		= Новый ПолеКомпоновкиДанных("Договор");
	ОтборДоговор.ВидСравнения 		= ВидСравненияКомпоновкиДанных.Равно;
	ОтборДоговор.ПравоеЗначение 	= НастройкиРасшифровки.Отбор.Элементы[4].ПравоеЗначение.ДоговорКонтрагента;
	ОтборДоговор.Использование 		= Истина;
	//ОтборДоговор.РежимОтображения 	= РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
    КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
    МакетКомпоновки = КомпоновщикМакета.Выполнить(МакетСКД, Настройки, ДанныеРасшифровкиОтчета);
    
    ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
    ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровкиОтчета);

    ДокументРезультат = Результат;
	ДокументРезультат.Очистить(); 
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	//ДокументРезультат.Показать();

КонецПроцедуры	

