<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Сумма</dataPath>
			<field>Сумма</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Документ</dataPath>
			<field>Документ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Документ</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Договор</dataPath>
			<field>Договор</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Договор</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВЫБОР
		КОГДА &amp;ВидДокумента = "Счета"
			ТОГДА АР_СчетНаАренду.Ссылка
		ИНАЧЕ АР_НачислениеАренднойПлаты.Ссылка
	КОНЕЦ КАК Документ,
	ВЫБОР
		КОГДА &amp;ВидДокумента = "Счета"
			ТОГДА АР_СчетНаАренду.Ссылка.СуммаДокумента
		ИНАЧЕ АР_НачислениеАренднойПлаты.СуммаДокумента
	КОНЕЦ КАК Сумма,
	ВЫБОР
		КОГДА &amp;ВидДокумента = "Счета"
			ТОГДА АР_СчетНаАренду.ДоговорКонтрагента
		ИНАЧЕ АР_НачислениеАренднойПлаты.ДоговорКонтрагента
	КОНЕЦ КАК Договор
ИЗ
	Документ.АР17_НачислениеАренднойПлаты КАК АР_НачислениеАренднойПлаты,
	Документ.АР17_СчетНаАренду КАК АР_СчетНаАренду
ГДЕ
	ВЫБОР
			КОГДА &amp;ДатаНачало &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
					И &amp;ДатаКонец &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ВЫБОР
						КОГДА &amp;ВидДокумента = "Счета"
							ТОГДА АР_СчетНаАренду.НачалоПериода &lt;= &amp;ДатаКонец
									И АР_СчетНаАренду.ОкончаниеПериода &gt;= &amp;ДатаНачало
						ИНАЧЕ АР_НачислениеАренднойПлаты.НачалоПериода &lt;= &amp;ДатаКонец
								И АР_НачислениеАренднойПлаты.ОкончаниеПериода &gt;= &amp;ДатаНачало
					КОНЕЦ
		КОНЕЦ</query>
	</dataSet>
