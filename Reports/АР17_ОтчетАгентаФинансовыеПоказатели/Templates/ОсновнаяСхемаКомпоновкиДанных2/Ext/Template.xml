		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ДоговорыКонтрагентов.Ссылка КАК ДоговорКонтрагента,
	АР_ЗаключениеДоговораАренды.Ссылка КАК ДоговорДокумент,
	АР_ЗаключениеДоговораАренды.Контрагент КАК Контрагент,
	АР_ЗаключениеДоговораАренды.Дата КАК Дата,
	ПениОстаткиИОбороты.СуммаНачальныйОстаток КАК ПениНачисленоНаНачалоПериода,
	ПениОстаткиИОбороты.СуммаОборот КАК ПениНачисленоЗаПериод,
	ПениОстаткиИОбороты.СуммаКонечныйОстаток КАК ПениНаКонецПериода,
	ОбеспечительныйПлатеж.СуммаОстаток КАК ОбеспечительныйПлатеж,
	ПредоплатаТаблица.СуммаНачальныйОстаток КАК Предоплата,
	ПредоплатаТаблица.СуммаОборот КАК СуммаОборотДепозит,
	ПредоплатаТаблица.СуммаКонечныйОстаток КАК ПредоплатаИтог,
	АрендаОбороты.СуммаНачальныйОстаток КАК НачальныйДолг,
	АрендаОбороты.СуммаОборот КАК НачисленоВсего,
	АрендаОбороты.СуммаКонечныйОстаток КАК КонечныйДолг,
	ОплаченоОборотыТолько.СуммаОборот КАК Оплачено,
	Начисленно.СуммаОборот КАК Начислено,
	Начисленно.КоличествоКорОборот КАК Площадь,
	Начисленно.КорСубконто3 Как Услуга
ИЗ
	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		ПО (АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка)
		И АР_ЗаключениеДоговораАренды.ФактическоеЗакрытие = &amp;ПустаяДата ИЛИ АР_ЗаключениеДоговораАренды.ФактическоеЗакрытие &gt; &amp;ПериодКон
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;ПериодНач, &amp;ПериодКон, Период, , , , Субконто3 ССЫЛКА Документ.АР_НачислениеПени) КАК ПениОстаткиИОбороты
		ПО (ПениОстаткиИОбороты.Субконто2 = ДоговорыКонтрагентов.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Остатки(&amp;ПериодНач, Счет.Код = "62.04", , ) КАК ОбеспечительныйПлатеж
		ПО (ОбеспечительныйПлатеж.Субконто2 = ДоговорыКонтрагентов.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;ПериодНач, &amp;ПериодКон, Период, , Счет.Код = "62.02", , ) КАК ПредоплатаТаблица
		ПО (ПредоплатаТаблица.Субконто2 = ДоговорыКонтрагентов.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;ПериодНач, &amp;ПериодКон, Период, , Счет.Код = "62.01", , ) КАК АрендаОбороты
		ПО (АрендаОбороты.Субконто2 = ДоговорыКонтрагентов.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Обороты(&amp;ПериодНач, &amp;ПериодКон, Запись, Счет.Код = "62.01", , , , ) КАК Начисленно
		ПО (Начисленно.Субконто2 = ДоговорыКонтрагентов.Ссылка) И Начисленно.КорСубконто3 ссылка справочник.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ХозрасчетныйОборотыДтКт.СубконтоКт2 КАК ДоговорКонтрагента,
			СУММА(ХозрасчетныйОборотыДтКт.СуммаОборот) КАК СуммаОборот
		ИЗ
			РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(&amp;ПериодНач, &amp;ПериодКон, Регистратор, , , счетКТ.Код = "62.01", , ) КАК ХозрасчетныйОборотыДтКт
		ГДЕ
			(ХозрасчетныйОборотыДтКт.Регистратор ССЫЛКА Документ.ПриходныйКассовыйОрдер
					ИЛИ ХозрасчетныйОборотыДтКт.Регистратор ССЫЛКА Документ.ПоступлениеНаРасчетныйСчет)
		
		СГРУППИРОВАТЬ ПО
			ХозрасчетныйОборотыДтКт.СубконтоКт2) КАК ОплаченоОборотыТолько
		ПО (ОплаченоОборотыТолько.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка)</query>
	</dataSet>
