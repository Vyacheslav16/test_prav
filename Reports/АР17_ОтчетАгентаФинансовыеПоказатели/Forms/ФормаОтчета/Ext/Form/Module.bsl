	Область.Параметры.ДЗ = ?((АрендаНачисленоТекущие+ДопНачисленоТекущие) = 0,0,Окр(Область.Параметры.Сумма/(АрендаНачисленоТекущие+ДопНачисленоТекущие)*100,2));
	ИтогоИКСумма = ИтогоИКСумма + Область.Параметры.Сумма;
	ТД.Вывести(Область);
	
