	               |			ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокКт КАК СуммаКонечныйОстатокКт,
	               |			ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Субконто2
	               |		ИЗ
	               |			РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	               |					&НачалоПериода,
	               |					&КонецПериода,
	               |					,
	               |					,
	               |					Счет.Код = ""62.02""
	               |						ИЛИ Счет.Код = ""76.09"",
	               |					,
	               |					) КАК ХозрасчетныйОстаткиИОбороты) КАК ПредоплатаИтог
	               |		ПО ВТ_Ставки.Договор = ПредоплатаИтог.Субконто2
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	               |				&НачалоПериода,
	               |				&КонецПериода,
	               |				,
	               |				,
	               |				Счет.Код = ""62.02""
	               |					ИЛИ Счет.Код = ""76.09"",
	               |				,
	               |				) КАК Предоплата
	               |		ПО ВТ_Ставки.Договор = Предоплата.Субконто2
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РасчетыПоДоговорамОстаткиИОбороты КАК ВТ_РасчетыПоДоговорамОстаткиИОбороты
	               |		ПО ВТ_Ставки.Договор = ВТ_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА &Договор <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	               |				ТОГДА ВТ_Ставки.Договор = &Договор
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |				ТОГДА ВТ_Ставки.Договор.Владелец = &Контрагент
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &Организация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	               |				ТОГДА ВТ_Ставки.Договор.Организация = &Организация
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &ИК <> ЗНАЧЕНИЕ(Справочник.АР_ОбъектыАренды.ПустаяСсылка)
	               |				ТОГДА ВТ_Ставки.Регистратор.ИК = &ИК
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И (СуммыПоДоговорам.ДатаНачалаСрокаАренды <= &КонецПериода
	               |				И СуммыПоДоговорам.ДатаОкончанияСрокаАренды >= &НачалоПериода
	               |			ИЛИ Предоплата.СуммаНачальныйОстатокКт > 0
	               |			ИЛИ ОбеспечительныйПлатеж.СуммаКонечныйОстатокКт > 0
	               |			ИЛИ Остатки.НачальныйОстаток > 0
	               |			ИЛИ Оплачено.СуммаОборот > 0
	               |			ИЛИ АрендаОбороты.СуммаКонечныйОстаток > 0)";
					
					Если ВидДоговора.Количество() > 0 Тогда
					Запрос.Текст = Запрос.Текст + " и	ВТ_Ставки.Регистратор.ВидДоговора В (&ВидДоговора)";
					КонецЕсли;
					Запрос.Текст = Запрос.Текст + "
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВТ_Ставки.Договор.Владелец.Наименование,
	               |	ВТ_Ставки.Договор.Наименование";
				   
				   
				   
	Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
	Запрос.УстановитьПараметр("Организация",Отчет.Организация);
	Запрос.УстановитьПараметр("ИК",Отчет.ИК);
	Запрос.УстановитьПараметр("Договор",Договор);
	Запрос.УстановитьПараметр("НачалоПериода",Отчет.НачалоПериода);			   
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(Отчет.КонецПериода));
	Запрос.УстановитьПараметр("Статус",Статус);
	
	Если ВидДоговора.Количество() > 0 Тогда
	Запрос.УстановитьПараметр("ВидДоговора",ВидДоговора);
		//МассивВД = Новый Массив;
		//
		//Для каждого Стр Из ВидДоговора Цикл
		//	МассивВД.Добавить(Стр.Значение);
		//КонецЦикла;
		//
		//Запрос.УстановитьПараметр("ВидДоговора", МассивВД);
		
	КонецЕсли; 
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	
	Возврат Выгрузка;
	
КонецФункции	

Функция ПолучитьСписокОП_(Договор,Дата)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	-ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток КАК ОбеспечительныйПлатеж,
	               |	ХозрасчетныйОстаткиИОбороты.Период КАК Период,
	               |	ХозрасчетныйОстаткиИОбороты.Регистратор КАК Регистратор
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	               |			,
	               |			&КонецПериода,
	               |			Регистратор,
	               |			,
	               |			Счет.Код = ""62.04""
	               |				ИЛИ Счет.Код = ""76.09.1"",
	               |			,
	               |			Субконто2 = &Договор) КАК ХозрасчетныйОстаткиИОбороты";
				   
				   Запрос.УстановитьПараметр("КонецПериода",КонецДня(Дата));
				   Запрос.УстановитьПараметр("Договор",Договор);
				   Выгрузка = Запрос.Выполнить().Выгрузить();
				   Выборка = Запрос.Выполнить().Выбрать();
				   Если Выборка.Следующий() Тогда					   
						Возврат Выборка.ОбеспечительныйПлатеж;
					Иначе
						Возврат 0;
					КонецЕсли;	
КонецФункции	

Функция ПолучитьОплачено(ДоговорКонтрагента)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ХозрасчетныйОборотыДтКт.СуммаОборот КАК СуммаОборот,
	               |	ХозрасчетныйОборотыДтКт.СубконтоКт2 КАК ДоговорКонтрагента,
	               |	ХозрасчетныйОборотыДтКт.Период КАК Период,
	               |	ХозрасчетныйОборотыДтКт.Регистратор КАК Регистратор
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
	               |			&НачалоПериода,
	               |			&КонецПериода,
	               |			Регистратор,
	               |			,
	               |			,
	               |			СчетКт.Код = ""62.01""
	               |				ИЛИ СчетКт.Код = ""62.02""
	               |				ИЛИ СчетКт.Код = ""76.09"",
	               |			,
	               |			) КАК ХозрасчетныйОборотыДтКт
	               |ГДЕ
	               |	ТИПЗНАЧЕНИЯ(ХозрасчетныйОборотыДтКт.Регистратор) <> ТИП(Документ.РеализацияТоваровУслуг)
	               |	И ХозрасчетныйОборотыДтКт.СубконтоКт2 = &ДоговорКонтрагента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ХозрасчетныйОборотыДтКт.СубконтоКт2,
	               |	ХозрасчетныйОборотыДтКт.Период,
	               |	ХозрасчетныйОборотыДтКт.Регистратор,
	               |	ХозрасчетныйОборотыДтКт.СуммаОборот";
	
	Запрос.УстановитьПараметр("НачалоПериода",Отчет.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(Отчет.КонецПериода));
	Запрос.УстановитьПараметр("ДоговорКонтрагента",ДоговорКонтрагента);
	
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка;
	
КонецФункции	

Функция ПолучитьСписокОПИтог(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(-ХозрасчетныйОстаткиИОбороты.СуммаОборот, 0) КАК ОбеспечительныйПлатеж
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	               |			&НачалоПериода,
	               |			&КонецПериода,
	               |			,
	               |			,
	               |			Счет.Код = ""62.04""
	               |				ИЛИ Счет.Код = ""76.09.1"",
	               |			,
	               |			Субконто2 = &Договор) КАК ХозрасчетныйОстаткиИОбороты";
	
	    Запрос.УстановитьПараметр("НачалоПериода",Отчет.НачалоПериода);
		Запрос.УстановитьПараметр("КонецПериода",КонецДня(Отчет.КонецПериода));
		Запрос.УстановитьПараметр("Договор",Договор);
		Выгрузка = Запрос.Выполнить().Выгрузить();
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.ОбеспечительныйПлатеж;
		Иначе 
			Возврат 0;
		КонецЕсли;	
КонецФункции	

