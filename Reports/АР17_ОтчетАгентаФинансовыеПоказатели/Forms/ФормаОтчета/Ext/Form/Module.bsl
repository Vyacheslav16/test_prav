
&НаКлиенте
Процедура Сформировать(Команда)
	СформироватьНаСервере();
КонецПроцедуры

Функция ПолучитьЗапросДоговоры(Статус)
	
	Запрос = Новый запрос;
	Запрос.Текст =  "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                |	АР_Ставки.Регистратор КАК Регистратор,
	                |	АР_Ставки.Договор КАК ДоговорКонтрагента,
	                |	АР_Ставки.Регистратор.ВидДоговора КАК ВидДоговора,
	                |	АР_Ставки.Договор.Владелец.Наименование КАК КонтрагентНаименование,
	                |	АР_Ставки.Договор.Организация КАК Организация,
	                |	АР_Ставки.Договор.Наименование КАК ДоговорНаименование,
	                |	АР_Ставки.Регистратор.ВидДоговора.Наименование КАК ВидДоговораНаименование,
	                |	АР_Ставки.Договор.Владелец КАК Контрагент
	                |ПОМЕСТИТЬ ВТ_Ставки
	                |ИЗ
	                |	РегистрСведений.АР_Ставки КАК АР_Ставки
	                |ГДЕ
	                |	АР_Ставки.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды";
					Если Статус = "Текущие" Тогда
					    Запрос.Текст = Запрос.Текст + 
							"	И (АР_Ставки.Регистратор.ФактическоеОкончание = ДАТАВРЕМЯ(1, 1, 1)
					        |			ИЛИ АР_Ставки.Регистратор.ФактическоеОкончание >= &КонецПериода)";
					Иначе
					    Запрос.Текст = Запрос.Текст + 
							"	И АР_Ставки.Регистратор.ФактическоеОкончание <= &КонецПериода";
							//|		И АР_Ставки.Регистратор.ФактическоеОкончание >= &НачалоПериода";
					КонецЕсли;
					    Запрос.Текст = Запрос.Текст + 
					"
	                |СГРУППИРОВАТЬ ПО
	                |	АР_Ставки.Договор,
	                |	АР_Ставки.Регистратор,
	                |	АР_Ставки.Регистратор.ВидДоговора,
	                |	АР_Ставки.Договор.Владелец.Наименование,
	                |	АР_Ставки.Договор.Наименование,
	                |	АР_Ставки.Регистратор.ВидДоговора.Наименование,
	                |	АР_Ставки.Договор.Организация,
					|	АР_Ставки.Договор.Владелец
	                |;
	                |
	                |////////////////////////////////////////////////////////////////////////////////
	                |ВЫБРАТЬ
	                |	ВТ_Ставки.Регистратор,
	                |	ВТ_Ставки.ВидДоговора КАК ВидДоговора,
	                |	ВТ_Ставки.Контрагент КАК Контрагент,
	                |	ВТ_Ставки.Организация КАК Организация,
	                |	ВТ_Ставки.ДоговорНаименование КАК ДоговорНаименование,
	                |	ВТ_Ставки.ДоговорКонтрагента,
	                |	ВТ_Ставки.ВидДоговораНаименование КАК ВидДоговораНаименование,
					|	ВТ_Ставки.КонтрагентНаименование КАК КонтрагентНаименование
	                |ИЗ
	                |	ВТ_Ставки КАК ВТ_Ставки
	                |ГДЕ
	                |	ВЫБОР
	                |			КОГДА &Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	                |				ТОГДА ВТ_Ставки.Контрагент = &Контрагент
	                |			ИНАЧЕ ИСТИНА
	                |		КОНЕЦ
	                |	И ВЫБОР
	                |			КОГДА &Организация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	                |				ТОГДА ВТ_Ставки.Организация = &Организация
	                |			ИНАЧЕ ИСТИНА
	                |		КОНЕЦ
	                |	И ВЫБОР
	                |			КОГДА &ИК <> ЗНАЧЕНИЕ(Справочник.АР_ОбъектыАренды.ПустаяСсылка)
	                |				ТОГДА ВТ_Ставки.Регистратор.ИК = &ИК
	                |			ИНАЧЕ ИСТИНА
	                |		КОНЕЦ
					|";
					
					Если ВидДоговора.Количество() > 0 Тогда
					Запрос.Текст = Запрос.Текст + " и	ВТ_Ставки.Регистратор.ВидДоговора В (&ВидДоговора)";
					КонецЕсли;
					Запрос.Текст = Запрос.Текст + "

	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	ВидДоговораНаименование,
	                |	КонтрагентНаименование,
	                |	ДоговорНаименование";

		Если ВидДоговора.Количество() > 0 Тогда
				
	Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
	//Если ВидДоговора.Количество() > 0 Тогда
	//	
	//	МассивВД = Новый Массив;
	//	
	//	Для каждого Стр Из ВидДоговора Цикл
	//		МассивВД.Добавить(Стр.Значение);
	//	КонецЦикла;
	//	
	//	Запрос.УстановитьПараметр("ВидДоговора", МассивВД);
	//	
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("НачалоПериода",Отчет.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецДня(Отчет.КонецПериода));
	Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
	Запрос.УстановитьПараметр("Организация",Отчет.Организация);
	Запрос.УстановитьПараметр("ИК",Отчет.ИК);

	Выгрузка = Запрос.Выполнить().Выгрузить();
	
	Возврат Выгрузка;
	
	
КонецФункции	

Функция ПолучитьСписокОП(Договор)
	Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//               |	ХозрасчетныйОстатки.Субконто3 КАК Регистратор,
	//               |	ХозрасчетныйОстатки.СуммаОстатокКт КАК ОбеспечительныйПлатеж,
	//               |	ХозрасчетныйОстатки.Субконто3.Дата КАК Период
	//               |ИЗ
	//               |	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет.Код = ""62.04"", , ) КАК ХозрасчетныйОстатки
	//               |ГДЕ
	//               |	ХозрасчетныйОстатки.Субконто2 = &Договор";
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	-ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток КАК ОбеспечительныйПлатеж
				   //|	ХозрасчетныйОстаткиИОбороты.Период КАК Период,
				   //|	ХозрасчетныйОстаткиИОбороты.Регистратор КАК Регистратор
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	               |			,
	               |			&КонецПериода,
	               |			,
	               |			,
	               |			Счет.Код = ""62.04""
	               |				ИЛИ Счет.Код = ""76.09.1"",
	               |			,
	               |			Субконто2 = &Договор) КАК ХозрасчетныйОстаткиИОбороты";
				   
				   Запрос.УстановитьПараметр("КонецПериода",КонецДня(Отчет.КонецПериода));
				   Запрос.УстановитьПараметр("Договор",Договор);
				   Выгрузка = Запрос.Выполнить().Выгрузить();
				   Возврат Выгрузка;
КонецФункции	

&НаСервере
Процедура СформироватьНаСервере()

	ТД.Очистить();
	//Макет = Отчеты.АР17_ОтчетАгентаФинансовыеПоказатели.ПолучитьМакет("Макет");
	Макет = РеквизитФормыВЗначение("Отчет").ПолучитьМакет("Макет");
	Область = Макет.ПолучитьОбласть("Шапка_");
	Область.Параметры.НачалоПериода = Формат(Отчет.НачалоПериода,"ДЛФ=Д");
	Область.Параметры.КонецПериода = Формат(Отчет.КонецПериода,"ДЛФ=Д");
	Область.Параметры.ИК = Отчет.ИК;
	Область.Параметры.Адрес = Отчет.ИК.Адрес;
	ТД.Вывести(Область);
	
	Область = Макет.ПолучитьОбласть("Шапка");
	ТД.Вывести(Область);
	
	сзСтатусы = Новый СписокЗначений;
	сзСтатусы.Добавить("Текущие");
	сзСтатусы.Добавить("Закрытые");
	//
	ПредоплатаВД = 0;
	НачальныйДолгВД = 0;
	ПениНачисленоНаНачалоПериодаВД = 0;
	НачисленоВД = 0;
	ПениНачисленоЗаПериодВД = 0;
	ОплаченоВД = 0;
	ПредоплатаИтогВД = 0;
	КонечныйДолгВД = 0;
	ПениНаКонецПериодаВД = 0;
	//
	АрендаНачисленоТекущие = 0;
	ДопНачисленоТекущие = 0;
	АрендаОПТекущие = 0;
	АрендаНачальныйДолгТекущие = 0;
	АрендаКонечныйДолгТекущие = 0;
	АрендаКонечныйДолгЗакрытые = 0;
	АрендаНачальныйДолгЗакрытые = 0;
	АрендаПредоплатаЗакрытые = 0;
	АрендаПредоплатаТекущие = 0;
	ДопНачальныйДолгТекущие = 0;
	ДопКонечныйДолгТекущие = 0;
	ДопКонечныйДолгЗакрытые = 0;
	ДопНачальныйДолгЗакрытые = 0;
	ДопПредоплатаТекущие = 0;
	АрендаОплаченоТекущие = 0;
	ДопОплаченоТекущие = 0;
	ДопПредоплатаЗакрытые = 0;
	//+ИтогоВсего
	ПредоплатаИтогоВсего = 0;
	НачальныйДолгИтогоВсего = 0;
	ПениНачисленоНаНачалоПериодаИтогоВсего = 0;
	НачисленоИтогоВсего = 0;
	ПениНачисленоЗаПериодИтогоВсего = 0;
	ОплаченоИтогоВсего = 0;
	ПредоплатаИтогИтогоВсего = 0;
	КонечныйДолгИтогоВсего = 0;
	ПениНаКонецПериодаИтогоВсего = 0;
	//-ИтогоВсего
	АрендаПредшествующая = 0;
	ДопПредшествующая = 0;
	
	
	
	Для Каждого Статус Из сзСтатусы Цикл
	
		ВыгрузкаДог = ПолучитьЗапросДоговоры(Статус.Значение);
		ВыгрузкаДог.Свернуть("ВидДоговора,ДоговорКонтрагента");
	
		сзВидДоговора = Новый СписокЗначений;
		
		ОбеспечительныйПлатежИтого = 0;
		ПредоплатаИтого = 0;
		НачальныйДолгИтого = 0;
		ПениНачисленоНаНачалоПериодаИтого = 0;
		НачисленоИтого = 0;
		ПениНачисленоЗаПериодИтого = 0;
		ОплаченоИтого = 0;
		ПредоплатаИтогИтого = 0;
		КонечныйДолгИтого = 0;
		ПениНаКонецПериодаИтого = 0;
		
		ИтогВД = Ложь;
		Для Каждого Договор Из ВыгрузкаДог Цикл
			
			Выгрузка = ПолучитьЗапрос(Договор.ДоговорКонтрагента,Статус.Значение);
			Если Выгрузка.Количество()=0 Тогда Продолжить; КонецЕсли;
			ТЗОплачено = ПолучитьОплачено(Договор.ДоговорКонтрагента);
			
			ТЗОплачено_ = ПолучитьОплачено(Договор.ДоговорКонтрагента);
			
			Если сзВидДоговора.НайтиПоЗначению(Договор.ВидДоговора)=Неопределено Тогда
				Если ИтогВД Тогда
					Область = Макет.ПолучитьОбласть("Итого");
					Область.Параметры.ПредоплатаИтого = ПредоплатаВД;
					Область.Параметры.НачальныйДолгИтого = НачальныйДолгВД;
					Область.Параметры.ПениНачисленоНаНачалоПериодаИтого = ПениНачисленоНаНачалоПериодаВД;
					Область.Параметры.НачисленоИтого = НачисленоВД;
					Область.Параметры.ПениНачисленоЗаПериодИтого = ПениНачисленоЗаПериодВД;
					Область.Параметры.ОплаченоИтого = ОплаченоВД;
					Область.Параметры.ПредоплатаИтогИтого = ПредоплатаИтогВД;
					Область.Параметры.КонечныйДолгИтого = КонечныйДолгВД;
					Область.Параметры.ПениНаКонецПериодаИтого = ПениНаКонецПериодаВД;
					Если ПредоплатаВД=0 и НачальныйДолгВД=0 и ПениНачисленоНаНачалоПериодаВД=0 и НачисленоВД=0 и ПениНачисленоЗаПериодВД=0
						и ОплаченоВД=0 и ПредоплатаИтогВД = 0 и КонечныйДолгВД=0 и ПениНаКонецПериодаВД=0 
						Тогда
						ТД.УдалитьОбласть(ТД.Область("ВидДоговора"),ТипСмещенияТабличногоДокумента.ПоГоризонтали);
					Иначе
						ТД.Вывести(Область);
					КонецЕсли;	
					//+
					ПредоплатаИтогоВсего = ПредоплатаИтогоВсего + ПредоплатаВД;
					НачальныйДолгИтогоВсего = НачальныйДолгИтогоВсего + НачальныйДолгВД;
					ПениНачисленоНаНачалоПериодаИтогоВсего = ПениНачисленоНаНачалоПериодаИтогоВсего + ПениНачисленоНаНачалоПериодаВД;
					НачисленоИтогоВсего = НачисленоИтогоВсего + НачисленоВД;
					ПениНачисленоЗаПериодИтогоВсего = ПениНачисленоЗаПериодИтогоВсего + ПениНачисленоЗаПериодВД;
					ОплаченоИтогоВсего = ОплаченоИтогоВсего + ОплаченоВД;
					ПредоплатаИтогИтогоВсего = ПредоплатаИтогИтогоВсего + ПредоплатаИтогВД;
					КонечныйДолгИтогоВсего = КонечныйДолгИтогоВсего + КонечныйДолгВД;
					ПениНаКонецПериодаИтогоВсего = ПениНаКонецПериодаИтогоВсего + ПениНаКонецПериодаВД;
					//-
				КонецЕсли;
				ИтогВД = Истина;

				//
				ПредоплатаВД = 0;
				НачальныйДолгВД = 0;
				ПениНачисленоНаНачалоПериодаВД = 0;
				НачисленоВД = 0;
				ПениНачисленоЗаПериодВД = 0;
				ОплаченоВД = 0;
				ПредоплатаИтогВД = 0;
				КонечныйДолгВД = 0;
				ПениНаКонецПериодаВД = 0;
				//
				сзВидДоговора.Добавить(Договор.ВидДоговора);
				ОбластьВД = Макет.ПолучитьОбласть("ВидДоговора");
				ОбластьВД.Параметры.ВидДоговора = СокрЛП(Договор.ВидДоговора) + " (" + Статус.Значение+ ")";
				ТД.Вывести(ОбластьВД);
			КонецЕсли;	
			
			СтараяНоменклатура = Новый СписокЗначений;
			сзОплачено = Новый СписокЗначений;
			сзОП = Новый СписокЗначений;
			НомерСтроки = 1;
			БылОП = Ложь;
			//Область = Макет.ПолучитьОбласть("СтрТД_");
			//ТД.Вывести(Область);
			ИтогНачислено = Выгрузка.Скопировать();
			ИтогНачислено.Свернуть("Услуга,Начислено");
			ИтогОплачено = Выгрузка.Скопировать();
			ИтогОплачено.Свернуть("ОплаченоРегистратор,Оплачено");
			СтарыйДоговор = ""; // + NAI Becar Комментирование Смирнов А.А. от 15.01.2018 13:59
			Для Каждого Стр Из Выгрузка Цикл
				КонечныйДолг = 0;
				Область = Макет.ПолучитьОбласть("СтрТД");
				Если НомерСтроки = 1 Тогда
					Область.Параметры.Площадь = Стр.Площадь;
					Область.Параметры.Контрагент = Стр.Контрагент;
					Область.Параметры.Договор = "№ " + СокрЛП(Стр.Договор.Номер) + " от " + Формат(Стр.Договор.Дата,"ДЛФ=Д");
					Область.Параметры.ДатаАктаПП = Формат(Стр.ДатаАктаПП,"ДЛФ=Д");
					Область.Параметры.ОбеспечительныйПлатежПримечание = ?(Стр.ОбеспечительныйПлатежПримечание<>0,"Зачет ОП",0);
					Область.Параметры.Предоплата = Стр.Предоплата;
					Область.Параметры.НачальныйДолг = Стр.НачальныйДолг;
					Область.Параметры.ДоговорСсылка = Стр.Договор;
					Область.Параметры.ПредоплатаИтог = Стр.ПредоплатаИтог;
					КонечныйДолг = Стр.НачальныйДолг + ИтогНачислено.Итог("Начислено") - ИтогОплачено.Итог("Оплачено") - Стр.Предоплата;
					Если КонечныйДолг <=0 Тогда КонечныйДолг=0; КонецЕсли;
					Область.Параметры.КонечныйДолг = КонечныйДолг;
					Область.Параметры.ПениНаКонецПериода = Стр.ПениНаКонецПериода;
					
					ПредоплатаИтого = ПредоплатаИтого + Стр.Предоплата;
					НачальныйДолгИтого = НачальныйДолгИтого + Стр.НачальныйДолг;
					ПредоплатаИтогИтого = ПредоплатаИтогИтого + Стр.ПредоплатаИтог;
					КонечныйДолгИтого = КонечныйДолгИтого + КонечныйДолг;
					
					ПредоплатаВД = ПредоплатаВД + Стр.Предоплата;
					//НачальныйДолгВД = НачальныйДолгВД + Стр.НачальныйДолг;
					ПредоплатаИтогВД = ПредоплатаИтогВД + Стр.ПредоплатаИтог;
					//КонечныйДолгВД = КонечныйДолгВД + КонечныйДолг;
					//--
					Если (Договор.ВидДоговора = Справочники.АР_ВидыДоговоров.Аренда или Договор.ВидДоговора = Справочники.АР_ВидыДоговоров.Субаренда)
						и Статус.Значение = "Текущие" Тогда
							АрендаОПТекущие = АрендаОПТекущие + Стр.ОбеспечительныйПлатеж;
							АрендаНачальныйДолгТекущие = АрендаНачальныйДолгТекущие + Стр.НачальныйДолг;
							АрендаПредоплатаТекущие = АрендаПредоплатаТекущие + Стр.Предоплата;
							АрендаКонечныйДолгТекущие = АрендаКонечныйДолгТекущие + КонечныйДолг;
