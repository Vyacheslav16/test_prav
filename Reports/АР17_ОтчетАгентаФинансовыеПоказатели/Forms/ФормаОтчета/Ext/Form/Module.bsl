	ДопЗакрытые = ?(Область.Параметры.Доп < 0,0,Область.Параметры.Доп);
	Область.Параметры.Сумма = АрендаЗакрытые + ДопЗакрытые; //Область.Параметры.Аренда + Область.Параметры.Доп;
	Область.Параметры.ДЗ = ?((АрендаНачисленоТекущие+ДопНачисленоТекущие) = 0,0,Окр(Область.Параметры.Сумма/(АрендаНачисленоТекущие+ДопНачисленоТекущие)*100,2));//?(АрендаСумма = 0,0,Окр(Область.Параметры.Сумма/АрендаСумма*100));
