	Область = Макет.ПолучитьОбласть("ОП_Текущая");
	//Область.Параметры.Сумма = ОбеспечительныйПлатежИтого;
	СуммаОП_Текущая=0;
	Для Каждого Дог Из МассивДоговоров Цикл
		Если Дог.Договор.ФактическоеОкончание = ДАТА(1, 1, 1) ИЛИ Дог.Договор.ФактическоеОкончание >= Отчет.КонецПериода Тогда
	    //Если ПолучитьСписокОП_(Дог.Договор.ДоговорКонтрагента,КонецДня(Отчет.КонецПериода)) = 0 Тогда
			СуммаОП_Текущая = СуммаОП_Текущая + Дог.Договор.СуммаЗалога - ПолучитьСписокОП_(Дог.Договор.ДоговорКонтрагента,КонецДня(Отчет.КонецПериода)); //Дог.СуммаЗалога;
		//КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Область.Параметры.Сумма = СуммаОП_Текущая;
	ТД.Вывести(Область);
	
	Область = Макет.ПолучитьОбласть("ПустаяСтрока");
	ТД.Вывести(Область);
	
	//тзОпИтог = ПолучитьСписокОПИтог();
	//Область = Макет.ПолучитьОбласть("ОП_Всего");
	//Область.Параметры.Сумма = тзОпИтог.Итог("ОбеспечительныйПлатеж");
	//ТД.Вывести(Область);
	//
	//Для Каждого СтрОП Из тзОпИтог Цикл
	//	Область = Макет.ПолучитьОбласть("ОП_Расшифровка");
	//	Область.Параметры.Контрагент = СтрОП.Контрагент;
	//	Область.Параметры.Договор = СтрОП.Договор;
	//	Область.Параметры.Сумма = СтрОП.ОбеспечительныйПлатеж;
	//	ТД.Вывести(Область);
	//КонецЦикла;
	
	//
	СуммаОП_Текущая=0;
	Для Каждого Дог Из МассивДоговоров Цикл
	    Если ПолучитьСписокОПИтог(Дог.Договор.ДоговорКонтрагента) <= 0 Тогда Продолжить; КонецЕсли;
			СуммаОП_Текущая = СуммаОП_Текущая + ПолучитьСписокОПИтог(Дог.Договор.ДоговорКонтрагента);
	КонецЦикла;
	Область = Макет.ПолучитьОбласть("ОП_Всего");
	Область.Параметры.Сумма = СуммаОП_Текущая;
	ТД.Вывести(Область);
	Для Каждого СтрОП Из МассивДоговоров Цикл
		Если ПолучитьСписокОПИтог(СтрОП.Договор.ДоговорКонтрагента) <= 0 Тогда Продолжить; КонецЕсли;
			Область = Макет.ПолучитьОбласть("ОП_Расшифровка");
			Область.Параметры.Контрагент = СтрОП.Договор.ДоговорКонтрагента.Владелец;
			Область.Параметры.Договор = СтрОП.Договор.ДоговорКонтрагента;
			Область.Параметры.Сумма = ПолучитьСписокОПИтог(СтрОП.Договор.ДоговорКонтрагента);
			ТД.Вывести(Область);
	КонецЦикла;
	//
	
	ТД.ФиксацияСверху = 10;
	ТД.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТД.АвтоМасштаб = Истина;
	//Элементы.ТД.ОтображатьЗаголовки = Истина; ФиксацияСверху
	Элементы.ТД.ТолькоПросмотр = Истина;

КонецПроцедуры

Функция ПолучитьЗапрос(Договор,Статус)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента КАК ДоговорКонтрагента,
