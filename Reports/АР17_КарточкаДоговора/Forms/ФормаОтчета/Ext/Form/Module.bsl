	|	ХозрасчетныйОстаткиИОбороты.Субконто3 КАК ДокументРасчетов,
	|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток КАК Сумма
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Период,
	|			,
	|			Счет.Код = ""62.01""
	|				ИЛИ Счет.Код = ""76.09"",
	|			,
	|			) КАК ХозрасчетныйОстаткиИОбороты
	|ГДЕ
	|	ХозрасчетныйОстаткиИОбороты.Субконто2 = &Договор
	|	И ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток > 0";
	
	
	////////	"ВЫБРАТЬ
	////////|	АР_ВзаиморасчетыПоАрендеОстаткиИОбороты.СуммаВзаиморасчетовКонечныйОстаток,
	////////|	АР_ВзаиморасчетыПоАрендеОстаткиИОбороты.СуммаКонечныйОстаток,
	////////|	АР_ВзаиморасчетыПоАрендеОстаткиИОбороты.ДокументРасчетов
	////////|ИЗ
	////////|	РегистрНакопления.АР_ВзаиморасчетыПоАренде.ОстаткиИОбороты(, , , , ДокументРасчетов В (&МассивАктов)) КАК АР_ВзаиморасчетыПоАрендеОстаткиИОбороты
	////////|ГДЕ
	////////|	АР_ВзаиморасчетыПоАрендеОстаткиИОбороты.СуммаКонечныйОстаток > 0";

	
	Запрос.УстановитьПараметр("НачалоПериода", Отчет.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", Отчет.КонецПериода);
	Запрос.УстановитьПараметр("Договор", Отчет.Договор.ДоговорКонтрагента);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗ;

	
