Функция НеВозвращен(Док)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПереданныеДокументыОстатки.ПереданоЭкземпляровОстаток КАК Остаток
		|ИЗ
		|	РегистрНакопления.АР_ПереданныеДокументы.Остатки(&ДатаК, Документ = &Док) КАК ПереданныеДокументыОстатки";
	Запрос.УстановитьПараметр("ДатаК", КонецДня(Отчет.КонецПериода));	
	Запрос.УстановитьПараметр("Док", Док);
	ТЗ = Запрос.Выполнить().Выгрузить();
		
	Возврат ТЗ[0].Остаток;
	
