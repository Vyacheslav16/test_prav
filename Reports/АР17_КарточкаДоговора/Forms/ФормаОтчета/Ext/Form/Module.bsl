&НаСервере
Функция ПолучитьСумму(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ссылка КАК Ссылка,
	               |	АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Услуга КАК Услуга,
	               |	СУММА(АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Количество) КАК Количество,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ставка) КАК Ставка,
	               |	СУММА((ВЫРАЗИТЬ(АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ставка КАК ЧИСЛО(15, 2))) * АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Количество) КАК Сумма
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты КАК АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ссылка = &Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Ссылка,
	               |	АР_ЗаключениеДоговораАрендыПеременнаяЧастьАренднойПлаты.Услуга
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка,
	               |	АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга,
	               |	АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Количество,
	               |	АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ставка,
	               |	(ВЫРАЗИТЬ(АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ставка КАК ЧИСЛО(15, 2))) * АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Количество
	               |ИЗ
	               |	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты
	               |ГДЕ
	               |	АР_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Договор);
	Результат = Запрос.Выполнить().Выгрузить();
	Возврат Результат.Итог("Сумма");
				   
КонецФункции	


