				НоваяСтрока.СуммаОстаток = ПолучитьСуммуЗаМесяц(СтрМес.НачалоПериода);
			КонецЕсли;
		КонецЦикла;
		//-
		
		ТЗ.Сортировать("НачалоПериода Возр");
		Для Каждого Стр из ТЗ Цикл
			Область = Макет.ПолучитьОбласть("СтрокаОЗ");
			
			Если Стр.СчетНаАренду = Неопределено Тогда
				Область.Параметры.Наименование = Формат(Стр.НачалоПериода, "ДФ='ММММ yyyy'");
				Если Стр.СуммаОстаток = Неопределено Тогда
					Область.Параметры.Сумма = 0;
				Иначе	
					Область.Параметры.Сумма = Макс(Стр.СуммаОстаток, -Стр.СуммаОстаток); //Стр.СуммаДокумента;
				КонецЕсли;
			Иначе	
				Наименование = ?(ТипЗнч(Стр.СчетНаАренду) = Тип("ДокументСсылка.АР17_СчетНаАренду"), "Счет №", "Ввод начальных остатков №");
				Область.Параметры.Наименование = Наименование + Стр.СчетНаАренду.Номер + " от " + Формат(Стр.СчетНаАренду.Дата, "ДЛФ=Д");
				Если Стр.СуммаОстаток = Неопределено Тогда
					Область.Параметры.Сумма = 0;
				Иначе	
					Область.Параметры.Сумма = Макс(Стр.СуммаОстаток, -Стр.СуммаОстаток); //Стр.СуммаДокумента;
				КонецЕсли;
				Область.Параметры.Документ = Стр.СчетНаАренду;
			КонецЕсли;	
			
			ТД.Вывести(Область);				
		КонецЦикла;	
		//Итог = ТЗ.Итог("СуммаДокумента");
		Итог = ТЗ.Итог("СуммаОстаток");
		Итог = Макс(Итог,-Итог);
		Если Итог <> 0 Тогда
			Область = Макет.ПолучитьОбласть("ИтогоОЗ");
			Область.Параметры.Итого = Итог;
			ТД.Вывести(Область);
		КонецЕсли;	
		Область = Макет.ПолучитьОбласть("ПодвалОЗ");
		Если Итог = 0 Тогда
			Область.Параметры.Подвал = "Оперативная задолженность по договору отсутствует.";
		ИначеЕсли Итог > 0 Тогда
			//Область.Параметры.Подвал = "Задолженность по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643").ПараметрыПрописиНаРусском) + ")";
			Область.Параметры.Подвал = "Задолженность по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
		ИначеЕсли Итог < 0 Тогда
			Итог = Итог * (-1);
			Область.Параметры.Подвал = "Переплата по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
		КонецЕсли;	
		ТД.Вывести(Область);
	КонецЕсли;
	
	// Регламентированная задолженность
	Если Рег Тогда
		ТЗ = ПолучитьРег();
		//Если ТипЗнч(ТЗ) <> Тип("Строка") Тогда
			Область = Макет.ПолучитьОбласть("ШапкаРег");
			Область.Параметры.Заголовок = "РЕГЛАМЕНТИРОВАННАЯ ЗАДОЛЖЕННОСТЬ на " + Формат(ТекущаяДата(), "ДЛФ=Д") + " (без учета депозита).";
			ТД.Вывести(Область);	
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ШапкаТабРег");
				ТД.Вывести(Область);	
			КонецЕсли;
			// + NAI Becar Комментирование Смирнов А.А. от 13.09.2017 17:14
			ТЗОст = ПолчитьОстаткиРег();
			Если ТЗОст.Количество() > 0 Тогда
				СуммаКонечныйОстаток = 0;
				Отбор = Новый Структура();
				Отбор.Вставить("ДоговорАренды",Отчет.Договор);
				Строки = ТЗОст[0].Ссылка.ВводОстатков.НайтиСтроки(Отбор);
				Если Строки.Количество() > 0 Тогда
					Область = Макет.ПолучитьОбласть("СтрокаРег");
					СуммаКонечныйОстаток = Строки[0].ФактическийОстаток;
					Область.Параметры.Сумма = СуммаКонечныйОстаток;
					Область.Параметры.Наименование = ТЗОст[0].Ссылка;
					Область.Параметры.Документ = ТЗОст[0].Ссылка;
					ТД.Вывести(Область);				
				КонецЕсли;
				
				//Наименование = ?(ТипЗнч(Стр.ДокументРасчетов) = Тип("ДокументСсылка.РеализацияТоваровУслуг"), "Реализация товаров и услуг №", "Поступление на расчетный счет №");
				//Область.Параметры.Наименование = "Акт №" + Строка(Стр.ДокументРасчетов.Номер) + " от " + Формат(Стр.ДокументРасчетов.Дата, "ДЛФ=Д");
				//Область.Параметры.Документ = Стр.ДокументРасчетов;
			КонецЕсли;	
			// - NAI Becar Комментирование Смирнов А.А.
			Для Каждого Стр из ТЗ Цикл
				Область = Макет.ПолучитьОбласть("СтрокаРег");
				Наименование = ?(ТипЗнч(Стр.ДокументРасчетов) = Тип("ДокументСсылка.РеализацияТоваровУслуг"), "Реализация товаров и услуг №", "Поступление на расчетный счет №");
				Область.Параметры.Наименование = "Акт №" + Строка(Стр.ДокументРасчетов.Номер) + " от " + Формат(Стр.ДокументРасчетов.Дата, "ДЛФ=Д");
				Область.Параметры.Сумма = Стр.Сумма;
				Область.Параметры.Документ = Стр.ДокументРасчетов;
				ТД.Вывести(Область);				
			КонецЦикла;	
			Итог = ТЗ.Итог("Сумма");
			Если Итог <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ИтогоРег");
				Область.Параметры.Итого = Итог;
				ТД.Вывести(Область);
			КонецЕсли;	
			Область = Макет.ПолучитьОбласть("ПодвалРег");
			Если Итог = 0 Тогда
				Область.Параметры.Подвал = "Регламентированная задолженность по договору отсутствует.";
			ИначеЕсли Итог > 0 Тогда
				Область.Параметры.Подвал = "Задолженность по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			ИначеЕсли Итог < 0 Тогда
				Итог = Итог * (-1);
				Область.Параметры.Подвал = "Переплата по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			КонецЕсли;	
			ТД.Вывести(Область);
		//Иначе
		//	Сообщить("Для организации: " + Договор.Организация + " не настроен учет депозитных платежей!");
		//КонецЕсли;	
	КонецЕсли;
	
	// Настройки
	ТД.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТД.АвтоМасштаб = Истина;
	ТД.ТолькоПросмотр = Истина;
	
	Элементы.ТД.ОтображениеСостояния.ДополнительныйРежимОтображения=ДополнительныйРежимОтображения.НеИспользовать;
	Элементы.ТД.ОтображениеСостояния.Видимость = ложь;
	
КонецПроцедуры

Функция ПолчитьОстаткиРег()
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаКонечныйОстаток,
	               |	АР_РасчетыПоДоговорамОстаткиИОбороты.Регистратор КАК Ссылка
	               |ИЗ
	               |	РегистрНакопления.АР_РасчетыПоДоговорам.ОстаткиИОбороты(, &КонецПериода, Регистратор, , ) КАК АР_РасчетыПоДоговорамОстаткиИОбороты
	               |ГДЕ
	               |	АР_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента = &ДоговорКонтрагента
	               |	И ТИПЗНАЧЕНИЯ(АР_РасчетыПоДоговорамОстаткиИОбороты.Регистратор) = &Тип";
	
	Запрос.УстановитьПараметр("КонецПериода",Отчет.НачалоПериода);
	Запрос.УстановитьПараметр("ДоговорКонтрагента",Отчет.Договор.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Тип", Тип("ДокументСсылка.АР17_КорректировкаОстатковРасчетовПоДоговорам"));
	Выборка = Запрос.Выполнить().Выбрать();
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Возврат Выгрузка;	
	
КонецФункции	

