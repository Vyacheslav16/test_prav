Функция ПолучитьДатаИзм(Договор)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АР_СтатусыОбъектовАрендыСрезПоследних.ДатаНачалаАренды КАК ДатаНачалаАренды,
	               |	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга КАК Услуга,
	               |	1 КАК Кол
	               |ИЗ
	               |	РегистрСведений.АР_СтатусыОбъектовАренды.СрезПоследних(, ЗаключениеДоговора = &Договор) КАК АР_СтатусыОбъектовАрендыСрезПоследних
	               |ГДЕ
	               |	АР_СтатусыОбъектовАрендыСрезПоследних.Услуга.АР_ПостояннаяЧастьОплаты = ИСТИНА
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаНачалаАренды УБЫВ
	               |ИТОГИ
	               |	МАКСИМУМ(ДатаНачалаАренды),
	               |	СУММА(Кол)
	               |ПО
	               |	Услуга";
				   
	Запрос.УстановитьПараметр("Договор",Договор);
	//Запрос.УстановитьПараметр("КонецПериода",Отчет.КонецПериода);
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Если Выгрузка[0].Кол >= 2 Тогда
		Возврат Формат(Выгрузка[0].ДатаНачалаАренды,"ДЛФ=Д");
	Иначе
		Возврат "";	
	КонецЕсли;	
	
КонецФункции	

Функция ПереданВозвращен(Док, ПриходРасход)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	ПереданныеДокументы.Период КАК ДатаПередачи
	//	|ИЗ
	//	|	РегистрНакопления.ПереданныеДокументы КАК ПереданныеДокументы
	//	|ГДЕ
	//	|	ПереданныеДокументы.Период МЕЖДУ &ДатаН И &ДатаК
	//	|	И ПереданныеДокументы.Документ = &Док
	//	|	И ПереданныеДокументы.ВидДвижения = &ПриходРасход";
	
	 "ВЫБРАТЬ
	 |	АР_ПереданныеДокументы.Период КАК ДатаПередачи
	 |ИЗ
	 |	РегистрНакопления.АР_ПереданныеДокументы КАК АР_ПереданныеДокументы
	 |ГДЕ
	 |	АР_ПереданныеДокументы.Период МЕЖДУ &ДатаН И &ДатаК
	 |	И АР_ПереданныеДокументы.Документ = &Док
	 |	И АР_ПереданныеДокументы.ВидДвижения = &ПриходРасход";
	 
	Запрос.УстановитьПараметр("ДатаН", НачалоДня(Отчет.НачалоПериода));	
	Запрос.УстановитьПараметр("ДатаК", КонецДня(Отчет.КонецПериода));	
	Запрос.УстановитьПараметр("Док", Док);
	Запрос.УстановитьПараметр("ПриходРасход", ПриходРасход);
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Передан = "";
	Для Каждого Стр из ТЗ Цикл
		Передан = Передан + Формат(Стр.ДатаПередачи, "ДЛФ=Д") + Символы.ПС;
	КонецЦикла;	
	Передан = Сред(Передан, 1, СтрДлина(Передан) - 1);
	
	Возврат Передан;
	
КонецФункции	


