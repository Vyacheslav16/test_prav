	|				ИЛИ Счет.Код = ""76.09.1"",
	|			,
	|			) КАК ХозрасчетныйОстаткиИОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Договоры КАК Договоры
	|		ПО ХозрасчетныйОстаткиИОбороты.Субконто2 = Договоры.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстаток КАК ПениНаНачалоПоБУ,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотКт КАК ОплатаПени,
	|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток КАК ПениНаКонецПоБУ,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотДт КАК НачислениеПени,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ Пени
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, Месяц, , Счет.Код = ""76.02"", , ) КАК ХозрасчетныйОстаткиИОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Договоры КАК Договоры
	|		ПО ХозрасчетныйОстаткиИОбороты.Субконто2 = Договоры.ДоговорКонтрагента";
	
	ЗапросДетализацияВоВремТаблицу =
	
	";
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Пени.ПениНаНачалоПоБУ, 0)) КАК ПениНаНачалоПоБУ,
	|	СУММА(ЕСТЬNULL(Пени.ОплатаПени, 0)) КАК ОплатаПени,
	|	СУММА(ЕСТЬNULL(Пени.ПениНаКонецПоБУ, 0)) КАК ПениНаКонецПоБУ,
	|	СУММА(ЕСТЬNULL(Пени.НачислениеПени, 0)) КАК ПениНачислено,
	|	СУММА(ЕСТЬNULL(РеализованныеУслугиПоДоговору.Пост, 0)) КАК Пост,
	|	СУММА(ЕСТЬNULL(РеализованныеУслугиПоДоговору.Перем, 0)) КАК Перем,
	|	СУММА(ЕСТЬNULL(РеализованныеУслугиПоДоговору.Ку, 0)) КАК КУ,
	|	СУММА(ЕСТЬNULL(ОстаткиИОплаты.СуммаНачальныйОстаток, 0)) КАК СуммаНачальныйОстаток,
	|	СУММА(ЕСТЬNULL(ОстаткиИОплаты.СуммаРасход, 0)) КАК СуммаРасход,
	|	СУММА(ЕСТЬNULL(ОстаткиИОплаты.СуммаКонечныйОстаток, 0)) КАК СуммаКонечныйОстаток,
	|	СУММА(ЕСТЬNULL(Депозиты.ДепозитНаНачалоПоБУ, 0) + Договоры.СуммаЗалога) КАК ДепозитНаНачало,
	|	СУММА(ЕСТЬNULL(Депозиты.ОплатаДепозита, 0)) КАК ОплатаДепозита,
	|	СУММА(ЕСТЬNULL(Депозиты.НачислениеДепозита, 0)) КАК НачислениеДепозита,
	
	//|	СУММА(ЕСТЬNULL(Депозиты.ДепозитНаКонецПоБУ, 0) + Договоры.СуммаЗалога) КАК ДепозитНаКонец,
	|СУММА(ВЫБОР
	|		КОГДА &ТолькоДолжники
	|			ТОГДА ВЫБОР
	|					КОГДА ЕСТЬNULL(Депозиты.ДепозитНаКонецПоБУ, 0) + Договоры.СуммаЗалога > 0
	|						ТОГДА ЕСТЬNULL(Депозиты.ДепозитНаКонецПоБУ, 0) + Договоры.СуммаЗалога
	|				КОНЕЦ
	|		ИНАЧЕ ЕСТЬNULL(Депозиты.ДепозитНаКонецПоБУ, 0) + Договоры.СуммаЗалога
	|	КОНЕЦ) КАК ДепозитНаКонец,

	|	СУММА(Договоры.СуммаЗалога) КАК СуммаЗалога,
	|	Договоры.Контрагент
	|ПОМЕСТИТЬ ДетальныеЗаписи
	|ИЗ
	|	Договоры КАК Договоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиИОплаты КАК ОстаткиИОплаты
	|		ПО Договоры.ДоговорКонтрагента = ОстаткиИОплаты.ДоговорКонтрагента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РеализованныеУслугиПоДоговору КАК РеализованныеУслугиПоДоговору
	|		ПО Договоры.ДоговорКонтрагента = РеализованныеУслугиПоДоговору.ДоговорКонтрагента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Депозиты КАК Депозиты
	|		ПО Договоры.ДоговорКонтрагента = Депозиты.ДоговорКонтрагента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Пени КАК Пени
	|		ПО Договоры.ДоговорКонтрагента = Пени.ДоговорКонтрагента
	|
	|СГРУППИРОВАТЬ ПО
	|	Договоры.Контрагент";
	
	ЗапросПоКонкретным =
	
	";
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДетальныеЗаписи.ПениНаНачалоПоБУ,
	|	ДетальныеЗаписи.ОплатаПени,
	|	ДетальныеЗаписи.ПениНаКонецПоБУ,
	|	ДетальныеЗаписи.ПениНачислено,
	|	ДетальныеЗаписи.Пост,
	|	ДетальныеЗаписи.Перем,
	|	ДетальныеЗаписи.КУ,
	|	ДетальныеЗаписи.СуммаНачальныйОстаток,
	|	ДетальныеЗаписи.СуммаРасход,
	|	ДетальныеЗаписи.СуммаКонечныйОстаток,
	|	ДетальныеЗаписи.ДепозитНаНачало,
	|	ДетальныеЗаписи.ОплатаДепозита,
	|	ДетальныеЗаписи.НачислениеДепозита,
	|	ДетальныеЗаписи.ДепозитНаКонец,
	|	ДетальныеЗаписи.СуммаЗалога,
	|	ДетальныеЗаписи.Контрагент
	|ИЗ
	|	ДетальныеЗаписи КАК ДетальныеЗаписи
	|ГДЕ
	|	(ДетальныеЗаписи.Контрагент В (&МассивКА)
	|			ИЛИ (ДетальныеЗаписи.СуммаНачальныйОстаток > 0
	|				ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток > 0))";
	
	ЗапросГруппировка = 
	
	";
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ДетальныеЗаписи.ПениНаНачалоПоБУ) КАК ПениНаНачалоПоБУ,
	|	СУММА(ДетальныеЗаписи.ОплатаПени) КАК ОплатаПени,
	|	СУММА(ДетальныеЗаписи.ПениНаКонецПоБУ) КАК ПениНаКонецПоБУ,
	|	СУММА(ДетальныеЗаписи.ПениНачислено) КАК ПениНачислено,
	|	СУММА(ДетальныеЗаписи.Пост) КАК Пост,
	|	СУММА(ДетальныеЗаписи.Перем) КАК Перем,
	|	СУММА(ДетальныеЗаписи.КУ) КАК КУ,
	|	СУММА(ДетальныеЗаписи.СуммаНачальныйОстаток) КАК СуммаНачальныйОстаток,
	|	СУММА(ДетальныеЗаписи.СуммаРасход) КАК СуммаРасход,
	|	СУММА(ДетальныеЗаписи.СуммаКонечныйОстаток) КАК СуммаКонечныйОстаток,
	|	СУММА(ДетальныеЗаписи.ДепозитНаНачало) КАК ДепозитНаНачало,
	|	СУММА(ДетальныеЗаписи.ОплатаДепозита) КАК ОплатаДепозита,
	|	СУММА(ДетальныеЗаписи.НачислениеДепозита) КАК НачислениеДепозита,
	|	СУММА(ДетальныеЗаписи.ДепозитНаКонец) КАК ДепозитНаКонец,
	|	СУММА(ДетальныеЗаписи.СуммаЗалога) КАК СуммаЗалога
	|ИЗ
	|	ДетальныеЗаписи КАК ДетальныеЗаписи
	|ГДЕ
	|	(НЕ ДетальныеЗаписи.Контрагент В (&МассивКА)
	|			ИЛИ ДетальныеЗаписи.СуммаНачальныйОстаток < 0
	|			ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток < 0)";

	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ТипОбъектаПомещение", Справочники.АР_ТипыОбъектовАренды.Помещение);
	Запрос.УстановитьПараметр("ВидДвиженияПриход", ВидДвиженияНакопления.Приход);
	Запрос.УстановитьПараметр("ИК", Объект.ИК);
	Запрос.УстановитьПараметр("КонецПериода", Объект.ОкончаниеПериода);
	Запрос.УстановитьПараметр("НачалоПериода", Объект.НачалоПериода);
	Запрос.УстановитьПараметр("ТипРТУ", Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	Запрос.УстановитьПараметр("ТипЗначения", ПланыВидовХарактеристик.АР_СвойстваУниверсальногоРегистра.ИмущественныйКомплекс);
	
	Запрос.УстановитьПараметр("ТолькоДолжники",Объект.ТолькоДолжники); // + NAI Becar Комментирование Смирнов А.А. от 05.07.2018 15:20
	
	Если Объект.ВыделенныеКонтрагенты.Количество() > 0 Тогда
		
		МассивКА = Новый Массив;
		
		Для каждого Стр Из Объект.ВыделенныеКонтрагенты Цикл
			МассивКА.Добавить(Стр.Значение);
		КонецЦикла;
		
		Запрос.УстановитьПараметр("МассивКА", МассивКА);
		
	КонецЕсли; 

    /////////////набор запросов-
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб			= Истина;
	ТабДок.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;

	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("Основной");
	
	//заголовок+
	Область = Макет.ПолучитьОбласть("Заголовок");
	Область.Параметры.Заголовок = "Финансовые показатели по управляемым объектам за "+ Месяц;
	Область.Параметры.ИК = "Объект "+Объект.ИК;

	ТабДок.Вывести(Область);
	//заголовок-
	
	ВыделяемКА = Ложь;
	Если Объект.ВыделятьКредиторов Или Объект.ВыделенныеКонтрагенты.Количество() > 0 Тогда
		ВыделяемКА = Истина;
	Иначе
		
		ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка,
		"ГДЕ
		|	(НЕ ДетальныеЗаписи.Контрагент В (&МассивКА)
		|			ИЛИ ДетальныеЗаписи.СуммаНачальныйОстаток < 0
		|			ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток < 0)", ""); 
		
		//ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка, "ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток < 0)", "");
		//ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка, "НЕ ДетальныеЗаписи.Контрагент В (&МассивКА)", ""); 
		
	КонецЕсли;
	
	Если Не Объект.ВыделятьКредиторов Тогда
		
		Если ВыделяемКА Тогда
			ЗапросПоКонкретным = СтрЗаменить(ЗапросПоКонкретным, "ИЛИ (ДетальныеЗаписи.СуммаНачальныйОстаток > 0", ""); 
			ЗапросПоКонкретным = СтрЗаменить(ЗапросПоКонкретным, "ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток > 0)", ""); 
		КонецЕсли;
		
		ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка, "ИЛИ ДетальныеЗаписи.СуммаНачальныйОстаток < 0", ""); 
		ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка, "ИЛИ ДетальныеЗаписи.СуммаКонечныйОстаток < 0", ""); 
	
	КонецЕсли; 
	
	Если Объект.ВыделенныеКонтрагенты.Количество() = 0  Тогда
		
		Если ВыделяемКА Тогда
			ЗапросПоКонкретным = СтрЗаменить(ЗапросПоКонкретным, "ДетальныеЗаписи.Контрагент В (&МассивКА)", "Ложь");
		КонецЕсли;
		ЗапросГруппировка = СтрЗаменить(ЗапросГруппировка, "НЕ ДетальныеЗаписи.Контрагент В (&МассивКА)", "Ложь");
		
	КонецЕсли;	
	
	ИтогоНачислено = 0;
	ИтогоОплачено = 0;
	ИтогоДолг = 0;
	ИтогоДолгНаНачало = 0;
	
	Если ВыделяемКА Тогда //выделенные контрагенты+
		
		Запрос.Текст = ОсновнойЗапрос + Символы.ПС + ЗапросДетализацияВоВремТаблицу + Символы.ПС + ЗапросПоКонкретным; 
		
		РЗ = Запрос.Выполнить().Выбрать();
		
		Пока РЗ.Следующий() Цикл
			
			Область = Макет.ПолучитьОбласть("АрендаторСводнаяТЧ");
			Область.Параметры.АрендаторСводнойТЧ = РЗ.Контрагент;
			ТабДок.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("ШапкаСводнойТЧ");
			ТабДок.Вывести(Область);  
			
			Область = Макет.ПолучитьОбласть("СтрокаСводнойТЧ");
			ЗаполнитьЗначенияСвойств(Область.Параметры, РЗ); 
			ТабДок.Вывести(Область);
			
			
			Область = Макет.ПолучитьОбласть("ИтогоСводнойТЧ");
			
			Начислено = РЗ.ПениНачислено + РЗ.Перем + РЗ.Пост + РЗ.КУ + РЗ.НачислениеДепозита;  //нет депозита!!
			Оплачено = РЗ.ОплатаПени + РЗ.ОплатаДепозита + РЗ.СуммаРасход;
			Задолженность = РЗ.СуммаКонечныйОстаток + РЗ.ДепозитНаКонец + РЗ.ПениНаКонецПоБУ;
			Процент = (?(Начислено <> 0, Оплачено/Начислено, 0))*100;
			
			Область.Параметры.ИтогоНачислено = Начислено;
			Область.Параметры.ИтогоОплачено = Оплачено;
			Область.Параметры.ИтогоДолгНаКонец = Задолженность;
			Область.Параметры.Процент =  Строка(Окр(Процент, 2))+ "%";;
			
			ТабДок.Вывести(Область);
			
			ИтогоНачислено = ИтогоНачислено + Начислено;
			ИтогоОплачено = ИтогоОплачено + Оплачено;
			ИтогоДолг = ИтогоДолг + Задолженность;
			
			ИтогоДолгНаНачало = ИтогоДолгНаНачало + РЗ.СуммаНачальныйОстаток + РЗ.ДепозитНаНачало + РЗ.ПениНаНачалоПоБУ;
			
		КонецЦикла;	
		
		Область = Макет.ПолучитьОбласть("АрендаторСводнаяТЧ");
		Область.Параметры.АрендаторСводнойТЧ = "Остальные арендаторы";
		ТабДок.Вывести(Область);
		
	КонецЕсли; //выделенные контрагенты-
	
	//группировка+
	Запрос.Текст = ОсновнойЗапрос + Символы.ПС + ЗапросДетализацияВоВремТаблицу + Символы.ПС + ЗапросГруппировка;
	РЗ = Запрос.Выполнить().Выбрать();
	
	Пока РЗ.Следующий() Цикл
		
		Если РЗ.СуммаКонечныйОстаток = Null Тогда
		
			Продолжить; // + NAI Becar Конюшок С.Н. от 26.04.2017 02:22  заглушка, придумать лучше, срабатывает, когдадля группировки не отбирается никого
		
		КонецЕсли; 
		
		Область = Макет.ПолучитьОбласть("ШапкаСводнойТЧ");
		ТабДок.Вывести(Область);  
		
		Область = Макет.ПолучитьОбласть("СтрокаСводнойТЧ");
		ЗаполнитьЗначенияСвойств(Область.Параметры, РЗ); 
		ТабДок.Вывести(Область);
		
		Область = Макет.ПолучитьОбласть("ИтогоСводнойТЧ");
		
		Начислено = РЗ.ПениНачислено + РЗ.Перем + РЗ.Пост + РЗ.КУ + РЗ.НачислениеДепозита;  
		Оплачено = РЗ.ОплатаПени + РЗ.ОплатаДепозита + РЗ.СуммаРасход;
		Задолженность = РЗ.СуммаКонечныйОстаток + РЗ.ДепозитНаКонец + РЗ.ПениНаКонецПоБУ;
		
		Область.Параметры.ИтогоНачислено = Начислено;
		Область.Параметры.ИтогоОплачено = Оплачено;
		Область.Параметры.ИтогоДолгНаКонец = Задолженность;

		Процент = (?(Область.Параметры.ИтогоНачислено <> 0, Область.Параметры.ИтогоОплачено/Область.Параметры.ИтогоНачислено, 0))*100;
		Область.Параметры.Процент = Строка(Окр(Процент, 2))+ "%";
		
		ТабДок.Вывести(Область);
		
		Если ВыделяемКА Тогда
			Область = Макет.ПолучитьОбласть("ОбщийИтогСводнойТЧ");
			
			Область.Параметры.ИтогоДолгНаНачало = ИтогоДолгНаНачало + РЗ.СуммаНачальныйОстаток + РЗ.ДепозитНаНачало + РЗ.ПениНаНачалоПоБУ;
			
			Область.Параметры.ИтогоНачислено = Начислено + ИтогоНачислено;
			Область.Параметры.ИтогоОплачено = Оплачено + ИтогоОплачено;
			Область.Параметры.ИтогоДолгНаКонец = Задолженность + ИтогоДолг;
			
			//ИтогоНачислено = ИтогоНачислено + Начислено;
			//ИтогоОплачено = ИтогоОплачено + Оплачено;
			//ИтогоДолг = ИтогоДолг + Задолженность;
			
			Процент = (?(Область.Параметры.ИтогоНачислено <> 0, Область.Параметры.ИтогоОплачено/Область.Параметры.ИтогоНачислено, 0))*100;
			
			Область.Параметры.Процент = Строка(Окр(Процент, 2))+ "%";
			
			ТабДок.Вывести(Область);
		КонецЕсли;
		
		ИтогоНачислено = ИтогоНачислено + Начислено;
		ИтогоОплачено = ИтогоОплачено + Оплачено;
		ИтогоДолг = ИтогоДолг + Задолженность;
		
	КонецЦикла;
	//группировка-
	
	//площади+
	Запрос.Текст = ЗапросПлощади;
	РЗ = Запрос.Выполнить().Выбрать();
	
	Если РЗ.Следующий() Тогда
		
		Область = Макет.ПолучитьОбласть("ТЧПлощади");
		Область.Параметры.ОбщаяП = Объект.ИК.ЗначениеХарактеристики;
		Область.Параметры.АП = Объект.ИК.АП;
		Область.Параметры.Сдано = РЗ.ПлощадьСданных;
		Область.Параметры.Свободно = Объект.ИК.АП - РЗ.ПлощадьСданных;
		Область.Параметры.Заполнение = ?(Объект.ИК.АП=0,0,Строка(Окр(((РЗ.ПлощадьСданных /Объект.ИК.АП)*100),2))+"%"); 
		Область.Параметры.СданоЗаОтчПериод = РЗ.ПлощадьСданыхЗаОтчПериод;
		
		//ЗаполнитьЗначенияСвойств(Область.Параметры, РЗ); 
		ТабДок.Вывести(Область);
		
	КонецЕсли; 
	//площади-
	
	
	
	Запрос.Текст = ОсновнойЗапрос + Символы.ПС + СтрЗаменить(ЗапросДетализацияВоВремТаблицу, "ПОМЕСТИТЬ ДетальныеЗаписи", "");
	РЗ = Запрос.Выполнить().Выбрать();
	
	Область = Макет.ПолучитьОбласть("ШапкаДетализация");
	ТабДок.Вывести(Область);
	
	ТЗЗадолженностей = Новый ТаблицаЗначений;
	ТЗЗадолженностей.Колонки.Добавить("Основание");
	ТЗЗадолженностей.Колонки.Добавить("Сумма");
	
	Пока РЗ.Следующий() Цикл
		
		Если РЗ.СуммаКонечныйОстаток <> 0 Тогда
			НСтр = ТЗЗадолженностей.Добавить();
			НСтр.Основание = "Арендная плата";
			НСтр.Сумма = РЗ.СуммаКонечныйОстаток;
		КонецЕсли;	
			
		Если РЗ.ПениНаКонецПоБУ <> 0 Тогда
			НСтр = ТЗЗадолженностей.Добавить();
			НСтр.Основание = "Пени";
			НСтр.Сумма = РЗ.ПениНаКонецПоБУ;
		КонецЕсли;	
			
		Если РЗ.ДепозитНаКонец <> 0 и РЗ.ДепозитНаКонец <> null Тогда
			НСтр = ТЗЗадолженностей.Добавить();
			НСтр.Основание = "Депозит";
			НСтр.Сумма = РЗ.ДепозитНаКонец;
		КонецЕсли;
		
		Если ТЗЗадолженностей.Количество() = 1 Тогда
			
			Область = Макет.ПолучитьОбласть("Строка1Детализация");
			Область.Параметры.Основание1 = ТЗЗадолженностей[0].Основание; 
			Область.Параметры.Сумма1 = ТЗЗадолженностей[0].Сумма; 
			Область.Параметры.Контрагент = РЗ.Контрагент;
			
			ТабДок.Вывести(Область);
			
		ИначеЕсли ТЗЗадолженностей.Количество() = 2 Тогда
			Область = Макет.ПолучитьОбласть("Строка2Детализация");
			
			Область.Параметры.Основание1 = ТЗЗадолженностей[0].Основание; 
			Область.Параметры.Сумма1 = ТЗЗадолженностей[0].Сумма; 
			
			Область.Параметры.Основание2 = ТЗЗадолженностей[1].Основание; 
			Область.Параметры.Сумма2 = ТЗЗадолженностей[1].Сумма;
			
			Область.Параметры.Контрагент = РЗ.Контрагент;
			
			ТабДок.Вывести(Область);
			
		ИначеЕсли ТЗЗадолженностей.Количество() = 3 Тогда
			Область = Макет.ПолучитьОбласть("Строка3Детализация");
			
			Область.Параметры.Основание1 = ТЗЗадолженностей[0].Основание; 
			Область.Параметры.Сумма1 = ТЗЗадолженностей[0].Сумма; 
			
			Область.Параметры.Основание2 = ТЗЗадолженностей[1].Основание; 
			Область.Параметры.Сумма2 = ТЗЗадолженностей[1].Сумма; 
			
			Область.Параметры.Основание3 = ТЗЗадолженностей[2].Основание; 
			Область.Параметры.Сумма3 = ТЗЗадолженностей[2].Сумма; 
			
			Область.Параметры.Контрагент = РЗ.Контрагент;
			
			ТабДок.Вывести(Область);
			
		КонецЕсли;
		
		ТЗЗадолженностей.Очистить();
		
	КонецЦикла;
	
	Область = Макет.ПолучитьОбласть("ИтогДетализация");	
	Область.Параметры.Сумма = ИтогоДолг;
	ТабДок.Вывести(Область);
	
	Объект.Таблица = ТабДок;
	
	
КонецПроцедуры

