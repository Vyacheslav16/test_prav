
&НаКлиенте
Процедура Сформировать(Команда)
	
	Объект.ВыделенныеКонтрагенты = ВыделенныеКонтрагенты;
	
	СформироватьНаСервере();
КонецПроцедуры

&НаСервере
Процедура СформироватьНаСервере()
	
	//проверки
	Если Не ЗначениеЗаполнено(Объект.ИК)Тогда
		Сообщить("Необходимо указать имущественный комплекс!");
		Возврат;
	КонецЕсли; 
	
	Если Месяц = "" Тогда
		Сообщить("Необходимо указать период!");
		Возврат;
	КонецЕсли;	
	
	//запросы +
	
	ЗапросПлощади ="ВЫБРАТЬ
	               |	ВЫРАЗИТЬ(АР_УниверсальныйРегистр.Объект КАК Справочник.АР_ОбъектыАренды) КАК ОбъектАрендыИК
	               |ПОМЕСТИТЬ ОбъектыИК
	               |ИЗ
	               |	РегистрСведений.АР_УниверсальныйРегистр КАК АР_УниверсальныйРегистр
				   |ГДЕ
				   |	АР_УниверсальныйРегистр.Значение = &ИК
				   |	И АР_УниверсальныйРегистр.ТипЗначения = &ТипЗначения
				   |	И ВЫРАЗИТЬ(АР_УниверсальныйРегистр.Объект КАК Справочник.АР_ОбъектыАренды).ТипОбъекта = &ТипОбъектаПомещение				   
				   |
				   |ИНДЕКСИРОВАТЬ ПО
				   |	ОбъектАрендыИК
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	АР_СтатусыОбъектовАренды.ДатаНачалаАренды,
	               |	АР_СтатусыОбъектовАренды.ДатаОкончанияАренды,
	               |	АР_СтатусыОбъектовАренды.ОбъектАренды,
	               |	АР_СтатусыОбъектовАренды.Договор
	               |ПОМЕСТИТЬ СтатусыОбъектов
	               |ИЗ
	               |	ОбъектыИК КАК ОбъектыИК
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АР_СтатусыОбъектовАренды КАК АР_СтатусыОбъектовАренды
	               |		ПО ОбъектыИК.ОбъектАрендыИК = АР_СтатусыОбъектовАренды.ОбъектАренды
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	МИНИМУМ(СтатусыОбъектов.ДатаНачалаАренды) КАК ДатаНачалаАренды,
	               |	МАКСИМУМ(СтатусыОбъектов.ДатаОкончанияАренды) КАК ДатаОкончанияАренды,
	               |	СтатусыОбъектов.ОбъектАренды,
	               |	СтатусыОбъектов.Договор
	               |ПОМЕСТИТЬ ДействиеПоДоговорам
	               |ИЗ
	               |	СтатусыОбъектов КАК СтатусыОбъектов
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СтатусыОбъектов.ОбъектАренды,
	               |	СтатусыОбъектов.Договор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СУММА(ДействиеПоДоговорам.ОбъектАренды.ЗначениеХарактеристики) КАК ПлощадьСданыхЗаОтчПериод
	               |ПОМЕСТИТЬ СданоЗаОтчПериод
	               |ИЗ
	               |	ДействиеПоДоговорам КАК ДействиеПоДоговорам
	               |ГДЕ
	               |	ДействиеПоДоговорам.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	МИНИМУМ(СтатусыОбъектов.ДатаНачалаАренды) КАК ДатаНачалаАренды,
	               |	МАКСИМУМ(СтатусыОбъектов.ДатаОкончанияАренды) КАК ДатаОкончанияАренды,
	               |	СтатусыОбъектов.ОбъектАренды
	               |ПОМЕСТИТЬ ДействиеПоПомещениям
	               |ИЗ
	               |	СтатусыОбъектов КАК СтатусыОбъектов
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СтатусыОбъектов.ОбъектАренды
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СУММА(ДействиеПоПомещениям.ОбъектАренды.ЗначениеХарактеристики) КАК ПлощадьСданных
	               |ПОМЕСТИТЬ Сданные
	               |ИЗ
	               |	ДействиеПоПомещениям КАК ДействиеПоПомещениям
	               |ГДЕ
	               |	(ДействиеПоПомещениям.ДатаОкончанияАренды > &КонецПериода
	               |				И ДействиеПоПомещениям.ДатаНачалаАренды < &НачалоПериода
	               |			ИЛИ ДействиеПоПомещениям.ДатаНачалаАренды МЕЖДУ &НачалоПериода И &КонецПериода)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕстьNull(Сданные.ПлощадьСданных, 0) Как ПлощадьСданных,
	               |	ЕстьNull(СданоЗаОтчПериод.ПлощадьСданыхЗаОтчПериод, 0) Как ПлощадьСданыхЗаОтчПериод
	               |ИЗ
	               |	Сданные КАК Сданные,
	               |	СданоЗаОтчПериод КАК СданоЗаОтчПериод";	
	
	ОсновнойЗапрос =
	
	"ВЫБРАТЬ Разрешенные
	|	АР17_ЗаключениеДоговораАренды.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	АР17_ЗаключениеДоговораАренды.Контрагент КАК Контрагент,
	|	АР17_ЗаключениеДоговораАренды.СуммаЗалога КАК СуммаЗалога
	|ПОМЕСТИТЬ Договоры
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
	|ГДЕ
	|	АР17_ЗаключениеДоговораАренды.Проведен
	|	И АР17_ЗаключениеДоговораАренды.ИК = &ИК
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|	АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаРасход КАК СуммаРасход,
	|	ВЫБОР
	|		КОГДА &ТолькоДолжники
	|			ТОГДА ВЫБОР
	|					КОГДА АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаКонечныйОстаток > 0
	|						ТОГДА АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаКонечныйОстаток
	|				КОНЕЦ
	|		ИНАЧЕ АР_РасчетыПоДоговорамОстаткиИОбороты.СуммаКонечныйОстаток
	|	КОНЕЦ КАК СуммаКонечныйОстаток,
	|	Договоры.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ ОстаткиИОплаты
	|ИЗ
	|	РегистрНакопления.АР_РасчетыПоДоговорам.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, Месяц, , ) КАК АР_РасчетыПоДоговорамОстаткиИОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Договоры КАК Договоры
	|		ПО АР_РасчетыПоДоговорамОстаткиИОбороты.ДоговорКонтрагента = Договоры.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АР_РасчетыПоДоговорам.Регистратор КАК Регистратор,
	|	Договоры.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ Реализации
	|ИЗ
	|	РегистрНакопления.АР_РасчетыПоДоговорам КАК АР_РасчетыПоДоговорам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Договоры КАК Договоры
	|		ПО АР_РасчетыПоДоговорам.ДоговорКонтрагента = Договоры.ДоговорКонтрагента
	|ГДЕ
	|	АР_РасчетыПоДоговорам.Период <= &КонецПериода
	|	И АР_РасчетыПоДоговорам.Период >= &НачалоПериода
	|	И АР_РасчетыПоДоговорам.ВидДвижения = &ВидДвиженияПриход
	|	И ТИПЗНАЧЕНИЯ(АР_РасчетыПоДоговорам.Регистратор) = &ТипРТУ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугУслуги.Сумма КАК Сумма,
	|	Реализации.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугУслуги.Номенклатура.АР_ПостояннаяЧастьОплаты
	|			ТОГДА ""Пост""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РеализацияТоваровУслугУслуги.Номенклатура.АР_КоммунальныеУслуги
	|					ТОГДА ""КУ""
	|				ИНАЧЕ ""Перем""
	|			КОНЕЦ
	|	КОНЕЦ КАК ВидНоменклатуры
	|ПОМЕСТИТЬ РеализованныеУслуги
	|ИЗ
	|	Реализации КАК Реализации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Услуги КАК РеализацияТоваровУслугУслуги
	|		ПО Реализации.Регистратор = РеализацияТоваровУслугУслуги.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугАгентскиеУслуги.Сумма,
	|	Реализации.ДоговорКонтрагента,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугАгентскиеУслуги.Номенклатура.АР_ПостояннаяЧастьОплаты
	|			ТОГДА ""Пост""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РеализацияТоваровУслугАгентскиеУслуги.Номенклатура.АР_КоммунальныеУслуги
	|					ТОГДА ""КУ""
	|				ИНАЧЕ ""Перем""
	|			КОНЕЦ
	|	КОНЕЦ
	|ИЗ
	|	Реализации КАК Реализации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.АгентскиеУслуги КАК РеализацияТоваровУслугАгентскиеУслуги
	|		ПО Реализации.Регистратор = РеализацияТоваровУслугАгентскиеУслуги.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализованныеУслуги.Сумма КАК Пост,
	|	0 КАК Перем,
	|	0 КАК Ку,
	|	РеализованныеУслуги.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ РеализованныеУслуги1
	|ИЗ
	|	РеализованныеУслуги КАК РеализованныеУслуги
	|ГДЕ
	|	РеализованныеУслуги.ВидНоменклатуры = ""Пост""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	0,
	|	РеализованныеУслуги.Сумма,
	|	0,
	|	РеализованныеУслуги.ДоговорКонтрагента
	|ИЗ
	|	РеализованныеУслуги КАК РеализованныеУслуги
	|ГДЕ
	|	РеализованныеУслуги.ВидНоменклатуры = ""Перем""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	0,
	|	0,
	|	РеализованныеУслуги.Сумма,
	|	РеализованныеУслуги.ДоговорКонтрагента
	|ИЗ
	|	РеализованныеУслуги КАК РеализованныеУслуги
	|ГДЕ
	|	РеализованныеУслуги.ВидНоменклатуры = ""КУ""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Договоры.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ ДоговораБезРТУ
	|ИЗ
	|	Договоры КАК Договоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Реализации КАК Реализации
	|		ПО Договоры.ДоговорКонтрагента = Реализации.ДоговорКонтрагента
	|ГДЕ
	|	Реализации.ДоговорКонтрагента ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоговораБезРТУ.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	АР17_ПроведениеДоговораАренды.Ссылка КАК ПроведениеДоговораАренды
	|ПОМЕСТИТЬ УслугиПоДоговору1
	|ИЗ
	|	ДоговораБезРТУ КАК ДоговораБезРТУ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ПроведениеДоговораАренды КАК АР17_ПроведениеДоговораАренды
	|		ПО ДоговораБезРТУ.ДоговорКонтрагента = АР17_ПроведениеДоговораАренды.ДоговорКонтрагента
	|ГДЕ
	|	АР17_ПроведениеДоговораАренды.Дата >= &НачалоПериода
	|	И АР17_ПроведениеДоговораАренды.Дата <= &КонецПериода
	|	И АР17_ПроведениеДоговораАренды.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АР17_ПроведениеДоговораАрендыУслуги.Сумма КАК Сумма,
	|	УслугиПоДоговору1.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВЫБОР
	|		КОГДА АР17_ПроведениеДоговораАрендыУслуги.Номенклатура.АР_ПостояннаяЧастьОплаты
	|			ТОГДА ""Пост""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА АР17_ПроведениеДоговораАрендыУслуги.Номенклатура.АР_КоммунальныеУслуги
	|					ТОГДА ""КУ""
	|				ИНАЧЕ ""Перем""
	|			КОНЕЦ
	|	КОНЕЦ КАК ВидНоменклатуры
	|ПОМЕСТИТЬ УслугиПоДоговору2
	|ИЗ
	|	УслугиПоДоговору1 КАК УслугиПоДоговору1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ПроведениеДоговораАренды.Услуги КАК АР17_ПроведениеДоговораАрендыУслуги
	|		ПО УслугиПоДоговору1.ПроведениеДоговораАренды = АР17_ПроведениеДоговораАрендыУслуги.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УслугиПоДоговору2.ДоговорКонтрагента КАК ДоговорКонтрагента,
