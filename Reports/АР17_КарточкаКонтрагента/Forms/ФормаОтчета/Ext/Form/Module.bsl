Процедура ОтчетВывести()Экспорт
	
	ТД = Элементы.ТД;//ЭлементыФормы.ТД;
	
	ТД.Очистить();
	Макет = РеквизитФормыВЗначение("Отчет").ПолучитьМакет("Отчет");//Отчеты.АР17_КарточкаКонтрагента.ПолучитьМакет("Отчет");

	
	 //Шапка
	Область = Макет.ПолучитьОбласть("Шапка");
	Область.Параметры.Контрагент = Отчет.Контрагент;
	ТД.Вывести(Область);
	
	// Комплекты документов
	Если Комплекты Тогда
		РЗДоговоры = ПолучитьКомплекты();
		
		Область = Макет.ПолучитьОбласть("Заголовок_Комплекты");
		ТД.Вывести(Область);			
		
		Пока РЗДоговоры.Следующий() Цикл
			
			Если РЗДоговоры.ДопСоглашение = Null Тогда
				
				Область = Макет.ПолучитьОбласть("ШапкаКомплектов");
				Область.Параметры.Договор = РЗДоговоры.ВводДоговора.ДоговорКонтрагента;
				ТД.Вывести(Область);			
				
				ТЗ = ПолучитьКомплекты_(РЗДоговоры.ВводДоговора);
				Для Каждого Стр из ТЗ Цикл
					Область = Макет.ПолучитьОбласть("СтрКомплектов");
					
					Если Найти(Строка(Стр.ДоговорСсылка),"Изменение") > 0 Тогда
						Область.Параметры.Наименование = Стр.ДоговорСсылка;
					Иначе	
						Область.Параметры.Наименование = "Договор" + " №" + Стр.ДоговорСсылка.Номер + " от " + формат(Стр.ДоговорСсылка.Дата,"ДЛФ=Д");
						Область.Параметры.Передан = формат(Стр.ДоговорСсылка.Передан,"ДЛФ=Д");
					КонецЕсли;	
					
					Область.Параметры.ДатаН = формат(Стр.ДатаЗаключенияДоговора,"ДЛФ=Д");
					Область.Параметры.ДатаК = формат(Стр.ДатаОкончанияДоговора,"ДЛФ=Д");
					Область.Параметры.Площадь = Стр.Площадь;
					//Область.Параметры.Сумма = ПолучитьСуммуЗаМесяц(РЗДоговоры.ВводДоговора);
					//ТЗ = ПолучитьКомплекты_(РЗДоговоры.ВводДоговора);
					//Кол = ТЗ.Количество();
					//Область.Параметры.Сумма = ТЗ[ТЗ.Количество()-1].СуммаПоДоговору;
					Область.Параметры.Сумма = Стр.СуммаПоДоговору;
					
					Область.Параметры.ДатаИзм = формат(Стр.СрокИзменения,"ДЛФ=Д");
					Область.Параметры.Возвращен = формат(Стр.Ссылка.Возвращен,"ДЛФ=Д"); //ПереданВозвращен(Стр.ДоговорСсылка, ВидДвиженияНакопления.Расход);
					Область.Параметры.Невозвр = НеВозвращен(Стр.ДоговорСсылка);
					Область.Параметры.Документ = Стр.ДоговорСсылка;
					ТД.Вывести(Область);

				КонецЦикла;	
				
			Иначе
				
				Область = Макет.ПолучитьОбласть("СтрКомплектов");
				Область.Параметры.Наименование = Строка(ТипЗнч(РЗДоговоры.ДопСоглашение)) + " №" + АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(РЗДоговоры.ДопСоглашение.Номер) + " от " + формат(РЗДоговоры.ДопСоглашение.Дата,"ДЛФ=Д");
				Если ТипЗнч(РЗДоговоры.ДопСоглашение) = Тип("ДокументСсылка.АР17_ДополнительноеСоглашение") Тогда
					Область.Параметры.ДатаН = формат(РЗДоговоры.ДопСоглашение.ДатаЗаключенияДоговора,"ДЛФ=Д");
					Область.Параметры.ДатаК = формат(РЗДоговоры.ДопСоглашение.ДатаОкончанияДоговора,"ДЛФ=Д");
				КонецЕсли;	
				Область.Параметры.Площадь = РЗДоговоры.ВводДоговора.ОбъектыАренды.Итог("Площадь");
				Область.Параметры.Сумма = РЗДоговоры.СуммаДопСоглашения;
				Область.Параметры.ДатаИзм = формат(РЗДоговоры.ДопСоглашение.Дата,"ДЛФ=Д");
				Область.Параметры.Передан = формат(РЗДоговоры.ДопСоглашение.Передан,"ДЛФ=Д");
				Область.Параметры.Возвращен = ПереданВозвращен(РЗДоговоры.ДопСоглашение, ВидДвиженияНакопления.Расход);
				Область.Параметры.Невозвр = НеВозвращен(РЗДоговоры.ДопСоглашение);
				Область.Параметры.Документ = РЗДоговоры.ДопСоглашение;
				ТД.Вывести(Область);
				
			КонецЕсли;
			
			
		КонецЦикла;
		Если РЗДоговоры.Количество() <> 0 Тогда
			Область = Макет.ПолучитьОбласть("ПодвалКомплектов");
			ТД.Вывести(Область);			
		КонецЕсли;	
		
	КонецЕсли;
	
	// Информационный документ
	ТЗ = ПолучитьИД();
	Если ТЗ.Количество() <> 0 Тогда
		Область = Макет.ПолучитьОбласть("ШапкаИД");
		ТД.Вывести(Область);			
	КонецЕсли;	
	Для Каждого Стр из ТЗ Цикл
		Область = Макет.ПолучитьОбласть("СтрИД");
		Область.Параметры.Наименование = Стр.Ссылка.Наименование + " № " + Стр.Ссылка.Номер; //"Информационный документ";
		Область.Параметры.НомерДата =  Стр.Ссылка.Номер + " от " + Формат(Стр.Ссылка.Дата, "ДЛФ=Д");
		Область.Параметры.Содержание = Стр.Ссылка.Текст;
		Область.Параметры.Передан = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Приход);
		Область.Параметры.Возвращен = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Расход);
		Область.Параметры.Невозвр = НеВозвращен(Стр.Ссылка);
		Область.Параметры.Документ = Стр.Ссылка;
		ТД.Вывести(Область);
	КонецЦикла;	
	Если ТЗ.Количество() <> 0 Тогда
		Область = Макет.ПолучитьОбласть("ПодвалИД");
		ТД.Вывести(Область);			
	КонецЕсли;	
	/////
	
	// Акты П/П
	Если АктыПП Тогда
		ТЗ = ПолучитьАктыПП();
		Если ТЗ.Количество() <> 0 Тогда
			Область = Макет.ПолучитьОбласть("ШапкаАктовПП");
			ТД.Вывести(Область);			
		КонецЕсли;	
		Для Каждого Стр из ТЗ Цикл
			Область = Макет.ПолучитьОбласть("СтрАктовПП");
			//Область.Параметры.Наименование = ?(Стр.Тип = Перечисления.ТипыАктовПриемаПередачи.Передача, "Акт передачи в аренду", "Акт возврата арендатором");
			Область.Параметры.Наименование = Строка(ТипЗНЧ(Стр.Ссылка)) + " №" + АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(Стр.Ссылка.Номер);
			Комнаты = "";
			//Для Каждого Стр_К из Стр.Документ.СоставОбъекта Цикл
			//	Комнаты = Комнаты + Стр_К.Комната + ", ";
			//КонецЦикла;	
			//Комнаты = Сред(Комнаты, 1, СтрДлина(Комнаты) - 2);
			//Область.Параметры.Помещения = Комнаты;
			Область.Параметры.Дата = Стр.Ссылка.Дата;
			Площадь = "";//Стр.Документ.СоставОбъекта.Итог("АрендуемаяПлощадь"); 
			Область.Параметры.Площадь = Стр.Площадь; // ?(Стр.Тип = Перечисления.ТипыАктовПриемаПередачи.Передача, Площадь, (-1) * Площадь); //-са
			//Если ТипЗнч(Стр.Ссылка) = Тип("ДокументСсылка.АР_АктПриемаПередачиПомещенияВАренду") Тогда
			//	Область.Параметры.Передан = ?(ЗначениеЗаполнено(Стр.Ссылка.Передан),"1","");
			//	Область.Параметры.Возвращен = ?(ЗначениеЗаполнено(Стр.Ссылка.Возвращен),"1","");
			//Иначе
			//	Область.Параметры.Передан = ?(ЗначениеЗаполнено(Стр.Ссылка.Передан),"1","");
			//	Область.Параметры.Возвращен = ?(ЗначениеЗаполнено(Стр.Ссылка.Возвращен),"1","");
			//КонецЕсли;
			//
			//Область.Параметры.Передан = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Приход);
			//Область.Параметры.Возвращен = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Расход);
			Область.Параметры.Передан = Стр.Ссылка.Передан;
			Область.Параметры.Возвращен = Стр.Ссылка.Возвращен;
			//
			Область.Параметры.Невозвр = НеВозвращен(Стр.Ссылка);
			Область.Параметры.Документ = Стр.Ссылка;
			ТД.Вывести(Область);
