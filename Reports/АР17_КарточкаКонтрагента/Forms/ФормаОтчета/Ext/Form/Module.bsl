Функция ПолучитьКомплекты()
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР_ЗаключениеДоговораАренды.Ссылка КАК ВводДоговора,
		|	NULL КАК СуммаДопСоглашения,
		|	NULL КАК ДопСоглашение,
		|	АР_ЗаключениеДоговораАренды.ОбщаяСумма КАК СуммаДоговора
		|ПОМЕСТИТЬ ДоговорыИСуммы
		|ИЗ
		|	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		|ГДЕ
		|	АР_ЗаключениеДоговораАренды.Контрагент = &Контрагент
		|	И АР_ЗаключениеДоговораАренды.Проведен = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МАКСИМУМ(АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Ссылка.ДокументОснование),
		|	СУММА(АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Сумма),
		|	АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Ссылка,
		|	NULL
		|ИЗ
		|	Документ.АР17_ДополнительноеСоглашение.ПостояннаяЧастьАренднойПлаты КАК АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты
		|ГДЕ
		|	АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Ссылка.Контрагент = &Контрагент
		|	И АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Ссылка.Проведен = ИСТИНА
		|
		|СГРУППИРОВАТЬ ПО
		|	АР_ДополнительноеСоглашениеПостояннаяЧастьАренднойПлаты.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МАКСИМУМ(АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ссылка.ДокументОснование),
		|	СУММА((ВЫРАЗИТЬ(АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ставка КАК ЧИСЛО(15, 2))) * (ВЫРАЗИТЬ(АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Количество КАК ЧИСЛО(15, 2)))),
		|	АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ссылка,
		|	NULL
		|ИЗ
		|	Документ.АР17_ДополнительноеСоглашение.ПеременнаяЧастьАренднойПлаты КАК АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты
		|ГДЕ
		|	АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ссылка.Контрагент = &Контрагент
		|	И АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ссылка.Проведен = ИСТИНА
		|
		|СГРУППИРОВАТЬ ПО
		|	АР_ДополнительноеСоглашениеПеременнаяЧастьАренднойПлаты.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АР_РасторжениеДоговораАренды.ДокументОснование,
		|	NULL,
		|	АР_РасторжениеДоговораАренды.Ссылка,
		|	NULL
		|ИЗ
		|	Документ.АР17_РасторжениеДоговораАренды КАК АР_РасторжениеДоговораАренды
		|ГДЕ
		|	АР_РасторжениеДоговораАренды.Контрагент = &Контрагент
		|	И АР_РасторжениеДоговораАренды.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоговорыИСуммы.ВводДоговора,
		|	СУММА(ДоговорыИСуммы.СуммаДопСоглашения) КАК СуммаДопСоглашения,
		|	ДоговорыИСуммы.ДопСоглашение,
		|	СУММА(ДоговорыИСуммы.СуммаДоговора) КАК СуммаДоговора
		|ИЗ
		|	ДоговорыИСуммы КАК ДоговорыИСуммы
		|
		|СГРУППИРОВАТЬ ПО
		|	ДоговорыИСуммы.ВводДоговора,
		|	ДоговорыИСуммы.ДопСоглашение";
	
	Запрос.УстановитьПараметр("Контрагент", Отчет.Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат РезультатЗапроса;
	
