			Область = Макет.ПолучитьОбласть("ПодвалАктовПП");
			ТД.Вывести(Область);			
		КонецЕсли;	
	КонецЕсли;
	
	// Письма
	Если Письма Тогда
		ТЗ = ПолучитьПисьма();
		Если ТЗ.Количество() <> 0 Тогда
			Область = Макет.ПолучитьОбласть("ШапкаПисем");
			ТД.Вывести(Область);			
		КонецЕсли;	
		Для Каждого Стр из ТЗ Цикл
			Область = Макет.ПолучитьОбласть("СтрПисем");
			Область.Параметры.Наименование = "Письмо";
			Область.Параметры.НомерДата =  АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(Стр.Ссылка.Номер) + " от " + Формат(Стр.Ссылка.Дата, "ДЛФ=Д");
			Область.Параметры.Содержание = Стр.Ссылка.Содержание;
			//Область.Параметры.Сумма = Стр.Сумма;
			Область.Параметры.Передан = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Приход);
			Область.Параметры.Возвращен = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Расход);
			Область.Параметры.Невозвр = НеВозвращен(Стр.Ссылка);
			Область.Параметры.Документ = Стр.Ссылка;
			ТД.Вывести(Область);
		КонецЦикла;	
		Если ТЗ.Количество() <> 0 Тогда
			Область = Макет.ПолучитьОбласть("ПодвалПисем");
			ТД.Вывести(Область);			
		КонецЕсли;	
	КонецЕсли;
	
	// Счета
	Если Счета Тогда
		
		//+
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР17_ЗаключениеДоговораАренды.Ссылка
		               |ИЗ
		               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |ГДЕ
		               |	АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент";
					   
		Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
		ВыборкаДог = Запрос.Выполнить().Выбрать();
		//-
		
		Пока ВыборкаДог.Следующий() Цикл
		
			ТЗ = ПолучитьСчета(ВыборкаДог.Ссылка);
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ШапкаСчетов");
				Область.Параметры.Договор = ВыборкаДог.Ссылка.ДоговорКонтрагента;
				ТД.Вывести(Область);			
			КонецЕсли;	
			Для Каждого Стр из ТЗ Цикл
				Область = Макет.ПолучитьОбласть("СтрСчетов");
				//Область.Параметры.Наименование = "Счет №" + ОбщегоНазначения.ПолучитьНомерНаПечать(Стр.Ссылка) + " от " + Формат(Стр.Ссылка.Дата, "ДЛФ=Д");
				Область.Параметры.Наименование = "Счет №" + Стр.Ссылка.Номер + " от " + Формат(Стр.Ссылка.Дата, "ДЛФ=Д");
				Область.Параметры.ГруппаУслуг = Стр.ГруппаУслуг;
				Область.Параметры.Сумма = Стр.Сумма;
				Область.Параметры.Передан = ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Приход);
				Область.Параметры.Передан = Формат(Стр.Ссылка.Передан, "ДФ=dd.MM.yyyy");
				Область.Параметры.Документ = Стр.Ссылка;
				ТД.Вывести(Область);
			КонецЦикла;	
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ПодвалСчетов");
				ТД.Вывести(Область);			
			КонецЕсли;
		КонецЦикла;	
			
	КонецЕсли;

	// Акты
	Если Акты Тогда
		
		//+
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР17_ЗаключениеДоговораАренды.Ссылка
		               |ИЗ
		               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |ГДЕ
		               |	АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент";
					   
		Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
		ВыборкаДог = Запрос.Выполнить().Выбрать();
		//-
		
		Пока ВыборкаДог.Следующий() Цикл
		
			ТЗ = ПолучитьАкты(ВыборкаДог.Ссылка);
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ШапкаАктов");
				Область.Параметры.Договор = ВыборкаДог.Ссылка.ДоговорКонтрагента;
				ТД.Вывести(Область);			
			КонецЕсли;	
			Для Каждого Стр из ТЗ Цикл
				Область = Макет.ПолучитьОбласть("СтрАктов");
				Область.Параметры.Наименование = "Акт №" + НомерРеализации(Стр.Ссылка) + " от " + Формат(Стр.Ссылка.Дата, "ДЛФ=Д");
				Область.Параметры.ГруппаУслуг = Стр.ГруппаУслуг;
				Область.Параметры.Сумма = Стр.Ссылка.СуммаДокумента;
				Область.Параметры.Передан = ?(Стр.Ссылка.Передан<>Дата(1,1,1),Формат(Стр.Ссылка.Передан, "ДЛФ=Д"),"");//ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Приход);
				Область.Параметры.Возвращен = ?(Стр.Ссылка.Возвращен<>Дата(1,1,1),Формат(Стр.Ссылка.Возвращен, "ДЛФ=Д"),"");//ПереданВозвращен(Стр.Ссылка, ВидДвиженияНакопления.Расход);
				Область.Параметры.Невозвр = ?(НеВозвращен(Стр.Ссылка)>1,1,0);
				Область.Параметры.Документ = Стр.Ссылка;
				ТД.Вывести(Область);
			КонецЦикла;	
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ПодвалАктов");
				ТД.Вывести(Область);			
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	// Оперативная задолженность
	Если ОЗ Тогда
		Область = Макет.ПолучитьОбласть("ШапкаОЗ");
		Область.Параметры.Заголовок = "ОПЕРАТИВНАЯ ЗАДОЛЖЕННОСТЬ на " + Формат(ТекущаяДата(), "ДЛФ=Д") + " (без учета депозита).";//+ Символы.ПС + "Договор № " + РЗДоговоры.ВводДоговора.ДоговорКонтрагента.Номер;
		ТД.Вывести(Область);
		
		//+
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР17_ЗаключениеДоговораАренды.Ссылка
		               |ИЗ
		               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |ГДЕ
		               |	АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент";
					   
		Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
		ВыборкаДог = Запрос.Выполнить().Выбрать();
		//-
		
		Пока ВыборкаДог.Следующий() Цикл
			ТЗ.Очистить();
			ТЗ = ПолучитьОЗ(ВыборкаДог.Ссылка);
			//Итог = ТЗ.Итог("СуммаОстаток");
			//Если Итог > 0 Тогда
			Если ТЗ.Количество() > 0 Тогда
				Область = Макет.ПолучитьОбласть("ШапкаТабОЗ");
				Область.Параметры.ЗаголовокОЗ = "Договор № " + ВыборкаДог.Ссылка.ДоговорКонтрагента.Номер;
				ТД.Вывести(Область);	
			//КонецЕсли;
		
				//+
				//Мес = РазбитьПериод(ВыборкаДог.Ссылка.Дата, Мин(Отчет.КонецПериода, ВыборкаДог.Ссылка.ДатаОкончания));
				Мес = РазбитьПериод(Отчет.НачалоПериода, Мин(Отчет.КонецПериода, ВыборкаДог.Ссылка.ДатаОкончания));
				Для Каждого СтрМес из Мес Цикл
					Нач = НачалоМесяца(СтрМес.НачалоПериода);
					Если ТЗ.Найти(Нач, "НачалоПериода") = Неопределено Тогда
						НоваяСтрока = ТЗ.Добавить();
						НоваяСтрока.НачалоПериода = СтрМес.НачалоПериода;
						НоваяСтрока.СуммаОстаток = ПолучитьСуммуЗаМесяц(ВыборкаДог.Ссылка, СтрМес.НачалоПериода);
					КонецЕсли;
				КонецЦикла;
				//-
			
				ТЗ.Сортировать("НачалоПериода Возр");
				Для Каждого Стр из ТЗ Цикл
					Если Стр.СуммаОстаток = 0 Тогда Продолжить; КонецЕсли;
					Область = Макет.ПолучитьОбласть("СтрокаОЗ");
					Если Стр.СчетНаАренду = Неопределено Тогда
						Область.Параметры.Наименование = Формат(Стр.НачалоПериода, "ДФ='ММММ yyyy'");
						Если Стр.СуммаОстаток = Неопределено Тогда
							Область.Параметры.Сумма = 0;
						Иначе	
							Область.Параметры.Сумма = Макс(Стр.СуммаОстаток, -Стр.СуммаОстаток); //Стр.СуммаДокумента;
						КонецЕсли;
					Иначе	
						Наименование = ?(ТипЗнч(Стр.СчетНаАренду) = Тип("ДокументСсылка.АР17_СчетНаАренду"), "Счет №", "Ввод начальных остатков №");
						Область.Параметры.Наименование = Наименование + Стр.СчетНаАренду.Номер + " от " + Формат(Стр.СчетНаАренду.Дата, "ДЛФ=Д");
						Если Стр.СуммаОстаток = Неопределено Тогда
							Область.Параметры.Сумма = 0;
						Иначе	
							Область.Параметры.Сумма = Макс(Стр.СуммаОстаток, -Стр.СуммаОстаток); //Стр.СуммаДокумента;
						КонецЕсли;
						Область.Параметры.Документ = Стр.СчетНаАренду;
					КонецЕсли;	
					ТД.Вывести(Область);				
				КонецЦикла;
				
			КонецЕсли; //---	
				
			//Итог = ТЗ.Итог("СуммаДокумента");
			Итог = ТЗ.Итог("СуммаОстаток");
			Если Итог <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ИтогоОЗ");
				Область.Параметры.Итого = Итог;
				ТД.Вывести(Область);
			КонецЕсли;	
			Область = Макет.ПолучитьОбласть("ПодвалОЗ");
			Если Итог = 0 Тогда
				Область.Параметры.Подвал = "Оперативная задолженность по договору " + ВыборкаДог.Ссылка.ДоговорКонтрагента.Номер + " отсутствует.";
			ИначеЕсли Итог > 0 Тогда
				Область.Параметры.Подвал = "Задолженность по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			ИначеЕсли Итог < 0 Тогда
				Итог = Итог * (-1);
				Область.Параметры.Подвал = "Переплата по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			КонецЕсли;	
			ТД.Вывести(Область);
			
		КонецЦикла;	
			
	КонецЕсли;
	
	// Регламентированная задолженность
	Если Рег Тогда
		Область = Макет.ПолучитьОбласть("ШапкаРег");
		Область.Параметры.Заголовок = "РЕГЛАМЕНТИРОВАННАЯ ЗАДОЛЖЕННОСТЬ на " + Формат(ТекущаяДата(), "ДЛФ=Д") + " (без учета депозита)."; //+ Символы.ПС + "Договор № " + РЗДоговоры.ВводДоговора.ДоговорКонтрагента.Номер;
		ТД.Вывести(Область);	
			
		//+
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АР17_ЗаключениеДоговораАренды.Ссылка
		               |ИЗ
		               |	Документ.АР17_ЗаключениеДоговораАренды КАК АР17_ЗаключениеДоговораАренды
		               |ГДЕ
		               |	АР17_ЗаключениеДоговораАренды.Контрагент = &Контрагент";
					   
		Запрос.УстановитьПараметр("Контрагент",Отчет.Контрагент);
		ВыборкаДог = Запрос.Выполнить().Выбрать();
		//-
		
		Пока ВыборкаДог.Следующий() Цикл
			ТЗ.Очистить();
			ТЗ = ПолучитьРег(ВыборкаДог.Ссылка);
			
			Если ТЗ.Количество() <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ШапкаТабРег");
				Область.Параметры.ЗаголовокРЗ = "Договор № " + ВыборкаДог.Ссылка.ДоговорКонтрагента.Номер;
				ТД.Вывести(Область);	
			КонецЕсли;
			
			Для Каждого Стр из ТЗ Цикл
				Область = Макет.ПолучитьОбласть("СтрокаРег");
				Наименование = ?(ТипЗнч(Стр.ДокументРасчетов) = Тип("ДокументСсылка.РеализацияТоваровУслуг"), "Реализация товаров и услуг №", "Поступление на расчетный счет №");
				Область.Параметры.Наименование = "Акт №" + Строка(Стр.ДокументРасчетов.Номер) + " от " + Формат(Стр.ДокументРасчетов.Дата, "ДЛФ=Д");
				Область.Параметры.Сумма = Стр.Сумма;
				Область.Параметры.Документ = Стр.ДокументРасчетов;
				ТД.Вывести(Область);				
			КонецЦикла;	
			Итог = ТЗ.Итог("Сумма");
			Если Итог <> 0 Тогда
				Область = Макет.ПолучитьОбласть("ИтогоРег");
				Область.Параметры.Итого = Итог;
				ТД.Вывести(Область);
			КонецЕсли;	
			Область = Макет.ПолучитьОбласть("ПодвалРег");
			Если Итог = 0 Тогда
				Область.Параметры.Подвал = "Регламентированная задолженность по договору отсутствует.";
			ИначеЕсли Итог > 0 Тогда
				Область.Параметры.Подвал = "Задолженность по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			ИначеЕсли Итог < 0 Тогда
				Итог = Итог * (-1);
				Область.Параметры.Подвал = "Переплата по договору составляет: " + Формат(Итог, "ЧДЦ=2") + " (" + ЧислоПрописью(Итог, , Справочники.Валюты.НайтиПоКоду("643")) + ")";
			КонецЕсли;	
			ТД.Вывести(Область);
		//Иначе
		//	Сообщить("Для организации: " + Договор.Организация + " не настроен учет депозитных платежей!");
		//КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Настройки
	ТД.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТД.АвтоМасштаб = Истина;
	ТД.ТолькоПросмотр = Истина;
	
	Элементы.ТД.ОтображениеСостояния.ДополнительныйРежимОтображения=ДополнительныйРежимОтображения.НеИспользовать;
	Элементы.ТД.ОтображениеСостояния.Видимость = ложь;
	
КонецПроцедуры

Функция ПолучитьИД()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АР17_ИнформационныйДокумент.Ссылка
		|ИЗ
		|	Документ.АР17_ИнформационныйДокумент КАК АР17_ИнформационныйДокумент
		|ГДЕ
		|	АР17_ИнформационныйДокумент.Проведен = ИСТИНА
		|	И АР17_ИнформационныйДокумент.ДоговорКонтрагента.Владелец = &Контрагент";
		
	Запрос.УстановитьПараметр("Контрагент", Отчет.Контрагент);
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗ;
	
КонецФункции	


Функция НомерРеализации(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РеализацияТоваровУслуг.Номер
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	               |ГДЕ
	               |	РеализацияТоваровУслуг.СчетНаОплатуПокупателю = &Ссылка";
				   
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Номер;
	
КонецФункции	

Функция РазбитьПериод(ДатаС, ДатаПО)
	//Ответ = Новый Массив;
	//Мес = НачалоМесяца(ДатаС);
	//Пока Мес <= ДатаПО Цикл
	//	Д = Мин(ДатаПО,КонецМесяца(Мес));
	//    Ответ.Добавить(Новый Структура("Месяц", Формат(Д,"ДФ='ММММ yyyy'")));
	//    Мес = ДобавитьМесяц(Мес, 1)
	//КонецЦикла;     
	//Возврат Ответ
	
	Ответ = Новый Массив;
	ДатаС = Макс(ДатаС,'20140101');
    Мес = НачалоМесяца(ДатаС);
    Пока Мес <= ДатаПО Цикл
