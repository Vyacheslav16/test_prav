	               |	АР_РасчетыПоСчетамБухОстатки.Субконто1,
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто2 КАК СчетНаАренду,
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто2.НачалоПериода КАК НачалоПериода
	               |ИЗ
	               |	РегистрБухгалтерии.АР_РасчетыПоСчетамБух.Остатки(&Период, Счет = &Счет, , Субконто1 = &Договор) КАК АР_РасчетыПоСчетамБухОстатки
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	АР_РасчетыПоСчетамБухОстатки.Субконто2.Дата";
				   
	Запрос.УстановитьПараметр("Период",Отчет.КонецПериода);
	Запрос.УстановитьПараметр("Договор",Договор.ДоговорКонтрагента);
	//Запрос.УстановитьПараметр("Договор",Источник.ДоговорКонтрагента);
	Запрос.УстановитьПараметр("Счет",ПланыСчетов.АР_РасчетыПоСчетам.НайтиПоНаименованию("Услуга"));
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗ;
	
КонецФункции	

