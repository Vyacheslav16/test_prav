
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	ТабРезультат = Новый ТаблицаЗначений;
    КЧ = Новый КвалификаторыЧисла(12,2);
    КД = Новый КвалификаторыДаты(ЧастиДаты.Дата);
    КС = Новый КвалификаторыСтроки(20);
    Массив = Новый Массив;
    Массив.Добавить(Тип("Число"));
    ОписаниеТиповЧ = Новый ОписаниеТипов(Массив, , ,КЧ);
    Массив.Очистить();
    Массив.Добавить(Тип("Дата"));
    ОписаниеТиповД = Новый ОписаниеТипов(Массив, , ,КД);
	Массив.Очистить();
	Массив.Добавить(Тип("Строка"));
    ОписаниеТиповС = Новый ОписаниеТипов(Массив, , КС);
	ТабРезультат.Колонки.Добавить("ОбеспечительныйВзнос",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Ставка",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Контрагент",Новый описаниеТипов("СправочникСсылка.Контрагенты"));
	ТабРезультат.Колонки.Добавить("Договор",Новый описаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ТабРезультат.Колонки.Добавить("ДатаОкончанияСрокаАренды", ОписаниеТиповД);
	ТабРезультат.Колонки.Добавить("ДатаНачалаСрокаАренды", ОписаниеТиповД);    
	ТабРезультат.Колонки.Добавить("ДатаАкта", ОписаниеТиповД);           
	//ТабРезультат.Колонки.Добавить("Организация",Новый описаниеТипов("СправочникСсылка.Организации"));
	ТабРезультат.Колонки.Добавить("ВидДоговора",Новый описаниеТипов("СправочникСсылка.АР_ВидыДоговоров"));
	ТабРезультат.Колонки.Добавить("Комментарий",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ПлощадьПоДоговору",ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("Номенклатура",Новый описаниеТипов("СправочникСсылка.Номенклатура"));
	ТабРезультат.Колонки.Добавить("Этаж",Новый описаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Офис",Новый описаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Помещение",Новый описаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Здание",Новый описаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Объект",Новый описаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Валюта",Новый описаниеТипов("СправочникСсылка.Валюты"));
	ТабРезультат.Колонки.Добавить("СтоимостьПоНоменклатуре", ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("РазмерПоБТИ", ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("РазмерПоБома", ОписаниеТиповЧ);
	ТабРезультат.Колонки.Добавить("НазваниеБренд",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("НомерПоПлану", ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ИК",Новый ОписаниеТипов("СправочникСсылка.АР_ОбъектыАренды"));
	ТабРезультат.Колонки.Добавить("Профиль",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ОдностороннееРасторжениеСоСтороныАрендодателя",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ОдностороннееРасторжениеСоСтороныАрендатора",ОписаниеТиповС);
	//ТабРезультат.Колонки.Добавить("Арендодатель",Новый описаниеТипов("СправочникСсылка.Контрагенты"));
	ТабРезультат.Колонки.Добавить("Организация",Новый описаниеТипов("СправочникСсылка.Организации"));
	ТабРезультат.Колонки.Добавить("Индексация",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("USD",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ЦенаКвМГод",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("Номер",ОписаниеТиповС);
	ТабРезультат.Колонки.Добавить("ФактическоеНачало", ОписаниеТиповД);
	ТабРезультат.Колонки.Добавить("ФактическоеОкончание", ОписаниеТиповД);    
	
	ТабРезультат.Колонки.Добавить("Ссылка",Новый описаниеТипов("ДокументСсылка.АР17_ЗаключениеДоговораАренды"));
	ТабРезультат.Колонки.Добавить("СуммаЗалога", ОписаниеТиповЧ);
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ВложенныйЗапрос.ДокументДата) КАК ДокументДата,
		|	ВложенныйЗапрос.ДокументСсылка,
		|	ВложенныйЗапрос.Ссылка,
		|	МАКСИМУМ(ВложенныйЗапрос.СуммаЗалога) КАК СуммаЗалога,
		|	ВложенныйЗапрос.ОбщаяПлощадь
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Документ.Дата) КАК ДокументДата,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Документ.Ссылка КАК ДокументСсылка,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка КАК Ссылка,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеНачало КАК ФактическоеНачало,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание КАК ФактическоеОкончание,
		|		NULL КАК СуммаЗалога,
		|		NULL КАК ОбщаяПлощадь
		|	ИЗ
		|		Документ.АР17_ЗаключениеДоговораАренды.ДополнительныеСоглашения КАК АР_ЗаключениеДоговораАрендыДополнительныеСоглашения
		|	ГДЕ
		|		ВЫБОР
		|				КОГДА &Статус <> ""Закрытые""
		|						И &Статус <> ""Текущие""
		|					ТОГДА АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.Дата МЕЖДУ &ДатаНач И &ДатаКон
		|				ИНАЧЕ ВЫБОР
		|						КОГДА &Статус = ""Закрытые""
		|							ТОГДА АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание <= &ДатаКон
		|									И АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание >= &ДатаНач
		|						ИНАЧЕ ВЫБОР
		|								КОГДА &Статус = ""Текущие""
		|									ТОГДА (АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание >= &ДатаКон
		|											ИЛИ АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание = ДАТАВРЕМЯ(1, 1, 1))
		|											И АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.СтатусДоговора = ЗНАЧЕНИЕ(Перечисление.АР_СтатусДоговора.Согласован)
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	
		|	СГРУППИРОВАТЬ ПО
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Документ.Ссылка,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеНачало,
		|		АР_ЗаключениеДоговораАрендыДополнительныеСоглашения.Ссылка.ФактическоеОкончание
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		АР_ЗаключениеДоговораАренды.Дата,
		|		АР_ЗаключениеДоговораАренды.Ссылка,
		|		АР_ЗаключениеДоговораАренды.Ссылка,
		|		АР_ЗаключениеДоговораАренды.ФактическоеНачало,
		|		АР_ЗаключениеДоговораАренды.ФактическоеОкончание,
		|		АР_ЗаключениеДоговораАренды.СуммаЗалога,
		|		АР_ЗаключениеДоговораАренды.ОбщаяПлощадь
		|	ИЗ
		|		Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		|	ГДЕ
		|		ВЫБОР
		|				КОГДА &Статус <> ""Закрытые""
		|						И &Статус <> ""Текущие""
		|					ТОГДА АР_ЗаключениеДоговораАренды.Ссылка.Дата МЕЖДУ &ДатаНач И &ДатаКон
		|				ИНАЧЕ ВЫБОР
		|						КОГДА &Статус = ""Закрытые""
		|							ТОГДА АР_ЗаключениеДоговораАренды.Ссылка.ФактическоеОкончание <= &ДатаКон
		|									И АР_ЗаключениеДоговораАренды.Ссылка.ФактическоеОкончание >= &ДатаНач
		|						ИНАЧЕ ВЫБОР
		|								КОГДА &Статус = ""Текущие""
		|									ТОГДА (АР_ЗаключениеДоговораАренды.Ссылка.ФактическоеОкончание >= &ДатаКон
		|											ИЛИ АР_ЗаключениеДоговораАренды.Ссылка.ФактическоеОкончание = ДАТАВРЕМЯ(1, 1, 1))
		|											И АР_ЗаключениеДоговораАренды.Ссылка.СтатусДоговора = ЗНАЧЕНИЕ(Перечисление.АР_СтатусДоговора.Согласован)
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.ДокументСсылка,
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.ОбщаяПлощадь";
	
	КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроек.ПолучитьНастройки());
	Настройки = КомпоновщикНастроек.Настройки; 
	 
	НачалоПериода = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ДатаНачала"));
	КонецПериода = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ДатаКонца"));
	Статус = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Статус"));
	Запрос.УстановитьПараметр("ДатаНач",Дата(НачалоПериода.Значение));
	Запрос.УстановитьПараметр("ДатаКон",Дата(КонецПериода.Значение));
	Если Статус.Использование Тогда
		Запрос.УстановитьПараметр("Статус",Статус.Значение);
	Иначе
		Запрос.УстановитьПараметр("Статус","");
	КонецЕсли;	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	//ОбработкаПрерыванияПользователя();
	Если ТипЗнч(ВыборкаДетальныеЗаписи.ДокументСсылка) = Тип("ДокументСсылка.АР17_ЗаключениеДоговораАренды") Тогда
		ПутьКИК = "";
	Иначе
		ПутьКИК = ".ДокументОснование";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.ОбъектАренды,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Услуга,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Количество,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ставка,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.ДатаОкончанияСрокаАренды,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка.ФактическоеНачало КАК ФактическоеНачало,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка.ФактическоеОкончание КАК ФактическоеОкончание,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка.ИК КАК ИК,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка.СуммаЗалога КАК СуммаЗалога,
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка.ОбщаяПлощадь
	|ПОМЕСТИТЬ ТабДоговоров
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК ПоследнийДокПостояннаяЧастьАренднойПлаты
	|ГДЕ
	|	ПоследнийДокПостояннаяЧастьАренднойПлаты.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.ОбъектАренды,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Услуга,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Количество,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ставка,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.ДатаОкончанияСрокаАренды,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка.ФактическоеНачало,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка.ФактическоеОкончание,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка.ИК,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка.СуммаЗалога,
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка.ОбщаяПлощадь
	|ИЗ
	|	Документ.АР17_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты КАК ПоследнийДокПеременнаяЧастьАренднойПлаты
	|ГДЕ
	|	ПоследнийДокПеременнаяЧастьАренднойПлаты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабДоговоров.Ссылка.Организация КАК Организация,
	|	ТабДоговоров.Ссылка.Контрагент КАК Контрагент,
	|	ТабДоговоров.Ссылка.ДоговорКонтрагента КАК Договор,
	|	ТабДоговоров.ОбщаяПлощадь КАК ПлощадьПоДоговору,
	|	АР_АктПриемаПередачиПомещенияВАренду.Дата КАК ДатаАкта,
	|	ТабДоговоров.Услуга КАК Номенклатура,
	|	ТабДоговоров.Количество,
	|	ТабДоговоров.Ставка,
	|	(ВЫРАЗИТЬ(ТабДоговоров.Ставка КАК ЧИСЛО(15, 2))) * (ВЫРАЗИТЬ(ТабДоговоров.Количество КАК ЧИСЛО(15, 2))) КАК СтоимостьПоНоменклатуре,
	|	ТабДоговоров.Ссылка,
	|	ТабДоговоров.ДатаНачалаСрокаАренды,
	|	ТабДоговоров.ДатаОкончанияСрокаАренды,
	|	ТабДоговоров.Ссылка.Комментарий КАК Комментарий,
	|	ТабДоговоров.Ссылка.ВидДоговора КАК ВидДоговора,
	|	ТабДоговоров.ИК,
	|	ТабДоговоров.СуммаЗалога,
	|	"""" КАК НазваниеБренд,
	|	"""" КАК Профиль,
	|	ТабДоговоров.Ссылка.СуммаЗалога КАК ОбеспечительныйВзнос,
	|	ТабДоговоров.Ссылка.ВалютаДепозита КАК Валюта,
	|	"""" КАК ОдностороннееРасторжениеСоСтороныАрендатора,
	|	"""" КАК USD,
	|	"""" КАК Индексация,
	|	"""" КАК ЦенаКвМГод,
	|	ТабДоговоров.ФактическоеНачало КАК ФактическоеНачало,
	|	ТабДоговоров.ФактическоеОкончание КАК ФактическоеОкончание,
	|	"""" КАК ОдностороннееРасторжениеСоСтороныАрендодателя,
	|	ТабДоговоров.Ссылка.Номер КАК Номер
	|ИЗ
	|	ТабДоговоров КАК ТабДоговоров
