		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Контрагент КАК ФИО,
	АР17_Д_ОтчетИнвестора.Помещение.ПомещениеНомерБТИ КАК НомерПИБ,
	АР17_Д_ОтчетИнвестора.Помещение КАК НомерПомещения,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента.Номер КАК НомерДоговора,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента.Дата КАК ДатаДоговора,
	АР17_Д_ОтчетИнвестора.ДоляПомещения * ЕСТЬNULL(АР17_Д_ОтчетИнвестора.Выручка, 0) КАК ПолученныйДоход,
	АР17_Д_ОтчетИнвестора.ДоляПомещения * ЕСТЬNULL(АР17_Д_ОтчетИнвестора.РасходыСумма, 0) КАК Расходы,
	АР17_Д_ОтчетИнвестора.ДоляПомещения * ЕСТЬNULL(АР17_Д_ОтчетИнвестора.РасходыУслугиУК, 0) КАК ВознаграждениеУК,
	АР17_Д_ОтчетИнвестора.ЧестныйДоход КАК ДоходРасходПринципалаБезКорректировки,
	ЕСТЬNULL(АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Гарантированныйдоход, 0) - (АР17_Д_ОтчетИнвестора.ЧестныйДоход - АР17_Д_ОтчетИнвестора.ЧестныйРасход - АР17_Д_ОтчетИнвестора.ЧестнаяКУ) КАК НеустойкаГаранта,
	ЕСТЬNULL(АР17_Д_ОтчетИнвестора.Оснащение, 0) КАК РасходОснащения,
	АР17_Д_ОтчетИнвестора.ЧистыйДоход - ЕСТЬNULL(АР17_Д_ОтчетИнвестора.Оснащение, 0) КАК КВыплате,
	АР17_Д_ОтчетИнвестора.ДоляПомещения КАК Доля,
	АР17_Д_ОтчетИнвестора.СреднийТариф КАК СуммаАренднойСтавки,
	КОНЕЦПЕРИОДА(АР17_Д_ОтчетИнвестора.Период, МЕСЯЦ) КАК Период,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента КАК СсылкаДоговорКонтрагента,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора КАК ЗДА,
	АР17_Д_ОтчетИнвестора.ДоляПомещения КАК ДоляПомещения,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Гарантированныйдоход КАК ДоговорИнвестораГарантированныйдоход,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ПрограммаДоходности КАК ДоговорИнвестораПрограммаДоходности,
	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи КАК ДатаПередачи,
	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь КАК Площадь,
	АР17_Д_ОтчетИнвестора.Ссылка КАК Ссылка,
	АР17_Д_ОтчетИнвестора.КомиссионноеВознаграждение КАК КомиссионноеВознаграждение,
	АР17_Д_ОтчетИнвестора.СтоимостьЗавтраков КАК СтоимостьЗавтраков,
	АР17_Д_ОтчетИнвестора.ТекущийРемонт КАК ТекущийРемонт,
	АР17_Д_ОтчетИнвестора.СуммаДохода КАК СуммаДохода,
	АР17_Д_ОтчетИнвестора.СуммаКРаспределению КАК СуммаКРаспределению,
	АР17_Д_ОтчетИнвестора.ПлощадьКотла КАК ПлощадьКотла
ИЗ
	Документ.АР17_Д_ОтчетИнвестора КАК АР17_Д_ОтчетИнвестора
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АР17_ЗаключениеАгентскогоДоговора.ОбъектыАренды КАК АР17_ЗаключениеАгентскогоДоговораОбъектыАренды
		ПО АР17_Д_ОтчетИнвестора.ДоговорИнвестора = АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Ссылка
ГДЕ
	АР17_Д_ОтчетИнвестора.Проведен = ИСТИНА
	И АР17_Д_ОтчетИнвестора.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
{ГДЕ
	(АР17_Д_ОтчетИнвестора.ИК = &amp;ИК
			ИЛИ АР17_Д_ОтчетИнвестора.ИК ЕСТЬ NULL)}

СГРУППИРОВАТЬ ПО
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Контрагент,
	АР17_Д_ОтчетИнвестора.Помещение.ПомещениеНомерБТИ,
	АР17_Д_ОтчетИнвестора.Помещение,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента.Номер,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента.Дата,
	АР17_Д_ОтчетИнвестора.СреднийТариф,
	КОНЕЦПЕРИОДА(АР17_Д_ОтчетИнвестора.Период, МЕСЯЦ),
	АР17_Д_ОтчетИнвестора.ЧистыйДоход - ЕСТЬNULL(АР17_Д_ОтчетИнвестора.Оснащение, 0),
	ЕСТЬNULL(АР17_Д_ОтчетИнвестора.Оснащение, 0),
	АР17_Д_ОтчетИнвестора.ДоляПомещения,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ДоговорКонтрагента,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора,
	АР17_Д_ОтчетИнвестора.ЧестныйДоход,
	ЕСТЬNULL(АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Гарантированныйдоход, 0) - (АР17_Д_ОтчетИнвестора.ЧестныйДоход - АР17_Д_ОтчетИнвестора.ЧестныйРасход - АР17_Д_ОтчетИнвестора.ЧестнаяКУ),
	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.ДатаПередачи,
	АР17_ЗаключениеАгентскогоДоговораОбъектыАренды.Площадь,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.Гарантированныйдоход,
	АР17_Д_ОтчетИнвестора.ДоговорИнвестора.ПрограммаДоходности,
