Функция ПолучитьТаблицуФорм() Экспорт 
	Результат = Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюТаблицуФормУведомления();
	
	Стр = Результат.Добавить();
	Стр.ИмяФормы = "Форма2026_1";
	Стр.ОписаниеФормы = "Приказ ФНС России от --.--.---- № ЕД-----/---@";
	Стр.ДатаНачала = '20210701';
	Стр.ДатаКонца = '20991231';

	Возврат Результат;
КонецФункции

Функция ЭлектронноеПредставление(Объект, ИмяФормы, УникальныйИдентификатор) Экспорт
	Если ИмяФормы = "Форма2026_1" Тогда
		Возврат ЭлектронноеПредставление_Форма2026_1(Объект, УникальныйИдентификатор);
	КонецЕсли;
КонецФункции

Функция СформироватьСписокЛистов(Объект) Экспорт
	Если Объект.ИмяФормы = "Форма2026_1" Тогда
		Возврат СформироватьСписокЛистов_Форма2026_1(Объект);
	КонецЕсли;
КонецФункции

Функция ПроверитьДокументСВыводомВТаблицу(Объект, ИмяФормы, УникальныйИдентификатор) Экспорт 
	Если ИмяФормы = "Форма2026_1"  Тогда 
		Возврат ПроверитьДокументСВыводомВТаблицу_Форма2026_1(
			УведомлениеОСпецрежимахНалогообложения.ДанныеУведомленияДляВыгрузки(Объект), УникальныйИдентификатор);
	КонецЕсли;
КонецФункции

Процедура ПроверкаТовар_Форма2026_1(ТаблицаОшибок, Товар, ИмяСтраницы, Данные)
	Если Не СтрПодобнаПоРегулярномуВыражению(Товар.ТНВЭД, "[0-9]{10}") Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указан / неправильно указан ТНВЭД", ИмяСтраницы, "ТНВЭД", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.НаимТов) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указано наименование товара", ИмяСтраницы, "НаимТов", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.ПрПТ) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указан признак подакцизности товара", ИмяСтраницы, "ПрПТ", Товар.УИД));
	КонецЕсли;
	Если Товар.ПрПТ = "0" И ЗначениеЗаполнено(Товар.КодПТ) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Код подакцизного товара не указывается", ИмяСтраницы, "КодПТ", Товар.УИД));
	ИначеЕсли Товар.ПрПТ = "1" И Не ЗначениеЗаполнено(Товар.КодПТ) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Необходимо указать код подакцизного товара", ИмяСтраницы, "КодПТ", Товар.УИД));
	КонецЕсли;
	Если Не СтрПодобнаПоРегулярномуВыражению(Товар.ОКЕИ, "[0-9]{3}") Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указан / неправильно указан код ОКЕИ", ИмяСтраницы, "ОКЕИ", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.КолТов) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указано количество товара", ИмяСтраницы, "КолТов", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.СтоимТов) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана стоимость товара", ИмяСтраницы, "СтоимТов", Товар.УИД));
	КонецЕсли;
	Если Не СтрПодобнаПоРегулярномуВыражению(Товар.ОКСМПроисх, "[0-9]{3}") Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указан / неправильно указан код страны", ИмяСтраницы, "ОКСМПроисх", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.СтрПроисх) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана страна происхождения", ИмяСтраницы, "СтрПроисх", Товар.УИД));
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Товар.ОсобПризн) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указан особый признак", ИмяСтраницы, "ОсобПризн", Товар.УИД));
	КонецЕсли;
	
	СтавкиАкцизаЗаполнены = УведомлениеОСпецрежимахНалогообложения.БлокЗаполнен(Товар, "АкцТвСт,АкцАдвСт");
	Если Товар.ПрПТ = "0" И СтавкиАкцизаЗаполнены Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Ставки акцизов не заполняются", ИмяСтраницы, ?(ЗначениеЗаполнено(Товар.АкцТвСт), "АкцТвСт", "АкцАдвСт"), Товар.УИД));
	КонецЕсли;
	Если Товар.ПрПТ = "1" И Не СтавкиАкцизаЗаполнены Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не заполнены ставки акцизов", ИмяСтраницы, "АкцТвСт", Товар.УИД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Товар.АкцТвСт) И Не ЗначениеЗаполнено(Товар.АкцизТвБаза) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана налоговая база акциза", ИмяСтраницы, "АкцизТвБаза", Товар.УИД));
	ИначеЕсли Не ЗначениеЗаполнено(Товар.АкцТвСт) И ЗначениеЗаполнено(Товар.АкцизТвБаза) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Налоговая база акциза не указывается", ИмяСтраницы, "АкцизТвБаза", Товар.УИД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Товар.АкцАдвСт) И Не ЗначениеЗаполнено(Товар.АкцизАдвБаза) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана налоговая база акциза", ИмяСтраницы, "АкцизАдвБаза", Товар.УИД));
	ИначеЕсли Не ЗначениеЗаполнено(Товар.АкцАдвСт) И ЗначениеЗаполнено(Товар.АкцизАдвБаза) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Налоговая база акциза не указывается", ИмяСтраницы, "АкцизАдвБаза", Товар.УИД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Товар.АкцТвСт) И Не ЗначениеЗаполнено(Товар.СумАкцизТв) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана сумма акциза", ИмяСтраницы, "СумАкцизТв", Товар.УИД));
	ИначеЕсли Не ЗначениеЗаполнено(Товар.АкцТвСт) И ЗначениеЗаполнено(Товар.СумАкцизТв) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Сумма акциза не указывается", ИмяСтраницы, "СумАкцизТв", Товар.УИД));
	КонецЕсли;
	Если ЗначениеЗаполнено(Товар.АкцАдвСт) И Не ЗначениеЗаполнено(Товар.СумАкцизАдв) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Не указана сумма акциза", ИмяСтраницы, "СумАкцизАдв", Товар.УИД));
	ИначеЕсли Не ЗначениеЗаполнено(Товар.АкцАдвСт) И ЗначениеЗаполнено(Товар.СумАкцизАдв) Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Сумма акциза не указывается", ИмяСтраницы, "СумАкцизАдв", Товар.УИД));
	КонецЕсли;
	
	Если Товар.ОсобПризн = "0" Тогда
		Если Не ЗначениеЗаполнено(Товар.НДССт) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана ставка НДС", ИмяСтраницы, "НДССт", Товар.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Товар.НДСБаза) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана база НДС", ИмяСтраницы, "НДСБаза", Товар.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Товар.СумНДС) И Товар.НДССт <> "0" Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана сумма НДС", ИмяСтраницы, "СумНДС", Товар.УИД));
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(Товар.НДССт) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
