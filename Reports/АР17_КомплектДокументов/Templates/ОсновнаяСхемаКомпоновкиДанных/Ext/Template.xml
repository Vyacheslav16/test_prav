		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	АР_Ставки.ДатаНачалаАренды КАК ДатаНачалаАренды,
	АР_Ставки.Регистратор КАК Регистратор
ПОМЕСТИТЬ хз
ИЗ
	РегистрСведений.АР_Ставки КАК АР_Ставки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	АР_Ставки.Услуга КАК Услуга,
	АР_Ставки.Регистратор КАК Регистратор,
	МАКСИМУМ(АР_Ставки.ДатаНачалаАренды) КАК ДатаНачалаАренды,
	хз.ДатаНачалаАренды КАК Период
ПОМЕСТИТЬ хз2
ИЗ
	РегистрСведений.АР_Ставки КАК АР_Ставки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ хз КАК хз
		ПО АР_Ставки.Регистратор = хз.Регистратор
			И АР_Ставки.ДатаНачалаАренды &lt;= хз.ДатаНачалаАренды

СГРУППИРОВАТЬ ПО
	АР_Ставки.Услуга,
	АР_Ставки.Регистратор,
	хз.ДатаНачалаАренды
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	хз2.Регистратор КАК Регистратор,
	МИНИМУМ(хз2.ДатаНачалаАренды) КАК Мин
ПОМЕСТИТЬ МинПериод
ИЗ
	хз2 КАК хз2

СГРУППИРОВАТЬ ПО
	хз2.Регистратор
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	АР_Ставки.Регистратор КАК Регистратор,
	АР_Ставки.Услуга КАК Услуга,
	АР_Ставки.Ставка КАК Ставка,
	АР_Ставки.ДатаНачалаАренды КАК ДатаНачалаАренды,
	АР_Ставки.СуммаПоДоговору КАК СуммаПоДоговору
ПОМЕСТИТЬ хз3
ИЗ
	РегистрСведений.АР_Ставки КАК АР_Ставки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка КАК Ссылка,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка.ИК КАК ИмущественныйКомплекс,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга КАК Услуга,
	СУММА(АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Количество) КАК Площадь,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды КАК ДатаНачалаСрокаАренды
ПОМЕСТИТЬ втПлощадь
ИЗ
	Документ.АР17_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты КАК АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты

СГРУППИРОВАТЬ ПО
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Ссылка.ИК,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.Услуга,
	АР17_ЗаключениеДоговораАрендыПостояннаяЧастьАренднойПлаты.ДатаНачалаСрокаАренды
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	АР_АктПриемаВозвратаАрендуемогоПомещения.Дата КАК ДатаАктаПВ,
	АР_АктПриемаПередачиПомещенияВАренду.Дата КАК ДатаАктаПП,
	АР_АктПриемаПередачиПомещенияВАренду.Ссылка КАК Ссылка
ПОМЕСТИТЬ втАкты
ИЗ
	Документ.АР_АктПриемаПередачиПомещенияВАренду КАК АР_АктПриемаПередачиПомещенияВАренду
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР_АктПриемаВозвратаАрендуемогоПомещения КАК АР_АктПриемаВозвратаАрендуемогоПомещения
		ПО АР_АктПриемаПередачиПомещенияВАренду.Ссылка = АР_АктПриемаВозвратаАрендуемогоПомещения.ДокументОснование
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	хз2.Период КАК Период,
	СУММА(ВЫРАЗИТЬ(хз3.Ставка КАК ЧИСЛО(15, 2))) КАК Ставка,
	хз2.Регистратор КАК Регистратор,
	ВЫРАЗИТЬ(хз2.Регистратор.Комментарий КАК СТРОКА(900)) КАК Комментарий,
	втАкты.ДатаАктаПП КАК ДатаАктаПП,
	втАкты.ДатаАктаПВ КАК ДатаАктаПВ,
	втПлощадь.Площадь КАК Площадь,
	втАкты.Ссылка КАК Ссылка,
	СУММА(хз3.СуммаПоДоговору) КАК СуммаПоДоговору
ПОМЕСТИТЬ Общ
ИЗ
	хз2 КАК хз2
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ хз3 КАК хз3
		ПО хз2.Услуга = хз3.Услуга
			И хз2.Регистратор = хз3.Регистратор
			И хз2.Период = хз3.ДатаНачалаАренды
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПлощадь КАК втПлощадь
		ПО хз2.Регистратор = втПлощадь.Ссылка
			И хз2.Услуга = втПлощадь.Услуга
			И хз2.ДатаНачалаАренды = втПлощадь.ДатаНачалаСрокаАренды
		ЛЕВОЕ СОЕДИНЕНИЕ втАкты КАК втАкты
		ПО хз2.Регистратор = втАкты.Ссылка.ДокументОснование
ГДЕ
	хз2.Регистратор ССЫЛКА Документ.АР17_ЗаключениеДоговораАренды

СГРУППИРОВАТЬ ПО
	хз2.Период,
	хз2.Регистратор,
	ВЫРАЗИТЬ(хз2.Регистратор.Комментарий КАК СТРОКА(900)),
	втАкты.ДатаАктаПВ,
	втАкты.ДатаАктаПП,
	втПлощадь.Площадь,
	втАкты.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка КАК Ссылка,
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.Дата КАК ДатаЗаключенияДоговора,
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.ДатаОкончанияДоговора КАК ДатаОкончанияДоговора,
	АР17_ДополнительноеСоглашениеОбъектыАренды.Площадь КАК Площадь,
	ВЫРАЗИТЬ(АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.Комментарий КАК СТРОКА(900)) КАК Комментарий
ПОМЕСТИТЬ втДоп
ИЗ
	Общ КАК Общ
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АР17_ДополнительноеСоглашение.ОбъектыАренды КАК АР17_ДополнительноеСоглашениеОбъектыАренды
		ПО Общ.Регистратор = АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.ДокументОснование

СГРУППИРОВАТЬ ПО
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка,
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.ДатаОкончанияДоговора,
	ВЫРАЗИТЬ(АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.Комментарий КАК СТРОКА(900)),
	АР17_ДополнительноеСоглашениеОбъектыАренды.Площадь,
	АР17_ДополнительноеСоглашениеОбъектыАренды.Ссылка.Дата
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втДоп.Ссылка КАК Ссылка,
