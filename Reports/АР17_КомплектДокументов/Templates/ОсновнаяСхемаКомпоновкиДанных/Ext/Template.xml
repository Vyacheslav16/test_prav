			</title>
			<presentationExpression>ВЫБОР 
КОГДА ВЫРАЗИТЬ(Договор, "Документ.АР17_ЗаключениеДоговораАренды") ЕСТЬ НЕ NULL 
ТОГДА "Договор № " + Договор.Номер + " от " + ФОРМАТ(Договор.Дата, "ДФ=dd.MM.yyyy")
Иначе ВЫБОР 
	КОГДА ВЫРАЗИТЬ(Договор, "Документ.АР17_ДополнительноеСоглашение") ЕСТЬ НЕ NULL 
	ТОГДА Выбор 
	Когда Договор.ВидОперации = Значение(Перечисление.АР_ВидыОперацийДополнительноеСоглашение.Письмо) Тогда
	 "Письмо № " + АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(Договор.Номер) + " от " + ФОРМАТ(Договор.Дата, "ДФ=dd.MM.yyyy")
	Иначе
	"Дополнительное соглашение № " + АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(Договор.Номер) + " от " + ФОРМАТ(Договор.Дата, "ДФ=dd.MM.yyyy")
	Конец
Иначе ВЫБОР 
	КОГДА ВЫРАЗИТЬ(Договор, "Документ.АР17_РасторжениеДоговораАренды") ЕСТЬ НЕ NULL
	Тогда "Расторжение договора от              " + ФОРМАТ(Договор.Дата, "ДФ=dd.MM.yyyy")

Иначе ВЫБОР 
	КОГДА ВЫРАЗИТЬ(Договор, "Документ.АР17_ИнформационныйДокумент") ЕСТЬ НЕ NULL
	Тогда "Информационный документ " + АР_ОбщиеПроцедуры.ПолучитьНомерОтчеты(Договор.Номер) + " от " + ФОРМАТ(Договор.Дата, "ДФ=dd.MM.yyyy")

Иначе
Договор 
КОНЕЦ
Конец 
Конец 
Конец</presentationExpression>
