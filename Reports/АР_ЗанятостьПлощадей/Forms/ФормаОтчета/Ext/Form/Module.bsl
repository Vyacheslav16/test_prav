&НаКлиенте
Функция Уровень(СтрокаДерева)
   Родитель=СтрокаДерева.ПолучитьРодителя();
   Возврат ?(Родитель=Неопределено, 0, 1+Уровень(Родитель));
КонецФункции

&НаКлиенте
Процедура ОбойтиСтроки(Строки,ТаблицаСтатусов,Excel)
	ТекущийЛист = "";
	ВыборкаПоФайламПлощадь = 0;
	Для Каждого ВыборкаПоФайлам Из Строки Цикл
		
		Уровень = Уровень(ВыборкаПоФайлам);
		
		Если Уровень=0 Тогда
			
			Если Не ЗначениеЗаполнено(ВыборкаПоФайлам.ФайлПланировки) Тогда
				Продолжить;
			КонецЕсли;
			
			ФайлШаблона = АР_ОбщиеПроцедуры.ПолучитьПутьКФайлуПланировки(ВыборкаПоФайлам.ФайлПланировки);
			Если Не ЗначениеЗаполнено(ФайлШаблона) Тогда
				Прервать;
			КонецЕсли;
			
			Файл = Новый Файл(ФайлШаблона);
			Если Не Файл.Существует() Тогда
				Сообщить("Файл """ + СокрЛП(ФайлШаблона) + """ не существует!", СтатусСообщения.Важное); 
				Продолжить;
