&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Отчет.Период = ТекущаяДата();
	
	Если НЕ НастройкиВостановлены ИЛИ Отчет.СоставИнформации.Количество() = 0 Тогда
		СписокИнформации = Новый СписокЗначений;
		СписокИнформации.Добавить("ОбъектАренды", "Объект аренды", Истина);
		СписокИнформации.Добавить("ОбъектАренды.ЗначениеХарактеристики", "Объект аренды.Площадь", Истина);
		СписокИнформации.Добавить("Контрагент", "Арендатор", Истина);	
		Для Каждого Элемент Из СписокИнформации Цикл
			Стр = Отчет.СоставИнформации.Добавить();
			Стр.Использование = Элемент.Пометка;
			Стр.ИмяПоля = Элемент.Значение;
			Стр.Информация = Элемент.Представление;
		КонецЦикла;
	КонецЕсли;
	
	
КонецПроцедуры

