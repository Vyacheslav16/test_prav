ВЫБРАТЬ
	АР_ЗаключениеДоговораАренды.Контрагент,
	АР_ЗаключениеДоговораАренды.СтавкаПени,
	АР_ЗаключениеДоговораАренды.СуммаЗалога КАК СуммаДепозита,
	ХЗ.ДолгНаНач,
	ХЗ.НачисленоАП,
	ХЗ.НачисленоПени,
	ХЗ.НачисленоДепозит,
	ХЗ.ОплаченоПени,
	ХЗ.ОплаченоДепозит,
	ЕСТЬNULL(ХЗ.Договор, АР_ЗаключениеДоговораАренды.ДоговорКонтрагента) КАК Договор,
	ХЗ.ОплаченоАП,
	АР_ЗаключениеДоговораАренды.ПостояннаяЧастьАренднойПлаты.(
		СУММА(Сумма) КАК ПостСумма
	),
	АР_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты.(
		СУММА(ВЫРАЗИТЬ(АР_ЗаключениеДоговораАренды.ПеременнаяЧастьАренднойПлаты.Ставка КАК ЧИСЛО(15, 2))) КАК ПеремСумма
	),
	АР_ЗаключениеДоговораАренды.Ссылка,
	АР_ЗаключениеДоговораАренды.СуммаЗалога,
	АР_ЗаключениеДоговораАренды.ИК
ИЗ
	Документ.АР17_ЗаключениеДоговораАренды КАК АР_ЗаключениеДоговораАренды
		ЛЕВОЕ СОЕДИНЕНИЕ хз КАК ХЗ
		ПО АР_ЗаключениеДоговораАренды.ДоговорКонтрагента = ХЗ.Договор
			И АР_ЗаключениеДоговораАренды.Контрагент = ХЗ.Контрагент
{ГДЕ
	(АР_ЗаключениеДоговораАренды.ИК В ИЕРАРХИИ (&amp;ИК)),
	(АР_ЗаключениеДоговораАренды.Организация В (&amp;Организация)),
	(АР_ЗаключениеДоговораАренды.ДатаЗаключенияДоговора &lt; &amp;КонецПериода)}</query>
