ОБЪЕДИНИТЬ

ВЫБРАТЬ
	0,
	0,
	0,
	АР_СчетНаАренду.СуммаДокумента,
	0,
	0,
	0,
	АР_СчетНаАренду.ДоговорКонтрагента,
