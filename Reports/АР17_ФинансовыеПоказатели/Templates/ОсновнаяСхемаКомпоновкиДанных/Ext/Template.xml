	0 КАК НачисленоАП,
	0 КАК НачисленоПени,
	0 КАК НачисленоДепозит,
	0 КАК ОплаченоАП,
	0 КАК ОплаченоПени,
	0 КАК ОплаченоДепозит,
	ХозрасчетныйОстаткиИОборотыН.Субконто2 КАК Договор,
	ХозрасчетныйОстаткиИОборотыН.Субконто1 КАК Контрагент
ПОМЕСТИТЬ хз
ИЗ
	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, Период, Движения, Счет В ИЕРАРХИИ (&amp;Счет6201), , {(Организация = &amp;Организация)}) КАК ХозрасчетныйОстаткиИОборотыН
ГДЕ
	ТИПЗНАЧЕНИЯ(ХозрасчетныйОстаткиИОборотыН.Субконто3) = ТИП(Документ.РеализацияТоваровУслуг)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	0,
	ХозрасчетныйОстаткиИОборотыН.СуммаОборотДт,
	0,
	0,
	0,
	0,
	0,
	ХозрасчетныйОстаткиИОборотыН.Субконто2,
	ХозрасчетныйОстаткиИОборотыН.Субконто1
ИЗ
	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, Период, Движения, Счет В ИЕРАРХИИ (&amp;Счет6201), , {(Организация = &amp;Организация)}) КАК ХозрасчетныйОстаткиИОборотыН
ГДЕ
	ТИПЗНАЧЕНИЯ(ХозрасчетныйОстаткиИОборотыН.Субконто3) = ТИП(Документ.РеализацияТоваровУслуг)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	0,
	0,
	ХозрасчетныйОстаткиИОборотыП.СуммаОборотДт,
	0,
	0,
	0,
	0,
	ХозрасчетныйОстаткиИОборотыП.Субконто2,
