		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>№ Номер документа/Дата</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>СтоимостьВсегоСУчетомНалога</dataPath>
		<expression>Сумма(СтоимостьВсегоСУчетомНалога)</expression>
		<group>Ссылка</group>
	</totalField>
	<totalField>
		<dataPath>СтоимостьТовараБезНалога</dataPath>
		<expression>Сумма(СтоимостьТовараБезНалога)</expression>
		<group>Ссылка</group>
	</totalField>
	<totalField>
		<dataPath>СуммаНДСДокумента</dataPath>
		<expression>Сумма(СуммаНДСДокумента)</expression>
		<group>Ссылка</group>
	</totalField>
	<totalField>
		<dataPath>СтоимостьВсегоСУчетомНалога</dataPath>
		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Максимум(СтоимостьВсегоСУчетомНалога)","Ссылка"))
</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаНДСДокумента</dataPath>
		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Максимум(СуммаНДСДокумента)","Ссылка"))
</expression>
	</totalField>
	<totalField>
		<dataPath>СтоимостьТовараБезНалога</dataPath>
		<expression>Сумма(ВычислитьВыражениеСГруппировкойМассив("Максимум(СтоимостьТовараБезНалога)","Ссылка"))
</expression>
	</totalField>
